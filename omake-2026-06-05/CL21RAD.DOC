-----------------------------------------------------------------------------
.TMM_initRsMidi                                                              
RS-MIDIルーチンの登録                                                        
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_initRsMidi(RSCTRL *rsctrl);                                          
                                                                             
- 戻り値 -                                                                   
0　:正常終了                                                                 
-14:すでに登録済                                                             
                                                                             
- 機能 -                                                                     
  rsctrlの示すRSCTRL構造体の情報に従ってRS232CMIDIの入出力用コールバックルー 
チンを登録します。ここに登録できるのはアセンブラので記述されたコールバックル 
ーチンです。MIDI ManagerではRS-MIDIポートに対してデータを出力するとき、ここに
登録されている出力用コールバックルーチンに対してalレジスタにデータを入れてコ 
ールします。また、RS-MIDIポートからデータを受け取る場合も入力用コールバックル
ーチンをコールします。入力用コールバックルーチンではデータがある場合は、alレ 
ジスタに0を入れdlレジスタにデータを入れて返します。データが無い場合はalレジス
タに1を入れて返します。                                                      
                                                                             
-----------------------------------------------------------------------------
.TMM_openMidiMan                                                             
MIDI Managerのオープン                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_openMidiMan(MIDIMANCTRL *midimanctrl);                               
                                                                             
- 戻り値 -                                                                   
  0:正常終了                                                                 
- 3:バッファ、スタック等のサイズ不足                                         
-13:ベクタ設定時のエラー                                                     
-14:すでにオープン済                                                         
                                                                             
- 機能 -                                                                     
  ドライバの初期化を行います。設定済のMIDIMANCTRL構造体の情報に従って各種初期
化を行います。                                                               
                                                                             
- 例 -                                                                       
MIDIMANCTRL midimanctrl;                                                     
int ret;                                                                     
                                                                             
midimanctrl.mc_interval = 480000*5 /* 5msec */                               
　　･                                                                        
 MIDIMANCTRL構造体のその他の設定                                             
　　･                                                                        
                                                                             
ret = TMM_openMidiMan(&midimanctrl);                                         
                                                                             
-----------------------------------------------------------------------------
.TMM_outputMidiEvent                                                         
MIDIデータの出力                                                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_outputMidiEvent(PORT port,unsigned char *event);                     
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  指定のポートにMIDIイベントを出力します。データ出力する出力ポート番号とデー 
タを格納した文字列へのポインタを渡します。データの構造は下記の様になっていま 
す。実際に送られるデータは8バイト目からで内容のチェック等は一切行われません。
エクスクルーシブメッセージなども送信可能です。                               
　ただし､複数のイベントをS-MPUに送ることはできません｡
                                                                             
  *event　 + 0|dword|イベントの発生時間(無視)                                
           + 4|dword|送信するデータのサイズ                                  
           + 8|byte |データ1バイト目(ステータス)                             
           + 9|byte |データ2バイト目                                         
           +10|byte |データ2バイト目                                         
                .         .                                                  
                .         .                                                  
                .         .                                                  
                                                                             
- 例 -                                                                       
unsgined char event16];                                                      
                                                                             
*(int *)&event[0] = 0;         /* ダミー               */                    
*(int *)&event[4] = 3;　       /* 転送するバイト数     */                    
event[ 8] = 0xb0;              /* コントロールチェンジ */                    
event[ 9] = 0x01;              /* モジュレーションを   */                    
event[10] = 0x00; 　　         /* 0 に設定　　　　　　 */                    
TMM_outputMidiEvent(0,event);  /* ポート0 に送信       */                    
                                                                             
-----------------------------------------------------------------------------
