.TMM_sendInternalVoice                                                       
内蔵音源へのMIDIデータ出力                                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_sendInternalVoice(unsigned char data);                               
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  内蔵音源にdataの示すMIDIデータを1バイト送信します。                        
                                                                             
- 例 -                                                                       
unsigned char event[] = {0xb0,64,0,0xff};                                    
                                                                             
int i;                                                                       
                                                                             
for(i = 0;event[i] != 0xff;i++)                                              
　　TMM_sendInternalVoice(event[i]);                                         
                                                                             
-----------------------------------------------------------------------------
.TMM_setAssignFilter                                                         
アサインフィルタの設定                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setAssignFilter(char map_numebr,ASSIGNFILTER *filter);               
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  アサインフィルターを登録します。map_numberの指すマップにfilterの構造体をコ 
ピーします。                                                                 
                                                                             
- 例 -                                                                       
ASSIGN assign;                                                               
                                                                             
assign.as_status = 0xffff;                                                   
assign.as_chmap = 0xffff;                                                    
assign.as_track = 0;                                                         
assign.as_velo = 0;                                                          
assign.as_oct = 0;                                                           
assign.as_ctrlmap = 0;                                                       
TMM_setAssignFilter(0,&assign);  /* map 0 に登録 */                          
                                                                             
-----------------------------------------------------------------------------
.TMM_setAssignMap                                                            
アサインマップの設定                                                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setAssignMap(PORT port,char map_numebr);                             
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  各入力ポートのアサインマップを設定します。portで示す入力ポートのイベントを 
map_numberの指すアサインマップにしたがって出力ポートへアサインします。       
                                                                             
  port         =　入力ポート番号                                             
  map_number =　アサインマップ番号 (0～3)                                    
                                                                             
-----------------------------------------------------------------------------
.TMM_setCFunc                                                                
Ｃ関数のコールバックルーチン登録                                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setCFunc(CFUNCCTRL c_func);                                          
                                                                             
- 戻り値 -                                                                   
0以上      :ハンドル                                                         
マイナス値 :エラー                                                           
                                                                             
- 機能 -                                                                     
  C関数のユーザーコールバックルーチンを登録します。これはTMM_setUserFuncがア 
センブラ関数しか登録できないことを補うための関数で、内部ではTMM_set UserFunc 
関数を呼び出しています。よって、この設定に対する解除はTMM_resetUserFuncを呼び
出してください。引数のCFUNCCTRL構造体は以下のようになっています。この関数は割
り込みが発生するとレジスタの情報をスタックに積んでコールバックルーチンをコー 
ルします。スタックの切替え等は行わないのでコールバックルーチン内でスタックを 
大量に消費しないように気をつけてください。                                   
                                                                             
  typedef struct{                                                            
  　void (*(cfc_idletask))();                                                
    void (*(cfc_rectask))(PORT,FLAG,TRACK,unsigned char *);                  
　  void (*(cfc_eventtask))(TRACK,PORT,unsigned char *);                     
  }CFUNCCTRL;                                                                
                                                                             
- 例 -                                                                       
 void idle_func();                                                           
 void rec_func(PORT input,FLAG assign,TRACK track,unsigned char *event);     
                                                                             
 void event_func(TRACK track,PORT port,unsigned char *event);                
                                                                             
 CFUNCCTRL  c_func;                                                          
 int handle;                                                                 
                                                                             
    c_func.cfc_rectask = rec_func;                                           
    c_func.cfc_idletask = idle_func;                                         
    c_func.cfc_eventtask = event_func;                                       
 　 if((handle = TMM_setCFunc(&c_func)) < 0)                                 
       return ERROR;                                                         
 　 else                                                                     
 　　　  ･                                                                   
 　　　　･                                                                   
 　 TMM_resetUserFunc(handle);                                               
                                                                             
-----------------------------------------------------------------------------
.TMM_setEupTempoOffset                                                       
EUPデータ相対テンポの設定                                                    
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setEupTempoOffset(int tempo_offset);                                 
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  EUPファイル演奏のテンポを相対的に変化させます。tempo_offsetの示す値をEUPフ 
ァイル演奏時のテンポに加えます。                                             
                                                                             
-----------------------------------------------------------------------------
.TMM_setInputPortMap                                                         
入力ポートマップの設定                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setInputPortMap(PORT physical,PORT logical);                         
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  入力ポートマップを設定します。physicalの示す物理ポートにlogicalの示す論理ポ
ート番号を登録します。                                                       
                                                                             
-----------------------------------------------------------------------------
.TMM_setInternalChannel                                                      
内蔵音源のMIDIチャンネル設定                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setInternalChannel(unsigned char voice_ch,                           
 　　　　　　　　　　　　　　 MIDICH midi_ch);                               
- 戻り値 -                                                                   
 0:正常終了                                                                  
-3:パラメータ値異常                                                          
                                                                             
- 機能 -                                                                     
  内蔵音源のMIDIチャンネルを設定します。voice_chの示す内蔵音源チャンネルが   
midi_chで示すMIDIチャンネルデータを受信する様にします。                      
                                                                             
  voice_ch  = 内蔵音源チャンネル (0～5、64～71)                              
  midi_ch   = MIDIチャンネル    (0～15)                                      
                                                                             
- 例 -                                                                       
/* pcmの0チャンネル目をMIDIチャンネル1に設定 */                              
TMM_setInternalChannel(64,0);                                                
                                                                             
-----------------------------------------------------------------------------
.TMM_setInternalVolume                                                       
内蔵音源のマスターボリューム設定                                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setInternalVolume(char volume);                                      
                                                                             
- 戻り値 -                                                                   
 0:正常終了                                                                  
-3:パラメータ値異常                                                          
                                                                             
- 機能 -                                                                     
  内蔵音源のマスターボリュームをvolumeで示された値(0-127)に設定します。      
                                                                             
- 例 -                                                                       
TMM_setInternalVolume(100);                                                  
                                                                             
-----------------------------------------------------------------------------
.TMM_setMetronome                                                            
メトロノームの設定                                                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setMetronome(METRONOME *metronome);                                  
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  メトロノームを設定します。metronomeで示されるMETRONOME構造体に従ってメトロ 
ノームの設定を行います。                                                     
                                                                             
-----------------------------------------------------------------------------
.TMM_setOutputPortMap                                                        
出力ポートマップの設定                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setOutputPortMap(PORT logical,PORT physical);                        
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  出力ポートマップを設定します。logicalの示すポートの物理出力ポートに        
physicalのポートを登録します。                                               
                                                                             
-----------------------------------------------------------------------------
.TMM_setPlayMode                                                             
演奏モードの設定                                                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setPlayMode(char mode);                                              
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  プレイモードを設定します。0ならノーマルモード、1ならエンドレスモード、2なら
ループモードとなります。エンドレスモードにすると、演奏中に終端マーカーを検出 
しても最終小節の拍子、テンポのままで演奏のカウントのみを続けます。元データの 
ない録音時などに利用します。また、ループモードを設定すると演奏データの終端マ 
ーカを検出するとバッファの先頭にポインタを設定し直して演奏を続けるようになり 
ます。                                                                       
                                                                             
  mode = 0　ノーマル再生                                                     
         1　エンドレス再生                                                   
         2　ループ再生                                                       
                                                                             
-----------------------------------------------------------------------------
.TMM_setRelativeTempo                                                        
相対テンポの設定                                                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setRelativeTempo(int relative_tempo);                                
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  現在のテンポを1％から1000％までの間で相対的に変化させることができます。設定
後にテンポを変更してもこの設定は有効となるのでテンポチェンジが含まれる曲全体 
を速く演奏させたい時などに使用します。また0％を指定するとステップ演奏モードと
なります。このモード時ではTMM_ste pModeEntry(ステップモードの進行)を用いて、 
任意のタイミングでシーケンスを進行させることができるようになります。         
                                                                             
-----------------------------------------------------------------------------
.TMM_setRemoteMode                                                           
リモートモードの設定                                                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setRemoteMode(char mode);                                            
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  リモートモードの設定、解除をします。modeが0以外の時はリモートモードとなり、
同期入力ポートから受け取ったスタート(0xFA)、コンティニュ(0xFB)、ストップ     
(0xFC)に反応して演奏のポーズ/解除がおこなわれます。                          
                                                                             
  mode = 0    　リモートモードオフ                                           
         0以外  リモートモードオン                                           
                                                                             
-----------------------------------------------------------------------------
.TMM_setSmpteLag                                                             
SMPTE同期精度の設定                                                          
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setSmpteLag(int lag,int correction);                                 
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  SMPTE同期の際の補正パラメータを設定します。SMPTE同期演奏モードでは演奏実時 
間とSMPTE実時間の差がlag(1/480000000sec単位)に収まる場合を同期中とみなしま   
す。同期演奏中にlagを超えるずれが生じた場合にcorrection(1/48000000sec 単位)時
間だけ演奏を継続し、もしその時間内に再びタイムラグ内に差が収まらなければ同期 
が外れたと見なし演奏を中断します。これは、S-MPUから送られてくるSMPTE時間が何 
らかの理由(例えばMIDI入出力を優先して処理した時や、テープに記録されている    
SMPTE情報が正しく読み取れなかった時)で正確でない場合でもそれをイレギュラーと 
みなして同期を確保するためです。同期開始前にSMPTE時間と演奏開始時間の差を計測
しつづけ、タイムラグ内になると演奏を開始(pause解除)します。従って、タイムラグ
を小さくとるとSMPTEの内部的に送られてくる時間によっては同期を開始しない場合が
あります。初期値はlagが960000(2msec)、correctionが96000000(200msec)です。    
                                                                             
-----------------------------------------------------------------------------
.TMM_setSmpteOffset                                                          
SMPTE開始位置の設定                                                          
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setSmpteOffset(REALTIME *time);                                      
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  SMPTEシンクをする場合のオフセットタイムを設定します。timeで示される        
REALTIME構造体の時間をSMPTE同期のスタート時間とします。                      
                                                                             
-----------------------------------------------------------------------------
.TMM_setSmpuTime                                                             
S-MPU内部時間の設定                                                          
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setSmpuTime(REALTIME *time);                                         
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  S-MPUの内部時計を設定します。                                              
                                                                             
-----------------------------------------------------------------------------
.TMM_setSyncIn                                                               
同期モードの設定                                                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setSyncIn(char mode,PORT port,char master,                           
 　　　　　　　　　int type,int level);                                      
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  同期モードを設定します。modeに同期モードを入れます。同期モードがMIDIクロッ 
クまたはMIDIタイムコードの場合はportで示す入力ポートの情報にシンクロします。 
また、同期モードがSMPTEの場合はどのタイムコードに同期するかをmasterに設定し  
S-MPUに対してタイムコードフレームタイプとコレクションレベル(推奨7)を指定しま 
す。                                                                         
                                                                             
  mode   = 0    内蔵タイマ同期モード                                         
         = 1    MIDIクロック同期モード                                       
         = 2    SMPTE同期モード                                              
  port   =　    同期入力ポート                                               
  master = 0    S-MPU内蔵タイマ                                              
         = 1    S-MPU外部機器                                                
         = 2    MIDIタイムコード                                             
  type   =      SMPTEフレームタイプ                                          
  level  =      エラー補正レベル(コレクションレベル 0～15)                   
                                                                             
-----------------------------------------------------------------------------
.TMM_setSyncOut                                                              
同期信号出力の設定                                                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setSyncOut(char mode,PORT port);                                     
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  同期信号出力を設定します。modeがINTERNALSYNC(0)の時は同期信号を出力しませ  
ん。MIDISYNC(1)のときは指定されたポートからMIDIクロックを出力します。        
SMPTESYNCの時は未サポートです。出力先のポート番号をportに設定します。        
                                                                             
  mode = 0  同期信号出力オフ                                                 
       = 1  MIDIクロック同期信号出力                                         
  port =    同期信号出力ポート                                               
                                                                             
-----------------------------------------------------------------------------
.TMM_setTempo                                                                
テンポの設定                                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setTempo(char type,int tempo);                                       
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  テンポを設定します。                                                       
  テンポの範囲は5BPM～500BPMの間です。typeの値によって指定方法が異なります。 
typeが0の時tempoで示す値は1/10BPM単位(実際のテンポ*10､120bpmなら1200)に設定し
ます。typeが1の時は四分音符の長さをμs単位で指定します。ただしこの時も計算し 
た結果が5bpm～500bpmの間になければなりません。                               
                                                                             
-----------------------------------------------------------------------------
.TMM_setUserFunc                                                             
ユーザーコールバックルーチンの登録                                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_setUserFunc(FUNCCTRL *func_ctrl);                                    
                                                                             
- 戻り値 -                                                                   
0以上   :ハンドル                                                            
マイナス:既に4個登録済                                                       
                                                                             
- 機能 -                                                                     
  func_ctrlの示すFUNCCTRL構造体の情報に従ってコールバックルーチンエントリを登
録します。戻り値にはハンドルが返されます。戻り値がマイナス値の場合は登録失敗 
です。コールバックルーチンにはレジスタに各情報が格納されて呼び出されるのでア 
センブラ記述しなければなりません。C関数を登録したい場合はTMM_set CFuncを使っ 
てください。                                                                 
  コールバックルーチンに渡されるレジスタの情報はFUNCCTRL構造体の説明をお読み 
ください。                                                                   
                                                                             
- 例 -                                                                       
FUNCCTRL funcctrl;                                                           
int handle;                                                                  
                                                                             
extern void IdleFunction();                                                  
                                                                             
funcctrl.fc_idletask = IdleFunction;                                         
funcctrl.fc_idleseg = 0x0c;                                                  
　　　　･                                                                    
　 　　･                                                                     
 　　　･                                                                     
handle = TMM_setUserFunc(&funcctrl);                                         
                                                                             
-----------------------------------------------------------------------------
.TMM_smpteToRealtime                                                         
SMPTE時間から実時間への変換                                                  
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_smpteToRealtime(REALTIME *time,SMPTE *smpte);                        
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  タイムコードを実時間情報にコンバートします。SMPTE構造体smpteのタイムコード 
をREALTIME構造体timeの時間情報にコンバートします。                           
                                                                             
-----------------------------------------------------------------------------
.TMM_stepModeEntry                                                           
ステップモードの進行                                                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_stepModeEntry(int step_clock);                                       
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  ステップ演奏モード時の演奏の進行を指示します。TMM_setRelativeTempo(相対テン
ポの設定)にて0％を指定するとステップ演奏モードとなります。このモードではこの 
関数によって指示されたクロック(step_clock)だけシーケンスが進行するので、ステ 
ップ録音等に利用できます。                                                   
                                                                             
-----------------------------------------------------------------------------
.TMM_termRsMidi                                                              
RS-MIDIルーチンの解除                                                        
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_termRsMidi(RSCTRL *rsctrl);                                          
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  RS232CMIDI処理ルーチンの登録を解除します。                                 
                                                                             
*****************************************************************************
第7章　CD-ROMライブラリ                                                      
*****************************************************************************
                                                                             
1.　CD-ROMライブラリ                                                         
                                                                             
 1.1　関数一覧                                                               
                                                                             
 ┌────────────┬───────────────────┐        
 │関数名　　　　　　　　　│機能　　　　　　　　　　　　　　　　　│        
 ├────────────┼───────────────────┤        
 │cdr_dopen           　　│CD-ROMトレイオープン　                │        
 ├────────────┼───────────────────┤        
 │cdr_dclose          　　│CD-ROMトレイクローズ　                │        
 ├────────────┼───────────────────┤        
 │cdr_dunlock         　　│オープン/クローズの有効設定           │        
 ├────────────┼───────────────────┤        
 │cdr_dlock           　　│オープン/クローズの無効設定           │        
 └────────────┴───────────────────┘        
                                                                             
 2.2　各関数の解説                                                           
                                                                             
-----------------------------------------------------------------------------
.cdr_dclose                                                                  
CD-ROMトレイクローズ　                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <CDRFRB.h>                                                          
int cdr_dclose(deviceno);                                                    
int deviceno;               /* デバイス番号(0) */                            
                                                                             
- 戻り値 -                                                                   
0     : 正常終了                                                             
0以外 : エラー                                                               
                                                                             
- 例 -                                                                       
  int deviceno = 0;                                                          
                                                                             
  ret = cdr_dclose(deviceno);                                                
                                                                             
- 内容 -                                                                     
  CD-ROMドライブのトレイをクローズします｡                                    
　ハードウェアにマウント/イジェクト機能のない機種では､コマンド異常終了エラー 
となります｡                                                                  
                                                                             
-----------------------------------------------------------------------------
.cdr_dlock                                                                   
オープン/クローズの無効設定                                                  
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <CDRFRB.h>                                                          
int cdr_dlock(deviceno);                                                     
int deviceno;               /* デバイス番号(0) */                            
                                                                             
- 戻り値 -                                                                   
0     : 正常終了                                                             
0以外 : エラー                                                               
                                                                             
- 例 -                                                                       
  int deviceno = 0;                                                          
                                                                             
  ret = cdr_dlock(deviceno);                                                 
                                                                             
- 内容 -                                                                     
  CD-ROMドライブのオープン/クローズボタンを無効にします｡                     
　ハードウェアにマウント/イジェクト機能のない機種では､状態は何も変化せず､正常
終了となります｡                                                              
                                                                             
-----------------------------------------------------------------------------
.cdr_dopen                                                                   
CD-ROMトレイオープン　                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <CDRFRB.h>                                                          
int cdr_dopen(deviceno);                                                     
int deviceno;               /* デバイス番号(0) */                            
                                                                             
- 戻り値 -                                                                   
0     : 正常終了                                                             
0以外 : エラー                                                               
                                                                             
- 例 -                                                                       
  int deviceno = 0;                                                          
                                                                             
  ret = cdr_dopen(deviceno);                                                 
                                                                             
- 内容 -                                                                     
  CD-ROMドライブのトレイをオープンします｡                                    
　ハードウェアにマウント/イジェクト機能のない機種では､コマンド異常終了エラー 
となります｡                                                                  
                                                                             
-----------------------------------------------------------------------------
.cdr_dunlock                                                                 
オープン/クローズの有効設定                                                  
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <CDRFRB.h>                                                          
int cdr_dunlock(deviceno);                                                   
int deviceno;               /* デバイス番号(0) */                            
                                                                             
- 戻り値 -                                                                   
0     : 正常終了                                                             
0以外 : エラー                                                               
                                                                             
- 例 -                                                                       
  int deviceno = 0;                                                          
                                                                             
  ret = cdr_dunlock(deviceno);                                               
                                                                             
- 内容 -                                                                     
  CD-ROMドライブのオープン/クローズボタンを有効にします｡                     
　ハードウェアにマウント/イジェクト機能のない機種では､状態は何も変化せず､正常
終了となります｡                                                              
