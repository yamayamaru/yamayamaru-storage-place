.TMM_getPlayPlace                                                            
演奏位置の取得                                                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <midiman.h>                                                         
int TMM_getPlayPlace(FLAG *flag,unsigned char **ptr,                         
　　　　　　　　　　 PLACE *place);                                          
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 機能 -                                                                     
  演奏状態、ポインタ、演奏位置を読み込みます。                               
  flagに現在の演奏状態を返します。それぞれの状態は下記の様に各ビットに割り振 
られているので、各ビットとアンドをとることによって現在の状態を把握できます。 
演奏中の場合はptrに現在演奏しているアドレス位置をplace構造体に現在の演奏位置 
を返します。                                                                 
                                                                             
  bit 　　7　6　5　4　3　2　1　0                                             
　　  ┌─┬─┬─┬─┬─┬─┬─┬─┐                                     
*flag │0 │0 │0 │0 │0 │＊│＊│＊│                                     
    　└─┴─┴─┴─┴─┴┬┴┬┴┬┘                                     
　　　　┌─────────┘　│　│                                       
　　　　│┌──────────┘　│                                       
　　　　││┌───────────┘                                       
　  　　││└──PLAYFLAG  ビットが立っていたら演奏中                       
        │└───PAUSEFLAG ビットが立っていたら一時停止中                   
        └────RECFLAG   ビットが立っていたら録音中                       
                                                                             
- 例 -                                                                       
PLACE place;                                                                 
SMPTE smpte;                                                                 
unsigned char *ptr;                                                          
FLAG flags;                                                                  
char str[2][20];                                                             
                                                                             
TMM_getPlayPlace(&flags,&ptr,&place);                                        
sprintf(str[0],"%3d:%2d:%3d",place.p_meas+1,place.p_beat+1,                  
        place.p_tick);                                                       
smpte.tc_type = SMPTE25;                                                     
if(TMM_realtimeToSmpte(&smpte,&place.p_time) == 0)                           
  sprintf(str[1],"%2d:%2d:%2d.%2d",smpte.tc_hr,smpte.tc_min,                 
          smpte.tc_sec,smpte.tc_fr);                                         
                                                                             
-----------------------------------------------------------------------------
