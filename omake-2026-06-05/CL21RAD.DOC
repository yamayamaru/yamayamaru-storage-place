 1.4　各関数の解説                                                           
                                                                             
-----------------------------------------------------------------------------
.EGB_digitizeAdjust                                                          
ディジタイズ画面取り込み位置の補正                                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <EGB.H>                                                             
int 　　EGB_digitizeAdjust( egb_work , xPlus , yPlus );                      
void    *egb_work;      /*  ＥＧＢ作業領域　　　　　　　　　　　*/           
int     xPlus;          /*  取り込み位置補正値Ｘ　　　　　　    */           
int     yPlus;  　　　  /*  取り込み位置補正値Ｙ　      　　　  */           
                                                                             
- 戻り値 -                                                                   
0 :正常終了                                                                  
-1:エラー                                                                    
                                                                             
- 例 -                                                                       
char    egb_work[EgbWorkSize];                                               
                                                                             
EGB_digitizeAdjust( egb_work , 8 , -1 );                                     
                                                                             
- 内容 -                                                                     
  ディジタイズ画面取り込み位置を補正します。                                 
  補正値は、現在の取り込み位置の差分を代入します。                           
  正の方向へ補正する場合は正の値を、負の方向へ補正する場合は負の値を代入しま 
す。                                                                         
                                                                             
-----------------------------------------------------------------------------
.EGB_getActiveBit                                                            
ＶＲＡＭ有効ビットの取得                                                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <EGB.H>                                                             
int     EGB_getActiveBit( handle , vrambit );                                
int     handle; 　　　　　　　/*　解像度ハンドル　　　　　　　　*/           
void    *vrambit;     　　　  /*  取得バッファのアドレス　　    */           
                                                                             
- 戻り値 -                                                                   
0　:正常終了                                                                 
-1 :エラー                                                                   
                                                                             
- 例 -                                                                       
char　　vrambit[8];                                                          
int 　　ret;                                                                 
                                                                             
ret = EGB_getActiveBit( 0 , vrambit );                                       
                                                                             
- 内容 -                                                                     
  画面のVRAM有効ビットを取得します。                                         
  解像度無依存インタフェースを使用して取得した解像度ハンドルを渡します。現在 
表示されている画面のVRAM有効ビットを取得する場合は解像度ハンドルにNULL(0)を渡
します。                                                                     
  総画面数分の取得バッファ(1ページ当たり4バイト必要)を用意する必要がありま   
  す。総画面数はEGB_getActivePage()を使用して取得します。                    
                                                                             
  取得バッファのデータ形式                                                   
  ┌─────┬──┬───┬───┬───────────────┐       
  │  ページ0 │　　│offset│ size │　　　　　内容　　　　　　　　│       
  │　　　　　│　　├───┼───┼───────────────┤       
  │パラメータ│　　│　+00 │　Ｂ　│ＶＲＡＭ青対応ビット　　　　　│       
  │　　　　　│　　├───┼───┼───────────────┤       
  ├─────┼┐　│　+01 │　Ｂ　│ＶＲＡＭ赤対応ビット　　　　　│       
  │  ページ1 ││  ├───┼───┼───────────────┤       
  │   　　　 ││  │　+02 │　Ｂ　│ＶＲＡＭ緑対応ビット　　　　　│       
  │パラメータ││  ├───┼───┼───────────────┤       
  │ 　 　　　││  │  +03 │　Ｂ　│ＶＲＡＭ輝度対応ビット　　　　│       
  ├─────┤└─┴───┴───┴───────────────┘       
  │          │                                                             
                                                                             
-----------------------------------------------------------------------------
.EGB_getActivePage                                                           
表示設定可能ページの取得                                                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <EGB.H>                                                             
int     EGB_getActivePage( handle , display );                               
int     handle; 　　　　　　/*　解像度ハンドル　　　　　　　　　*/           
void    *display;     　　  /*  現在の画面の表示可能なページ    */           
                                                                             
- 戻り値 -                                                                   
-1　　:エラー                                                                
-1以外:表示可能ページ                                                        
                                                                             
 　31　　　　　　　01　00                                                    
┌───────┬─┬─┐                                                   
└───────┴─┴─┘                                                   
 　　　　　　　　　↑　↑                                                    
 　　　　　　　　　│　└─ページ0表示可能状態                               
 　　　　　　　　　└───ページ1表示可能状態                               
 　　　　　　　　　　　　（0→表示不可能，1→表示可能)                       
                                                                             
- 例 -                                                                       
int 　　display;                                                             
                                                                             
mode = EGB_getActivePage( 0 , &display );                                    
                                                                             
- 内容 -                                                                     
  画面の表示設定可能なページを取得します。                                   
  解像度無依存インタフェースを使用して取得した解像度ハンドルを渡します。現在 
表示されている画面の表示可能ページを取得する場合は解像度ハンドルにNULL(0) を 
渡します。                                                                   
  現在の画面の表示可能なページを返す変数のポインタがNULL(0)の場合、変数に対し
て値を返しません。                                                           
                                                                             
-----------------------------------------------------------------------------
.EGB_getActivePalette                                                        
パレット有効ビットの取得                                                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <EGB.H>                                                             
int     EGB_getActivePalette( handle , palette );                            
int     handle; 　　　　　　　/*　解像度ハンドル　　　　　　　　*/           
void    *palette;     　　　  /*  取得バッファのアドレス　　    */           
                                                                             
- 戻り値 -                                                                   
0　:正常終了                                                                 
-1 :エラー                                                                   
                                                                             
- 例 -                                                                       
char　　palette[8];                                                          
int 　　ret;                                                                 
                                                                             
ret = EGB_getActivePalette( 0 , palette );                                   
                                                                             
- 内容 -                                                                     
  画面のパレット有効ビットを取得します。                                     
  解像度無依存インタフェースを使用して取得した解像度ハンドルを渡します。現在 
表示されている画面のパレット有効ビットを取得する場合は解像度ハンドルにNULL(0)
を渡します。                                                                 
  総画面数分の取得バッファ(1ページ当たり8バイト必要)を用意する必要がありま   
す。総画面数はEGB_getActivePage()を使用して取得します。                      
  パレット/輝度の有効ビットは、設定時に有効となるビットを返します。パレットが
存在しない画面モードの場合、0が返ります。                                    
  表現に必要な最小値は、色/輝度を表現するための最小値を返します。            
  パレットが存在しない画面モードの場合、0が返ります。                        
                                                                             
  取得バッファのデータ形式                                                   
  ┌─────┬──┬───┬───┬───────────────┐       
  │ ページ0　│　　│offset│ size │　　　　　内容　　　　　　　　│       
  │　　　　　│　　├───┼───┼───────────────┤       
  │パラメータ│　　│　+00 │　Ｂ　│青パレットの有効ビット　　　　│       
  │　　　　　│　　├───┼───┼───────────────┤       
  ├─────┼┐　│  +01 │　Ｂ　│赤パレットの有効ビット　　　　│       
  │ ページ1　││　├───┼───┼───────────────┤       
  │  　　　　││　│  +02 │　Ｂ　│緑パレットの有効ビット　　　　│       
  │パラメータ││　├───┼───┼───────────────┤       
  │　　  　　││　│　+03 │　Ｂ　│輝度の有効ビット　　　　　　　│       
  ├─────┤│　├───┼───┼───────────────┤       
  │　　　　　│└┐│　+04 │　Ｂ　│青色表現に必要な最小値　　　　│       
  │　　　　　│　│├───┼───┼───────────────┤       
　  　　　　　　　││　+05 │　Ｂ　│赤色表現に必要な最小値　　　　│       
　  　　　　　　　│├───┼───┼───────────────┤       
　  　　　　　　　││　+06 │　Ｂ　│緑色表現に必要な最小値　　　　│       
　  　　　　　　　│├───┼───┼───────────────┤       
　  　　　　　　　││　+07 │　Ｂ　│輝度表現に必要な最小値　　　　│       
　　  　　　　　　└┴───┴───┴───────────────┘       
                                                                             
-----------------------------------------------------------------------------
.EGB_getDisplayInfo                                                          
現在の表示画面サイズの取得                                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <egb.h>                                                             
void     EGB_getDisplayInfo( page , buf );                                   
int 　　 page;　　　　　/*　取得ページ(0，1)          　　  */               
void     *buf;          /*  情報取得バッファ(16バイト)　　  */               
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
char     buf[16];                                                            
                                                                             
EGB_getDisplayInfo( 1 , buf );                                               
                                                                             
- 内容 -                                                                     
  現在表示されている画面の表示開始位置と表示画面サイズを返します。           
  画面倍率を考慮しないピクセル単位の位置とサイズを返します。                 
  16バイトの取得バッファを用意する必要があります。取得バッファには以下のよう 
な情報が返ります。                                                           
  buf+00 ┌────┬──────────┐                                  
 　　　　│　ＤＷ　│　表示開始位置Ｘ　　│                                  
  buf+04 ├────┼──────────┤                                  
　 　　　│　ＤＷ　│　表示開始位置Ｙ　　│                                  
  buf+08 ├────┼──────────┤                                  
　 　　　│　ＤＷ　│　画面サイズＸ　　　│                                  
  buf+12 ├────┼──────────┤                                  
　 　　　│　ＤＷ　│　画面サイズＹ　　　│                                  
 　　　　└────┴──────────┘                                  
                                                                             
-----------------------------------------------------------------------------
.EGB_getResolutionIndex                                                      
パラメータによる解像度ハンドルの取得                                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <EGB.H>                                                             
int     EGB_getResolutionIndex( video , totalPage , para );                  
int     video;          /*  ビデオモード(0→無効，1→有効)　*/               
int     totalPage;      /*  設定する画面総数(1 or 2)　　　　　*/             
void    *para;　　　　　/*  パラメータのアドレス　      　　　  */           
                                                                             
- 戻り値 -                                                                   
-1以外:正常終了。パラメータの内容に対応した解像度ハンドルを返す。            
       ハンドルはOSの版数により変動するので値の内容を期待してはいけない。    
-1　　:エラー                                                                
                                                                             
- 例 -                                                                       
int 　　handle;                                                              
char    egb_work[EgbWorkSize];                                               
RESOLUTION para[]                                                            
= { 1024, 512, 640, 480,   4, 512, (void *)0x00000, 0x120, 0 ,               
     1024, 512, 640, 480,   4, 512, (void *)0x40000, 0x120, 0 };             
                                                                             
handle = EGB_getResolutionIndex( 0 , 2 , para );                             
EGB_resolutionHandle( egb_work , 0 , handle );                               
                                                                             
- 内容 -                                                                     
  パラメータを渡し、解像度ハンドルの取得を行います。                         
  パラメータのアドレスに設定する画面総数分のパラメータを用意する必要がありま 
す。パラメータは、他の解像度無依存インタフェースを使用して取得した値を使用し 
ます。今後の画面サイズの拡大に対応できないため、固定値の代入は避けてくださ   
い。                                                                         
                                                                             
- パラメータの形式 -                                                         
  ┌─────┬──┬───┬───┬───────────────┐       
  │ ページ0　│　　│offset│ size │　　　　　　内容　　　　　　　│       
  │　　　　　│　　├───┼───┼───────────────┤       
  │パラメータ│　  │　+00 │　DW　│仮想画面Ｘの解像度（ドット数）│       
  │　　　　　│　　├───┼───┼───────────────┤       
  ├─────┼┐　│　+04 │　DW　│仮想画面Ｙの解像度（ドット数）│       
  │ ページ1　││　├───┼───┼───────────────┤       
  │　　　　　││　│　+08 │　DW　│表示画面Ｘの解像度（ドット数）│       
  │パラメータ││　├───┼───┼───────────────┤       
  │　　　　　││　│　+12 │　DW　│表示画面Ｙの解像度（ドット数）│       
  ├─────┤│　├───┼───┼───────────────┤       
  │　　　　　││　│　+16 │　DW　│ＶＲＡＭピクセルのビット数　　│       
  │　　　　　││　├───┼───┼───────────────┤       
　  　　　　　　└┐│　+20 │　DW　│1ラインのバイト数　　　　　　 │       
　　  　　　　　　│├───┼───┼───────────────┤       
　　　  　　　　　││　+24 │　DW　│ＶＲＡＭ先頭オフセット　　　　│       
　　　　  　　　　│├───┼───┼───────────────┤       
　　　　　  　　　││　+28 │　Ｗ　│ＶＲＡＭセレクタ　　　　　　　│       
　　　　　　  　　│├───┼───┼───────────────┤       
　　　　　　　  　││　+30 │　Ｗ　│リザーブ　　　　　　　　　　　│       
　　　　　　　　  └┴───┴───┴───────────────┘       
                                                                             
-----------------------------------------------------------------------------
.EGB_getResolutionMax                                                        
ピクセル数(色数)による最大解像度の取得                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <EGB.H>                                                             
int 　  EGB_getResolutionMax( video , color , buf );                         
int     video;          /*  ビデオモード(0→無効，1→有効)　*/               
void    *color; 　　　　/*  パラメータのアドレス　      　　　  */           
void    *buf; 　　　　　/*  取得バッファのアドレス　　  　　　  */           
                                                                             
- 戻り値 -                                                                   
-1以外:正常終了。パラメータの内容に対応した解像度ハンドルを返すハンドルはOS  
       の版数により変動するので値の内容を期待してはいけない。                
-1　　:エラー                                                                
                                                                             
- 例 -                                                                       
char         para[12];                                                       
RESOLUTION   buf[2];                                                         
int 　　　   handle;                                                         
                                                                             
DWORD( para + 0 ) = 2;                                                       
DWORD( para + 4 ) = 4;                                                       
DWORD( para + 8 ) = 4;                                                       
handle = EGB_getResolutionMax( 0 , para , buf );                             
                                                                             
- 内容 -                                                                     
  パラメータで指定されたピクセル数の最大解像度を取得します。                 
  パラメータで指定した総ページ数分の取得バッファ(1ページ当たり32バイト必要)を
用意する必要があります。                                                     
                                                                             
- パラメータの形式 -                                                         
 ┌───┬───┬────────────┐                                
 │offset│ size │　　　　　内容　　　　　│                                
 ├───┼───┼────────────┤                                
 │　+00 │　DW　│　総ページ数（1 or 2）　│                                
 ├───┼───┼────────────┤                                
 │　+04 │　DW　│　ページ0のピクセル数 　│                                
 ├───┼───┼────────────┤                                
 │　+08 │　DW　│　ページ1のピクセル数 　│                                
 └───┴───┴────────────┘                                
                                                                             
- 取得バッファのデータ形式 -                                                 
                                                                             
 ┌─────┬──┬───┬───┬───────────────┐        
 │ ページ0　│　　│offset│ size │　　　　　内容　　　　　　　　│        
 │　　　　　│　　├───┼───┼───────────────┤        
 │パラメータ│　　│　+00 │　DW　│仮想画面Ｘの解像度（ドット数）│        
 │　　　　　│　　├───┼───┼───────────────┤        
 ├─────┼┐　│　+04 │　DW　│仮想画面Ｙの解像度（ドット数）│        
 │ ページ1　││　├───┼───┼───────────────┤        
 │　　　　　││　│　+08 │　DW　│表示画面Ｘの解像度（ドット数）│        
 │パラメータ││　├───┼───┼───────────────┤        
 │　　　　　││　│　+12 │　DW　│表示画面Ｙの解像度（ドット数）│        
 ├─────┤│　├───┼───┼───────────────┤        
 │　　　　　││　│　+16 │　DW　│ＶＲＡＭピクセルのビット数　　│        
 │　　　　　││　├───┼───┼───────────────┤        
 　　　　　　　└┐│　+20 │　DW　│1ラインのバイト数　　　　 　　│        
 　　　　　　　　│├───┼───┼───────────────┤        
 　　　　　　　　││　+24 │　DW　│ＶＲＡＭ先頭オフセット　　　　│        
 　　　　　　　　│├───┼───┼───────────────┤        
 　　　　　　　　││　+28 │　Ｗ　│ＶＲＡＭセレクタ　　　　　　　│        
 　　　　　　　　│├───┼───┼───────────────┤        
 　　　　　　　　││　+30 │　Ｗ　│リザーブ　　　　　　　　　　　│        
 　　　　　　　　└┴───┴───┴───────────────┘        
                                                                             
-----------------------------------------------------------------------------
.EGB_getResolutionMode                                                       
画面モード番号による解像度ハンドルの取得                                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <EGB.H>                                                             
int     EGB_getResolutionMode( mode , buf );                                 
void    *mode;          /*  パラメータのアドレス　　　　　　　　*/           
void    *buf; 　　　　　/*  取得バッファのアドレス      　　　  */           
                                                                             
- 戻り値 -                                                                   
-1以外:正常終了。パラメータの内容に対応した解像度ハンドルを返すハンドルはOS  
       の版数により変動するので値の内容を期待してはいけない。                
-1　　:エラー                                                                
                                                                             
- 例 -                                                                       
int 　       handle;                                                         
char         para[12];                                                       
RESOLUTION   buf[2];                                                         
                                                                             
DWORD( para+0 ) = 2;                                                         
DWORD( para+4 ) = 3;                                                         
DWORD( para+8 ) = 3;                                                         
handle = EGB_getResolutionMode( para , buf );                                
                                                                             
- 内容 -                                                                     
  パラメータを渡し、解像度ハンドルの取得を行います。                         
  パラメータのアドレスに設定する画面総数分のパラメータを用意する必要がありま 
す。                                                                         
  パラメータで指定した総ページ数分の取得バッファ(1ページ当たり32バイト必要)を
用意する必要があります。                                                     
                                                                             
- パラメータの形式 -                                                         
 ┌───┬───┬──────────────┐                            
 │offset│ size │　　　　　　内容　　　　　　│                            
 ├───┼───┼──────────────┤                            
 │  +00 │　DW　│　総ページ数（1 or 2）　　　│                            
 ├───┼───┼──────────────┤                            
 │　+04 │　DW　│　ページ0の画面モード番号 　│                            
 ├───┼───┼──────────────┤                            
 │　+08 │　DW　│　ページ1の画面モード番号 　│                            
 └───┴───┴──────────────┘                            
                                                                             
- 取得バッファのデータ形式 -                                                 
 ┌─────┬──┬───┬───┬───────────────┐        
 │  　　　　│　　│offset│ size │　　　　　内容　　　　　　　　│        
 │ ページ0　│　　├───┼───┼───────────────┤        
 │パラメータ│　　│　+00 │　DW　│仮想画面Ｘの解像度（ドット数）│        
 │　　　　　│　　├───┼───┼───────────────┤        
 ├─────┼┐　│　+04 │　DW　│仮想画面Ｙの解像度（ドット数）│        
 │　　　　　││　├───┼───┼───────────────┤        
 │ ページ1　││  │　+08 │　DW　│表示画面Ｘの解像度（ドット数）│        
 │パラメータ││　├───┼───┼───────────────┤        
 │　　　　　││　│　+12 │　DW　│表示画面Ｙの解像度（ドット数）│        
 ├─────┤│　├───┼───┼───────────────┤        
 │　　　　　││  │　+16 │　DW　│ＶＲＡＭピクセルのビット数　　│        
 │　　　　　││　├───┼───┼───────────────┤        
 　　　　　　　└┐│　+20 │　DW　│1ラインのバイト数　　　　　　 │        
   　　　　　  　│├───┼───┼───────────────┤        
   　　　　　　　││　+24 │　DW　│ＶＲＡＭ先頭オフセット　　　　│        
　 　　　　　　　│├───┼───┼───────────────┤        
　 　　　　　　　││　+28 │　Ｗ　│ＶＲＡＭセレクタ　　　　　　　│        
　 　　　　　　　│├───┼───┼───────────────┤        
　 　　　　　　　││　+30 │　Ｗ　│リザーブ　　　　　　　　　　　│        
　 　　　　　　　└┴───┴───┴───────────────┘        
                                                                             
-----------------------------------------------------------------------------
.EGB_getResolutionPage                                                       
ページ指定による解像度の取得                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <EGB.H>                                                             
int     EGB_getResolutionPage( page , buf );                                 
int     page; 　　　　　/*  取得するページ番号(0 or 1)        */             
void    *buf; 　　　　　/*  取得バッファのアドレス　　  　　　  */           
                                                                             
- 戻り値 -                                                                   
-1以外:正常終了。パラメータの内容に対応した解像度ハンドルを返す。            
       ハンドルはOSの版数により変動するので値の内容を期待してはいけない。    
-1　　:エラー                                                                
                                                                             
- 例 -                                                                       
RESOLUTION   buf[1];                                                         
int 　       handle;                                                         
                                                                             
handle = EGB_getResolutionPage( 1 , buf );                                   
                                                                             
- 内容 -                                                                     
  現在設定されている画面の解像度情報を取得します。32バイトの取得バッファを用 
意する必要があります。                                                       
                                                                             
- 取得バッファのデータ形式 -                                                 
 ┌───┬───┬───────────────┐                          
 │offset│ size │　　　　　　内容　　　　　　　│                          
 ├───┼───┼───────────────┤                          
 │　+00 │　DW　│仮想画面Ｘの解像度（ドット数）│                          
 ├───┼───┼───────────────┤                          
 │　+04 │　DW　│仮想画面Ｙの解像度（ドット数）│                          
 ├───┼───┼───────────────┤                          
 │　+08 │　DW　│表示画面Ｘの解像度（ドット数）│                          
 ├───┼───┼───────────────┤                          
 │　+12 │　DW　│表示画面Ｙの解像度（ドット数）│                          
 ├───┼───┼───────────────┤                          
 │　+16 │　DW　│ＶＲＡＭピクセルのビット数　　│                          
 ├───┼───┼───────────────┤                          
 │　+20 │　DW　│1ラインのバイト数　　　　 　　│                          
 ├───┼───┼───────────────┤                          
 │　+24 │　DW　│ＶＲＡＭ先頭オフセット　　　　│                          
 ├───┼───┼───────────────┤                          
 │　+28 │　Ｗ　│ＶＲＡＭセレクタ　　　　　　　│                          
 ├───┼───┼───────────────┤                          
 │　+30 │　Ｗ　│リザーブ　　　　　　　　　　　│                          
 └───┴───┴───────────────┘                          
                                                                             
-----------------------------------------------------------------------------
.EGB_resolutionHandle                                                        
解像度ハンドルによる仮想画面の設定                                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <EGB.H>                                                             
int     EGB_resolutionHandle( work , crtc , handle );                        
char    *egb_work;     /*  ＥＧＢ作業領域　　　　　　　　　　　*/            
int     crtc;          /*  0→CRTC設定　1→CRTC設定しない      */            
int     handle; 　　　 /*  解像度ハンドル　　　　      　　　  */            
                                                                             
- 戻り値 -                                                                   
0　:正常終了                                                                 
-1 :エラー                                                                   
                                                                             
- 例 -                                                                       
int 　       handle;                                                         
char         egb_work[EgbWorkSize];                                          
char         para[12];                                                       
RESOLUTION   buf[2];                                                         
                                                                             
DWORD( para+0 ) = 2;                                                         
DWORD( para+4 ) = 3;                                                         
DWORD( para+8 ) = 3;                                                         
handle = EGB_getResolutionMode( para , buf );                                
EGB_resolutionHandle( egb_work , 0 , handle );                               
                                                                             
- 内容 -                                                                     
  取得した解像度ハンドルを使用して仮想画面の設定を行います。                 
  作業領域を以下のように初期化します。                                       
                                                                             
  書き込みページ　　:　ページ0                                               
  表示ページ　　　　:　ハードウェア依存                                      
  前景色　　　　　　:　最大色識別番号                                        
  背景色　　　　　　:　色識別番号0                                           
  繰抜色　　　　　　:　色識別番号0                                           
  混色比率　　　　　:　128(平均)                                             
  ビューポート　　　:　画面域                                                
  文字間の空白　　　:　0                                                     
  文字の方向　　　　:　右                                                    
  文字の並び　　　　:　右方向                                                
  文字描画X座標　　 :　0                                                     
  文字描画Y座標　　 :　0                                                     
  面塗りモード　　　:　境界ベタ                                              
  面塗り色　　　　　:　色識別番号0                                           
  描画モード　　　　:　PSET                                                  
  スーパーインポーズ:　OFF                                                   
  インポーズ領域　　:　なし                                                  
  インポーズ輝度　　:　高輝度                                                
  ペンの太さ　　　　:　1                                                     
  字体　　　　　　　:　標準                                                  
  線分パターン　　　:　直線                                                  
  ハッチングパターン:　未登録                                                
  タイルパターン　　:　未登録                                                
                                                                             
  設定された画面が16色モード、もしくは256色モードの場合にはパレットデータが初
期化されます。                                                               
                                                                             
-----------------------------------------------------------------------------
.EGB_setStackAddress                                                         
スタック領域アドレスの設定                                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <EGB.H>                                                             
void　　EGB_setStackAddress( egb_work , buf );                               
void    *egb_work;   　 /*  ＥＧＢ作業領域　　　　　　　　　　　*/           
void    *para           /*  パラメータのアドレス　　　　　　    */           
                                                                             
- 戻り値 -                                                                   
  なし                                                                       
                                                                             
- 内容 -                                                                     
  EGBが描画時に使用するスタックのアドレスを指定します。                      
  以下の16バイトのパラメータを用意します。                                   
  システム動作用スタックサイズは8192を代入します。                           
  総スタック領域は、スタックサイズ＋システム動作用スタックサイズ分の領域を必 
要とします。                                                                 
                                                                             
  para+00┌────┬────────────────┐                      
 　　　　│　ＤＷ　│　スタックサイズ　　　　　　　　│                      
 　　 04 ├────┼────────────────┤                      
 　　　　│　ＤＷ　│　システム動作用スタックサイズ　│                      
 　　 08 ├────┼────────────────┤                      
 　　　　│　ＤＷ　│　スタック先頭アドレス　　　　　│                      
 　　 12 ├────┼────────────────┤                      
 　　　　│　ＤＷ　│　スタックセレクタ　　　　　　　│                      
 　　　　└────┴────────────────┘                      
                                                                             
-----------------------------------------------------------------------------
.EGB_setStackEvent                                                           
スタック領域取得開放イベントの設定                                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <EGB.H>                                                             
void　　EGB_setStackEvent( egb_work , allocEvent , freeEvent );              
void    *egb_work;   　　  　　　 /*  ＥＧＢ作業領域　　　　　　*/           
void　　(*allocEvent)();    　　　/*  スタック確保イベント　　　*/           
void　　(*freeEvent)(); 　  　    /*  スタック開放イベント　    */           
                                                                             
- 戻り値 -                                                                   
  なし                                                                       
                                                                             
- 内容 -                                                                     
  EGBが描画時に必要とするスタック領域を確保/開放するための処理を登録します。 
EGBは描画中にスタックを必要とするときに自動的にスタック確保イベントを呼び、  
EGB_setStackAddress()で渡された領域をスタックとして使用し、描画終了後、EGBは 
自動的にスタック開放イベントを呼びます。                                     
  EGB_init()，EGB_resolution()，EGB_writePage()が呼ばれた時、登録された処理が
クリアされ、EGBは通常のスタック領域を使用します。                            
  スタック確保イベントに対してEGBが必要とするスタックサイズを渡します。詳しく
は｢動的スタック変更サンプルプログラム｣を参照願います。                       
  登録するイベントはAUTO変数を使用しないでください。変数は必ずstatic変数を使 
用してください。(イベント動作中、DS≠SSとなるケースがあり、AUTO変数は正常動作
しません)                                                                    
                                                                             
*****************************************************************************
第2章　マウスライブラリ                                                      
*****************************************************************************
                                                                             
1.　マウスライブラリ                                                         
                                                                             
 1.1　関数一覧                                                               
                                                                             
┌───────────┬─────────────────────┐       
│関数名　　　　　　　　│機能　　　　　　　　　　　　　　　　　　　│       
├───────────┼─────────────────────┤       
│MOS_resolutionHandle　│解像度ハンドルによるマウスの仮想画面の設定│       
├───────────┼─────────────────────┤       
│MOS_saveEvent 　　　　│マウスイベント･サブルーチンの退避　　　 　│       
├───────────┼─────────────────────┤       
│MOS_restoreEvent　　　│マウスイベント･サブルーチンの復元　　　 　│       
└───────────┴─────────────────────┘       
                                                                             
 1.2　各関数の解説                                                           
                                                                             
-----------------------------------------------------------------------------
.MOS_resolutionHandle                                                        
解像度ハンドルによるマウスの仮想画面の設定                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <MOS.H>                                                             
int     MOS_resolutionHandle( handle );                                      
int     handle; 　　　　/*  解像度ハンドル　　　　      　　　  */           
                                                                             
- 戻り値 -                                                                   
0　:正常終了                                                                 
-1 :エラー                                                                   
                                                                             
- 例 -                                                                       
int 　　handle;                                                              
MOS_resolutionHandle( handle );                                              
                                                                             
- 内容 -                                                                     
  取得した解像度ハンドルを使用してマウスの仮想画面の設定を行います。         
  画面の表示制御は行いません。画面の表示制御はEGBで行ってください。          
  仮想画面の設定時、以下のように設定します。                                 
                                                                             
 マウスカーソル位置　　:画面中央                                             
 マウスカーソル形状　　:システム形状                                         
 マウスカーソル移動範囲:画面全体                                             
                                                                             
-----------------------------------------------------------------------------
.MOS_restoreEvent                                                            
マウスイベント･サブルーチンの復元                                            
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <mos.h>                                                             
void     MOS_restoreEvent( buf );                                            
void     *buf;          /*  イベント退避領域　　　　　　　  */               
                                                                             
- 戻り値 -                                                                   
  なし                                                                       
                                                                             
- 例 -                                                                       
char     buff[MosEventSave];                                                 
                                                                             
MOS_restoreEvent( buff );                                                    
                                                                             
- 内容 -                                                                     
  MOS_saveEvent()で退避したイベントとサブルーチン呼び出し条件を復元します。  
  必ずMOS_saveEvent()と対で使用してください。                                
                                                                             
-----------------------------------------------------------------------------
.MOS_saveEvent                                                               
マウスイベント･サブルーチンの退避                                            
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <mos.h>                                                             
void     MOS_saveEvent( buf );                                               
void     *buf;          /*  イベント退避領域　　　　　　　  */               
                                                                             
- 戻り値 -                                                                   
  なし                                                                       
                                                                             
- 例 -                                                                       
char     buff[MosEventSave];                                                 
                                                                             
MOS_saveEvent( buff );                                                       
                                                                             
- 内容 -                                                                     
  MOS_setEvent()で登録したマウスイベントのアドレスと、MOS_entsub()で登録した 
ユーザ定義サブルーチンアドレスと呼び出し条件を退避します。                   
  上記のイベントを保存した後、イベントが動作しないようにイベントアドレスをク 
リアして、イベントを停止します。                                             
  イベント退避領域として36バイトの退避領域を指定する必要があります。         
                                                                             
*****************************************************************************
第3章　ＦＭ　Ｃ関数ライブラリ                                                
*****************************************************************************
                                                                             
1.　ＦＭ　Ｃ関数ライブラリ                                                   
                                                                             
 1.1　関数一覧                                                               
                                                                             
   ･補助記憶装置サポート                                                     
┌──────────┬──────────────────────┐       
│ 関数名　　　　　　 │機能　　　　　　　　　　　　　　　　　　　　│       
├──────────┼──────────────────────┤       
│ DKB_format         │トラックフォーマット　　　　　　　　　　　　│       
├──────────┼──────────────────────┤       
│ DKB_rddetailerr    │詳細エラー情報の取り出し（SCSIのみ）　　　　│       
├──────────┼──────────────────────┤       
│ DKB_scsiintf       │特殊SCSIインターフェース　　　　　　　　　　│       
└──────────┴──────────────────────┘       
                                                                             
  ･RS-232Cインターフェイス                                                   
┌──────────┬──────────────────────┐       
│ 関数名　　　　　　 │機能　　　　　　　　　　　　　　　　　　　　│       
├──────────┼──────────────────────┤       
│ RSB_clsxoff     　 │XOFF受信のクリア　      　    　　　　　　　│       
├──────────┼──────────────────────┤       
│ RSB_gettxlen    　 │送信バッファ内の有効データ数の読み取り　　　│       
├──────────┼──────────────────────┤       
│ RSB_hdchk       　 │FIFO機能の有無の検出　　　　　　　　　　　　│       
├──────────┼──────────────────────┤       
│ RSB_rdpara      　 │通信パラメータの読み取り      　　　　　　　│       
└──────────┴──────────────────────┘       
                                                                             
 1.2　各関数の解説                                                           
                                                                             
-----------------------------------------------------------------------------
.DKB_format                                                                  
トラックフォーマット                                                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <FMCFRB.H>                                                          
int     DKB_format( devno, cylno, headno, datasize, buf);                    
int     devno;              /*  デバイス番号  　　　　　　　  　*/           
int     cylno;              /*  シリンダ番号    　　　　　　　　*/           
int    headno;              /*  ヘッド番号      　　　　　　　　*/           
int  datasize;              /*  フォーマットデータのサイズ　　　*/           
char     *buf;              /*  フォーマットデータ　　　　　　　*/           
                                                                             
- 戻り値 -                                                                   
0000H :正常終了                                                              
0002H :デバイス番号の誤り                                                    
0003H :メモリエラー                                                          
8???H :ハードエラー(？？？は詳細エラー情報)                                  
                                                                             
- 例 -                                                                       
int     devno, cylno, headno, datasize, ret, i;                              
char    buf[13000];                                                          
devno = 0x0020;                                                              
cylno = 0x0001;                                                              
headno = 0;                                                                  
datasize = 13000;                                                            
                                                                             
for(i=0;i<13000;i++)                                                         
   buf[i] = 0x00;                                                            
                                                                             
ret = DKB_format( devno, cylno, headno, datasize, buf);                      
                                                                             
- 内容 -                                                                     
  1シリンダ分のフォーマットを行います。                                      
  この機能実行時には、書き込むデータが正しく書かれたかどうか、(ハード上)検出 
することができないため(リターンが正常終了であっても、再度読み込むことができな
い場合がある)、この機能を実行時に、書き込む1シリンダ分のセクタをベリファイす 
ることを推奨します。                                                         
                                                                             
-----------------------------------------------------------------------------
.DKB_rddetailerr                                                             
詳細エラー情報の取り出し(ＳＣＳＩのみ)                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <FMCFRB.H>                                                          
int     DKB_rddetailerr( devno, err );                                       
int     devno;          　　/*  デバイス番号　　　　　　　　　  */           
char    *err;               /*  エラー情報  　　　　　　　　　  */           
                                                                             
- 戻り値 -                                                                   
0000H :正常終了                                                              
0002H :デバイス番号の誤り                                                    
8???H :ハードエラー(???は詳細エラー情報)                                     
                                                                             
- 例 -                                                                       
int     devno, ret;                                                          
char    err[256];                                                            
                                                                             
devno  = 0x00B0;                                                             
                                                                             
ret = DKB_rddetailerr( devno, err );                                         
                                                                             
- 内容 -                                                                     
  詳細なエラー情報を読み出します。                                           
  出力データエリアは、256バイト用意してください。                            
  取り出したエラー情報は、各SCSIデバイスの仕様書を参照してください。         
                                                                             
-----------------------------------------------------------------------------
.DKB_scsiintf                                                                
特殊ＳＣＳＩインターフェース                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <FMCFRB.H>                                                          
int     DKB_scsiintf( devno, unitno, cmdsize, transfsize,                    
　                                   　　memsize, status, message, paraaddr);
                                                                             
int     devno;  　　/*  デバイス番号　　　　　　        */                   
int     unitno; 　　/*  ＬＵＮ(ロジカルユニット番号)  */                     
int     cmdsize;　　/*  コマンドデータサイズ　　        */                   
int     transfsize; /*  転送データサイズ　　　　        */                   
int     *memsize;   /*  メモリサイズ (KB)               */                   
char    *status;    /*  ステータス(ステータスフェーズのデータ)  */           
char    *message;   /*  メッセージ(メッセージアウトフェーズのデータ)*/       
char    *paraaddr;  /*  パラメータアドレス      　　　　*/                   
                                                                             
- 戻り値 -                                                                   
0000H :正常終了                                                              
0001H :SCSIバスビジィ                                                        
0002H :デバイス未接続                                                        
0003H :メモリエラー                                                          
       ﾒﾓﾘｴﾗｰのとき、ﾒﾓﾘｻｲｽﾞに最大に取得できるﾒﾓﾘｻｲｽﾞ(KB)が入る              
                                                                             
- 例 -                                                                       
int    devno, unitno, cmdsize, transfsize, memset, memsize, ret, i;          
char   status;                                                               
char   message;                                                              
struct                                                                       
{                                                                            
   unsigned int offset;                                                      
   unsigned short dsec;                                                      
   char   cmd_data[6];}                                                      
}paraaddr;                                                                   
char   transf_data[512];                                                     
struct SREGS seg;                                                            
_segread(&seg);                                                              
                                                                             
devno = 0x00B0;                                                              
unitno = 0x00;                                                               
cmdsize = 6;                                                                 
transfsize = 512;                                                            
                                                                             
BSETDATAADR( (char *)&paraaddr.offset, transf_data);                         
paraaddr.dsec = seg.ds;                                                      
                                                                             
for(i=0; i<6; i++)                                                           
   paraaddr.cmd_data[i] = 0x00;                                              
                                                                             
for(i=0; i<512 ; i++)                                                        
   transf_data[i] = 0x00;                                                    
                                                                             
ret = DKB_scsiintf( devno, unitno, cmdsize, transfsize, &memset, &memsize,   
　　　　　　　　　　　　　　　　　　　&status, &message, (char *)&paraaddr); 
                                                                             
- 内容 -                                                                     
  アプリケーションから与えられたパラメータをもとに、SCSIの処理およびデータの 
リード･ライトを行い、ステータスを返します。                                  
                                                                             
┌─┬─┬───────┐　　┌───→┌─┬─┬────┬──             
│Ｅ│Ｐ│ﾃﾞｰﾀ 転送ｱﾄﾞﾚｽ├──┘　　　　│Ｅ│Ｂ│転送ﾃﾞｰﾀ│↑               
├─┼─┼───────┼──　　　　　├─┼─┼────┤│               
│Ｅ│Ｂ│ｺﾏﾝﾄﾞ(CDB)    │↑　　　　　　│　│　│　　　　│datasize         
├─┼─┼───────┤│　　　　　　～　～　～　　　　～│               
│　│　│　　　　  　　│cmdsize       │　│　│　　　　│↓               
～　～　～　　　  　　　～│　　　　　  └─┴─┴────┴──             
│　│　│　　　　　  　│↓                                                 
└─┴─┴───────┴──                                               
                                                                             
- 注意 -                                                                     
  このインターフェイスは、ステータス、メッセージが1バイトのみ有効です。      
  転送データサイズとコマンドデータとデータ転送アドレスを合わせた大きさが、   
24KB以下になるように行ってください。                                         
                                                                             
-----------------------------------------------------------------------------
.RSB_clsxoff
ＸＯＦＦ受信のクリア
-----------------------------------------------------------------------------

- 定義 -
#include <FMCFRB.H> 
int     RSB_clsxoff(int port);
int 　　port;               /*  ポート番号(0～4) */ 

- 戻り値 -
0：正常終了
2：範囲外のポートを指定した
3：拡張カードが接続されていないポートを指定した
4：回線がオープン状態ではない

- 例 -
int   port = 0; 
int   ret;

ret = RSB_clsxoff(port);

- 内容 -
　XON/XOFF制御を行っているときに､通常はXOFFのあとにXONが送信されて来ますが､何
らかの原因でXONが来なかった場合は送信不可能となります。送信不可能となった場合､
この関数を実行することにより､XOFFの受信をクリアし、送信可能とします。

-----------------------------------------------------------------------------
.RSB_gettxlen
送信バッファ内の有効データ数の読み取り
-----------------------------------------------------------------------------

- 定義 -
#include <FMCFRB.H> 
int     RSB_gettxlen(int port, int *len); 
int 　　port;               /*  ポート番号(0～4) */ 
int     *len;               /*  データ数         */ 

- 戻り値 -
0：正常終了
2：範囲外のポートを指定した
3：拡張カードが接続されていないポートを指定した
4：回線がオープン状態ではない

- 例 -
int   port = 0; 
int   len;
int   ret;

ret = RSB_gettexlen(port, &len);

- 内容 -
　送信バッファ内に入っているデータ数を返します。

-----------------------------------------------------------------------------
.RSB_hdchk                                                                   
ＦＩＦＯ機能の有無の検出                                                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <FMCFRB.H>                                                          
unsigned int  RSB_hdchk();                                                   
                                                                             
- 戻り値 -                                                                   
  検出データ                                                                 
                                                                             
- 例 -                                                                       
unsigned int  fifodt;                                                        
fifodt = RSB_hdchk();                                                        
                                                                             
- 内容 -                                                                     
  ポート0(標準ポート)のFIFO機能の有無を読み取ります。                        
                                                                             
　　　　        検出データ                                                   
　　　　   15  14  13  12  11  10   9   8                                    
        ┌─┬─┬─┬─┬─┬─┬─┬─┐                                   
 ifodt: │ -│ -│ -│ -│ -│ -│ -│ -│                                   
        └─┴─┴─┴─┴─┴─┴─┴─┘                                   
                                                                             
　  　　　  7   6   5   4   3   2   1   0                                    
　      ┌─┬─┬─┬─┬─┬─┬─┬─┐                                   
　      │ -│ -│ -│ -│ -│ -│ -│　│                                   
　      └┬┴┬┴┬┴┬┴┬┴┬┴┬┴┬┘                                   
　        └─┼─┴─┴─┴─┴─┘　└─　ポート0                          
　　　　　　　│                                                             
              └─────────────　リザーブ                         
                                                                             
  ビット対応により、0:FIFO機能なし，1:FIFO機能有りとなります。               
                                                                             
-----------------------------------------------------------------------------
.RSB_rdpara
通信パラメータの読み取り
-----------------------------------------------------------------------------

- 定義 -
#include <FMCFRB.H> 
int     RSB_rdpara(int port, RSB＿PARA *paraadr); 
int 　　port;               /*  ポート番号(0～4) */ 
RSB_PARA *paraadr;        /*  通信パラメータ   */ 

- 戻り値 -
0：正常終了
2：範囲外のポートを指定した
3：拡張カードが接続されていないポートを指定した
7：通信パラメータが設定されていないのに、通信パラメータを取得しようとした

- 例 -
int   port = 0; 
RSB_PARA para_adr;
int   ret;

ret = RSB_rdpara(port, &paraadr); 

- 内容 -
　RSB_setpara関数で設定した通信パラメータを、指定された通信パラメータ領域に読
み込みます。

- 注意 -
　オフセット12H 以降は通信モードの拡張モード指定(bit 7) がONのときのみ読み取
りができ､OFF のとき読み取りができません。


　　　　　　　通信パラメータアドレス

 paraadr   → 　┌─┬─┬─────────────┐
        　　　 0｜R ｜B ｜　通信モード　　　　　　　｜
　　　　　　　　├─┼─┼─────────────┤
　　　　　　　 1｜R ｜B ｜　ボーレート　　　　　　　｜
　　　　　　　　├─┼─┼─────────────┤
　　　　　　　 2｜R ｜D ｜　受信バッファオフセット　｜
　　　　　　　　├─┼─┼─────────────┤
　　　　　　　 6｜R ｜W ｜　受信バッファセレクタ　　｜
　　　　　　　　├─┼─┼─────────────┤
　　　　　　　 8｜R ｜W ｜　送信タイムアウト時間　　｜
　　　　　　　　├─┼─┼─────────────┤
　　　　　　　 A｜R ｜W ｜　受信タイムアウト時間　　｜
　　　　　　　　├─┼─┼─────────────┤
　　　　　　　 C｜R ｜D ｜　受信通知オフセット　　　｜
　　　　　　　　├─┼─┼─────────────┤
　　　　　　　10｜R ｜W ｜　受信通知セレクタ　　　　｜
　　　　　　　　├─┼─┼─────────────┤
　　　　　　　12｜R ｜B ｜　拡張通信モード　　　　　｜
　　　　　　　　├─┼─┼─────────────┤
　　　　　　　13｜R ｜B ｜　ＸＯＮコード　　　　　　｜
　　　　　　　　├─┼─┼─────────────┤
　　　　　　　14｜R ｜B ｜　ＸＯＦＦコード　　　　　｜
  　　　　　　　├─┼─┼─────────────┤
　　　　　　　15｜R ｜D ｜　送信バッファオフセット　｜
　　　　　　　　├─┼─┼─────────────┤
　　　　　　　19｜R ｜W ｜　送信バッファセレクタ　　｜
　　　　　　　　└─┴─┴─────────────┘　　　　　　　　　　　　　　　　　　　　　
*****************************************************************************
第4章　サウンドライブラリ                                                    
*****************************************************************************
                                                                             
1.　サウンドライブラリ                                                       
                                                                             
 1.1　関数一覧                                                               
                                                                             
 ┌───────────┬──────────────────────┐  
 │関数名　　　　　　　　│機能　　　　　　　　　　　　　　　　　　　　│  
 ├───────────┼──────────────────────┤  
 │SND_pcm_play_auto 　　│現在空いているチャンネルを使用した音声モード│  
 │　　　　　　　　　　　│再生の開始　　　　　　　　　　　　　　　　　│  
 ├───────────┼──────────────────────┤  
 │SND_pcm_play_rom_auto │現在空いているチャンネルを使用した音声モード│  
 │　　　　　　　　　　　│再生の開始(システムROM) 　　　　　　　　　　│  
 ├───────────┼──────────────────────┤  
 │SND_saveEvent     　　│サウンド･イベントの退避　　　　　　　　　 　│  
 ├───────────┼──────────────────────┤  
 │SND_restoreEvent　　　│サウンド･イベントの復元　　　　　　　　　 　│  
 └───────────┴──────────────────────┘  
                                                                             
 1.2　各関数の解説                                                           
                                                                             
-----------------------------------------------------------------------------
.SND_pcm_play_auto                           
現在空いているチャンネルを使用した音声モード再生の開始      
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <snd.h>                                                             
void     SND_pcm_play_auto( note, vol, buff );                         
int      note;           /*  音程(1～127)                     */
int      vol;            /*  音量(0～127)                     */
void     *buff;          /*  SNDデータのアドレス　　　　　　  */       
                                                                             
- 戻り値 -                                                                   
64～71 : 音声を出力したチャンネル番号
2      : キーON中｡現在音声が出力できるチャンネルが無い                        
                                                                             
- 例 -                                                                       
char     *buff;
int      ch;
ch = SND_pcm_play_auto( 60, 127 ,buff);
if (ch != 2){
    do {} while ( SND_pcm_status( ch ));
    SND_pcm_play_stop( ch );
    }          
                                                                             
- 内容 -                                                                     
　｢PCM音声モードチャンネル数の設定｣で確保されているチャンネル数の範囲内で現在
使用されていないチャンネルを探して音声を出力します｡
　出力できた場合には返り値として､音声を出力したンネル番号を返します｡返り値を
利用して音声の停止や再生アドレスの取得などを行います｡
　出力できない場合は返り値として､2(キーON中｡現在音声が出力できるチャンネルが
無い)を返します｡

-----------------------------------------------------------------------------
.SND_pcm_play_rom_auto                           
現在空いているチャンネルを使用した音声モード再生の開始(システムROM)
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <snd.h>                                                             
void     SND_pcm_play_rom_auto( note, vol, romnum );                         
int      note;           /*  音程(1～127)                     */
int      vol;            /*  音量(0～127)                     */
int      romnum;         /*  システムROM番号(1～10)       　  */       
                                                                             
- 戻り値 -                                                                   
64～71 : 音声を出力したチャンネル番号
2      : キーON中｡現在音声が出力できるチャンネルが無い                       
-1     : 指定された番号のシステムROM音声は存在しない                         
                                                                             
- 例 -                                                                       
int      ch;
ch = SND_pcm_play_rom_auto( 60, 127 , 10 );
if ((ch != 2) && (ch != -1 )){
    do {} while ( SND_pcm_status( ch ));
    SND_pcm_play_stop( ch );
    }          
                                                                             
- 内容 -                                                                     
　｢PCM音声モードチャンネル数の設定｣で確保されているチャンネル数の範囲内で現在
使用されていないチャンネルを探してシステムROM上の音声を出力します｡
　出力できた場合には返り値として､音声を出力したチャンネル番号を返します｡
  返り値を利用して音声の停止や再生アドレスの取得などを行います｡
　出力できない場合は返り値として､2(キーON中｡現在音声が出力できるチャンネルが
無い)を返します｡
　指定された番号のシステムROM音声が存在しない場合は返り値として-1を返します｡

　romnumを設定することにより､以下の音声が出力されます｡
 ┌───────────┬────────┐  
 │システムROMデータ番号 │音声メッセージ　│  
 ├───────────┼────────┤  
 │         1            │おはよう        │  
 │　　　　 2　　　　　　│こんにちは　　　│  
 │         3            │こんばんは      │  
 │　　　　 4　　　　　　│バイバイ　　　　│  
 │         5            │さようなら      │  
 │　　　　 6　　　　　　│おやすみ　　　　│  
 │         7            │選んでください  │  
 │　　　　 8　　　　　　│入力してください│  
 │         9            │ごめんなさい    │  
 │　　　　10　　　　　　│確認してください│  
 └───────────┴────────┘  

-----------------------------------------------------------------------------
.SND_restoreEvent                                                            
サウンド･イベントの復元                                                      
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <snd.h>                                                             
void     SND_restoreEvent( buf );                                            
void     *buf;          /*  イベント退避領域　　　　　　　  */               
                                                                             
- 戻り値 -                                                                   
  なし                                                                       
                                                                             
- 例 -                                                                       
char     buff[SndEventSave];                                                 
                                                                             
SND_restoreEvent( buff );                                                    
                                                                             
- 内容 -                                                                     
  SND_saveEvent()で退避したイベントを復元します。                            
  必ず SND_saveEvent()と対で使用してください。                               
                                                                             
-----------------------------------------------------------------------------
.SND_saveEvent                                                               
サウンド･イベントの退避                                                      
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <snd.h>                                                             
void     SND_saveEvent( buf );                                               
void     *buf;          /*  イベント退避領域　　　　　　　  */               
                                                                             
- 戻り値 -                                                                   
  なし                                                                       
                                                                             
- 例 -                                                                       
char     buff[SndEventSave];                                                 
                                                                             
SND_saveEvent( buff );                                                       
                                                                             
- 内容 -                                                                     
  各イベント登録関数で登録された、サウンド･イベントのアドレスを退避します。  
  上記のイベントを保存した後、イベントが動作しないようにイベントアドレスをク 
リアして、イベントを停止します。                                             
  イベント退避領域として96バイトの退避領域を指定する必要があります。         
                                                                             
*****************************************************************************
第5章　ＷＡＶＥライブラリ                                                    
*****************************************************************************
                                                                             
1.　ＷＡＶＥライブラリについて                                               
                                                                             
 1.1　概要                                                                   
                                                                             
   FM TOWNSでは音声データを取り扱うデータファイル(拡張子は｢.SND｣)をサポートし
 ています。このデータファイル形式(以下SNDフォーマットと呼ぶ)では             
                                                                             
   ･サンプリング周波数　:任意                                                
   ･サンプリングビット数:8ビット                                             
   ･データ種別　　　　　:モノラル                                            
                                                                             
 の通りで、FM TOWNSのPCM音源で十分に表現できます。                           
   技術が進みマルチメディアを扱う為のコンピュータ規格を定義したMPC(Multimedia
 Personal Computer)規格が提唱されました。それに伴いMicrosoft(R) Windows(TM)  
 V3.0 with Multimedia Extensions V1.0以降では、高音質の音声データを取り扱える
 マイクロソフトウェーブフォームデータファイル(拡張子は｢.WAV｣)が標準でサポート
 されています。このデータファイル形式(以下WAVEフォーマットと呼ぶ)では        
                                                                             
   ･サンプリング周波数　:11.025kHz, 22.050kHz, 44.100kHz *1                  
   ･サンプリングビット数:8ビット，16ビット                                   
   ･データ種別　　　　　:モノラル，ステレオ                                  
                                                                             
 の通りで、SNDフォーマットと比較して高音質の音声データが取り扱えることが分か 
 ります。                                                                    
 　Towns OS V2.1 L30以降では、音声データの流通性を考慮しWAVEフォーマットのデ 
 ータファイルをサポートしています。本ライブラリでは、WAVEフォーマットのデータ
 ファイルを取り扱う為の関数を提供しています。                                
                                                                             
 　下記のフローで分かるように、本ライブラリではサウンドBIOSの拡張機能部分のみ
 を提供しています。従って、本ライブラリを使用する為にはサウンドライブラリが必
 須です。                                                                    
                                                                             
┌────────┐                                                         
│Ｃ言語、アプリ等│                                                         
└───┬────┘                                                         
　　　　├───────┬──────────┐                             
　  　　│　　┌────┴────┐┌────┴────┐                   
　  　　│　　│サウンドライブラリ││　WAVEライブラリ　│                   
　　　　│　　└────┬────┘└────┬────┘                   
　  　　│　　　　　　　│　　　　　　　　　　│　　　　　　↑ライブラリ     
　　──┼───────┼──────────┼──────┼──────   
　  　　└────┐　　│　　　　　　　　　　│　　　　　　↓BIOS           
　　　　　　　┌─┴──┴───────┬──┴────┐                   
　  　　　　　│　従来のサウンドの処理　│　WAVEの処理　│                   
　　　　　　　└────────────┴───────┘                   
　 　　　　　　　　　　　　　サウンドBIOS                                    
                                                                             
　  *1:このサンプリング周波数は、MPC規格における推奨値です。WAVEフォーマット 
       自体では任意のサンプリング周波数に対応できるようになっています。      
                                                                             
 1.2　リングバッファについて                                                 
                                                                             
  1.2.1　概要                                                                
                                                                             
　  本ライブラリでは、長時間録音･再生を行う為にリングバッファ方式を採用してい
  ます。                                                                     
                                                                             
  1.2.2　リングバッファ管理テーブル                                          
                                                                             
  　リングバッファを使用する、及び、リングバッファの使用状況を通知する為にリ 
  ングバッファ管理テーブルを定義します。この管理テーブルを通してアプリケーシ 
  ョン及びシステムはリングバッファを使用しその状況を通知して、長時間録音･再生
  を行うことができます。                                                     
                                                                             
   リングバッファ管理テーブル構造                                            
  　┌─────┬─────────────────────────┐       
  　│　サイズ　│　　　　　　　　　内　　　　容　　　　　　　　　　│       
　　├─────┼─────────────────────────┤       
＋ 0│　　4　 　│リングバッファ総数　ｎ　　　　　　　　　　　　　　│       
　　├─────┼─────────────────────────┤       
＋ 4│　　4　 　│アプリケーション用処理バッファ位置（0～ｎ-1）   　│       
　　├─────┼─────────────────────────┤       
＋ 8│　　4　 　│システム用処理バッファ位置　　　　（0～ｎ-1）　   │       
　　├─────┼─────────────────────────┤       
＋12│　　4　 　│0番目バッファアドレス　　　　　　　　　 　　　　　│       
　　├─────┼─────────────────────────┤       
＋16│　　8　 　│システムリザーブ　　　　　　　　　　　　　　　　　│       
  　├─────┼─────────────────────────┤       
＋24│　　4　 　│1番目バッファアドレス　　　　　　　　　 　　　　　│       
　　├─────┼─────────────────────────┤       
＋28│　　8　 　│システムリザーブ　　　　　　　　　　　　　　　　　│       
　　├─────┼─────────────────────────┤       
  　～　　　　　　　　　　　　　　　…　　　　　　　　　　　　　　　～       
　　├─────┼─────────────────────────┤       
　  │　　4　 　│ｎ-1番目バッファアドレス　　　　　　　  　　　　　│       
　　├─────┼─────────────────────────┤       
  　│  　8  　 │システムリザーブ　　　　　　　　　　　　　　　　　│       
　　└─────┴─────────────────────────┘       
                                                                             
   ･リングバッファ総数                                                       
      リングバッファで使用されるバッファの総数                               
                                                                             
   ･アプリケーション用処理バッファ位置                                       
      アプリケーションが使用するリングバッファ位置を設定します。録音及び再生 
    における意味あいは以下の通りです。                                       
                                                                             
    録音時:録音されたデータを取り出し始めるバッファ位置                      
    再生時:再生データを設定し始めるバッファ位置                              
                                                                             
   ･システム用処理バッファ位置                                               
      システムが使用しているリングバッファ位置を設定します。録音及び再生にお 
    ける意味あいは以下の通りです。                                           
                                                                             
    録音時:現在録音中のバッファ位置                                          
    再生時:現在再生中のバッファ位置                                          
                                                                             
   ･バッファアドレス                                                         
      リングバッファの各バッファの先頭アドレス                               
      アプリケーションは、このアドレスを使用してデータの取り出し/設定を行って
    ください。                                                               
                                                                             
   ･システムリザーブ                                                         
      システムが使用します。アプリケーションは使用しないでください。         
                                                                             
  1.2.3　使用方法                                                            
                                                                             
　 録音･再生を行う時、システムが使用するリングバッファの順序は決まっていま   
 す。必ず0番目のバッファから始まり、以下1、2、…、n-1、0、1、2、…、という順 
 序でリングバッファを使用します。録音時･再生処理時における各処理バッファ位置 
 の使用例を以下に説明します。説明中では、リングバッファ総数を8と仮定していま 
 す。                                                                        
                                                                             
   1)録音時                                                                  
┌──────┬────┬─────┬──────────────────┐ 
│　　　　　　│アプリ用│システム用│　　　　　　　説　　明　　　　　　　│ 
├──────┼────┼─────┼──────────────────┤ 
│　　　　　　│　　　　│　　　　　│両方共に0に初期化されている　　　　 │ 
│録音開始前　│ 　0　　│　　0　 　│0～7全てのバッファは空　　　　　　　│ 
├──────┼────┼─────┼──────────────────┤ 
│　　　　　　│　　　　│　　　　　│0～3のバッファにPCMデータを録音済 　│ 
│録音中(1)   │ 　0　　│　　4　 　│現在4のバッファにPCMデータを録音中  │ 
│　　　　　　│　　　　│　　　　　│                                    │ 
├──────┼────┼─────┼──────────────────┤ 
│　　　　　　│　　　　│　　　　　│0～3のバッファを読みだし終えこのバッ│ 
│録音中(2)   │   4　　│　　4　 　│ファ群が空になったことを示す為に次の│ 
│　　　　　　│　　　　│　　　　　│読みだし位置をアプリケーションは設定│ 
│            │        │          │する                                │ 
├──────┼────┼─────┼──────────────────┤ 
│　　　　　　│　　　　│　　　　　│4～7のバッファにPCMデータを録音済 　│ 
│録音中(3)   │   4　　│　　0　 　│現在0のバッファにPCMデータを録音中  │ 
│　　　　　　│　　　　│　　　　　│                                    │ 
├──────┼────┼─────┼──────────────────┤ 
│　　　　　　│　　　　│　　　　　│4～7のバッファを読みだし終えこのバッ│ 
│録音中(4)   │　 0　　│　　0　 　│ファ群が空になったことを示す為に次の│ 
│　　　　　　│　　　　│　　　　　│読みだし位置をアプリケーションは設定│ 
│            │        │          │する                                │ 
└──────┴────┴─────┴──────────────────┘ 
                                                                             
   2)再生時                                                                  
┌──────┬────┬─────┬──────────────────┐ 
│　　　　　　│アプリ用│システム用│　　　　　　　説　　明　　　　　　　│ 
├──────┼────┼─────┼──────────────────┤ 
│　　　　　　│　　　　│　　　　　│両方共に0に初期化されている　　　　 │ 
│再生開始前　│ 　0　　│　　0　 　│0～7全てのバッファには予めアプリケー│ 
│　　　　　　│　　　　│　　　　　│ションが再生PCMデータを格納済　　　 │ 
├──────┼────┼─────┼──────────────────┤ 
│　　　　　　│　　　　│　　　　　│0～3のバッファのPCMデータは再生済 　│ 
│再生中（1） │　 0　　│　　4　 　│現在4のバッファのPCMデータを再生中  │ 
├──────┼────┼─────┼──────────────────┤ 
│　　　　　　│　　　　│　　　　　│0～3のバッファに再生PCMデータを格納 │ 
│再生中（2） │　 4　　│　　4　 　│し格納済を示す為に次の書き込み位置を│ 
│　　　　　　│　　　　│　　　　　│アプリケーションは設定する　 　　   │ 
├──────┼────┼─────┼──────────────────┤ 
│　　　　　　│　　　　│　　　　　│4～7のバッファのPCMデータは再生済 　│ 
│再生中（3） │　 4　　│　　0　 　│現在0のバッファのPCMデータを再生中  │ 
│　　　　　　│　　　　│　　　　　│                                    │ 
├──────┼────┼─────┼──────────────────┤ 
│　　　　　　│　　　　│　　　　　│4～7のバッファに再生PCMデータを格納 │ 
│再生中（4） │　0　 　│　　0　 　│し格納済を示す為に次の書き込み位置を│ 
│　　　　　　│　　　　│　　　　　│アプリケーションは設定する　  　　　│ 
└──────┴────┴─────┴──────────────────┘ 
                                                                             
- 注意 -                                                                     
  リングバッファの1バッファのサイズは4KBです。                               
  リングバッファとリングバッファ管理テーブルの領域はアプリケーションにて用意 
してください。それぞれの領域は、                                             
  ･リングバッファ　　　　　　　:(リングバッファ総数＋1)*4096                 
  ･リングバッファ管理テーブル　:(リングバッファ総数＋1)*12                   
  (単位はバイト)の大きさで確保してください。                                 
  リングバッファの領域を確保するのにリングバッファ総数＋1個分を確保するのは、
全バッファをページ境界に確実に割り当てるためです。                           
  リングバッファ管理テーブルの設定は、本ライブラリの関数(WAV_makeTable)を使用
してください。                                                               
                                                                             
 1.3　制限事項                                                               
                                                                             
 　録音/再生性能取得関数(WAV_getCapability)で取得された性能で16ビットPCMが無 
 い場合は、サウンドライブラリで使用しているPCM音源を使用してWAVEファイルの録 
 音･再生が行なわれます。その為、16ビットPCM上で録音･再生を行う場合と比較して 
 以下の制限があります。                                                      
                                                                             
   -　再生音量のミュート設定関数(WAV_setMute)でミュートの設定･解除を行った場 
    合、サウンドライブラリで設定されたPCM音源のミュート状態が変更されます。  
   -　再生音量のミュート取得関数(WAV_getMute)では、常に現在のPCM音源のミュー 
    ト状態が得られます。従って、再生音量のミュート設定関数でミュート設定を行 
    った後、サウンドライブラリでPCM音源のミュートを解除した場合は、ミュートが
    解除状態という値が返ります。                                             
   -　録音データは、8ビット、モノラルのみです。                              
   -　録音処理と同期して行う処理関数を設定しても無効です。                   
   -　録音時の即時復帰の指定は無効です。指定しても、完了復帰が指定されたもの 
    として処理を続行します。                                                 
   -　録音は、サウンドライブラリのPCM録音開始2関数(SND_pcm_rec2)と同様にタイ 
    マBをマスクしていません。音質を向上する為には、録音開始時にタイマB及びタ 
    イマAを停止させることをお勧めします。                                    
   -　録音は、リングバッファ総数分しか録音できません。ただし、録音前準備関数 
    (WAV_recPrepare)で録音データを格納するアドレスが指定された場合は、指定さ 
    れたサンプリングデータ長分録音します。                                   
   -　再生時には、再生するWAVEファイルにより以下の様にPCM音源の音声モードチャ
    ンネルを必要とします。                                                   
                                                                             
    ･ 8ビット、モノラル:1ch                                                  
    ･ 8ビット、ステレオ:2ch                                                  
    ･16ビット、モノラル:2ch                                                  
    ･16ビット、ステレオ:4ch                                                  
                                                                             
      従って、必要なPCM 音源の音声モードチャンネルが空いていない場合は、エラ 
    ーになります。                                                           
   -　16ビットのWAVEファイルを再生時には、出力される音量は8段階になります。  
    即ち、細かな再生音量の設定ができません。                                 
                                                                             
  │                                                                         
出│                      　┌──                                           
　│　　　　　　　　　　┌─┘                                               
力│　　　　　　　　┌─┘                                                   
　│　　　　　　┌─┘                                                       
音│　　　　┌─┘                                                           
　│　　┌─┘                                                               
量│┌─┘                                                                   
　└┴─────────────────                                     
　　　　　　　設定再生音量                                                   
                                                                             
   -　再生音量は､パンポットも同時に操作して設定していますので､サウンドライブ
    ラリでSNDデータを再生する場合､音源の定位の設定関数(SND_pan_set)でパンポッ
    トを再設定してください｡

2.　ＷＡＶＥライブラリ                                                       
                                                                             
 2.1　サンプルプログラム                                                     
                                                                             
//***************************************************************************
//                                                                           
//　ＷＡＶＥライブラリサンプルプログラム(録音編)                             
//                                                                           
//　機  能  :マイクからの音を以下の条件でサンプリングします。                
//          　サンプリング周波数  =22.050ｋＨｚ                              
//          　サンプリングビット数=8ビット(内蔵ＰＣＭ)                       
//          　                    　16ビット(16ビットＰＣＭ)                 
//          　データ種別          =モノラル                                  
//          　サンプリング時間    =10秒間                                    
//                                                                           
//          　出力ファイル名      =MICREC.WAV                                
//                                                                           
//　処理説明:メモリ上にサンプリングしてファイルを作成するか                  
//          　直接ファイルへ16ＫＢ毎にサンプリングデータを書き込む           
//                                                                           
//　制限事項:内蔵ＰＣＭでのサンプリングの場合は、直接ファイルに書き込むことは
//          　できない                                                       
//                                                                           
//***************************************************************************
#include <stdio.h>                                                           
#include <stdlib.h>                                                          
#include <string.h>                                                          
#include <egb.h>                                                             
#include <mos.h>                                                             
#include <snd.h>                                                             
#include <wav.h>                                                             
                                                                             
//  変数定義                                                                 
#define   freq    22050                   //  サンプリング周波数             
#define   kind    1                       //  データ種別(=モノラル)          
#define   bit8    8                       //  サンプリングビット数           
#define   pcmsz8  freq * ( 8/8) * 10      //  サンプリングデータ長           
#define   bit16   16                      //  サンプリングビット数           
#define   pcmsz16 freq * (16/8) * 10      //  サンプリングデータ長           
                                                                             
//  メッセージ文の定義                                                       
typedef struct tagMSG_DATA                                                   
{                                                                            
　    short           x ;                                                    
　    short           y ;                                                    
　    unsigned short  len ;                                                  
　    char            msg[80] ;                                              
　} MSG_DATA ;                                                               
                                                                             
　MSG_DATA  m[13] =                                                          
　{                                                                          
　    160,  80, 36, "マイクからの音を10秒間録音します.",                     
　    160, 112, 44, "マウスのボタンで録音時の処理を選択できます.",           
　    176, 144, 48, "左ボタン:一旦メモリに録音してファイルに保存する",       
　    176, 176, 32, "右ボタン:直接ファイルに保存する",                       
　    160, 208, 32, "録音時の処理を選択してください.",                       
　    160, 240, 20, "録音時の処理:メモリ",                                   
　    160, 240, 22, "録音時の処理:ファイル",                                 
　    160, 272, 36, "マウスの左ボタンを押すと開始します.",                   
　    160, 304, 28, "サンプリングを開始しました.",                           
　    160, 336, 28, "サンプリングが終了しました.",                           
　    160, 368, 40, "現在8ビットＰＣＭです.処理できません.",                 
　    160, 368, 30, "ファイルの作成に失敗しました.",                         
　    160, 368, 30, "作業領域の確保に失敗しました."                          
　} ;                                                                        
                                                                             
　//  グローバル変数の定義                                                   
　int   n_count ;                   //  同期関数の呼び出し回数               
　char  egb_wk[EgbWorkSize] ;       //  EGB関数用作業領域                    
　char  snd_wk[SndWorkSize] ;       //  SND関数用作業領域                    
　char  mos_wk[MosWorkSize] ;       //  MOS関数用作業領域                    
　char  *filenm = "MICREC.WAV" ;    //  作成するファイル名                   
                                                                             
　//  メモリ上へのサンプリング                                               
　void  recmem()                                                             
　{                                                                          
　    FILE  *pFile ;                //  ファイルポインタ                     
　    char  *pring ;                //  リングバッファポインタ               
　    struct  buf_ctrl                                                       
　    {                                                                      
　        int   sum ;                                                        
　        int   apply_loc ;                                                  
　        int   system_loc ;                                                 
　        struct                                                             
　        {                                                                  
　            char  *ptr ;                                                   
　            char  reserve[8] ;                                             
　        }   buftbl[2] ;                                                    
　    }   *pctrl ;                 //  リングバッファ管理テーブルポインタ    
　    char  *pdata ;                //  サンプリングデータ格納領域ポインタ   
　    int   cap ;                   //  性能情報                             
　    int   status ;                //  ステータス                           
　    int   ch, x, y ;              //  マウス用変数                         
　    int   bitno ;                 //  録音するサンプリングビット数         
　    int   pcmsz ;                 //  録音するPCMデータサイズ              
　    int   pcmstart ;              //  PCMデータ相対開始位置                
　    int   wrtsize ;               //  書き込まれたデータサイズ             
　  　//  リングバッファとリングバッファ管理テーブルの領域の確保を行う       
　　　//  リングバッファ数は2個                                              
　　　if ( (pring = malloc( (2+1)*4096 )) == NULL )                          
　　　{                                                                      
　　　　　EGB_sjisString( egb_wk, (char *)&m[12] ) ;  // エラーメッセージ通知
　　　　　return ;                                                           
　　　}                                                                      
　　　if ( (pctrl = (struct buf_ctrl *)malloc( (2+1)*12 )) == NULL )         
　　　{                                                                      
　　　　　EGB_sjisString( egb_wk, (char *)&m[12] ) ;  // エラーメッセージ通知
　  　　　goto MEMFIN_1 ;                                                    
　　　}                                                                      
                                                                             
　  　//  リングバッファ管理テーブルの作成                                   
　　　pctrl->sum = 2 ;                                //  バッファ総数の設定 
　　　pctrl->apply_loc = 0 ;                          //  アプリケーション位 
                                                      //  置のクリア         
　　　WAV_makeTable( pring, (char *)pctrl ) ;                                
                                                                             
　　　WAV_getCapability( &cap, freq ) ;                                      
　　　if ( cap & WAV_CAP_16PCM_EXIST )                                       
　  　{                                              //  16ビットPCMによるサ 
                                                     //  ンプリング          
　　　　　bitno = bit16 ;                                                    
　　　　　pcmsz = pcmsz16 ;                                                  
　　　}                                                                      
　　　else                                                                   
　　　{                                              //  内蔵PCMによるサンプ 
                                                     //  リング              
　　　　　bitno = bit8 ;                                                     
　　　　　pcmsz = pcmsz8 ;                                                   
　　　}                                                                      
                                                                             
　　　//  サンプリングデータを格納する領域の確保                             
　　　if ( (pdata = malloc( pcmsz )) == NULL )                               
　　　{                                                                      
　　　　　EGB_sjisString( egb_wk, (char *)&m[12] ) ;  // エラーメッセージ通知
　　　　　goto MEMFIN_2 ;                                                    
　　　}                                                                      
                                                                             
　　　//  録音前準備                                                         
　　　WAV_recPrepare( freq, bitno, kind, pdata, (void (*)())NULL ) ;         
                                                                             
　　　//  録音のメッセージを表示し、マウスのクリックを待つ                   
　　　do                                                                     
　　　{                                                                      
　　　　　MOS_rdpos(&ch, &x, &y) ;                                           
　　　} while( ch != 0 ) ;                           //  ボタンが解放されるの
                                                     //  を待つ              
　　　EGB_sjisString( egb_wk, (char *)&m[5] ) ;                              
　　　EGB_sjisString( egb_wk, (char *)&m[7] ) ;                              
　  　while( ch != 1 ) MOS_rdpos(&ch, &x, &y) ;      //  マウスの左ボタンが  
                                                     //  押されるまで待つ    
                                                                             
　  　//  録音開始                                                           
　　　EGB_sjisString( egb_wk, (char *)&m[8] ) ;      //  録音開始のメッセージ
　　　if ( cap & WAV_CAP_16PCM_EXIST )                                       
　　　{                                            　//  16ビットPCMによるサ 
                                                     //  ンプリング          
　　　　　WAV_rec( WAV_REC_IMMEDIATE, 0, pcmsz ) ;                           
　  　　　do                                   　    //  録音が開始するまで  
                                                     //  待つ                
　　　　　{                                                                  
　　　　　　　WAV_getStatus( &status ) ;                                     
　  　　　}    while( !( status & WAV_ST_REC_RECORDING ) ) ;                 
　　　　　do                                     　　 //  録音が終了するまで 
                                                      //  待つ               
　　　　　{                                                                  
　　　　　　　WAV_getStatus( &status ) ;                                     
　　　　　}    while( status & WAV_ST_REC_PROCESS ) ;                        
　　　}                                                                      
　　　else                                                                   
　　　{                                            　//  内蔵PCMによるサンプ 
                                                     //  リング              
　　　　　SND_fm_timer_b_set( 0, 0 ) ;      　　　 　//  音質向上の為タイマＢ
                                                     //  を停止              
　　　　　WAV_rec( WAV_REC_COMPLETE, 0, pcmsz ) ;                            
　　　　　SND_fm_timer_b_start() ;     　　  　　　  //  タイマＢを再起動    
　　　}                                                                      
                                                                             
　　　EGB_sjisString( egb_wk, (char *)&m[9] ) ;      //  録音終了のメッセージ
                                                                             
　　　//  サンプリングデータをファイルに保存する                             
　　　if ( (pFile = fopen( filenm, "wb" )) == NULL )  //  ファイル作成       
　　　{                                                                      
　　　　　EGB_sjisString( egb_wk, (char *)&m[11] ) ;  // エラーメッセージ通知
　　　　　goto MEMFIN_3 ;                                                    
　　　}                                                                      
　　　//  WAVEファイルの情報作成しファイルに書きだす                         
　　　//  (リングバッファ領域を作業領域として使用する)                       
　　　WAV_setWaveInfo( pring, freq, bitno, kind, pcmsz, &pcmstart ) ;        
　　　if ( (wrtsize = fwrite( pring, 1, 44, pFile)) != 44 )                  
　　　{                                                                      
　　　　　EGB_sjisString( egb_wk, (char *)&m[11] ) ;  // エラーメッセージ通知
　  　　　goto MEMFIN_4 ;                                                    
　　　}                                                                      
　　　//  サンプリングしたデータをファイルに書きだす                         
　　　if ( (wrtsize = fwrite( pdata, 1, pcmsz, pFile)) != pcmsz )            
　　　{                                                                      
　　　　　EGB_sjisString( egb_wk, (char *)&m[11] ) ;  // エラーメッセージ通知
　　　}                                                                      
                                                                             
　　　//  後処理                                                             
　MEMFIN_4:;                                                                 
　　　fclose( pFile ) ;                                                      
　MEMFIN_3:;                                                                 
　　　free( pdata ) ;                                                        
　MEMFIN_2:;                                                                 
　　　free( pctrl ) ;                                                        
　MEMFIN_1:;                                                                 
　　　free( pring ) ;                                                        
                                                                             
　　　return ;                                                               
　}                                                                          
                                                                             
　//  同期関数                                                               
　//  注意:この同期関数のアドレスが0の場合、NULL指定と誤判断されるので、     
　//        この関数の位置には注意が必要                                     
　void  syncfunc()                                                           
　{                                                                          
　　　n_count ++ ;                                                           
　　　return ;                                                               
　}                                                                          
                                                                             
　//  直接ファイルへ16ＫＢ毎にサンプリングデータを書き込む                   
　void  recfile()                                                            
　{                                                                          
　　　FILE  *pFile ;                //  ファイルポインタ                     
　　　char  *pring ;                //  リングバッファポインタ               
　　　struct  buf_ctrl                                                       
　　　{                                                                      
　　　　　int   sum ;                                                        
　  　　　int   apply_loc ;                                                  
　　　　　int   system_loc ;                                                 
　　　　　struct                                                             
　　　　　{                                                                  
　　　　　　　char  *ptr ;                                                   
　　　　　　　char  reserve[8] ;                                             
　　　　　}   buftbl[2] ;                                                    
　　　}   *pctrl ;                 //  リングバッファ管理テーブルポインタ    
　　　int   cap ;                   //  性能情報                             
　　　int   ch, x, y ;              //  マウス用変数                         
　　　int   pcmstart ;              //  PCMデータ相対開始位置                
　  　int   wrtsz ;                 //  書き込むデータサイズ                 
　　　int   wrtsize ;               //  書き込まれたデータサイズ             
　　　int   remain ;                //  残りサンプリングデータサイズ         
　　　int   fl = 0 ;                //  無限ループフラグ                     
　　　int   status ;                //  ステータス                           
　　　int   nextloc ;               //  次回のアプリケーション位置           
                                                                             
　　　EGB_sjisString( egb_wk, (char *)&m[6] ) ; 　　  //  処理内容表示       
　　　WAV_getCapability( &cap, freq ) ;                                      
　　　if ( !( cap & WAV_CAP_16PCM_EXIST ) )                                  
　　　{                                                                      
　　　　　EGB_sjisString( egb_wk, (char *)&m[10] ) ;  // エラーメッセージ通知
　　　　　return ;                                                           
　　　}                                                                      
                                                                             
　　　//  リングバッファとリングバッファ管理テーブルの領域の確保を行う       
　　　//  リングバッファ数は16個                                             
　　　if ( (pring = malloc( (16+1)*4096 )) == NULL )                         
　　　{                                                                      
　　　　　EGB_sjisString( egb_wk, (char *)&m[12] ) ;  // エラーメッセージ通知
　　　　　return ;                                                           
　　　}                                                                      
　　　if ( (pctrl = (struct buf_ctrl *)malloc( (16+1)*12 )) == NULL )        
　　　{                                                                      
　　　　　EGB_sjisString( egb_wk, (char *)&m[12] ) ;  // エラーメッセージ通知
　　　　　goto FILEFIN_1 ;                                                   
　　　}                                                                      
                                                                             
　  　//  リングバッファ管理テーブルの作成                                   
　　　pctrl->sum = 16 ;                               //　バッファ総数の設定 
　　　pctrl->apply_loc = 0 ;                          //  アプリケーション位 
                                                      //  置のクリア         
　  　WAV_makeTable( pring, (char *)pctrl ) ;                                
                                                                             
　　　//  サンプリングデータを保存するファイルを作成する                     
　　　if ( (pFile = fopen( filenm, "wb" )) == NULL )  //  ファイル作成       
　　　{                                                                      
　　　　　EGB_sjisString( egb_wk, (char *)&m[11] ) ;  // エラーメッセージ通知
　　　　　goto FILEFIN_2 ;                                                   
　  　}                                                                      
　　　//  WAVEファイルの情報を作成しファイルに書きだす                       
　　　//  (リングバッファ領域を作業領域として使用する)                       
　　　WAV_setWaveInfo( pring, freq, bit16, kind, pcmsz16, &pcmstart ) ;      
　　　if ( (wrtsize = fwrite( pring, 1, 44, pFile)) != 44 )                  
　　　{                                                                      
　　　　　EGB_sjisString( egb_wk, (char *)&m[11] ) ;  // エラーメッセージ通知
　　　　　goto FILEFIN_3 ;                                                   
　　　}                                                                      
                                                                             
　　　//  録音前準備                                                         
　　　remain = pcmsz16 ;                              //  残りサンプリングデ 
                                                      //  ータサイズ設定     
　　　n_count = 0 ;               　                  //  カウンタ値のクリア 
　　　nextloc = 4 ;                                   //  次回のアプリケーシ 
                                                      //  ョン位置の設定     
　　　wrtsz = 4*4096 ;                                //  一回当たりのファイ 
                                                      //  ル書き込みサイズ   
　　　WAV_recPrepare( freq, bit16, kind, NULL, syncfunc ) ;                  
                                                                             
　　　//  録音のメッセージを表示し、マウスのクリックを待つ                   
　　　do                                                                     
　　　{                                                                      
　　　　　MOS_rdpos(&ch, &x, &y) ;                                           
　　　} while( ch != 0 ) ;                           //  ボタンが解放されるの
                                                     //  を待つ              
　　　EGB_sjisString( egb_wk, (char *)&m[7] ) ;                              
　　　while( ch != 1 ) MOS_rdpos(&ch, &x, &y) ;      //  マウスの左ボタンが  
                                                     //  押されるまで待つ    
　　　//  録音開始                                                           
　　　EGB_sjisString( egb_wk, (char *)&m[8] ) ;      //  録音開始のメッセージ
　　　WAV_rec( WAV_REC_IMMEDIATE, 0, pcmsz16 ) ;     //  録音を行う          
                                                                             
　  　//  指定サイズ録音されるまで繰り返す                                   
　　　while( fl == 0 )                                                       
　　　{                                                                      
　　　　　WAV_getStatus( &status ) ;                                         
　　　　　if ( !( status & WAV_ST_REC_PROCESS ) )     //  録音処理が終了して 
　　　　　　　fl++ ;                                  //  いればflに1設定    
                                                                             
    　　　//  リングバッファ4個分サンプリングされていればファイルにデータを書
          //  きだす                                                         
　　　　　if ( n_count >= 4 )                                                
　  　　　{                                                                  
　　　　　　　n_count -= 4 ;                         //  カウンタ値の再設定  
　　　　　　　　　　　　　　　　　　　　　           //  書き込むサイズの設定
　　　　　　　if ( remain < wrtsz ) wrtsz = remain ;                         
　　　　　　　　　　　　　　　　　　　　　　          //  ファイルに書きだす 
　　　　　　　if ( (wrtsize = fwrite( pctrl->buftbl[pctrl->apply_loc].ptr,   
　　　　　　　　　　　　　　　　　　　　　1, wrtsz, pFile)) != wrtsz )       
　　　　　　　{                                                              
　　　　　　　　　EGB_sjisString( egb_wk, (char *)&m[11] ) ;                 
　　　　　　　　　goto FILEFIN_3 ;                                           
　　　　　　　}                                                              
　　        　//  次回のアプリケーション位置を設定し、次々回のアプリケーショ 
              //  ン位置を算出                                               
　　　　　　　pctrl->apply_loc = nextloc ;                                   
　　　　　　　if ( (nextloc += 4) == pctrl->sum )  nextloc = 0 ;             
                                                                             
　　　　　　　//  サンプリングデータの残りサイズの算出                       
　　　　　　　remain -= wrtsize ;                                            
　　　　　}                                                                  
　　　　　//  録音処理が終了していれば、残りのデータを全てファイルに書きだす 
　　　　　else if ( ( fl != 0 ) && ( remain > 0 ) )                          
　　　　　{                                                                  
　　　　　　　if ( (wrtsize = fwrite( pctrl->buftbl[pctrl->apply_loc].ptr,   
　　　　　　　　　　　　　　　　　　　　　1, remain, pFile)) != remain )     
　　　　　　　{                                                              
　　　　　　　　　EGB_sjisString( egb_wk, (char *)&m[11] ) ;                 
　　　　　　　　　goto FILEFIN_3 ;                                           
　　　　　　　}                                                              
　　　　　}                                                                  
　  　} ;                                            //  while文の終了       
                                                                             
　　　EGB_sjisString( egb_wk, (char *)&m[9] ) ;      //  録音終了のメッセージ
                                                                             
　　　//  後処理                                                             
　FILEFIN_3 :;                                                               
　　　fclose( pFile ) ;                                                      
　FILEFIN_2 :;                                                               
　  　free( pctrl ) ;                                                        
　FILEFIN_1 :;                                                               
　　　free( pring ) ;                                                        
                                                                             
　　　return ;                                                               
　}                                                                          
                                                                             
　//  メインルーチン                                                         
　void  main()                                                               
　{                                                                          
　　　int   mute ;                           //  ミュート状態                
　　　int   ch, x, y ;                       //  マウス用変数                
                                                                             
　　　SND_init( snd_wk ) ;                   //  サウンドドライバの初期化    
　　　WAV_init() ;                           //  WAVEライブラリの初期化      
　　　EGB_init( egb_wk, EgbWorkSize ) ;      //  グラフィック初期化          
　　　MOS_start( mos_wk, MosWorkSize ) ;     //  マウス動作開始の設定        
                                                                             
　　　SND_get_elevol_mute( &mute ) ;         //  現在のミュート状態の退避    
　　　SND_elevol_mute( 0 ) ;                 //  電子ボリュームを全てミュート
　　　SND_elevol_set( 2, 127, 127 ) ;        //  マイク入力を最大値設定      
                                                                             
　　　//  録音のメッセージを表示し、マウスのクリックを待つ                   
　　　do                                                                     
　　　{                                                                      
　　　　　MOS_rdpos(&ch, &x, &y) ;                                           
　　　} while( ch != 0 ) ;                           //  ボタンが解放されるの
                                                     //  を待つ              
　　　EGB_sjisString( egb_wk, (char *)&m[0] ) ;                              
　  　EGB_sjisString( egb_wk, (char *)&m[1] ) ;                              
　　　EGB_sjisString( egb_wk, (char *)&m[2] ) ;                              
　  　EGB_sjisString( egb_wk, (char *)&m[3] ) ;                              
　　　EGB_sjisString( egb_wk, (char *)&m[4] ) ;                              
　　　while( ch == 0 ) MOS_rdpos(&ch, &x, &y) ;       //  マウスのボタンが押 
                                                      //  されるまで待つ     
                                                                             
　　　switch( ch )                                                           
　　　{                                                                      
　　　　　case 1:                                     //  左ボタンが押された 
　　　　　　　recmem() ;                              //  メモリ             
　  　　　　　break ;                                                        
                                                                             
　　　　　case 2:                                     //  右ボタンが押された 
　　　　　　　recfile() ;                             //  ファイル           
　　　　　　　break ;                                                        
                                                                             
　　　　　default:                                                           
　　　　　　　break ;                                                        
　　　}                                                                      
                                                                             
　　　SND_elevol_mute( mute ) ;                       //  ミュート状態を復元 
                                                                             
　　　MOS_end() ;                                    //  マウス動作終了の設定
　　　WAV_end() ;                                    //  WAVEライブラリの終了
　　　SND_end() ;                                    //  サウンド動作終了の  
                                                     //  設定                
　}                                                                          
                                                                             
//***************************************************************************
//                                                                           
//　ＷＡＶＥライブラリサンプルプログラム(再生編)                             
//                                                                           
//　機  能  :WAVEファイルを再生します                                        
//　        　再生ファイル名:MICREC.WAV                                      
//                                                                           
//　処理説明:一旦メモリ上に再生データを読み込んでから再生するか              
//          　直接ファイルから16ＫＢ毎に再生データを読み込み再生する         
//                                                                           
//***************************************************************************
#include <stdio.h>                                                           
#include <stdlib.h>                                                          
#include <string.h>                                                          
#include <egb.h>                                                             
#include <mos.h>                                                             
#include <snd.h>                                                             
#include <wav.h>                                                             
                                                                             
//  メッセージ文の定義                                                       
typedef struct    tagMSG_DATA                                                
{                                                                            
    short           x ;                                                      
    short           y ;                                                      
    unsigned short  len ;                                                    
    char            msg[80] ;                                                
} MSG_DATA ;                                                                 
                                                                             
MSG_DATA    m[14] =                                                          
{                                                                            
    160,  80, 32, "ファイルMICREC.WAVを再生します.",                         
    160, 112, 44, "マウスのボタンで再生時の処理を選択できます.",             
    176, 144, 38, "左ボタン:一旦メモリに読み込み再生する",                   
    176, 176, 34, "右ボタン:直接ファイルから再生する",                       
    160, 208, 32, "再生時の処理を選択してください.",                         
    160, 240, 20, "再生時の処理:メモリ",                                     
    160, 240, 22, "再生時の処理:ファイル",                                   
    160, 272, 36, "マウスの左ボタンを押すと開始します.",                     
    160, 304, 20, "再生を開始しました.",                                     
    160, 336, 20, "再生が終了しました.",                                     
　　160, 368, 34, "ファイルのオープンに失敗しました.",                       
　　160, 368, 32, "ファイルのシークに失敗しました.",                         
　　160, 368, 34, "ファイルの読み込みに失敗しました.",                       
　　160, 368, 30, "作業領域の確保に失敗しました."                            
} ;                                                                          
                                                                             
//  グローバル変数の定義                                                     
int   n_count ;                       //  同期関数の呼び出し回数             
char  egb_wk[EgbWorkSize] ;           //  EGB関数用作業領域                  
char  snd_wk[SndWorkSize] ;           //  SND関数用作業領域                  
char  mos_wk[MosWorkSize] ;           //  MOS関数用作業領域                  
char  *filenm = "MICREC.WAV" ;        //  作成するファイル名                 
                                                                             
//  メモリ上からの再生                                                       
void    playmem()                                                            
{                                                                            
　　FILE  *pFile ;                      //  ファイルポインタ                 
　　char  *pring ;                      //  リングバッファポインタ           
　　struct  buf_ctrl                                                         
　　{                                                                        
　　　　int  sum ;                                                           
　　　　int  apply_loc ;                                                     
　　　　int  system_loc ;                                                    
　　　　struct                                                               
　　　　{                                                                    
　　　　　　char  *ptr ;                                                     
　　　　　　char  reserve[8] ;                                               
　　　　}   buftbl[2] ;                                                      
　　}   *pctrl ;                       //  リングバッファ管理テーブルポインタ
　　char  *pdata ;                     //  サンプリングデータ格納領域ポインタ
　　int   ret ;                        //  戻り値                            
　　int   status ;                     //  ステータス                        
　　int   ch, x, y ;                   //  マウス用変数                      
　　int   freq ;                       //  サンプリング周波数                
　　int   bitno ;                      //  サンプリングビット数              
　　int   kind ;                       //  データ種別                        
  　int   pcmsz ;                      //  PCMデータサイズ                   
  　int   pcmstart ;                   //  PCMデータ相対開始位置             
　　int   rdsz ;                       //  読み込むデータサイズ              
　　int   rdsize ;                     //  読み込まれたデータサイズ          
                                                                             
　　//  再生ファイルをオープンする                                           
　　if ( (pFile = fopen( filenm, "rb" )) == NULL )   //  ファイルオープン    
　　{                                                                        
　　　　EGB_0jisString( egb_wk, (char *)&m[10] ) ;   //  エラーメッセージ通知
　　　　return ;                                                             
　　}                                                                        
                                                                             
　　//  リングバッファとリングバッファ管理テーブルの領域の確保を行う         
　　//  リングバッファ数は2個                                                
　　if ( (pring = malloc( (2+1)*4096 )) == NULL )                            
　　{                                                                        
　　　　EGB_sjisString( egb_wk, (char *)&m[13] ) ;   //  エラーメッセージ通知
　　　　goto MEMFIN_1 ;                                                      
　　}                                                                        
　　if ( (pctrl = (struct buf_ctrl *)malloc( (2+1)*12 )) == NULL )           
　　{                                                                        
　　　　EGB_sjisString( egb_wk, (char *)&m[13] ) ;   //  エラーメッセージ通知
　　　　goto MEMFIN_2 ;                                                      
　　}                                                                        
                                                                             
　　//  リングバッファ管理テーブルの作成                                     
　　pctrl->sum = 2 ;                                  //  バッファ総数の設定 
　　pctrl->apply_loc = 0 ;                            //  アプリケーション位 
                                                      //  置のクリア         
　　WAV_makeTable( pring, (char *)pctrl ) ;                                  
                                                                             
　　//  リングバッファを使用してファイルの情報を取得する                     
　　rdsz = 0 ;                                                               
　　do                                                                       
　　{                                                                        
  　　　rdsz += 50 ;                                                         
　　　　//    ファイルポインタをWAVEデータの先頭に位置づける                 
　　　　ret = fseek( pFile, 0, SEEK_SET ) ;                                  
　　　　if ( ret != 0 )                                                      
  　　　{                                                                    
　　　　　　EGB_sjisString( egb_wk, (char *)&m[11] ) ;//エラーメッセージ通知 
　　　　　　goto MEMFIN_3 ;                                                  
　　　　}                                                                    
　　　　rdsize = fread( pring, 1, rdsz, pFile ) ;                            
　　　　if ( rdsize != rdsz )                                                
　　　　{                                                                    
　　　　　　EGB_sjisString( egb_wk, (char *)&m[12] ) ;//エラーメッセージ通知 
　　　　　　goto MEMFIN_3 ;                                                  
　　　　}                                                                    
　　　　ret = WAV_getWaveInfo( pring, rdsz, &freq, &bitno, &kind,            
　　　　　　　　　　　　　　　　　　　　　　　　　　 &pcmsz, &pcmstart) ;    
　　} while( ret == 23 ) ;                                                   
                                                                             
　　//  PCMデータを格納する領域の確保                                        
　　if ( (pdata = malloc( pcmsz )) == NULL )                                 
　　{                                                                        
　　　　EGB_sjisString( egb_wk, (char *)&m[13] ) ;   //  エラーメッセージ通知
　　　　goto MEMFIN_3 ;                                                      
　　}                                                                        
                                                                             
　　//  PCMデータを格納する                                                  
　　//  ファイルポインタをPCMデータの先頭に位置づける                        
　　ret = fseek( pFile, pcmstart, SEEK_SET ) ;                               
　　if ( ret != 0 )                                                          
　　{                                                                        
　　　　EGB_sjisString( egb_wk, (char *)&m[11] ) ;   //  エラーメッセージ通知
　　　　goto MEMFIN_4 ;                                                      
　　}                                                                        
　　//  PCMデータを読み込み、格納する                                        
　　rdsize = fread( pdata, 1, pcmsz, pFile ) ;                               
　　if ( rdsize != pcmsz )                                                   
　　{                                                                        
　　　　EGB_sjisString( egb_wk, (char *)&m[12] ) ;   //  エラーメッセージ通知
　　　　goto MEMFIN_4 ;                                                      
　　}                                                                        
                                                                             
　　//  再生前準備                                                           
  　WAV_playPrepare( freq, bitno, kind, pdata, (void (*)())NULL ) ;          
                                                                             
    //  再生のメッセージを表示し、マウスのクリックを待つ                     
    do                                                                       
    {                                                                        
        MOS_rdpos(&ch, &x, &y) ;                                             
    } while( ch != 0 ) ;                             //  ボタンが解放されるの
                                                     //  を待つ              
    EGB_sjisString( egb_wk, (char *)&m[5] ) ;                                
    EGB_sjisString( egb_wk, (char *)&m[7] ) ;                                
    while( ch != 1 ) MOS_rdpos(&ch, &x, &y) ;        //  マウスの左ボタンが  
                                                     //  押されるまで待つ    
                                                                             
    //  再生開始                                                             
    EGB_sjisString( egb_wk, (char *)&m[8] ) ;        //  再生開始のメッセージ
    WAV_play( pcmsz ) ;                              //  再生開始            
    do                                               //  再生が開始するまで  
                                                     //  待つ                
    {                                                                        
        WAV_getStatus( &status ) ;                                           
    }    while( !( status & WAV_ST_PLAY_PLAYING ) ) ;                        
    do                                               //  再生が終了するまで  
                                                     //  待つ                
    {                                                                        
        WAV_getStatus( &status ) ;                                           
    }    while( status & WAV_ST_PLAY_PROCESS ) ;                             
                                                                             
    EGB_sjisString( egb_wk, (char *)&m[9] ) ;        //  再生終了のメッセージ
                                                                             
    //  後処理                                                               
MEMFIN_4:;                                                                   
    free( pdata ) ;                                                          
MEMFIN_3:;                                                                   
    free( pctrl ) ;                                                          
MEMFIN_2:;                                                                   
    free( pring ) ;                                                          
MEMFIN_1:;                                                                   
    fclose( pFile ) ;                                                        
                                                                             
    return ;                                                                 
}                                                                            
                                                                             
//  同期関数                                                                 
//  注意:この同期関数のアドレスが0の場合、NULL指定と誤判断されるので、       
//        この関数の位置には注意が必要                                       
void  syncfunc()                                                             
{                                                                            
    n_count ++ ;                                                             
    return ;                                                                 
}                                                                            
                                                                             
//  直接ファイルから再生                                                     
void  playfile()                                                             
{                                                                            
    FILE  *pFile ;                      //  ファイルポインタ                 
    char  *pring ;                      //  リングバッファポインタ           
    struct    buf_ctrl                                                       
    {                                                                        
        int   sum ;                                                          
        int   apply_loc ;                                                    
        int   system_loc ;                                                   
        struct                                                               
        {                                                                    
            char  *ptr ;                                                     
            char  reserve[8] ;                                               
        }   buftbl[2] ;                                                      
    }   *pctrl ;                       //  リングバッファ管理テーブルポインタ
    int   ret ;                         //  戻り値                           
    int   ch, x, y ;                    //  マウス用変数                     
    int   remain ;                      //  残りサンプリングデータサイズ     
    int   fl = 0 ;                      //  無限ループフラグ                 
    int   status ;                      //  ステータス                       
    int   nextloc ;                     //  次回のアプリケーション位置       
    int   freq ;                        //  サンプリング周波数               
    int   bitno ;                       //  サンプリングビット数             
    int   kind ;                        //  データ種別                       
    int   pcmsz ;                       //  PCMデータサイズ                  
    int   pcmstart ;                    //  PCMデータ相対開始位置            
    int   rdsz ;                        //  読み込むデータサイズ             
    int   rdsize ;                      //  読み込まれたデータサイズ         
                                                                             
    //  リングバッファとリングバッファ管理テーブルの領域の確保を行う         
    //  リングバッファ数は16個                                               
    if ( (pring = malloc( (16+1)*4096 )) == NULL )                           
    {                                                                        
        EGB_sjisString( egb_wk, (char *)&m[12] ) ;   //  エラーメッセージ通知
        return ;                                                             
    }                                                                        
    if ( (pctrl = (struct buf_ctrl *)malloc( (16+1)*12 )) == NULL )          
    {                                                                        
        EGB_sjisString( egb_wk, (char *)&m[12] ) ;   //  エラーメッセージ通知
        goto FILEFIN_1 ;                                                     
    }                                                                        
                                                                             
    //  リングバッファ管理テーブルの作成                                     
    pctrl->sum = 16 ;                                 //  バッファ総数の設定 
    pctrl->apply_loc = 0 ;                            //  アプリケーション位 
                                                      //  置のクリア         
    WAV_makeTable( pring, (char *)pctrl ) ;                                  
                                                                             
    //  再生ファイルをオープンする                                           
    if ( (pFile = fopen( filenm, "rb" )) == NULL )    //  ファイルオープン   
    {                                                                        
        EGB_sjisString( egb_wk, (char *)&m[10] ) ;    // エラーメッセージ通知
        goto FILEFIN_2 ;                                                     
    }                                                                        
                                                                             
    //  リングバッファを使用してファイルの情報を取得する                     
    rdsz = 0 ;                                                               
    do                                                                       
    {                                                                        
        rdsz += 50 ;                                                         
        //  ファイルポインタをWAVEデータの先頭に位置づける                   
        ret = fseek( pFile, 0, SEEK_SET ) ;                                  
        if ( ret != 0 )                                                      
        {                                                                    
            EGB_sjisString( egb_wk, (char *)&m[11] ) ;//エラーメッセージ通知 
            goto FILEFIN_3 ;                                                 
        }                                                                    
        rdsize = fread( pring, 1, rdsz, pFile ) ;                            
                                                                             
        if ( rdsize != rdsz )                                                
        {                                                                    
            EGB_sjisString( egb_wk, (char *)&m[12] ) ;//エラーメッセージ通知 
            goto FILEFIN_3 ;                                                 
        }                                                                    
        ret = WAV_getWaveInfo( pring, rdsz, &freq, &bitno, &kind,            
                                                     &pcmsz, &pcmstart) ;    
　　　  } while( ret == 23 ) ;                                               
                                                                             
    //  ファイルポインタをPCMデータの先頭に位置づける                        
    ret = fseek( pFile, pcmstart, SEEK_SET ) ;                               
    if ( ret != 0 )                                                          
    {                                                                        
        EGB_sjisString( egb_wk, (char *)&m[11] ) ;   //  エラーメッセージ通知
        goto FILEFIN_3 ;                                                     
    }                                                                        
                                                                             
    //  再生データをリングバッファ分先読みしておく                           
    rdsz = 16*4096 ;                                                         
    if ( rdsz > pcmsz )  rdsz = pcmsz ;                                      
    if ( (rdsize = fread( pctrl->buftbl[pctrl->apply_loc].ptr,               
                                1, rdsz, pFile )) != rdsz )                  
    {                                                                        
        EGB_sjisString( egb_wk, (char *)&m[12] ) ;                           
        goto FILEFIN_3 ;                                                     
    }                                                                        
                                                                             
    //  再生前準備                                                           
    remain = pcmsz - rdsize ;                         //  残りPCMデータサイズ
                                                      //  設定               
    n_count = 0 ;                             　      //  カウンタ値のクリア 
    nextloc = 4 ;                                     //  次回のアプリケーシ 
                                                      //  ョン位置の設定     
    rdsz = 4*4096 ;                                   //  一回当たりのファイ 
                                                      //  ル読み込みサイズ   
    WAV_playPrepare( freq, bitno, kind, NULL, syncfunc ) ;                   
                                                                             
    //  再生のメッセージを表示し、マウスのクリックを待つ                     
    do                                                                       
    {                                                                        
        MOS_rdpos(&ch, &x, &y) ;                                             
    } while( ch != 0 ) ;                             //  ボタンが解放されるの
                                                     //  を待つ              
    EGB_sjisString( egb_wk, (char *)&m[6] ) ;         //  処理内容表示       
    EGB_sjisString( egb_wk, (char *)&m[7] ) ;                                
    while( ch != 1 ) MOS_rdpos(&ch, &x, &y) ;         //  マウスの左ボタンが 
                                                      //  押されるまで待つ   
                                                                             
    //  再生開始                                                             
    EGB_sjisString( egb_wk, (char *)&m[8] ) ;        //  再生開始のメッセージ
    WAV_play( pcmsz ) ;                              //  再生を行う          
                                                                             
    //  指定サイズ再生されるまで繰り返す                                     
    while( fl == 0 )                                                         
    {                                                                        
        WAV_getStatus( &status ) ;                                           
        if ( !( status & WAV_ST_PLAY_PROCESS ) )      //  再生処理が終了して 
            fl++ ;                                    //  いればflに1設定    
                                                                             
        //  リングバッファ4個分再生されていればファイルからデータを読みだす  
        if ( ( remain > 0 ) && ( n_count >= 4 ) )                            
        {                                                                    
            n_count -= 4 ;                            //  カウンタ値の再設定 
                                                      // 読みだすサイズの設定
            if ( remain < rdsz ) rdsz = remain ;                             
                                                      // ファイルから読みだす
            if ( (rdsize = fread( pctrl->buftbl[pctrl->apply_loc].ptr,       
                                    1, rdsz, pFile )) != rdsz )              
            {                                                                
                EGB_sjisString( egb_wk, (char *)&m[12] ) ;                   
                goto FILEFIN_3 ;                                             
            }                                                                
                                                                             
            //  次回のアプリケーション位置を設定し、次々回のアプリケーション 
            //  位置を算出                                                   
            pctrl->apply_loc = nextloc ;                                     
            if ( (nextloc += 4) == pctrl->sum )    nextloc = 0 ;             
                                                                             
            //  サンプリングデータの残りサイズの算出                         
            remain -= rdsize ;                                               
        }                                                                    
    } ;                                              //  while文の終了       
                                                                             
    EGB_sjisString( egb_wk, (char *)&m[9] ) ;         // 再生終了のメッセージ
                                                                             
    //  後処理                                                               
FILEFIN_3 :;                                                                 
    fclose( pFile ) ;                                                        
FILEFIN_2 :;                                                                 
    free( pctrl ) ;                                                          
FILEFIN_1 :;                                                                 
    free( pring ) ;                                                          
                                                                             
    return ;                                                                 
}                                                                            
                                                                             
//  メインルーチン                                                           
void  main()                                                                 
{                                                                            
    int  ch, x, y ;                                   //  マウス用変数       
                                                                             
    SND_init( snd_wk ) ;                              //  サウンドドライバの 
                                                      //  初期化             
    WAV_init() ;  　                                  //  WAVEライブラリの初 
                                                      //  期化               
    EGB_init( egb_wk, EgbWorkSize ) ;                 //  グラフィック初期化 
    MOS_start( mos_wk, MosWorkSize ) ;                // マウス動作開始の設定
                                                                             
    WAV_setVolume( 127, 127 ) ;                       //  再生音量の設定     
                                                                             
    //  再生のメッセージを表示し、マウスのクリックを待つ                     
    do                                                                       
    {                                                                        
        MOS_rdpos(&ch, &x, &y) ;                                             
    } while( ch != 0 ) ;                             //  ボタンが解放されるの
                                                     //  を待つ              
    EGB_sjisString( egb_wk, (char *)&m[0] ) ;                                
    EGB_sjisString( egb_wk, (char *)&m[1] ) ;                                
    EGB_sjisString( egb_wk, (char *)&m[2] ) ;                                
    EGB_sjisString( egb_wk, (char *)&m[3] ) ;                                
    EGB_sjisString( egb_wk, (char *)&m[4] ) ;                                
    while( ch == 0 ) MOS_rdpos(&ch, &x, &y) ;         //  マウスのボタンが押 
                                                      //  されるまで待つ     
                                                                             
    switch( ch )                                                             
    {                                                                        
        case 1:                                       //  左ボタンが押された 
            playmem() ;                               //  メモリ             
            break ;                                                          
                                                                             
        case 2:                                       //  右ボタンが押された 
            playfile() ;                              //  ファイル           
            break ;                                                          
                                                                             
        default:                                                             
            break ;                                                          
    }                                                                        
                                                                             
    MOS_end() ;                                     //  マウス動作終了の設定 
    WAV_end() ;                                     //  WAVEライブラリの終了 
    SND_end() ;                                     // サウンド動作終了の設定
}                                                                            
                                                                             
 2.2　関数一覧                                                               
                                                                             
 ┌──────────┬──────────────────────┐      
 │関数名　　　　　　　│機能　　　　　　　　　　　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_init　　　　　　│ライブラリの初期化　　　　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_end 　　　　　　│ライブラリの終了　　　　　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_reset 　　　　　│録音･再生状態の初期化　　　　　　 　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_setMute       　│再生音量のミュート設定　　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_getMute     　　│再生音量のミュート取得　　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_setVolume 　　　│再生音量設定　　　　　　　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_getVolume 　　　│再生音量取得　　　　　　　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_getCapability 　│録音/再生性能取得　　　　　　　　　　 　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_getStatus 　　　│録音/再生状態取得　　　　　　　　　　 　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_recPrepare　　　│録音前準備　　　　　　　　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_rec 　　　　　　│録音開始　　　　　　　　　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_recStop 　　　　│録音強制終了　　　　　　　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_recGetAddress 　│録音データの格納アドレスの取得　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_playPrepare 　　│再生前準備　　　　　　　　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_play　　　　　　│再生開始　　　　　　　　　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_playStop　　　　│再生強制終了　　　　　　　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_playGetAddress　│再生データアドレスの取得　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_setWaveInfo 　　│WAVEファイルの情報設定　　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_getWaveInfo 　　│WAVEファイルの情報取得　　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_makeTable 　　　│リングバッファ管理テーブル作成　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_pushTable 　　　│リングバッファ管理テーブル及びリングバッファ│      
 │　　　　　　　　　　│アドレスの退避　　　　　　　　　　　　　　　│      
 ├──────────┼──────────────────────┤      
 │WAV_popTable    　　│リングバッファ管理テーブル及びリングバッファ│      
 │  　　　　　　　　　│アドレスの復帰　　　　　　　　　　　　　　　│      
 └──────────┴──────────────────────┘      
                                                                             
 2.3　各関数の解説                                                           
                                                                             
   戻り値で特に指定の無い場合の返り値は以下の通りです。                      
   それ以外の戻り値は、サウンドライブラリと同様です。                        
                                                                             
      0:正常終了                                                             
     20:動作環境不備                                                         
     21:パラメタエラー                                                       
     22:WAVEフォーマットのデータではない                                     
     23:情報不足                                                             
     24:リングバッファ総数が1以下である                                      
     25:リングバッファ領域不当                                               
     26:録音を強制終了された                                                 
     27:既に初期化済                                                         
     28:リングバッファ管理テーブルが未作成                                   
     29:現在録音中又は再生中である                                           
                                                                             
-----------------------------------------------------------------------------
.WAV_end                                                                     
ライブラリの終了                                                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_end( void ) ;                                                     
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
int  ret ;                                                                   
                                                                             
ret = WAV_end( ) ;                                                           
                                                                             
- 内容 -                                                                     
  ハードウェア及びドライバの終了処理を行います。                             
  WAV_initと対になっているので、ドライバの初期化を行ったプログラムは必ずこの 
関数を呼び出してください。またこの関数を呼び出した後にSND_endを呼び出してくだ
さい。                                                                       
                                                                             
-----------------------------------------------------------------------------
.WAV_getCapability                                                           
録音/再生性能取得                                                            
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_getCapability( capa, freq ) ;                                     
int 　 *capa ;　　　　　　  /*  性能情報　　　　　　　　　　　　　　　*/     
int 　 freq ;     　　　　　/*  サンプリング周波数(単位:Hz)　　　　*/        
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
int  capa ;                                                                  
int  ret ;                                                                   
                                                                             
ret = WAV_getCapability( &capa, 44100 ) ;                                    
if ( capa & WAV_CAP_16BIT_REC )                                              
 printf(" サンプリングビット数16ビットの録音もサポートされています\n") ;     
if ( capa & WAV_CAP_STEREO_REC )                                             
 printf(" ステレオ録音がサポートされています\n") ;                           
                                                                             
- 内容 -                                                                     
  現在動作している環境上で指定したサンプリング周波数及びサンプリングビット数 
等のサポート情報を取得します。                                               
  capa用には以下の識別子が定義されています。                                 
                                                                             
  WAV_CAP_8BIT_REC  　:サンプリングビット数の8ビット録音サポート             
  WAV_CAP_8BIT_PLAY 　:サンプリングビット数の8ビット再生サポート             
  WAV_CAP_16BIT_REC 　:サンプリングビット数の16ビット録音サポート            
  WAV_CAP_16BIT_PLAY　:サンプリングビット数の16ビット再生サポート            
  WAV_CAP_STEREO_REC　:データ種別のステレオ録音サポート                      
  WAV_CAP_STEREO_PLA　:データ種別のステレオ再生サポート                      
  WAV_CAP_FREQ_REC  　:指定サンプリング周波数の録音サポート                  
  WAV_CAP_FREQ_PLAY 　:指定サンプリング周波数の再生サポート                  
  WAV_CAP_16PCM_EXIST :16ビットPCM有り                                       
                                                                             
- 注意 -                                                                     
  サポートしているサンプリング周波数は以下の通りです。                       
  8.000kHz、 9.600kHz、11.025kHz、12.000kHz、16.000kHz、19.200kHz、          
22.050kHz、24.000kHz、32.000kHz、44.100kHz、48.000kHz                        
                                                                             
-----------------------------------------------------------------------------
.WAV_getMute                                                                 
再生音量のミュート取得                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_getMute( mode ) ;                                                 
int    *mode ;          /*  ミュートモード( 0:解除中, 1:ミュート中) 　*/     
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
int  ret,mode ;                                                              
                                                                             
ret = WAV_getMute( &mode ) ;                                                 
                                                                             
- 内容 -                                                                     
  再生音量のミュート状態の取得を行います。                                   
                                                                             
-----------------------------------------------------------------------------
.WAV_getStatus                                                               
録音/再生状態取得                                                            
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_getStatus( status ) ;                                             
int 　 *status ;　　　　　　/*  録音/再生状態　　　　　　　　　　　　*/      
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
int  status ;                                                                
int  ret ;                                                                   
                                                                             
ret = WAV_getStatus( &status ) ;                                             
if ( status & WAV_ST_REC_PROCESS )                                           
{                                                                            
　 if ( status & WAV_ST_REC_RECORDING)                                       
　　 printf(" 現在録音中です\n") ;                                           
}                                                                            
                                                                             
- 内容 -                                                                     
  現在の録音/再生の状態を取得します。                                        
  status用には以下の識別子が定義されています。                               
                                                                             
  WAV_ST_REC_PROCESS 　:録音開始受付中                                       
  WAV_ST_REC_RECORDING :録音中                                               
  WAV_ST_REC_STOP  　　:録音を強制終了された                                 
  WAV_ST_REC_ABNORMAL　:録音中にエラー発生                                   
  WAV_ST_PLAY_PROCESS　:再生開始受付中                                       
  WAV_ST_PLAY_PLAYING　:再生中                                               
  WAV_ST_PLAY_STOP 　　:再生を強制終了された                                 
  WAV_ST_PLAY_ABNORMAL :再生中にエラー発生                                   
  WAV_ST_REC_OVERRUN 　:録音中にオーバーラン発生                             
  WAV_ST_PLAY_UNDERRUN :再生中にアンダーラン発生                             
                                                                             
- 注意 -                                                                     
  録音/再生中に発生するエラーは、リングバッファ管理テーブルのシステム用処理バ
ッファ位置がアプリケーション用処理バッファ位置に追いついた場合に発生します。 
この時、録音及び再生の処理を中断します。エラーが発生した場合、録音時には、ア 
プリケーション用処理バッファ位置のバッファ内の録音データの一部が壊れる事があ 
ります。また再生時には、アプリケーション用処理バッファ位置のバッファの再生デ 
ータの一部が再生される事があります。                                         
                                                                             
-----------------------------------------------------------------------------
.WAV_getVolume                                                               
再生音量取得                                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_getVolume( l_vol, r_vol ) ;                                       
int 　 *l_vol ; 　　　　　/*  左音量(0～127)　　　　　　　　　*/             
int 　 *r_vol ; 　　　　　/*  右音量(0～127)　　　　　　　　　*/             
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
int  l_vol, r_vol ;                                                          
int  ret ;                                                                   
                                                                             
ret = WAV_getVolume( &l_vol, &r_vol ) ;                                      
                                                                             
- 内容 -                                                                     
  再生時の設定音量を取得します。                                             
                                                                             
-----------------------------------------------------------------------------
.WAV_getWaveInfo                                                             
WAVEファイルの情報取得                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int  WAV_getWaveInfo( buf, bufsz, freq, bitno, kind, pcmsz, pcmst ) ;        
int  *buf ; 　 /*  WAVEデータの先頭部分を格納しているバッファアドレス*/      
int  bufsz ;　 /*  格納したWAVEデータの先頭部分のバイト数　　　　　　*/      
int  *freq ;　 /*  サンプリング周波数(単位:Hz)　　　　　　　　　　*/         
int  *bitno ;  /*  サンプリングビット数(8/16)　　　　　　　　　*/            
int  *kind ;　 /*  データ種別(1:モノラル、2:ステレオ)　　　　　*/            
int  *pcmsz ;  /*  PCMデータ長　　　　　　　　　　 　　　　　        */      
int  *pcmst ;  /*  PCMデータ格納開始相対位置(単位:バイト)         */         
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
char buf[120] ;                                                              
FILE *pFILE ;                                                                
int  freq, bitno, kind, pcmsz, pcmst ;                                       
int  ret ;                                                                   
                                                                             
pFILE = fopen("TEST.WAV", "rb") ;   /* WAVE ファイルのオープン　　  */       
ret = fseek( pFILE, 0, SEEK_SET) ;  /* WAVE ファイルの先頭に移動　  */       
ret = fread( buf, 1, 120, pFILE ) ; /* 120バイト読み込む            */       
                                                                             
ret = WAV_getWaveInfo( buf, 120, &freq, &bitno, &kind, &pcmsz, &pcmst ) ;    
                                                                             
- 内容 -                                                                     
  bufに読み込まれているWAVEファイルの情報を取得します。pcmstの値は、WAVEファ 
イル上でのPCMデータ格納開始相対位置であり、かつ、WAVEファイルの情報のサイズで
す。                                                                         
                                                                             
- 注意 -                                                                     
  WAVEファイルの情報取得に必要な読み込みサイズは、WAV_setWaveInfo関数で作成し
た場合は44バイトですが、WAVEファイルを作成したツール(例えば、Windows上で動作 
するアプリケーション等)によっては情報のサイズが44バイトより大きい可能性があり
ます。例では120バイト分bufに読み込んでいますが、もし情報の大きさがこれより大 
きい場合は、正しく情報を取得できないので戻り値23を返します。                 
  この問題を解決するには、bufを大きく(例えば、2倍の大きさ)確保してから再度こ 
の関数を使用する、という処理を繰り返すことによって解決できます。             
                                                                             
-----------------------------------------------------------------------------
.WAV_init                                                                    
ライブラリの初期化                                                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_init( ) ;                                                         
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
int  ret ;                                                                   
                                                                             
ret = WAV_init( ) ;                                                          
                                                                             
- 内容 -                                                                     
  ハードウェア及びドライバの初期化を行います。この関数を呼び出す前にSND_init 
関数を使ってサウンドライブラリを初期化しておかなければなりません。           
  WAV_initでは、以下の内容で初期化をします。                                 
  ･WAVE用ワークエリアの初期化                                                
  ･WAVE用ハードウェアの初期化                                                
  ･再生音量を0設定                                                           
                                                                             
-----------------------------------------------------------------------------
.WAV_makeTable                                                               
リングバッファ管理テーブル作成                                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_makeTable( ringbuf, cntltbl ) ;                                   
char　 *ringbuf ; 　　　　　/*  リングバッファ用領域アドレス　　　　　*/     
char　 *cntltbl ; 　　　　　/*  リングバッファ管理テーブルアドレス　　*/     
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
char ringbuf[16384] ; 　/*　リングバッファ総数=3、(3+1)*4096=16384　*/       
char cntltbl[48] ;　　　/*　(3+1)*12=48 　　　　　　　　　　　　　　　*/     
int  ret ;                                                                   
                                                                             
*(int *)cntltbl = 3 ; 　/*　リングバッファ総数の設定　　　　　　　　　*/     
ret = WAV_makeTable( ringbuf, cntltbl ) ;                                    
                                                                             
- 内容 -                                                                     
  録音/再生時に使用するリングバッファ管理テーブルを作成します。与えられたリン
グバッファ用領域を物理的に連続な4KB単位に領域を分割してリングバッファ管理テー
ブルに設定します。リングバッファ管理テーブル及びリングバッファ用領域は、必要
とするリングバッファ総数をnとすると                                          

  (n＋1)*12(単位:バイト)    ← リングバッファ管理テーブル              
  (n＋1)*4096(単位:バイト)  ← リングバッファ用領域                  
の大きさでなければなりません。                                               
                                                                             
- 注意 -                                                                     
  この関数を使用する前に必ずリングバッファ管理テーブルのリングバッファ総数の 
値を設定してください(リングバッファの個数は最低2個必要です)。                
  この関数で作成されたリングバッファ管理テーブルの各バッファアドレスとリング 
バッファの関係は、以下の通りです(例の場合)。                                 
                                                                             
  cntltbl 　　　　　　　　　　　　 ringbuf                                   
　  └→┌───────────┐　　└→┌───────┐                 
　　  　├───────────┤　　　　│　　　　　　　│                 
　　　  ├───────────┤　┌─→├───────┤                 
  　　　├───────────┤　│　　│　↑　4ＫＢ　 │                 
  　　　│0番目バッファアドレス ├─┘　　│　↓　　　　　│                 
　  　　├───────────┤　┌─→├───────┤                 
　　  　├───────────┤　│　　│　↑　4ＫＢ　 │                 
　　　  │1番目バッファアドレス ├─┘　　│　↓　　　　　│                 
　　　  ├───────────┤　┌─→├───────┤                 
　　　  ├───────────┤　│  　│　↑　4ＫＢ　 │                 
　　　  │2番目バッファアドレス ├─┘　　│　↓　　　　　│                 
　　  　├───────────┤　　　　├───────┤                 
　　　  └───────────┘　　　　└───────┘                 
                                                                             
-----------------------------------------------------------------------------
.WAV_play                                                                    
再生開始                                                                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_play( bufsz ) ;                                                   
unsigned int    bufsz ;    /*   サンプリングデータ長　　　　　　　　　*/     
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
int  ret ;                                                                   
                                                                             
ret = WAV_play( 10*4096 ) ;                                                  
                                                                             
- 内容 -                                                                     
  指定されたサンプリングデータ長分の再生を行います。                         
  この関数は再生が終了する前に戻ってきます。                                 
  再生動作は、リングバッファに設定されている再生データを順々に読みだしシステ 
ム用処理バッファ位置を更新していきます。この時、システム用処理バッファ位置と 
アプリケーション用処理バッファ位置が同じになったら、再生終了と判断して再生を 
終了します。                                                                 
  なお、再生前準備関数(WAV_playPrepare)で再生データの先頭アドレスを指定した場
合は、アプリケーション用処理バッファ位置の更新もシステムで行います。         
                                                                             
-----------------------------------------------------------------------------
.WAV_playGetAddress                                                          
再生データアドレスの取得                                                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_playGetAddress( buf ) ;                                           
char　 *buf ;           /*  再生データアドレスの取得バッファアドレス　*/     
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
char buf[6] ;                                                                
int  ret ;                                                                   
                                                                             
ret = WAV_playGetAddress( buf ) ;                                            
                                                                             
- 内容 -                                                                     
  再生データを取り出しているアドレスを取得します。                           
  この関数で取得するアドレスは、再生前準備関数(WAV_playPrepare)で、再生データ
の先頭アドレスplaybufを指定した場合に有効です。それ以外では取得したアドレスは
不定です。取得バッファのデータ格納形式は、以下の通りです。                   
                                                                             
┌──┬─────────────┐                                         
│ＤＷ│　再生データのオフセット　│                                         
├──┼─────────────┤                                         
│　Ｗ│　再生データのセレクタ　　│                                         
└──┴─────────────┘                                         
                                                                             
-----------------------------------------------------------------------------
.WAV_playPrepare                                                             
再生前準備                                                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_playPrepare( freq, bitno, kind, playbuf, syncFunc ) ;             
int 　 freq  ;　　　　　/*  サンプリング周波数(単位:Hz)　　　　　　*/        
int 　 bitno ;　　　　　/*  サンプリングビット数(8/16)　　　　　*/           
int 　 kind  ;　　　　　/*  データ種別(1:モノラル、2:ステレオ)　*/           
char　 *playbuf ; 　　　/*  再生データの先頭アドレス　　　　　　　　　*/     
void　 syncFunc() ; 　　/*  再生処理と同期して行う処理関数　　　　　　*/     
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
char playbuf[10*4096] ;                                                      
int  ret ;                                                                   
                                                                             
ret = WAV_playPrepare( 22050, 16, 2, playbuf, syncFunc ) ;                   
                                                                             
void syncFunc( )                                                             
{                                                                            
　　　…                                                                     
}                                                                            
                                                                             
- 内容 -                                                                     
  再生するWAVEデータの情報を設定します。                                     
  再生データの先頭アドレスplaybufを指定した場合は、システムの方でリングバッフ
ァの操作を行い再生します。但し、全再生データがメモリ上に存在していることが必 
要です。再生処理と同期して行う処理関数syncFunc()を登録すれば、再生処理中にあ 
る一定の間隔で呼び出されます。呼び出される間隔の例を以下に記します。         
                                                                             
  - 11.025kHz,8bit, モノラル:約371ms                                         
  - 11.025kHz,8bit, ステレオ:約185ms                                         
  - 22.050kHz,8bit, モノラル:約185ms                                         
  - 22.050kHz,8bit, ステレオ:約 92ms                                         
  - 44.100kHz,8bit, モノラル:約 92ms                                         
  - 44.100kHz,8bit, ステレオ:約 46ms                                         
                                                                             
- 注意 -                                                                     
  登録した再生処理と同期して行う処理関数syncFunc()の処理が長いと再生が途切れ 
る、あるいは、再生が停止することがあります。                                 
                                                                             
-----------------------------------------------------------------------------
.WAV_playStop                                                                
再生強制終了                                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_playStop( void ) ;                                                
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
int  ret ;                                                                   
                                                                             
ret = WAV_playStop( ) ;                                                      
                                                                             
- 内容 -                                                                     
  PCM再生を強制的に停止します。                                              
                                                                             
-----------------------------------------------------------------------------
.WAV_popTable                                                                
リングバッファ管理テーブル及びリングバッファアドレスの復帰                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_popTable( ptr ) ;                                                 
char          *ptr  ;   /*  退避領域アドレス(退避領域は16byteです)　*/       
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
 WAV_pushTable関数を参照してください。                                       
                                                                             
- 内容 -                                                                     
  退避されたリングバッファ管理テーブル及びリングバッファアドレスを復帰しま   
す。                                                                         
  録音処理中又は再生処理中に実行した場合は、実行されずエラーになります。     
                                                                             
- 注意 -                                                                     
  WAV_pushTable関数とペアで使用してください。                                
                                                                             
-----------------------------------------------------------------------------
.WAV_pushTable                                                               
リングバッファ管理テーブル及びリングバッファアドレスの退避                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_pushTable( ptr ) ;                                                
char    　      *ptr  ;   /*  退避領域アドレス(退避領域は16byteです)*/       
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
int  ret ;                                                                   
char ptr[16] ;                                                               
                                                                             
ret = WAV_pushTable( ptr ) ;                                                 
                                                                             
　　　　　…                                                                 
                                                                             
ret = WAV_popTable( ptr ) ;                                                  
                                                                             
- 内容 -                                                                     
  現在使用されているリングバッファ管理テーブル及びリングバッファアドレスを退 
避します。                                                                   
  録音処理中又は再生処理中に実行した場合は、実行されずエラーになります。     
                                                                             
- 注意 -                                                                     
  WAV_popTable関数とペアで使用してください。                                 
                                                                             
-----------------------------------------------------------------------------
.WAV_rec                                                                     
録音開始                                                                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_rec( mode, trig, bufsz ) ;                                        
int             mode  ;       /*  録音モード　　　　　　　　　　　　　*/     
int             trig  ;       /*  トリガレベル(0～127)    　　　　　  */     
unsigned int    bufsz ;       /*  サンプリングデータ長　　　　　　　　*/     
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
int  ret ;                                                                   
                                                                             
ret = WAV_rec( WAV_REC_IMMEDIATE, 0, 10*4096 ) ;                             
                                                                             
- 内容 -                                                                     
  PCM録音を開始します。                                                      
  modeには以下の識別子が定義されています。                                   
                                                                             
  .WAV_REC_COMPLETE　:指定されたデータ長まで録音した後終了(完了復帰)         
  .WAV_REC_IMMEDIATE :録音の設定が終了後直ちに終了　　　　(即時復帰)         
                                                                             
  WAV_REC_COMPLETEを指定した場合、録音動作を行い指定されたサンプリングデータ 
長分録音し終えたら終了します。                                               
  録音動作は、録音したPCMデータをリングバッファに格納してシステム用処理バッフ
ァ位置を更新していきます。この時、システム用処理バッファ位置とアプリケーショ 
ン用処理バッファ位置が同じになったら、録音終了と判断して録音を終了します。な 
お、録音前準備関数(WAV_recPrepare)で録音データの格納アドレスを指定した場合   
は、アプリケーション用処理バッファ位置の更新もシステムで行います。           
  サンプリングデータの絶対値が指定したトリガレベルを越えた時点から録音を開始 
します。                                                                     
  録音ソースは、サウンドライブラリを使用してマイク、CD、LINE等から選択するこ 
とができます。さらに、ミュートを解除し電子ボリュームを設定することにより、ミ 
ックスした音をサンプリングすることができます。                               
                                                                             
- 注意 -                                                                     
  この関数は、サウンドライブラリのPCM録音開始関数(SND_pcm_rec)のようにタイマB
の停止は行っていません。                                                     
  録音時には、再生音量を0に設定するかミュートしてください。再生音量が設定され
ていると録音時のハウリングの原因の一つになります。                           
  サンプリングビット数が16ビットの時、サンプリングデータの絶対値の上位8ビット
を指定したトリガレベルと比較します。                                         
                                                                             
-----------------------------------------------------------------------------
.WAV_recGetAddress                                                           
録音データの格納アドレスの取得                                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_recGetAddress( buf ) ;                                            
char　 *buf ;           /*  録音データアドレスの取得バッファアドレス　*/     
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
char buf[6] ;                                                                
int  ret ;                                                                   
                                                                             
ret = WAV_recGetAddress( buf ) ;                                             
                                                                             
- 内容 -                                                                     
  録音データを格納しているアドレスを取得します。                             
  この関数で取得するアドレスは、録音前準備関数(WAV_recPrepare)で、録音データ 
を格納するアドレスrecbufを指定した場合に有効です。それ以外では取得したアドレ 
スは不定です。取得バッファのデータ格納形式は、以下の通りです。               
                                                                             
┌──┬─────────────┐                                         
│ＤＷ│　録音データのオフセット　│                                         
├──┼─────────────┤                                         
│　Ｗ│　録音データのセレクタ　　│                                         
└──┴─────────────┘                                         
                                                                             
-----------------------------------------------------------------------------
.WAV_recPrepare                                                              
録音前準備                                                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_recPrepare( freq, bitno, kind, recbuf, syncFunc ) ;               
int 　 freq  ;　　　　　/*  サンプリング周波数(単位:Hz)　　　　　　*/        
int 　 bitno ;　　　　　/*  サンプリングビット数(8/16)　　　　　   */        
int 　 kind  ;　　　　　/*  データ種別(1:モノラル、2:ステレオ)   　*/        
char　 *recbuf ;        /*  録音データを格納するアドレス　　　　　　　*/     
void　 syncFunc() ; 　　/*  録音処理と同期して行う処理関数　　　　　　*/     
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
char recbuf[10*4096] ;                                                       
int  ret ;                                                                   
                                                                             
ret = WAV_recPrepare( 22050, 16, 2, recbuf, syncFunc ) ;                     
                                                                             
void syncFunc( )                                                             
{                                                                            
 　  …                                                                      
}                                                                            
                                                                             
- 内容 -                                                                     
  録音するWAVEデータの情報を設定します。                                     
  録音データを格納するアドレスrecbufを指定した場合は、システムの方でリングバ 
ッファの操作を行い録音します。但し、格納場所はメモリ上のみです。             
録音処理と同期して行う処理関数syncFunc()を登録すれば、録音処理中にある一定の 
間隔で呼び出されます。呼び出される間隔は、再生前準備関数(WAV_playprepare)を参
照してください。                                                             
                                                                             
- 注意 -                                                                     
  登録した録音処理と同期して行う処理関数syncFunc()の処理が長いと録音が途切れ 
る、あるいは、録音が停止することがあります。                                 
                                                                             
-----------------------------------------------------------------------------
.WAV_recStop                                                                 
録音強制終了                                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_recStop( ) ;                                                      
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
int  ret ;                                                                   
                                                                             
ret = WAV_recStop( ) ;                                                       
                                                                             
- 内容 -                                                                     
  PCM録音を強制的に停止します。                                              
  録音開始時にWAV_REC_COMPLETEを指定した場合は、録音が完了するまで戻ってきま 
せんので、割り込み処理等からこの関数を呼び出してください。                   
                                                                             
-----------------------------------------------------------------------------
.WAV_reset                                                                   
録音･再生状態の初期化                                                        
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_reset( ) ;                                                        
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
int  ret ;                                                                   
                                                                             
ret = WAV_reset( ) ;                                                         
                                                                             
- 内容 -                                                                     
  WAVEデータの録音･再生状態の初期化を行います。                              
  WAVEデータの録音･再生を行った後、サウンドライブラリにて録音又は音声モードチ
ャンネル数の設定を行う場合には、それらの関数を呼び出す前にこの関数を呼び出し 
初期化を行ってください。                                                     
  この関数では、再生音量を0に設定します。                                    
                                                                             
-----------------------------------------------------------------------------
.WAV_setMute                                                                 
再生音量のミュート設定                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_setMute( mode ) ;                                                 
int    mode ;              /*   ミュートモード(=0:解除,=1:設定) 　　　*/     
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
int  ret ;                                                                   
                                                                             
ret = WAV_setMute( 1 ) ;      /*ミュート設定                       */        
ret = WAV_setMute( 0 ) ;      /*ミュート解除                       */        
                                                                             
- 内容 -                                                                     
  再生音量のミュートの設定/解除を行います。                                  
  ただし、再生音量設定関数(WAV_setVolume)を実行すると、ミュートが自動的に解除
されてしまいますので注意が必要です。                                         
                                                                             
-----------------------------------------------------------------------------
.WAV_setVolume                                                               
再生音量設定                                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_setVolume( l_vol, r_vol ) ;                                       
int 　 l_vol ; 　　　　　　　/*  左音量(0～127)　　　　　　　　*/            
int 　 r_vol ; 　　　　　　　/*  右音量(0～127)　　　　　　　　*/            
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
int  ret ;                                                                   
                                                                             
ret = WAV_setVolume( 127, 127 ) ;                                            
                                                                             
- 内容 -                                                                     
  再生時の音量を設定します。                                                 
  再生音量を設定すると、自動的にミュートが解除されます。                     
                                                                             
-----------------------------------------------------------------------------
.WAV_setWaveInfo                                                             
WAVEファイルの情報設定                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <WAV.H>                                                             
int 　 WAV_setWaveInfo( buf, freq, bitno, kind, pcmsz, pcmst ) ;             
int 　 *buf ;         /*  WAVEファイルの情報を格納するバッファアドレス*/     
int 　 freq ;         /*  サンプリング周波数(単位:Hz)　　　　　　　   */     
int 　 bitno ;        /*  サンプリングビット数(8/16)　　　　　      　*/     
int 　 kind ;         /*  データ種別(1:モノラル、2:ステレオ)　　      */     
int 　 pcmsz ;        /*  PCMデータ長　　　　　　　　　　　　　　　   */     
int 　 *pcmst ;       /*  PCMデータ格納開始相対位置(単位:バイト)      */     
                                                                             
- 戻り値 -                                                                   
0:正常終了                                                                   
                                                                             
- 例 -                                                                       
#include <WAV.H>                                                             
FILE *pFILE ;                                                                
char buf[44] ;                                                               
int  pcmst ;                                                                 
int  ret ;                                                                   
                                                                             
ret = WAV_setWaveInfo( buf, 22050, 16, 2, 10*4096, &pcmst ) ;                
　　　　　　　　　　　　　　　　　　 /* pFILE:処理WAVEファイルのFILE変数 */  
pFILE = fopen("TEST.WAV", "wb") ;      /* WAVEファイルのオープン　　  */     
ret = fseek( pFILE, 0, SEEK_SET ) ; 　 /* ファイルの先頭にシーク　　  */     
ret = fwrite( buf, 1, pcmst, pFILE ) ; /* ファイルの先頭に情報の設定  */     
                                                                             
- 内容 -                                                                     
  bufにWAVEファイルの情報を作成します。                                      
  WAVEファイルの先頭には必ずこの関数を使用して情報を作成してください。この関 
数で作成される情報部分のサイズは44バイトです。                               
                                                                             
- 注意 -                                                                     
  WAVEファイルのサイズは、偶数でなければなりません。録音したPCMデータサイズが
奇数の場合は、PCMデータの最後に1バイトのパディングデータ(00h)を設定してファイ
ルに格納してください。但し、この関数のPCMデータ長にはこのパディングデータを含
めないPCMデータ長を指定してください。                                        
                                                                             
*****************************************************************************
第6章　ＭＩＤＩマネージャライブラリ                                          
*****************************************************************************
                                                                             
1.　ＭＩＤＩマネージャライブラリについて                                     
                                                                             
 1.1　概要                                                                   
                                                                             
  1.1.1　MIDI Managerとは                                                    
    MIDI ManagerはFM-TOWNSシリーズ上のMIDI環境を統合する拡張BIOSです。MIDI   
  ManagerはTOWNS-OS V2.1 L30より搭載され、特にV2.1 L30のスイッチャ環境におい 
  てその威力を発揮します。今までは出来なかったサイドワーク上でのMIDI演奏や、 
  各トラックのポート、MIDIチャンネル等の設定情報の複数のアプリでの共有、とい 
  ったことが可能になり、ユーザに対して統合されたMIDI環境を提供します。従来ま 
  でライブラリで提供されていたEUPHONYドライバとMIDIエミュレータの機能が包含さ
  れ、さらに標準MIDIファイル準拠フォーマットの演奏をサポートしました。これに 
  より単純なBIOSコールで4分音符あたり480クロックの高分解能シーケンサを作成す
  ることも可能です。さらに従来のMIDI I/Fカード、FMT-40xシリーズに加えROLAND社
  製のSuper-MPU(以下S-MPU)にも対応し、そのS-MPUのSMPTE READ/WRITE機能を利用し
  て業務用VTR/MTR等との同期演奏が可能となります。                     
    従来アプリがEUPHONYドライバから乗り換える場合は関数名を置き換えるだけで、
  ほとんど変更をせずに移行できます。                                         
                                                                             
  1.1.2　主要スペック                                                        
    ･最大トラック数    1～256トラック(プログラマブル)                        
    ･最大同時発音数    任意(プログラマブル)                                  
    ･テンポの範囲      5～500                                                
    ･MIDI入力フィルタ                                                        
　  MIDIチャンネル                                                           
　    コントロールチェンジの置き換え                                         
　    ベロシティに固定                                                       
　    トランスポーズ                                                         
    ･各トラックごとの制御情報                                                
    出力ポート                                                               
    出力MIDIチャンネル                                                       
    ミュート                                                                 
    各ステータスごとのミュート                                               
    トランスポーズ                                                           
    ベロシティのオフセット                                                   
    メインボリュームのオフセット                                             
    エクスプレッションのオフセット                                           
    ･各トラックのイベント出力毎に呼び出されるコールバックルーチンを登録可    
    ･各入力ポートのイベント入力毎に呼び出される録音用のコールバックルーチンの
   登録可                                                                    
    ･演奏の空き時間を利用するためのコールバックルーチン登録可                
    ･演奏データフォーマット                                                  
　  標準MIDIファイル準拠フォーマットおよびEUPフォーマットに対応の2つのフォー 
   マットに対応                                                              
                                                                             
  1.1.3　MIDIマネージャの登録                                                
    MIDIマネージャはTBIOSに含まれます。TBIOS.INIの中に以下のような文を登録し 
  ます。                                                                     
                                                                             
    TMM=\TBIOS\MIDIMAN.BIN                                                   
                                                                             
    これによりブート時に自動的にTBIOSのモジュールとしてメモリに常駐します。エ
  ントリアドレスは110:0c0hでアセンブラなら以下のようにコールします。         
                                                                             
    push   fs                                                                
    push   dword ptr 0110h                                                   
    pop    fs                                                                
    call   pword ptr fs:[0c0h]                                               
    pop    fs                                                                
                                                                             
  1.1.4　MIDIポートについて                                                  
 　MIDIポートには論理ポートと物理ポートがあります。物理ポートはMIDI I/Fの種類
 によって番号が決まっています。番号は8ビットで表し上位4ビットがI/Fの種類を、下
 位4ビットがその中の何番目のポートかを表します。例えばFMT-40xシリーズのMIDII/F
 カードの1枚目の1つ目の物理出力ポート(OUT A)は0x00、ROLAND社製のsuper-MPU の1
 枚目の2つめの物理出力ポート(OUT B)なら0x21です。論理ポートはその物理ポー トに
 対応するテーブルを介してアクセスされます。もし、テーブルを0x00で埋めておけば
 どの論理ポートにアクセスしてもすべて物理ポート0x00に出力されます。これらの設
 定はユーザがその環境にあわせて行うので、アプリはすべてのポートを同等に扱うこ
 とができます。                                                        
   また入力ポートの場合はある物理ポートにデータが到着した場合にそれをどの論理
 ポートからの入力に置き換えるかというふうに変換します。従ってすべての値が0に 
 なっていれば、どのポートからのデータでもすべて0番のポートからの入力であると 
 解釈されます。                                                              
   この後の説明に出てくるポートとは特に注記の無い場合はすべて論理ポートを意味
 します。                                                                    
   論理ポートと物理ポート対応の初期値は 0=0～255=255となっています｡
                                                                             
  タイプ別番号 I/F種別          出力ポート数  入力ポート数                   
　  　0x0n      FMT-40x シリーズ      8            4                         
　　  0x1n      RS-MIDI               1            1                         
　　  0x2n      ROLAND super-MPU      2            2                         
　　  0xfn      内蔵音源              1            0                         
                                                                             
 1.2　フォーマットについて                                                   
                                                                             
  1.2.1　標準MIDIファイル準拠フォーマット                                    
    標準MIDIファイルの演奏データはデルタタイム、イベント、デルタタイム、イベ 
  ント････という様な構成ですが、この演奏データフォーマットではイベントの前に 
  トラック(1バイト)を追加することによって、マルチトラック、マルチポートに対応
  しています。また、ノートオンにduration指定を追加しノートオンとオフを一括し 
  て管理できるようになっています。もちろん、通常の標準MIDIファイルのようにノ 
  ートオンとノートオフを別々に管理することも可能です。またタイムベースが四分 
  音符あたり480クロックなので、EUPフォーマットに比べより一層微妙な表現が可能 
  となります。                                                               
    データの先頭は可変長のデルタタイム(インターバル時間)で始まります。デルタ 
  タイムはまさしくイベントとイベントの間の時間で、同時に処理すべきイベントな 
  らそのイベント間のデルタタイムは0となります。もし0以外ならその時間だけ経過 
  した後に次のイベントを処理することになります。デルタタイムの次にはトラック 
  番号(1バイト)、さらにそれに続くイベントとなります。この3つのデータの繰り返 
  しにより演奏データが構成されます。また、トラックに関係ないグローバルなデー 
  タの場合(tempo、終端マーカー等)でもダミーのトラック番号(0)をいれてくださ   
  い。                                                                       
                                                                             
   <delta time> <track No.> <event>                                          
   <delta time> <track No.> <event>                                          
   <delta time> <track No.> <event>                                          
     .                                                                       
     .                                                                       
     .                                                                       
   <delta time> <track No.(0)> <event(終端マーカー)>                         
                                                                             
    デルタタイムを表す可変長データとは28ビットを効率良く圧縮したデータ形式で 
  す。MSBが立っている場合はそのバイトの下位7ビットを上位にシフトすることを繰 
  り返すことによって小さい数なら少ないビット数のままで表現できます。たとえ   
  ば、0xff，0x6bという表現なら、最初のバイトは0xff、つまりMSBが立っているので
  さらにデータがつづくことがわかります。まず、0xffの下位7ビットの0x7fを取り出
  し、それを7ビット左シフト(0x7f→0x3f80)します。次を見ると0x6bはMSBが立って 
  いないのでこのバイトが最下位バイトであることがわかります。したがって、最初 
  のデータ(0x3f80)と(0x6b)のorを取ると実際の値は0x3febであることがわかりま   
  す。可変長データの最大値は0xfffffffですので最大3回のシフト動作が加わりま   
  す。ここで注意しなければならないのはインテル系のCPUアドレスは下位アドレスに
  下位バイトがくるのですが、この可変長の場合は1バイトづつ評価するので下位アド
  レスにある方が上位ビットとなります。                                       
                                                                             
        　可変長            　実値                                           
   0x00                 　→       0x00                                      
   0x30                 　→       0x30                                      
   0x7f                 　→       0x7f                                      
   0x81,0x7f            　→       0xff                                      
   0x83,0xff,0x7f       　→     0x0fff                                      
   0xff,0xff,0xff,0x7f  　→ 0x0fffffff                                      
                                                                             
   ●チャンネルイベント                                                      
     すべてのチャンネルメッセージはMIDIチャンネルを持っていますが、実際に出力
   するときは、そのトラックの出力MIDIチャンネルに置き換えられます。ただし、そ
   のトラックの出力MIDIチャンネルが"omni"である時には、そのままのMIDIチャンネ
   ルで出力されます。また、標準MIDIファイルではランニングステータスによるステ
   ータスの省略が許されますが、MIDIManagerではステータスは省略せずに必ず入れ 
   てください。                                                              
    1)ノートオフ                                                             
    　0x8n,Note,Velocity                                                     
                                                                             
      通常は使用しないと思われますが、ノートオンとノートオフを別々に管理した 
    い場合に用います。その場合は対応するノートオンのDurationを0にしておいてく
    ださい。                                                                 
                                                                             
    2)ノートオン                                                             
      0x9n,Note,Velocity,Duration(VLen)[,Off-velocity]                       
                                                                             
      ノート番号(Note)、ベロシティ(Velocity)に続いてそのノートの長さ         
    (Duration)、さらに対応するノートオフのオフベロシティ(Off-velocity)があり 
    ます。長さは可変長データで表します。もし、長さが0の時は対応するノートオフ
    を出力しませんのでオフベロシティは必要ありません。                       
                                                                             
    3)ポリフォニックキープレッシャ                                           
　    0xan,Note,Value                                                        
                                                                             
      ノート番号と圧力値を指定します。                                       
                                                                             
    4)コントロールチェンジ                                                   
　    0xbn,Number,Value                                                      
                                                                             
      コントロール番号とコントロール値を指定します。                         
                                                                             
    5)プログラムチェンジ                                                     
　    0xcn,Number                                                            
                                                                             
　    プログラム番号を指定します。                                           
                                                                             
    6)チャンネルプレッシャ                                                   
      0xdn,Value                                                             
                                                                             
      圧力値を指定します。                                                   
                                                                             
    7)ピッチベンド                                                           
　    0xen,ValueL,ValueH                                                     
                                                                             
      ベンド値(上位、下位7ビットづつの計14ビット)を指定します。              
                                                                             
   ●システムエクスクルーシブイベント                                        
    1)システムエクスクルーシブメッセージ                                     
　    0xf0,Length(可変長),data....                                           
                                                                             
      0xf0を除くエクスクルーシブデータの長さを可変長で入れ、その後にデータの 
    本体をおきます。実際には0xf0が出力され、それにつづいて指定された長さのデ 
    ータを送ります。必ずしも0xf7(eox)で終わる必要はありませんが、その場合は次
    の継続データを使ってエクスクルーシブを完結させてください。               
                                                                             
    2)継続エクスクルーシブ                                                   
　    0xf7,Length(可変長),data....                                           
                                                                             
      エクスクルーシブデータが1つのパケットに収まらない場合などに使用します。
    もちろん最初の0xf7は実際のMIDI OUTへは出力されません。                   
                                                                             
   ●メタイベント                                                            
     メタイベントは直接MIDI出力されるデータではありませんが、シーケンス名やテ
   キスト、歌詞などのデータがあります。特に進行上非常に重要なテンポや拍子も含
   まれます。メタイベントは0xffで始まり、その次の1バイトがそれがどの様なメタ 
   イベントであるかを表します。さらに、可変長でそのデータ本体の長さがあり、そ
   の直後にデータ本体が続きます。MIDI Managerでは、以下のメタイベント以外は無
   視します。このメタイベントはトラックに関係無く処理されますので、どの様なト
   ラック番号が入っていても構いません。                                      
    1)テンポ                                                                 
      0xff,0x51,0x03,tempo(24bit)                                            
                                                                             
      tempoは3バイトで四分音符の長さ(単位usec)です。例えば1分あたり四分音符で
    120拍(120bpm)なら60000000usec / 120beatで500000usecが実際の値となります。
　    30bpmなら60000000usec / 30beatで2000000usecが実際の値です。このイベント
    が無い場合は120bpmで演奏されます。                                       
                                                                             
    2)拍子記号                                                               
　    0xff,0x58,0x04,signature(32bit)                                        
                                                                             
      signatureは4バイトで第1バイト目が拍数を、第2バイト目が分母を表します。 
    第3バイト目はメトロノームの間隔(MIDIクロック数)を、第4バイト目は音符の記 
    譜上の長さが入ります。MIDI Managerでは第3、第4バイト目は無視されます。第2
    バイト目の分母は2のマイナス乗が入ります。つまりn/4なら2、n/8なら3が入りま
    す。このイベントが無い場合は4/4で演奏されます。小節の途中の中途半端な位置
    にあった場合はそれより後の演奏がうまくできない恐れがありますので拍子記号 
    は必ず正しい位置に入れてください。                                       
                                                                             
- 例 -                                                                       
0xff,0x58,0x04,0x04,0x02,0x18,0x08    → 4/4                                 
0xff,0x58,0x04,0x02,0x02,0x18,0x08    → 2/4                                 
0xff,0x58,0x04,0x03,0x03,0x0c,0x08    → 3/8                                 
0xff,0x58,0x04,0x08,0x04,0x06,0x08    → 8/16                                
                                                                             
    3)終端マーカー                                                           
      0xff,0x2f,0x00                                                         
                                                                             
      曲の最後には必ずこのマーカーをいれてください。                         
                                                                             
    4)データ継続                                                             
　    0xff,0x7f,0x01,0x4b                                                    
                                                                             
      曲データが継続することを意味します。リングバッファなどにデータを転送し 
    ながら演奏する場合などにMIDI Managerが書き込みポインタを追い越してしまわ 
    ない様にするためにあります。                                             
                                                                             
   ●具体例                                                                  
     下の例では、テンポ150，4/4拍子で音色番号1の音で第2小節の頭に八分音符でド
   ミソの和音を鳴らし、その小節で終わります。                                
                                                                             
 　  0x00|0x00|0xff,0x58,0x03,0x06,0x1a,0x80                                 
       デルタタイム = 0、トラック = 0、テンポ=150(400000usec)                
　 　  0x00|0x00|0xff,0x51,0x04,0x04,0x02,0x18,0x08                          
       デルタタイム = 0、トラック = 0、4/4拍子                               
　　   0x00|0x01|0xc0,0x00                                                   
       デルタタイム = 0、トラック = 1、プログラムチェンジ 0                  
     0x8f,0x00|0x01|0x90,0x3c,0x60,0x81,0x70,0x00                            
       デルタタイム = 1920、トラック = 1、C3ノートオン、ベロシティ96         
                            長さ = 240(八分音符)オフベロシティ0              
　　 0x00|0x01|0x90,0x40,0x60,0x81,0x70,0x00                                 
       デルタタイム = 0、トラック = 1、E3ノートオン、ベロシティ96            
                             長さ = 240(八分音符)オフベロシティ0             
　　 0x00|0x01|0x90,0x43,0x60,0x81,0x70,0x00                                 
       デルタタイム = 0、トラック = 1、G3ノートオン、ベロシティ96            
                             長さ = 240(八分音符)オフベロシティ0             
     0x8f,0x00|0x00|0xff,0x2f,0x00                                           
       デルタタイム = 1920、トラック = 0、演奏データ終端                     
                                                                             
  1.2.2　EUPフォーマット                                                     
    EUPフォーマットは従来からのTOWNS用演奏ファイルフォーマットです。タイムベ 
  ースは四分音符あたり96クロックです。データ構造は6バイトを1パケットとし、一 
  部のイベントを除いて基本的には下記の様にステータス、トラック番号、小節の先 
  頭からの時間、データという形になっています。time low，time hiはそれぞれの下
  位7ビットづつを取り出した14ビットが実値となります。                        
                                                                             
     +0      +1      +2       +3        +4       +5                          
  status|track |time low|time hi |data 1|data 2  |                           
                    LSB(0-6) MSB(7-13)                                       
                                                                             
   ●チャンネルイベント                                                      
     すべてのチャンネルメッセージはMIDIチャンネルを持っていますが、実際に出力
   するときは、そのトラックのMIDIチャンネルに置き換えられます。ただし、そのト
   ラックのMIDIチャンネルが"omni"である時には、そのままのMIDIチャンネルで出力
   されます。                                                                
                                                                             
    1)ノートオン･オフ                                                        
　    0x9n,Track,TimeL,TimeH,Note,Velocity                                   
　    0x8n,DurationLL,DurationLH,DurationHL,DurationHH,Off-velocity          
　　　    |LSB (0-3) |LSB (4-7) |MSB (8-11)|MSB(12-15)|                      
                                                                             
     ノートオンは必ず対となるノートオフが直後にきます。ノートの長さ(Duration)
   は下位4ビットづつを取り出して16ビットにします。                           
                                                                             
    2)ポリフォニックキープレッシャ                                           
　    0xan,Track,TimeL,TimeH,Note,Value                                      
                                                                             
      ノート番号と圧力値を指定します。                                       
                                                                             
    4)コントロールチェンジ                                                   
　    0xbn,Track,TimeL,TimeH,Number,Value                                    
                                                                             
      コントロール番号とコントロール値を指定します。                         
                                                                             
    5)プログラムチェンジ                                                     
　    0xcn,Track,TimeL,TimeH,Number,0xff                                     
                                                                             
      プログラム番号を指定します。                                           
                                                                             
    6)チャンネルプレッシャ                                                   
    　0xdn,Track,TimeL,TimeH,Value,0xff                                      
                                                                             
    　圧力値を指定します。                                                   
                                                                             
    7)ピッチベンド                                                           
　    0xen,Track,TimeL,TimeH,ValueL,ValueH                                   
                                                                             
      ベンド値(上位、下位7ビットづつの計14ビット)を指定します。              
                                                                             
   ●システムエクスクルーシブイベント                                        
     0xf0,Track,TimeL,TimeH,0xff,0xff                                        
     ID,data2,data3,....                                                     
     dataN,0xf7,0xff,0xff,0xff,0xff                                          
                                                                             
   　エクスクルーシブデータの最初のパケットにはデータは入りません。2番目のパ 
   ケットからデータが入ります。このエクスクルーシブの間には他のパケットが入っ
   てはいけません。また、最後は必ず0xf7(End of Exlusive)の含まれるパケットで 
   終わらなければなりません。その場合パケット内の余分なところには0xffをいれて
   おいてください。                                                          
                                                                             
   ●小節マーカー                                                            
     0xf2,signature,TimeL,TimeH,0xff,0xff                                    
                                                                             
     EUPフォーマットに於いて重要なイベントです。EUPフォーマットでは1小節毎に 
   必ずこの小節マーカーが無ければなりません。TimeL，TimeHはこの小節マーカーま
   での時間、つまり前の小節の長さが入ります。signatureにはこの小節の拍子が入 
   ります。重要なのはこの小節マーカーのTimeL，TimeHと前の小節マーカの        
   signatureが矛盾しないことです。例えば、前の小節マーカーのsignatueが4/4な  
   ら、この小節マーカーのTimeは384(96*4)でなければなりません。               
                                                                             
   ●テンポ                                                                  
   　0xf8,0xff,TimeL,TimeH,TempoL,TempoH                                     
                                                                             
     テンポは14ビットで表現しますが、取りうる範囲は0～250までで、実際の値はそ
   れに30を足した、30bpm～280bpmです。                                       
                                                                             
   ●終端マーカー                                                            
　   0xf2,0xff,TimeL,TimeH,0xff,0xff                                         
                                                                             
     曲の最後には必ずこのマーカーをいれてください。TimeL，TimeHは小節マーカー
   同様にこの終端マーカーまでの時間、つまり最後の小節の長さが入ります。      
                                                                             
   ●データ継続                                                              
   　0xfd,0x??,0x??,0x??,0x??,0x??                                           
                                                                             
     曲データが継続することを意味します。リングバッファなどにデータを転送しな
   がら演奏する場合などにMIDI Managerが書き込みポインタを追い越してしまわない
   様にするためにあります。                                                  
                                                                             
   ●具体例                                                                  
     下の例では、テンポ150，4/4拍子で音色番号1の音で第2小節の頭に八分音符でド
   ミソの和音を鳴らし、その小節で終わります。                                
                                                                             
     0xf8,0xff,0x00,0x00,0x16,0x01                                           
         タイム = 0、テンポ150                                               
     0xc0,0x00,0x00,0x00,0x00,0xff                                           
         タイム = 0、トラック = 1、プログラムチェンジ 0                      
     0xf2,0x33,0x00,0x03,0xff,0xff                                           
         タイム = 384､4/4                                                    
     0x90,0x00,0x00,0x00,0x3c,0x60                                           
     0x80,0x00,0x03,0x00,0x00,0x00                                           
     0x90,0x00,0x00,0x00,0x40,0x60                                           
     0x80,0x00,0x03,0x00,0x00,0x00                                           
     0x90,0x00,0x00,0x00,0x43,0x60                                           
     0x80,0x00,0x03,0x00,0x00,0x00                                           
     0xfe,0x33,0x00,0x03,0xff,0xff                                           
         タイム = 384､4/4                                                    
                                                                             
 1.3　構造体について                                                         
                                                                             
  1.3.1　型宣言                                                              
    以下のような型宣言を"mmdef.h"において行っています。またその他の構造体につ
  いても次の項目より説明してあります。                                       
                                                                             
    typedef unsigned int       SIGN;     /* 拍子記号           */            
    typedef signed int         TIME;     /* 演奏位置(クロック) */            
    typedef unsigned char      TRACK;    /* トラック番号       */            
    typedef unsigned char      PORT;     /* MIDIポート番号     */            
    typedef unsigned char      MIDICH;   /* MIDIチャンネル     */            
    typedef unsigned char      FLAG;     /* フラグ             */            
                                                                             
  1.3.2　各種構造体について                                                  
    MIDI Managerを効果的に運用し、開発効率を上げる為いくつかの構造体を定義し 
  てあります。関数に複数のパラメータを渡す場合などにはすべてこの構造体のポイ 
  ンタを受渡しします。                                                       
                                                                             
   ●TRACKWORK構造体について                                                 
     TRACKWORK構造体は各トラックをコントロールするための管理テーブルです。ア 
   プリはこの構造体のメンバを直接書き替えることにより、各トラックに出力ポート
   やフィルタの値をコントロールできます。                                    
                                                                             
    typedef struct                                                           
    {                                                                        
        TRACK  trk_number;  /*track number                      */       
        FLAG   trk_mute;    /*play or mute                      */       
        int    trk_filter;  /*play filter bits                  */       
        PORT   trk_port;    /*output port                       */       
        char   trk_notemap; /*note number replace map number    */       
        char   trk_ctrlmap; /*control change replace map number */       
        char   trk_progmap; /*program change replace map number */       
        MIDICH trk_midich;  /*output midi ch                    */       
        char   trk_bias;    /*velocity shift                    */       
        char   trk_oct;     /*transpose shift                   */       
        char   trk_vol;     /*ctrl volume shift                 */       
        char   trk_exp;     /*ctrl expression shift             */       
        char   trk_resv1;   /*reseve                            */       
        char   trk_resv2;   /*reseve                            */       
    }TRACKWORK;                                                              
                                                                             
.............................................................................
TRACK trk_number;                                                            
                                                                             
  トラック番号を入れます。ここは内部で構造体アドレスからトラック番号を得るた 
めのフィールドですので必ず0から順に番号を格納してください。                  
.............................................................................
char  trk_mute;                                                              
                                                                             
  そのトラックのすべての出力をまとめてon/offできます。0以外なら出力、0なら出 
力を停止します。                                                             
.............................................................................
int trk_filter;                                                              
                                                                             
  各種MIDIメッセージを出力するかどうかを決めるビットフィールドです。ビットの 
対応は以下の通りで、ビットの立っているメッセージは出力されます。通常はすべて 
onにしておきます。                                                           
                                                                             
#define FLTNOTEOFF  0x01                                                     
#define FLTNOTEON   0x02                                                     
#define FLTKEYPRESS 0x04                                                     
#define FLTCTRL     0x08                                                     
#define FLTPROG     0x10                                                     
#define FLTCHPRESS  0x20                                                     
#define FLTPITCH    0x40                                                     
#define FLTEXC      0x80                                                     
#define FLTTEMPO    0x100                                                    
#define FLTMETA     0x200                                                    
.............................................................................
PORT trk_port;                                                               
                                                                             
  トラックのデータ出力ポートを指定します。                                   
.............................................................................
char   trk_notemap;                                                          
char   trk_ctrlmap;                                                          
char   trk_progmap;                                                          
                                                                             
  このトラックから出力されるノートやコントロールチェンジ、プログラムチェンジ 
の番号の置き換えやマスクを行う時に指定します。0～15までのどのマップを使用する
かを指定してください。置き換え等を行いたくない場合は-1を設定してください。   
.............................................................................
MIDICH trk_midich;                                                           
                                                                             
　トラックの出力MIDIチャンネルを指定します。ここで0-15を指定すればそのトラッ 
クの演奏データはすべてそのチャンネルに置換されて出力されます。0xff(omni)を指 
定すれば演奏データが持っている個々のチャンネルでそのまま出力されます。       
.............................................................................
char trk_bias;                                                               
char trk_oct;                                                                
char trk_vol;                                                                
char trk_exp;                                                                
                                                                             
  trk_biasはトラックから出力されるnote onのベロシティに、trk_octは           
note on/note off/polyphonic key press等の音程情報にこの値を加えます。        
trk_vol、trk_expはcontrol changeのmain volumeとexpressionにこの値を加えます。
トラック全体の音量等を変化させたい時に使用します。                           
────────────────────────────────────── 
   ●NOTEOFFTABLE構造体について                                              
     NOTEOFFTABLEはMIDI Managerが演奏時のnote on/offを管理するためのテーブル 
   です。後に説明されるMIDIMANCTRLにおいてmc_noteoffのサイズを求める際に重要 
   となります。演奏を行うとこのテーブルにnote on/offによって様々な値が書き込 
   まれます。                                                                
   　実際のテーブルのサイズは((最大同時発音数+1)×sizeof(NOTEOFFTABLE))になり
   ますが、余分に取られる部分、つまり0番目の配列の先頭のoff_timeには現在発音 
   中の音の数が入ります。1番目以降ではoff_timeはそのノートがいつoffになるかを
   示し、off_flagが立っているところは発音中であることを意味します。off_track 
   はそのノートがどのトラックからのものであるかの情報です。これらを元に画面に
   note情報を反映させることが可能です。                                      
                                                                             
     typedef struct                                                          
     {                                                                       
         int      off_time;                                                  
         FLAG     off_flag;                                                  
         TRACK    off_track;                                                 
         PORT     off_port;                                                  
         MIDICH   off_ch;                                                    
         char     off_note;                                                  
         char     off_velo;                                                  
     }NOTEOFFTABLE;                                                          
────────────────────────────────────── 
   ●REALTIME構造体について                                                  
     REALTIMEは実時間を表す構造体です。1単位が1/480000000秒なので64bitとなり 
   ます。                                                                    
　   REALTIMEとTIMEの違いは、リアルタイムは単純に時間を表すのに対して、TIMEは
   演奏時の総クロック数を表します。つまり、1クロックの長さはその時のテンポに 
   よって異なり、テンポ120なら60秒÷120拍÷480クロック(タイムベース=480)とな 
   り1041.6666usecとなります。これをREALTIME構造体で表すと、500000(REALTIME) 
   となります。これを4/4拍子で2小節演奏すると、演奏の総クロック数は480×4拍×
   2小節で3840クロックとなり、総演奏時間は3840クロック×500000=1920000000    
   (REALTIME)となります。  これらの計算は特にSMPTEを用いて外部機器と同期をと 
   る時に重要となります。シーケンスソフトは曲の途中から同期させたい場合などは
   上の計算方法にしたがってその途中までのクロック数や演奏時間をドライバに知ら
   せる必要があります。                                                      
                                                                             
     typedef struct                                                          
     {                                                                       
         int rt_lo;                                                          
         int rt_hi;                                                          
     } REALTIME;                                                             
────────────────────────────────────── 
   ●PLACE構造体について                                                     
　   PLACEは演奏位置を表す構造体です。小節、拍、チック、クロック数、実時間、 
   拍子記号が格納されます。つまり、演奏開始ポイントなどをドライバに知らせる場
   合や、現在の演奏位置を取得する場合などに、｢どの小節の何拍目の何チックの位 
   置にいて、その時の拍子やそこまでの総演奏時間が幾つか｣といった情報が1つの構
   造体で表せるようになっています。                                          
                                                                             
     typedef struct                                                          
     {                                                                       
         int      p_meas; (1～)                                              
         int      p_beat; (1～)                                              
         int      p_tick; (0～)                                              
         TIME     p_clock;                                                   
         REALTIME p_time;                                                    
         int      p_sign; (拍子記号を参照してください)                       
     } PLACE;                                                                
────────────────────────────────────── 
   ●SMPTE構造体について                                                     
     SMPTEはタイムコードを表すための構造体です。時、分、秒、フレーム、ビット 
   で表します。80ビットで1フレームとなり1秒あたりのフレーム数はそれぞれのタイ
   プにより異なります。それをtc_typeに定義します。フレームタイプは下記の通り 
   で実際のSMPTEの4種類と実時間計算用のフレームタイプがあります。SMPTE30(30フ
   レーム，NTSCカラー)の場合は1秒あたりのフレーム数が29.97となるため同じ     
   01:00:00'00でも実時間に約3.6秒の差がでます。それを補正するのがSMPTE30DF(ド
   ロップフレームモード)で、10で割り切れない分の最初の2フレームをスキップする
   ことで実時間と約60msec内の誤差に抑えています。また、実時間を表示する時など
   に計算し易いように100フレームで1秒となるSMPTERE ALモードがあります。      
     #define SMPTE24         0                                               
     #define SMPTE25         1                                               
     #define SMPTE30DF       2                                               
     #define SMPTE30         3                                               
     #define SMPTEREAL       4                                               
     typedef struct
     {                                                                       
                                                                             
          int tc_hr;   (0～23)                                               
          int tc_min;  (0～59)                                               
          int tc_sec;  (0～59)                                               
          int tc_fr;   (0～29)                                               
          int tc_bit;  (0～79)                                               
          int tc_type;                                                       
     } SMPTE;                                                                
 ──────────────────────────────────────
   ●METRONOME構造体について                                                 
     演奏時にメトロノームを鳴らす設定を行うための構造体です。TMM_setMetronome
   の引数として使用します。                                                  
                                                                             
     typedef struct{                                                         
                                                                             
          unsigned char  metro_mode;                                         
          PORT           metro_port;                                         
          MIDICH         metro_midich;                                       
          char           metro_hinote;                                       
          char           metro_hivelo;                                       
          char           metro_lownote;                                      
          char           metro_lowvelo;                                      
          char           metro_resv;                                         
          TIME           metro_duration;                                     
     } METRONOME;                                                            
.............................................................................
unsigned char  metro_mode;                                                   
                                                                             
  メトロノームを鳴らすかどうかを決めます。0なら鳴らしません。1なら録音中のみ 
鳴らします。2なら録音中、再生中共に鳴らします。                              
.............................................................................
PORT           metro_port;                                                   
MIDICH         metro_midich;                                                 
                                                                             
  メトロノームを出力するポートとMIDIチャンネルです。                         
.............................................................................
char           metro_hinote;                                                 
char           metro_hivelo;                                                 
char           metro_lownote;                                                
char           metro_lowvelo;                                                
                                                                             
  メトロノームの強拍、弱拍それぞれのノート番号およびベロシティです。         
.............................................................................
TIME           metro_duration;                                               
                                                                             
  メトロノームの各拍の鳴っている時間です。                                   
────────────────────────────────────── 
   ●MIDIMANCTRL構造体について                                               
     MIDIMANCTRL構造体はこのMIDI Managerを使用する場合に非常に重要な構造体の1
   つです。この構造体は初期化時にアプリケーションから渡されます。ここにはMIDI
   Managerが使用する種々のデータバッファとアプリとの連絡のための情報、動作環 
   境等が収められます。                                                      
                                                                             
     typedef struct                                                          
     {                                                                       
         int           mc_interval;                                          
         int           mc_maxnote;                                           
         int           mc_maxtrack;                                          
         unsigned char *mc_sbios;                                            
         NOTEOFFTABLE  *mc_noteoff;                                          
         TRACKWORK     *mc_trackwork;                                        
         char          *mc_filter[16];                                       
         char          *mc_event;                                            
         int           mc_eventsize;                                         
         char          *mc_fmtout;                                           
         int           mc_fmtoutsize;                                        
         char          *mc_fmtin;                                            
         int           mc_fmtinsize;                                         
         char          *mc_smpu;                                             
         int           mc_smpusize;                                          
         char          *mc_stackadr;                                         
         int           mc_stacksize;                                         
     } MIDIMANCTRL;                                                          
.............................................................................
int mc_interval;                                                             
                                                                             
  FMタイマおよびMIDIカード(FMT-401/402/403)のPIT(プログラマブルインターバルタ
イマ)の割り込み間隔を1/480us単位(つまり480000で1msec)で指定します。この間隔が
演奏時のシーケンサの分解能に影響します。例えばテンポが十分に速いと1クロックの
間隔が極端に小さくなりますが実際に人間の耳で聞き分けられる間隔以下になり、そ 
のままでは単にコンピュータの処理に大きな負担がかかるだけになります。そこであ 
る間隔より短い場合は一括して処理を行えば聴感上は違和感なく且つコンピュータに 
かかる負担を小さくすることができます。つまり、2msを指定すればテンポに関係なく
最大2ms以内の誤差でイベントが処理されるわけです。通常のシーケンサでは2msから 
5ms位、曲のノリをそれほどシビアに必要とせずかつ処理の負担を軽くしたいアプリ  
(ゲームソフトなど)であれば5msから20msあたりが適当です。また、vsync割り込みな 
どを使用して自分で割り込み処理エントリをコールする場合はこの値を0としてくださ
い。その場合はドライバは自分の割り込みを登録しなくなります。                 
.............................................................................
int mc_maxnote;                                                              
                                                                             
  全トラックで同時に発音する音の数を指定します。シーケンスソフトのような同時 
発音数が不定となる場合は十分に大きな値、たとえば256位を指定すると良いでしょ  
う。この値は後に出てくるノート管理テーブル(mc_noteoff)のサイズに影響します。 
.............................................................................
int mc_maxtrack;                                                             
                                                                             
  最大トラック数を指定します。たとえばコンダクタトラック+99データトラックのシ
ーケンサであるなら100を指定します。内蔵音源しかドライブしないものや、        
1 MIDI portしか扱わないようなものであるならもっと小さくしても良いでしょう。こ
の値は後に出てくるトラック管理テーブル(mc_trackwork)のサイズに影響します。   
.............................................................................
unsigned char *mc_sbios;                                                     
                                                                             
サウンドBIOSのワークアドレスを設定します。                                   
.............................................................................
NOTEOFFTABLE *mc_noteoff;                                                    
                                                                             
　演奏時のノートオン･オフを管理するためのワークです。このワークのサイズは最大
同時発音数(mc_maxnote)×(NOTEOFFTABLE構造体＋1)のサイズとなります。          
- 例 -  NOTEOFFTABLE noteoff_buff[MAXPLAYNOTE+1];                            
.............................................................................
TRACKWORK  *mc_trackwork;                                                    
                                                                             
　各トラックの管理情報を記憶するためのワークです。このワークのサイズは最大ト 
ラック数(mc_maxtrack)×TRACKWORK構造体のサイズとなります。                   
- 例 -  TRACKWORK trackwork_buff[MAXTRACK];                                  
.............................................................................
char *mc_filter[16];                                                         
                                                                             
  プログラムチェンジやコントロールチェンジの入力時の置換フィルタを登録しま   
す。1つのフィルタは128Byteからなります。そのテーブルの値を参照してコントロー 
ルチェンジを違う番号に置き換えたり、負の値にしてマスクしたりできます。そのフ 
ィルタの器を16個まで登録できます。フィルタを使用しない場合はNULLを入れてくだ 
さい。実際にどのフィルタをどのメッセージに適用するかは、assign mapを通して参 
照されます。                                                                 
.............................................................................
char *mc_event;                                                              
int mc_eventsize;                                                            
                                                                             
  各ポートからのMIDIイベントの入出力の際の使用するバッファを設定します。通常 
にMIDIメッセージは2または3Byteですので、それに時間情報(4Byte)とサイズ(4Byte) 
を足しても16Byteもあれば足りますが、Exclusiveデータを扱う場合にはこのバッファ
を十分に大きく取らないとデータが細切れになってしまいます。高機能なシーケンス 
ソフトなどでは、できればデータの細切れは避けたいところです。Exclusiveデータを
受信した場合、このバッファに入りきらない場合は続きのパケットとなります。バル 
クダンプなどを除けば大抵のExclusiveデータは256Byteに収まるので300Byte以上もあ
れば十分と言えます。                                                         
.............................................................................
char *mc_fmtout;                                                             
int mc_fmtoutsize;                                                           
char *mc_fmtin;                                                              
int mc_fmtinsize;                                                            
char *mc_smpu;                                                               
int mc_smpusize;                                                             
                                                                             
  FMT-40xシリーズ用の入出力バッファおよびS-MPU用の入力バッファを設定します。 
FMT-40xシリーズ用は最大4枚まで実装できるため最大入力4ポート、最大出力8ポート 
となりますので、十分に大きな値を設定してください。標準的には出力側64×8Byte入
力側128×4Byteぐらいです。                                                   
                                                                             
- 例 -                                                                       
 char fmt_out_buff[64*8];                                                    
 char fmt_in_buff[128*4];                                                    
 char smpu_in_buff[128];                                                     
 midiman.mc_fmtout = fmt_out_buff;                                           
 midiman.mc_fmtoutsize = 64*8;                                               
 midiman.mc_fmtin = fmt_in_buff;                                             
 midiman.mc_fmtinsize = 128*4;                                               
 midiman.mc_smpu = smpu_in_buff;                                             
 midiman.mc_smpusize = 128;                                                  
.............................................................................
char *mc_stackadr;                                                           
int mc_stacksize;                                                            
                                                                             
  割り込みルーチンで使用されるローカルスタックを設定します。割り込みはレベル 
4，5およびその割り出しのための合計4個のエリアが必要です。内部ではここで指定し
たバッファを4分割して使用するので、十分に大きなサイズを確保しないとスタックオ
ーバーフローとなってしまいます。推奨は768×4Byte以上です。次に述べる各種ユー 
ザールーチンの中でスタックを多く消費する可能性があるなら、さらにその分を加え 
てください。                                                                 
- 例 -                                                                       
 char local_stack[1024*4];                                                   
                                                                             
 midiman.mc_stackadr = local_stack;                                          
 midiman.mc_stacksize = 1024*4;                                              
────────────────────────────────────── 
 ●FUNCCTRL構造体について                                                    
   typedef struct                                                            
   {                                                                         
           void          (*(fc_idletask))();                                 
           short int     fc_idleseg;                                         
           void          (*(fc_rectask))();                                  
           short int     fc_recseg;                                          
           void          (*(fc_eventtask))();                                
           short int     fc_eventseg;                                        
           short int     fc_dataseg;                                         
   }FUNCCTRL;                                                                
                                                                             
   typedef struct                                                            
   {                                                                         
           void   (*(cfc_idletask))();                                       
           void   (*(cfc_rectask))(PORT,FLAG,TRACK,unsigned char *);         
　　　     void   (*(cfc_eventtask))(TRACK,PORT,unsigned char *);            
   }CFUNCCTRL;                                                               
                                                                             
   アプリが各種イベントの監視や録音、演奏データ作成の前処理などをおこなうため
 に、setUserFunc関数で割り込みルーチンの中から呼び出されるコールバックルーチ 
 ンのエントリアドレスを登録できます。コールバックルーチンは複数(最大4つ)のア 
 プリが同時に登録できます。従って、スイッチャ環境下で他のタスクが稼働中でもこ
 れらの割り込みは発生します。これによりどこかのアプリで演奏している時にそのレ
 ベルメータを違うアプリで表示したりすることができます。登録の必要がない関数が
 ある場合はその関数のポインタをNULLに設定してください。この3つのエントリは   
 far call(セグメント間コール)によって呼び出されます。ユーザールーチン側に来た
 時、ds，esにはfc_datasegの値が設定されます。ただし、このユーザールーチン内で
 は使用するレジスタは退避する必要があるので直接C言語で記述すると思わぬバグの 
 原因を生むことになるでしょう。もしC関数を登録したいのなら、ライブラリの     
 TMM_setCFunc関数を使って登録してください。この関数を使用すると自動的に内部ル
 ーチンをTMM_setUserFunc関数で登録し、ユーザのＣ関数を呼び出せるようにしてく 
 れます。登録の解除はTMM_resetUserFuncを使用してください。このコールバックは 
 割り込み処理のなかであるので、スタックを多く消費したりDOS-CALLをしたりするこ
 とは出来ません。また、メインルーチン側との共用ワークエリアのアクセスには注意
 が必要です。複雑な処理を行うのであれば通常は自前のアセンブラルーチンを通して
 Cルーチンをコールすることをお勧めします。                                   
.............................................................................
void          (*(fc_idletask))();                                            
short int     fc_idleseg;                                                    
                                                                             
  演奏やMIDIの入出力等の動作がない空き時間に呼び出されます。演奏時にデータを 
インタプリトしながら作成していく様なアプリでは、ここにそのルーチンを登録する 
ことによって、あたかも内部データをそのままドライブする様に動かすことができま 
す。                                                                         
                                                                             
.............................................................................
void          (*(fc_rectask))();                                             
short int     fc_recseg;                                                     
                                                                             
  入力ポートに何かMIDIイベントが到着すると呼び出されます。すでに演奏時の時間 
が付加されているのでリアルタイム録音などに利用できます。このルーチンが呼び出 
された時、ds:ediの指すアドレスにイベントが格納されています。先頭のdwordに演奏
クロック、次のdwordにそのイベントのサイズ、その次、つまり8バイト目から実際の 
イベントが格納されています。また、bhレジスタには演奏、一時停止、録音の状態、 
blレジスタにはそのイベントの入力ポート、dhレジスタにはそのイベントが         
assign filterによって出力するかどうか(0以外なら出力)の情報、dlレジスタには出 
力する際の出力フィルタのトラック番号が入っています。したがって、入力情報を   
assign outでMIDIポートに出力する前にデータを書き換えることも可能です。       
.............................................................................
void          (*(fc_eventtask))();                                           
short int     fc_eventseg;                                                   
                                                                             
  演奏時に出力ポートからデータが出力される度に呼び出されます。演奏情報を画面 
に出力したい場合などに利用できます。ただし注意しなければならないのはこのルー 
チンは割り込み処理の一部であるということを認識していなければなりません。ここ 
でダイレクトに画面書き替え等の重い処理をドライブすると演奏がよれたり思いがけ 
ないバグを発生させることになります。このルーチンではイベントをキューに積むな 
どの最小限の処理に抑えておかなければなりません。このルーチンが呼び出された   
時、ds:ediの指すアドレスにイベントが格納されています。また、blレジスタにはそ 
のイベントの出力ポートが、bhレジスタにはそのイベントがどのトラックのものかが 
入っています。したがって、実際にデータがMIDIポートに出力される前にデータを書 
き換えることも可能です。                                                     
.............................................................................
short int     fc_dataseg;                                                    
                                                                             
  各コールバックルーチンの呼び出し時にDS，ESセグメントに設定する値です。     
                                                                             
────────────────────────────────────── 
 ●RSCTRL構造体について                                                      
   MIDI Manager自身はRS-MIDIのI/Oをコントロールするドライバは含んでいません。
 　I/Oをコントロールするモジュールはライブラリ等からTMM_initRsMidiを通して登 
 録され、MIDI Managerからコールバックされます。その入出力処理ルーチンのエント
 リを示すためにRSCTRL構造体を使用します。コールバックルーチンはFARコールされ 
 るので、そのコードセグメントとオフセットを記述します。                      
   typedef struct                                                            
   {                                                                         
        void       (*(rc_output))();                                         
        short int  rc_outputseg;                                             
                                                                             
        void       (*(rc_input))();                                          
        short int  rc_inputseg;                                              
        short int  rc_dataseg;                                               
   }RSCTRL;                                                                  
 ──────────────────────────────────────
 ●ASSIGNFILTER構造体について                                                
   ASSIGNFILTER構造体はMIDI入力を制御する際に必要となる構造体です。          
   AssignFilterは全部で4つまで登録でき、各ポート毎にどのAssignFilterを使用す 
 るかを指定できます。例えば、あるポートにイベントが到着するとそのポートに登録
 されているAssignFilterの.as_statusと.as_chmapを参照して入力すべきイベントか 
 どうかを判断します。さらにベロシティの補正やトランスポーズの処理等をしたのち
 ユーザの録音ルーチンを呼び出します。その後､指定のトラックの出力パスに変換し 
 MIDIに出力します。                                                          
                                                                             
   typedef struct                                                            
   {                                                                         
       short int   as_status;                                                
       short int   as_chmap;                                                 
       TRACK       as_track;                                                 
       char        as_velo;                                                  
       char        as_oct;                                                   
       char        as_ctrlmap;                                               
   } ASSIGNFILTER;                                                           
.............................................................................
short int   as_status;  (各ビットはtrk_filterと同じ)     
short int   as_chmap;   (各ビットがMidi ch 1～16に対応します) 
TRACK       as_track;   (出力するトラック番号)    
char        as_velo;    (ベロシティの置き換え/0のときは置き換えなし)    
char        as_oct;     (入力時のトランスポーズ)    
char        as_ctrlmap; (置き換えられるマップ番号)    
                                                                             
