-----------------------------------------------------------------------------
._splitpath                                                                  
パス名を構成要素に分解する                                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h>     /* 必須 */                                           
void _splitpath(                                                             
　　　　char *path,     /*パス名のためのバッファ*/                           
　　　　char *drive,    /*ドライブ名*/                                       
　　　　char *dir,      /*ディレクトリのパス名*/                             
　　　　char *fname,    /*ファイル名*/                                       
　　　　char *ext       /*ファイル拡張子*/                                   
　　 );                                                                      
                                                                             
- 内容 -                                                                     
_splitpathは、フルパス名pathを4つの構成要素(ドライブ名、ディレクトリ名、ファ 
イル名、拡張子)に分割します。それぞれの構成要素のバッファの最大サイズは、    
stdlib.hで宣言される次の定数によって指定されています。                       
                                                                             
_MAX_DIR     パスのディレクトリ部の最大長                                    
_MAX_DRIVE   ドライブ識別子の最大長                                          
_MAX_EXT     ファイル拡張子の最大長                                          
_MAX_FNAME   ファイル名の最大長                                              
                                                                             
_splitpathの結果は、以下の表のように定義されます。                           
                                                                             
┌────┬───────────────────────────────┐ 
│バッファ│　　　　　　　　　　　内　　　　　　　　容　　　　　　　　　　│ 
├────┼───────────────────────────────┤ 
│ drive  │pathがドライブ指定を持つならば、driveはドライブ文字に続いてコ │ 
│　　　　│ロン(:)を含みます。そうでなければ、driveは空文字列を含みます。│ 
├────┼───────────────────────────────┤ 
│ dir    │pathがディレクトリパスを持つならば、dirは最後の\（もしあれば）│ 
│　　　　│を含むディレクトリパスを含みます。そうでなければ、driveは空文 │ 
│　　　　│字列を含みます。　　　　　　　　　　　　　　　　　　　　　　　│ 
├────┼───────────────────────────────┤ 
│ fname  │ファイル拡張子を除いた基本ファイル名を含みます。　　　　　　　│ 
├────┼───────────────────────────────┤ 
│ ext    │pathがファイル拡張子を持つならば、extは先頭のピリオドとファイ │ 
│　　　　│ル拡張子を含みます。そうでなければ、extは空文字列を含みます。 │ 
└────┴───────────────────────────────┘ 
                                                                             
- 参照 -                                                                     
_makepath                                                                    
                                                                             
- 例 -                                                                       
/*                                                                           
 バッファにフルパスでパス名を作成し、それから_splitpathでその構成要素に分割し
ます。                                                                       
*/                                                                           
                                                                             
#include <stdio.h>                                                           
#include <stdlib.h>                                                          
                                                                             
void main() {                                                                
　 char path_buffer[_MAX_PATH];                                              
　 char dirve[_MAX_DRIVE];                                                   
　 char dir[_MAX_DIR];                                                       
　 char fname[_MAX_FNAME];                                                   
　 char ext[_MAX_EXT];                                                       
                                                                             
　 /* フルパス名を作成する。*/                                               
　 _makepath(path_buffer, "d", "\\highc\\inc\\",                             
　　　　　　 "makpath","c");                                                 
　 printf("Path created with _makepath: %s\n\n",                             
　　　　　 path_buffer);                                                     
                                                                             
　 /* 要素に分割する。*/                                                     
　 _splitpath(path_buffer, drive, dir, fname, ext);                          
　 printf("Path extracted with _splitpath:\n");                              
　 printf("   drive: %s\n", drive);                                          
　 printf("   dir  : %s\n", dir);                                            
　 printf("   fname: %s\n", fname);                                          
　 printf("   ext  : %s\n", ext);                                            
}                                                                            
                                                                             
- 実行結果 -                                                                 
Path created with _makepath: d:\highc\inc\makpath.c                          
                                                                             
Path extracted with _splitpath:                                              
　 drive: d:                                                                 
　 dir  : highc\inc\                                                         
　 fname: makpath                                                            
　 ext  : .c                                                                 
                                                                             
-----------------------------------------------------------------------------
.sprintf                                                                     
文字列にフォーマットによる書き込みを行う                                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>                                                           
int sprintf(char *s, const char *format, ...);                               
                                                                             
- 内容 -                                                                     
出力を、fに結びつけられたファイルにではなく、文字列sに書き出すことを除いて、 
fprint(f,format,...)と等価です。fprintfを参照してください。                  
                                                                             
- 注意 -                                                                     
sprintfの引数の個数は、formatで指定される数以上でなければなりません。そうでな
ければ、ごみが表示されます。                                                 
sprintfの引数の型は、formatで指定される型と一致しなければなりません。        
そうでなければ、ごみが表示されます。                                         
                                                                             
- 戻り値 -                                                                   
sprintfは、変換された文字数(終わりのNULを含まない)を返します。               
                                                                             
- 参照 -                                                                     
fprintf, fscanf, printf, scanf, sscanf, vfprintf, vprintf,vsprintf           
                                                                             
これらの関数の記述については、fprintfの参照の節を参照してください。          
                                                                             
- 例 -                                                                       
/*                                                                           
 fpirntfに対する同様の例は、2つの関数のわずかな違いを紹介します。            
*/                                                                           
                                                                             
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char String[200];                                                         
　 char *S = String;                                                         
　 char s[14] = "like this one";                                             
　 int i = 10, x = 255, n;                                                   
　 double d = 3.1415927;                                                     
                                                                             
　 sprintf(S, "sprintf prints strings (%s), %n", s ,&n);                     
　 S += n; /* 次のspirntfの呼び出しは、最後の呼び出しで書き出した */         
　　　　　 /* NULのアドレスを渡さなければなりません。             */         
　 sprintf(S, "\ndecimal numbers (%d),%n",i ,&n);                            
　 S += n;                                                                   
　 sprintf(S, " hex numbers (%04X),\n%n", x, &n);                            
　 S += n;                                                                   
　 sprintf(S, "percent signs (%%),and\n%n", &n);                             
　 S += n;                                                                   
　 sprintf(S, "floating-points numbers (%+.4e).", d);                        
　 puts(String);                                                             
}                                                                            
                                                                             
- 実行結果 -                                                                 
sprintf prints strings (like this one),                                      
decimal numbers (10), hex numbers (00FF),                                    
percent signs (%), and                                                       
floating-point numbers (+3.1416e+00).                                        
                                                                             
-----------------------------------------------------------------------------
.sqrt                                                                        
平方根を求める                                                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <math.h>       /* 必須 */                                           
double sqrt(double x);                                                       
                                                                             
- 内容 -                                                                     
xの負でない平方根を返します。x < 0.0のとき、errnoにEDOMを設定し、0.0を返しま 
す。                                                                         
                                                                             
-----------------------------------------------------------------------------
.srand                                                                       
疑似乱数の生成関数に種を与える                                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h>                                                          
void srand(unsigned int seed);                                               
                                                                             
- 内容 -                                                                     
その引数を、randによって生成される疑似乱数列に対する種として使います。       
srandを呼び出す前にrand関数を呼び出した場合、使われる種は1です。             
                                                                             
- 参照 -                                                                     
rand    疑似乱数を生成する。                                                 
                                                                             
-----------------------------------------------------------------------------
._srotl                                                                      
._srotr                                                                      
short intを左または右に回転する                                              
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h>                                                          
unsigned short _srotl(unsigned short word,int amount );                      
unsigned short _srotr(unsigned short word,int amount );                      
                                                                             
- 内容 -                                                                     
これらの関数は、amountで与えらたビット数だけ、wordを左(_srotl)、あるいは右   
(_srotr)に回転します。                                                       
                                                                             
- 戻り値 -                                                                   
回転したワードを返します。                                                   
                                                                             
- 参照 -                                                                     
_lrotl, _lrotr                                                               
                                                                             
- 例 -                                                                       
#include <stdlib.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 unsigned short int k = 1, m = 0x8000;                                     
                                                                             
　 printf("Rotate left and right by"                                         
　　　　　" one bit at a time:\n");                                          
　 do {                                                                      
　　　printf("\t%4x\t\t%4x\n", k, m);                                        
　　　k = _srotl(k, 1);                                                      
　　　m = _srotr(m, 1);                                                      
　 } while (k != 1);                                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
Rotate left and right by one bit at a time:                                  
　 1    8000                                                                 
　 2    4000                                                                 
　 4    2000                                                                 
　 8    1000                                                                 
　10     800                                                                 
　20     400                                                                 
　40     200                                                                 
　80     100                                                                 
 100      80                                                                 
 200      40                                                                 
 400      20                                                                 
 800      10                                                                 
1000       8                                                                 
2000       4                                                                 
4000       2                                                                 
8000       1                                                                 
                                                                             
-----------------------------------------------------------------------------
.sscanf                                                                      
文字列を読み込みフォーマットによる変換を行う                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>                                                           
int sscanf(const char *s, const char *format ,...);                          
                                                                             
- 内容 -                                                                     
入力を、fに結びつけられたファイルからではなく、文字列sから読み出すことを除い 
て、fscanf(f,format,...)と等価です。fscanfを参照してください。               
                                                                             
- 注意 -                                                                     
sscanfに渡された引数の数がformatで指定された数より少ないならば、その変換仕様 
の結果、メモリ上の任意の場所に上書きされます。                               
sscanfは、formatに続く各引数が、変換仕様で指定された型へのポインタであると解 
釈します。引数の数が期待されたポインタでないときでも、期待されたポインタであ 
るとして扱われ、潜在的に変換の結果、メモリ上のある任意の場所が上書きされま   
す。不正な引数がポインタと同じサイズでないならば、続く引数が誤って解釈される 
ことがあります。                                                             
                                                                             
- 参照 -                                                                     
fpirntf, fscanf, printf, scanf, sprintf, vfprintf, vprintf, vsprintf         
                                                                             
これらの関数の記述については、fprintfの参照の節を参照ください。              
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char buff[] = "Rick 23";                                                  
　 char name[130];                                                           
　 int  age;                                                                 
                                                                             
　 sscanf(buff,"%s %d", name, &age);                                         
　 printf("My name is %s.\n", name);                                         
　 printf("My age is %d.", age);                                             
}                                                                            
                                                                             
- 実行結果 -                                                                 
My name is Rick.                                                             
My age is 23.                                                                
                                                                             
-----------------------------------------------------------------------------
._stat                                                                       
ファイルまたはディレクトリについての情報を得る                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <sys\types.h>  /* 必須 */                                           
#include <sys\stat.h>                                                        
int _stat(                                                                   
　 char *path,  /* ファイルまたはディレクトリのパス名 */                     
　 struct _stat {      /* ファイル情報を格納する構造体       */              
　　　dev_t st_dev;                                                          
　　　ino_t st_ino;                                                          
　　　unsigned short st_mode;                                                
　　　short st_nlink;                                                        
　　　short st_uid;                                                          
　　　short st_gid;                                                          
　　　dev_t st_rdev;                                                         
　　　off_t  st_size;                                                        
　　　time_t st_atime;                                                       
　　　time_t st_mtime;                                                       
　　　time_t st_ctime;                                                       
　　　} *buffer                                                              
　　);                                                                       
                                                                             
- 内容 -                                                                     
_statは、pathで指定されたファイルまたはディレクトリに関する情報を集め、buffer
によって指されたstat構造体に格納します。この構造体は、sys\stat.hで定義され、 
次のフィールドを持ちます。                                                   
                                                                             
┌─────┬─────────────────────────────┐   
│フィールド│　　　　　　　　　　　　　　値　　　　　　　　　　　　　　│   
├─────┼─────────────────────────────┤   
│st_mode   │ファイルモード情報　　　　　　　　　　　　　　　　　　　　│   
│          │_S_IFDIRビットは、pathがディレクトリを参照しているときに  │   
│          │セットします。　　　　　　　　　　　　　　　　　　　　　　│   
│          │_S_IFREGビットは、pathが通常のファイルを参照しているときに│   
│          │セットします。　　　　　　　　　　　　　　　　　　　　　　│   
│          │_S_IREADビットと_S_IWRITEビットは、ファイルの許可設定にし │   
│          │たがって、セットします。　　　　　　　　　　　　　　　　　│   
│          │_S_IEXECビットは、実行形式ファイルであることを示し、ファイ│   
│          │ルの拡張子に応じて、セットします。　　　　　　　　　　　　│   
│st_dev    │ファイルを含むディスクのドライブ番号（A=0, B=1, ...）。　 │   
│　　　　　│st_rdevと同じ　　　　　　　　　　　　　　　 　　　　　　　│   
│st_rdev   │ファイルを含むディスクのドライブ番号（A=0, B=1, ...）。 　│   
│　　　　　│st_devと同じ　　　　　　　　　　　　　　　　 　　　　　　 │   
│st_nlink  │常に1　　　　　　　　　　　　　　　　　　　　 　　　　  　│   
│st_size   │ファイルのバイト長　   　　　　　　　　　　　　　　　　 　│   
│st_atime  │ファイルを最後に修正した時刻（st_mtimeやst_ctimeと同様）  │   
│st_mtime  │ファイルを最後に修正した時刻（st_atimeやst_ctimeと同様）　│   
│st_ctime  │ファイルを最後に修正した時刻（st_atimeやst_mtimeと同様）　│   
└─────┴─────────────────────────────┘   
                                                                             
　stat構造体のst_ino, st_uid, st_gidフィールドは、DOSの下では意味のある値を持
ちません。                                                                   
                                                                             
- 戻り値 -                                                                   
_stat関数はファイル情報を得ることに成功すると、ゼロを返します。処理に失敗する
と、_statは-1を返し、グローバル変数errnoに、指定されたパスが見つからなかった 
ことを示すENOENTを設定します。                                               
                                                                             
- 参照 -                                                                     
_access        ファイルのアクセス権を調べる。                                
_chmod         ファイルに設定されている許可を変更する。                      
_fdopen        オープンされているハンドルにストリームを結びつける。          
_fsopen        ファイルをオープンし、シェアリングモードを設定する。          
_locking       ファイルへの同時アクセスを防止する。                          
_sopen         パス名で共有モードのファイルをオープンする。                  
                                                                             
- 例 -                                                                       
/*                                                                           
 指定ファイルの情報を表示します。                                            
*/                                                                           
                                                                             
#include <time.h>                                                            
#include <sys\types.h>                                                       
#include <sys\stat.h>                                                        
#include <stdio.h>                                                           
#include <dos.h>                                                             
#include <string.h>                                                          
#include <stdlib.h>                                                          
                                                                             
void main() {                                                                
　 struct _stat buf;                                                         
　 char fname[25];                                                           
                                                                             
　 printf("Please enter file name: ");                                       
　 gets(fname);                                                              
　 printf("\nStats on file name: %s\n", fname);                              
                                                                             
　 if (_stat(fname, &buf) != 0)                                              
　　　perror("Problem getting info.");                                       
　 else {                                                                    
　　　(buf.st_mode & _S_IFDIR) ? puts("directory")                           
　　　 : puts("not a directory");                                            
　　　(buf.st_mode & _S_IFREG) ? puts("ordinary file")                       
　　　 : puts("not a ordinary file");                                        
　　　(buf.st_mode & _S_IWRITE) ? puts("read/write file")                    
　　　 : puts("read-only file");                                             
　　　(buf.st_mode & _S_IEXEC) ? puts("executable file")                     
　　　 : puts("not an executable file");                                     
　　　printf("File size     : %ld\n", buf.st_size);                          
　　　printf("Drive number  : %d\n, buf.st_dev);                             
　　　printf("Time modified : %s", ctime(&buf.st_atime));                    
　 }                                                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
Please enter file name: stat.c                                               
Stats on file name: stat.c                                                   
not a directory                                                              
ordinary file                                                                
read/write file                                                              
not an executable file                                                       
File size     : 934                                                          
Drive number  : 4                                                            
Time modified : Tre Oct 17 17:04:10 1989                                     
                                                                             
-----------------------------------------------------------------------------
.stderr                                                                      
.stdin                                                                       
.stdout                                                                      
標準入力、標準出力、標準エラーストリームを表すマクロ                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>      /* 必須 */                                           
                                                                             
- 内容 -                                                                     
特定のストリームを制御するために、プログラム起動時に初期化されるFILE変数への 
ポインタに展開されます。                                                     
                                                                             
┌─────┬──────────────────────────────┐ 
│ストリーム│　　　　　　　　　　　内　　　　　容　　　　　　　　　　　　│ 
├─────┼──────────────────────────────┤ 
│stderr  　│標準エラーファイルに結びつけられ、書き込み専用で初期化され、│ 
│　　　　　│スクリーンに書き出します。　　　　　　　　　　　　　　　　　│ 
│stdin   　│標準入力ファイルに結びつけられ、読み込み専用で初期化され、　│ 
│　　　　　│キーボートから読み込みます。　　　　　　　　　　　　　　　　│ 
│stdout  　│標準出力ファイルに結びつけられ、書き込み専用で初期化され、　│ 
│　　　　　│スクリーンに書き出します。　　　　　　　　　　　　　　　　　│ 
└─────┴──────────────────────────────┘ 
                                                                             
　stderrは、デフォルトでバッファリングされません。stdinとstdoutは、それぞれキ
ーボードとスクリーンを参照するならば(つまり、リダイレクトされない限り)、デフ 
ォルトでラインバッファリングされます。そうでなければ、デフォルトでバッファリ 
ングされます。デフォルトバッファは、setbufまたはsetvbufへの呼び出しによって上
書きされます。                                                               
                                                                             
-----------------------------------------------------------------------------
.strcat                                                                      
文字列を連結する                                                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
char *strcat(char *s1, const char *s2);                                      
                                                                             
- 内容 -                                                                     
文字列s1に文字列s2のコピーを追加します。s2の最初の文字は、s1の終わりのNULに上
書きします。s1を返します。                                                   
                                                                             
- 注意 -                                                                     
strcatは、s1の大きさに関係なく、文字列s2の終わりまで書き込みます。           
                                                                             
- 参照 -                                                                     
_strncat   文字列を別の文字列に追加する。結果の文字列はn文字までとする。     
strncat 　 文字列からn文字までを別の文字に追加する。                         
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <string.h>                                                          
                                                                             
void main() {                                                                
　 char base[30] = "This is now ";                                           
　 char tag[] = "a whole string!";                                           
                                                                             
　 puts(base);                                                               
　 puts(tag);                                                                
　 strcat(base, tag);                                                        
　 puts(base);                                                               
}                                                                            
                                                                             
- 実行結果 -                                                                 
This is now                                                                  
a whole string!                                                              
This is a now a whole string!                                                
                                                                             
-----------------------------------------------------------------------------
._strcats                                                                    
複数の文字列を指定の長さまで連結する                                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
char *_strcats(int len,                                                      
　　　　　　　 char *s1,                                                     
　　　　　　　 const char *s2,                                               
　　　　　　　 ...,                                                          
　　　　　　　 NULL                                                          
　　　　　　　);                                                             
                                                                             
- 内容 -                                                                     
s2がNULLのとき、何も行いません。そうでないとき、文字列s2と次に続く引数をs1に 
連結します。この結果s1は、高々len-1個のNULでない文字を含みます。             
_strcatsの最後の引数は、NULLでなければなりません。NULLは結合を終了させます。 
文字をすべて追加し終わると、最後にNULを追加します。s2の最初の文字は、文字列s1
を終了させるNULを上書きし、次に続く各引数も同様の処理を行います。最初にs1が  
NULLを含んでいないとき、結果は不定です。                                     
                                                                             
- 注意 -                                                                     
_strcatsは、s1の実際の大きさに関係しません。s1が連結された文字列を保持するた 
めに十分な大きさを持つように注意してください。len引数は、この目的のために提供
されています。                                                               
                                                                             
- 参照 -                                                                     
strcat  　  2つの文字列を結合する。                                          
strncat 　  文字列を別の文字列に、長さを指定して追加する。                   
_strcat     文字列を別の文字列に、全体の長さを指定して追加する。             
                                                                             
- 例 -                                                                       
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char s1[65] ="This ";                                                     
　 char s2[]   ="string ";                                                   
　 char s3[]   ="contains ";                                                 
　 char s4[]   ="fifty ";                                                    
　 char s5[]   ="characters ";                                               
　 char s6[]   ="more ";                                                     
　 char s7[]   ="or ";                                                       
　 char s8[]   ="less";                                                      
　 char s9[]   =".\n";                                                       
　 char s10[]  ="More in fact than can be printed.";                         
　 _strcats(65, s1, s2, s3, s4, s5, s6, s7, s8, s9, s10, NULL);              
　 puts(s1);                                                                 
}                                                                            
                                                                             
- 実行結果 -                                                                 
This string contains fifty characters more or less.                          
More in fact                                                                 
                                                                             
-----------------------------------------------------------------------------
.strchr                                                                      
文字列中から指定した文字を探す                                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
char *strchr(const char *s, int c);                                          
                                                                             
- 内容 -                                                                     
文字列sの中で最初に文字c(int cの最下位バイト)が現われる位置を探します。      
見つかったとき、その文字へのポインタを返します。見つからないとき、NULLを返し 
ます。文字cに対してNULは有効な値であり、結果として(NULで終了する)文字列の終わ
りへのポインタを返します。                                                   
                                                                             
- 注意 -                                                                     
strchrは、｢2.6節 関数と引数｣で議論された慣習に適合するために、cをchar引数より
むしろintとして受け取ります。型charのオブジェクトがstrchrに渡されたとき、自動
的に型intに強制されます。                                                    
                                                                             
- 参照 -                                                                     
memchr, strcspn, strpbrk, strrchr, strspn                                    
これらの関数の短い記述については、memchrの参照の節を参照ください。           
                                                                             
- 例 -                                                                       
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char *s1 = "Testing strchr.";                                             
　 char *s2 = "This is correctly tested.";                                   
　 char *s;                                                                  
                                                                             
　 s = strchr(s1, (int)'t');                                                 
　 puts(s);                                                                  
　 s = strchr(s2, (int)'c');                                                 
　 puts(s);                                                                  
}                                                                            
                                                                             
- 実行結果 -                                                                 
ting strchr.                                                                 
correctly tested.                                                            
                                                                             
-----------------------------------------------------------------------------
._strcmpi                                                                    
._stricmp                                                                    
大文字小文字を区別しないで、2つの文字列を比較する                            
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
int _strcmpi(const char *s1, const char *s2);                                
int _stricmp(const char *s1, const char *s2);                                
                                                                             
- 内容 -                                                                     
_strcmpi関数と_stricmp関数は全く同じです。両関数は、2つの文字列s1とs2を比較し
ます。短い方の文字列の長さに達すると、比較を終了します。比較は、大文字小文字 
を区別しません。                                                             
                                                                             
- 戻り値 -                                                                   
s1がs2より小さいならば、ゼロより小さいintを返します。s1がs2より大きいならば、
ゼロより大きいintを返します。s1とs2が等しいならば、ゼロを返します。          
                                                                             
- 参照 -                                                                     
strcmp, _strnicmp, strncmp, strcmp                                           
                                                                             
- 例 -                                                                       
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char a[] = "tHIS iS A tEST Z";                                            
　 char b[] = "This is A Test z";                                            
　 char c[] = "[]";                                                          
　 char d[] = "{}";                                                          
　 char e[] = "1234";                                                        
　 char f[] = "5678";                                                        
                                                                             
　 if (_strcmpi(a,b) == 0)                                                   
　　　puts("_strcmpi equal test ok.");                                       
　 else                                                                      
　　　puts("_strcmpi unequal test failed.");                                 
                                                                             
　 if (_strcmpi(c,d) == 0)                                                   
　　　puts("_strcmpi unequal test failed.");                                 
　 else                                                                      
　　　puts("_strcmpi unequal test ok.");                                     
                                                                             
　 if (_strcmpi(e,e) == 0)                                                   
　　　puts("_strcmpi equal2 test ok.");                                      
                                                                             
　 else                                                                      
　　　puts("_strcmpi equal2 test failed.");                                  
                                                                             
　 if (_strcmpi(e,f) == 0)                                                   
　　　puts("_strcmpi unequal test failed.");                                 
　 else                                                                      
　　　puts("_strcmpi unequal test ok.");                                     
}                                                                            
                                                                             
- 実行結果 -                                                                 
_strcmpi equal test ok.                                                      
_strcmpi unequal test ok.                                                    
_strcmpi equal2 test ok.                                                     
_strcmpi unequal test ok.                                                    
                                                                             
-----------------------------------------------------------------------------
.strcmp                                                                      
2つの文字列を比較する                                                        
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
int strcmp(const char *s1, const char *s2);                                  
                                                                             
- 内容 -                                                                     
文字列s1と文字列s2を比較します。s1がs2より大きいならば、ゼロより大きい値を返 
します。s1がs2に等しいならば、ゼロを返します。s1がs2より小さいならば、ゼロよ 
り小さい値を返します。長さの違う2つの文字列が短い文字列の内容まで等しいなら  
ば、長い文字列が辞書式順序で大きいとします。つまり、"abc"は"ab"より大です。  
                                                                             
- 参照 -                                                                     
memcmp  　　　メモリ上の2つの領域を比較する。                                
strncmp 　　　文字列のある数の文字と別の文字列のある数の文字を比較する。     
_str*cmp*     大文字小文字の区別をしないで、文字列を比較する。               
                                                                             
- 例 -                                                                       
/*                                                                           
 以下のプログラムは、2つの文字列を比較します。                               
*/                                                                           
                                                                             
#include <string.h>                                                          
#include <stdio.h>                                                           
#include <stdlib.h>                                                          
                                                                             
void do_strcmp(char *a,char *b) {                                            
　 printf("First string: %s\nSecond string: %s\n"                            
　　　　　"strcmp returns: %d\n", a, b, strcmp(a,b));                        
}                                                                            
                                                                             
void main() {                                                                
　 do_strcmp("Test one!","Test one!");                                       
　 do_strcmp("Test Two.","Test two.");                                       
　 do_strcmp("Test three.","Test Three.");                                   
　 do_strcmp("a","a");                                                       
　 do_strcmp("a","z");                                                       
　 do_strcmp("z","a");                                                       
}                                                                            
                                                                             
- 実行結果 -                                                                 
First string: Test one!                                                      
Second string: Test one!                                                     
strcmp returns: 0                                                            
First string: Test Two.                                                      
Second string: Test two.                                                     
strcmp returns: -1                                                           
First string: Test three.                                                    
Second string: Test Three.                                                   
strcmp returns: 1                                                            
First string: a                                                              
Second string: a                                                             
strcmp returns: 0                                                            
First string: a                                                              
Second string: z                                                             
strcmp returns: -1                                                           
First string: z                                                              
Second string: a                                                             
strcmp returns: 1                                                            
                                                                             
-----------------------------------------------------------------------------
.strcoll                                                                     
現在の地域性で文字列を比較する                                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>                                                          
int strcoll(const char *s1, const char *s2);                                 
                                                                             
- 内容 -                                                                     
プログラムの地域性の照合列を使って、文字列s1と文字列s2を比較します。文字列s1 
が文字列s2より大きいとき、ゼロより大きい値を返します。2つの文字列が等しいと  
き、ゼロを返します。文字列s1が文字列s2より小さいとき、ゼロより小さい値を返し 
ます。                                                                       
                                                                             
High Cは、標準の地域性のみをサポートしています。そのため、strcollとstrcmpは等
価です。                                                                     
                                                                             
- 参照 -                                                                     
strxfrm 　　文字列を地域性に依存しない形式に変換する。                       
strcmp  　　文字列を別の文字列と比較する。                                   
                                                                             
-----------------------------------------------------------------------------
.strcpy                                                                      
文字列の文字を別の文字列に複写する                                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
char *strcpy(char *s1, const char *s2);                                      
                                                                             
- 内容 -                                                                     
文字列s2を文字列s1に、末尾のNULを含んで複写します。s1を返します。strcpyは左か
ら右(低アドレスから高アドレス)に複写します。s2<s1<s2+strlen(s2)のとき、つま  
り、文字列s1と文字列s2が重なっていて、複写先の領域が複写元の領域中から始まる 
とき、_rstrcpyを使用してください。                                           
                                                                             
- 注意 -                                                                     
strcpyは、s1の長さに関係せず、s2の終わりに出会うまで書き込みます。           
s2<s1<s2+strlen(s2)のように文字列s1と文字列s2が重なっているとき、その動作は不
定です。                                                                     
strcpyは、第2引数を最初の引数に複写します。                                  
                                                                             
- 参照 -                                                                     
memcpy, memset, _rmemcpy, _rstrcpy, _rstrncpy, strncpy                       
                                                                             
これらの関数の短い記述については、memcpyの参照の節を参照ください。           
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <string.h>                                                          
                                                                             
void main() {                                                                
　 char string[] = "This is what's in here now.";                            
                                                                             
　 puts(string);                                                             
　 strcpy(string, "Now it's different.");                                    
　 puts(string);                                                             
}                                                                            
                                                                             
- 実行結果 -                                                                 
This is what's in here now.                                                  
Now it's different.                                                          
                                                                             
-----------------------------------------------------------------------------
.strcspn                                                                     
ある文字列の先頭部分(ただし別の文字列の文字を含まない)の長さを決定する       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
size_t strcspn(const char *s1, const char *s2);                              
                                                                             
- 内容 -                                                                     
文字列s1の、その文字列の先頭から始まり、完全に文字列s2に現れない文字から成る 
部分の長さを返します。この目的のために、NULはs2の一部であるとはみなしません。
                                                                             
- 参照 -                                                                     
memchr, strchr, strpbrk, strrchr, strspn                                     
                                                                             
これらの関数の短い記述については、memchrの参照の節を参照ください。           
                                                                             
- 例 -                                                                       
memsetで提供された例を参照してください。                                     
                                                                             
-----------------------------------------------------------------------------
._strdate                                                                    
日付を文字列として報告する                                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <time.h>       /* 必須 */                                           
char *_strdate(char *sptr);                                                  
                                                                             
- 内容 -                                                                     
_strdate関数は、現在の日付を得て、それを文字形式に変換し、sptrで指された文字 
列に置きます。日付は、mm/dd/yyの形式であり、mmは月、ddは日、yyは年です。日付 
の各要素は2桁の数字であり、sptrの指す文字列は少なくとも9バイトの長さでなけれ 
ばなりません。この関数は、日付文字列の後にNUL文字を置きます。                
                                                                             
- 戻り値 -                                                                   
この関数は、文字列のポインタを返します。                                     
                                                                             
- 参照 -                                                                     
asctime, ctime, gmtime, localtime, mktime, time, _tzset                      
                                                                             
- 例 -                                                                       
#include <time.h>                                                            
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char a[15];                                                               
                                                                             
　 _strdate(&a[0]);                                                          
　 puts("The date is --");                                                   
　 puts(a);                                                                  
}                                                                            
                                                                             
- 実行結果 -                                                                 
The date is --                                                               
10/17/89                                                                     
                                                                             
-----------------------------------------------------------------------------
._strdup                                                                     
文字列をヒープ上に複写する                                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
char *_strdup(const char *strptr);                                           
                                                                             
- 内容 -                                                                     
_strdup関数は、strptrで指される文字列の長さを計算し、ヒープから適切な領域を得
るために、mallocを呼び出します。この関数は、次にstrptr文字列をmallocから得た 
領域に複写します。                                                           
                                                                             
- 戻り値 -                                                                   
mallocが文字列を新しく複写するために十分な領域を得ることができないならば、   
NULLを返します。そうでなければ、文字列の新しい複写へのポインタを返します。   
                                                                             
- 参照 -                                                                     
strcpy, malloc                                                               
                                                                             
- 例 -                                                                       
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char a[100];                                                              
　 int j;                                                                    
                                                                             
　 printf("Use _strdup to malloc all of memory!\n");                         
　 for (j = 0; j < 99; j++)                                                  
　　　a[j] = 1;                                                              
　 a[99] = 0;                                                                
　 j = 0;                                                                    
　 do j++;                                                                   
　 while (NULL != _strdup(a));                                               
　 printf("_strdup %d00 bytes before running"                                
　　　　　" out of heap.\n", j);                                             
}                                                                            
                                                                             
- 実行結果 -                                                                 
Use _strdup to malloc all of memory!                                         
_strdup 2852800 bytes before running out of heap.                            
                                                                             
-----------------------------------------------------------------------------
.strerror                                                                    
._strerror                                                                   
エラーコードをエラーメッセージ文字列にマッピングする。                       
エラーメッセージ文字列をユーザメッセージに追加する。                         
strerrorはANSI、_strerrorは拡張ANSIである                                    
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     　　　　/* 必須 */                                   
char *strerror(int errnum);                                                  
char *_strerror(char *string);                                               
                                                                             
#include <stdio.h>    　　　　　/* 次の変数を定義するためだけに必須 */       
int errno;            　　　　　/* エラー番号 */                             
int sys_nerr;         　　　　  /* エラーメッセージの数 */                   
char *sys_errlist[sys_nerr];  　/* エラーメッセージの配列 */                 
                                                                             
- 内容 -                                                                     
strerrorは、エラーメッセージ文字列のグローバル配列sys_errlistに対して、errnum
をインデックスの番号に使います。strerrorは、エラーメッセージ文字列を静的バッ 
ファに複写し、そのバッファへのポインタを返します。次にstrerrorを呼び出すと、 
このバッファは上書きされます。                                               
_strerror関数は、string、": "、グローバル変数errno(errnoは、最後にエラーが発 
生したライブラリのエラーコードを含む)の値に対応するsys_errlist中のエラーメッ 
セージ文字列からなる文字列へのポインタを返します。stringにNULLが渡されると、 
": "は含まれません。この文字列は、長さ128の静的バッファ上に作成されます。バッ
ファの境界を超えないためには、stringのメッセージを95文字未満にしなければなり 
ません。                                                                     
                                                                             
sys_errlist[]のエラーメッセージは、すべて改行('\n')で終わります。            
                                                                             
- 戻り値 -                                                                   
strerrorと_strerrorは、エラーメッセージ文字列へのポインタを返します。        
                                                                             
- 参照 -                                                                     
clearerr, ferror, perror                                                     
                                                                             
- 例 -                                                                       
/*                                                                           
 このプログラムは、システムエラーメッセージを表示します。                    
*/                                                                           
                                                                             
#include <stdio.h>                                                           
#include <string.h>                                                          
#include <stdlib.h>                                                          
                                                                             
void main() {                                                                
　 int i;                                                                    
　 /* strerrorフォーマットで、エラーメッセージを表示する。*/                 
　 puts("A few error messages:\n");                                          
　 for (i = 5; i <= 10; i++)                                                 
　　　printf(strerror(i));                                                   
                                                                             
　 /* _strerrorフォーマットを使う。*/                                        
　 puts("\nA few more with a different format:\n");                          
　 for (i = 10; i <= 15; i++) {                                              
　　　errno = i;                                                             
　　　printf(_strerror("This is an error message"));                         
　 }                                                                         
}                                                                            
                                                                             
- 実行結果 - (変化する)                                                      
A few error message:                                                         
                                                                             
Access denied                                                                
Invalid handle                                                               
Arena headers destoryed                                                      
Not enough memory                                                            
Invalid block                                                                
Bad environment                                                              
                                                                             
A few more with a different format:                                          
                                                                             
This is an error message: Bad environment                                    
This is an error message: Bad format                                         
This is an error message: Invalid access                                     
This is an error message: Invalid data                                       
This is an error message: Reserved                                           
                                                                             
-----------------------------------------------------------------------------
.strftime                                                                    
時刻と日付の文字列をフォーマットする                                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <time.h>       /* 必須 */                                           
size_t strftime(char *s,                                                     
　　　　　　　　size_t maxsize,                                              
　　　　　　　　const char *format,                                          
　　　　　　　　const struct tm *timeptr                                     
　　　　　　　 );                                                            
                                                                             
- 内容 -                                                                     
文字列formatの指定に応じて、文字列sをフォーマットします。フォーマット文字列  
は、ゼロまたはそれ以上の変換仕様と、通常のマルチバイト文字から構成されます。 
変換仕様は、%文字と次の変換を行う文字から構成されます。フォーマット文字中の通
常のマルチバイトは、文字列s中に変換せずに複写します。(終わりのNULを含めて)   
maxsize個以下の文字を文字列sに置きます。formatと文字列sが重なっているとき、  
動作は不定です。sの長さがmaxsizeを超えたとき、ゼロを返します。それ以外のと   
き、sの長さを返します。                                                      
                                                                             
┌──────┬────────────────────────────┐   
│フォーマット│　　　　　　　　　　説　　　　　　明　　　　　　　　　　│   
├──────┼────────────────────────────┤   
│    %a      │曜日名の省略形　　　　　　　　　　　　　　　　　　　　　│   
│　  %A      │曜日名　　　　　　　　　　　　　　　　　　　　　　　　　│   
│　  %b      │月名の省略形　　　　　　　　　　　　　　　　　　　　　　│   
│　  %B      │月名　　　　　　　　　　　　　　　　　　　　　　　　　　│   
│　  %c      │地域に適応した日付と時刻表現　　　　　　　　　　　　　　│   
│　  %d      │10進表記の日(01-31) 　　　　　　　　　　　　　　　　　　│   
│　  %H      │24時間表記の時(00-23) 　　　　　　　　　　　　　　　　　│   
│　  %I      │12時間表記の時(01-12) 　　　　　　　　　　　　　　　　　│   
│　  %j      │10進表記の経過日数(001-336) 　　　　　　　　　　　　　　│   
│　  %m      │10進表記の月(01-12) 　　　　　　　　　　　　　　　　　　│   
│　  %M      │10進表記の分(00-59) 　　　　　　　　　　　　　　　　　　│   
│　  %p      │12時間表記のAMまたはPM　　　　　　　　　　　　　　　　　│   
│　  %S      │10進表記の秒(00-59) 　　　　　　　　　　　　　　　　　　│   
│　  %U      │10進表記の経過週数(00-51)。日曜が週の最初の日。　　　　 │   
│　  %w      │10進表記の曜日(0-6)。日曜が最初。　　　　　　　　　　　 │   
│　  %W      │10進表記の経過週数(00-51)。月曜が週の最初の日。　　　　 │   
│　  %x      │地域日付表現　　　　　　　　　　　　　　　　　　　　　　│   
│　  %X      │地域時刻表現　　　　　　　　　　　　　　　　　　　　　　│   
│　  %y      │10進表記の世紀を除いた年(00-99) 　　　　　　　　　　　　│   
│　  %Y      │10進表記の世紀を含んだ年　　　　　　　　　　　　　　　　│   
│　  %z      │タイムゾーン名(タイムゾーンが未定ならば、無い)   　　　 │   
│　  %%      │%で置き換える  　　　　　　　　　　　　　　　　　　　　 │   
└──────┴────────────────────────────┘   
                                                                             
変換仕様がこれらの1つではないならば、動作は不定です。                        
                                                                             
-----------------------------------------------------------------------------
.strlen                                                                      
文字列の長さを求める                                                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
size_t strlen(char *s);                                                      
                                                                             
- 内容 -                                                                     
strlen関数は、文字列sのNULを含まない文字数を返します。                       
                                                                             
- 例 -                                                                       
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char string[] = "Here's yet another sentence.";                           
　 size_t i;                                                                 
                                                                             
　 i = strlen(string);                                                       
　 printf("There are %d characters in:\n\n", i);                             
　 printf("%s\n", string);                                                   
}                                                                            
                                                                             
- 実行結果 -                                                                 
There are 28 characters in:                                                  
                                                                             
Here's yet another sentence.                                                 
                                                                             
-----------------------------------------------------------------------------
._strlwr                                                                     
文字列の中の大文字を小文字に変換する                                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
char *_strlwr(char *strptr);                                                 
                                                                             
- 内容 -                                                                     
この関数は、strptrによって指された文字列の中に含まれる大文字を、対応する     
小文字に変換します。他の文字は変更されません。                               
                                                                             
- 戻り値 -                                                                   
引数、つまり、変換した文字列の先頭へのポインタを返します。                   
                                                                             
- 参照 -                                                                     
_strupr                                                                      
                                                                             
- 例 -                                                                       
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char a[97];                                                               
　 char *c;                                                                  
　 int j;                                                                    
                                                                             
　 for (j = 0; j < 64; j++)                                                  
　　　a[j] = j + 33;                                                         
　 a[64] = '\n';                                                             
　 for (j = 65; j < 95; j++)                                                 
　　　a[j] = j + 32;                                                         
　 a[96] = 0;                                                                
　 printf("The original string:\n\n%s\n\n",a);                               
　 c = _strlwr(a);                                                           
　 printf("  The _strlwr string:\n\n%s\n\n",a);                              
　 printf("  The result string:\n\n%s\n",c);                                 
}                                                                            
                                                                             
- 実行結果 -                                                                 
The original string:                                                         
                                                                             
!"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRST                         
UVWXYZ[\]^_'abcdefghijklmnopqrstuvwxyz{|}~                                   
                                                                             
　The _strlwr string:                                                        
                                                                             
!"#$%&'()*+,-./0123456789:;<=>?@abcdefghijklmnopqrst                         
uvwxyz[\]^_'abcdefghijklmnopqrstuvwxyz{|}~                                   
                                                                             
　The result string:                                                         
                                                                             
!"#$%&'()*+,-./0123456789:;<=>?@abcdefghijklmnopqrst                         
uvwxyz[\]^_'abcdefghijklmnopqrstuvwxyz{|}~                                   
                                                                             
-----------------------------------------------------------------------------
.strncat                                                                     
ある文字列を別の文字列に指定バイトだけ追加する                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
char *strncat(char *s1,                                                      
　　　　　　　const char *s2,                                                
　　　　　　　size_t n                                                       
　　　　　　 );                                                              
                                                                             
- 内容 -                                                                     
文字列s2から文字列s1にn文字まで追加します。文字列s2の最初の文字は、s1の終わり
のNULを上書きします。終わりのNULも追加します。よって、文字列s1は終わりのNUL以
降に、nバイト以上なければなりません。                                        
                                                                             
- 注意 -                                                                     
strncatは、s1のサイズに関係なく、n文字まで追加します。                       
                                                                             
- 戻り値 -                                                                   
strncat関数は、追加された文字列s1へのポインタを返します。                    
                                                                             
- 参照 -                                                                     
_strcat, _strcats, _strncat                                                  
                                                                             
これらの関数の短い記述については、strcatの参照の節を参照してください。       
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <string.h>                                                          
                                                                             
void main() {                                                                
　 char a[50] = "Testing for ";                                              
　 char b[30] = "strncat successfully faild";                                
　 char c[10] = ".";                                                         
　 char buf[50] = "Testing for strncat successful";                          
                                                                             
　 if (strcmp(buf, strncat(a, b, (size_t)18)) == 0)                          
　　　puts(a);                                                               
　 else                                                                      
　　　puts(strncat(a, b, (size_t)30));                                       
　 strncat(a, c, (size_t)30);                                                
　 puts(a);                                                                  
　 strncat(buf, a, 50 - strlen(buf));                                        
　 puts(buf);                                                                
}                                                                            
                                                                             
- 実行結果 -                                                                 
Testing for strncat successful                                               
Testing for strncat successful.                                              
Testing for strncat successfulTesting for strncat                            
                                                                             
-----------------------------------------------------------------------------
._strncat                                                                    
ある文字列を別の文字列に、全体が指定の長さになるまで追加する                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>                                                          
char *_strncat(char *s1,                                                     
　　　　　　　 const char *s2,                                               
　　　　　　　 size_t n                                                      
　　　　　　　);                                                             
                                                                             
- 内容 -                                                                     
文字列s2から文字列s1に文字を追加します。その結果の文字列s1は、合計n-1個のNUL 
でない文字を含みます。文字列s2の最初の文字は、文字列s1の終わりのNUL を上書き 
します。結果は常にNULで終わります。                                          
                                                                             
_strncatとstrncatの違いは、_strncatへの第3番目の引数は、結果のs1の最大長であ 
り、strncatの第3番目の引数は、s1に追加されるべき文字の最大数であることです。 
                                                                             
- 参照 -                                                                     
_strcats, strcat, strncat                                                    
                                                                             
これらの関数の短い記述については、strcatの参照の節を参照ください。           
                                                                             
- 例 -                                                                       
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char string1[50] =                                                        
　　　"This string contains forty charcters.  ";                             
　 char string2[50] =                                                        
　　　"Plus ten. This sentence will be ignored.";                            
　 _strncat(string1, string2, 50);                                           
　 puts(string1);                                                            
}                                                                            
                                                                             
- 実行結果 -                                                                 
This string contains forty characters. Plus ten.                             
                                                                             
-----------------------------------------------------------------------------
.strncmp                                                                     
指定バイトだけ文字列の比較を行う                                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
int strncmp(const char *s1,                                                  
　　　　　　const char *s2,                                                  
　　　　　　size_t n                                                         
　　　　　 );                                                                
                                                                             
- 内容 -                                                                     
文字列s1と文字列s2を比較します。n個以下の文字を比較します。文字列s1の最初のn 
文字(n個未満の文字を含むならば、全文字列)が文字列s2の対応する文字より大きいと
き、ゼロより大きい値を返します。2組の文字集合を比較して等しいとき、ゼロを返し
ます。最初の集合が2番目の集合より小さいとき、ゼロより小さい値を返します。長さ
が等しくない2つの文字列を比較して、短い文字列の内容まで等しく、短い文字列の長
さがn未満であるとき、長い文字列の方が辞書式に大きいとします。例えば、"abc"は 
"ab"より大です。                                                             
                                                                             
- 参照 -                                                                     
memcmp  　2つのメモリ領域を比較する。                                        
strcmp  　ある文字列と別の文字列を比較する。                                 
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <string.h>                                                          
                                                                             
void main() {                                                                
　 char str1[] = "String one.";                                              
　 char str2[] = "String two.";                                              
　 int  n = 2;                                                               
                                                                             
　 printf("First string is: %s\n"                                            
　　　　　"Second string is: %s\n", str1, str2);                             
　 while(!strncmp(str1, str2, n)) {                                          
　　　printf("The first %d characters are"                                   
　　　　　　 " the same.\n", n);                                             
　　　n++;                                                                   
　 }                                                                         
　 printf("The first %d charcters are"                                       
　　　　　" NOT the same.\n", n);                                            
}                                                                            
                                                                             
- 実行結果 -                                                                 
First string is : String one.                                                
Second string is : String two.                                               
The first 2 characters are the same.                                         
The first 3 characters are the same.                                         
The first 4 characters are the same.                                         
The first 5 characters are the same.                                         
The first 6 characters are the same.                                         
The first 7 characters are the same.                                         
The first 8 characters are NOT the same.                                     
                                                                             
-----------------------------------------------------------------------------
.strncpy                                                                     
文字列を別の文字列に、指定バイトだけ複写する                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
char *strncpy(char *s1, const char *s2, size_t n);                           
                                                                             
- 内容 -                                                                     
文字列s2から文字列s1に正確にn文字複写します。n文字が複写される前に、s2がNULで
終わるとき、文字列s1をNULで埋めます。s1にn文字が書き込まれる前に、NULに出会わ
なければ、結果の文字配列はNULで終わりません。s1を返します。                  
strncpyは、左から右(低アドレスから高アドレス)に複写します。s2 <s1<s2 + nのと 
き、つまり、複写元と複写先が重なっていて、複写先が複写元内からはじまるとき、 
_rstrncpyを使用してください。                                                
                                                                             
 - 注意 -                                                                    
strncpyはnバイト書き込みます。                                               
strncpyを呼び出した後、s1はNULで終わっていないことがあるので、文字列を期待す 
る関数にs1を渡すのは、安全ではありません。                                   
strncpyは、第2番目の引数を最初の引数に複写します。                           
                                                                             
- 参照 -                                                                     
memcpy, memset, _rmemcpy, rstrcpy, _rstrncpy, strcpy                         
                                                                             
これらの関数の短い記述については、memcpyの参照の節を参照ください。           
                                                                             
- 例 -                                                                       
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char string1[]=                                                           
　　　　"Original string.";                                                  
　 char string2[] =                                                          
　　　　"Modified will replace original.";                                   
                                                                             
　 puts(string1);                                                            
　 puts(string2);                                                            
　 strncpy(string1, string2, 8);                                             
　 puts(string1);                                                            
　 puts(string2);                                                            
}                                                                            
                                                                             
- 実行結果 -                                                                 
Original string.                                                             
Modified will replace original.                                              
Modified string.                                                             
Modified will replace original.                                              
                                                                             
-----------------------------------------------------------------------------
._strnicmp                                                                   
大文字小文字を区別しないで、2つの文字列を比較する                            
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
int _strnicmp(const char *s1,                                                
　　　　　　　const char *s2,                                                
　　　　　　　size_t kount                                                   
　　　　　　 );                                                              
                                                                             
- 内容 -                                                                     
_strnicmp関数は、2つの文字列s1, s2のkount文字を比較します。どちらかの文字列が
kount文字より短いとき、短い方の文字列長をkountの代わりに使用します。比較は、 
大文字と小文字を区別しないで行います。                                       
                                                                             
- 戻り値 -                                                                   
s1がs2より小さいならば、ゼロより小さい値を返します。s1がs2より大きいならば、 
ゼロより大きい値を返します。そうでなければ、s1とs2は等しく、ゼロを返します。 
                                                                             
- 参照 -                                                                     
_str*cmp*, strncmp                                                           
                                                                             
- 例 -                                                                       
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char a[] = "tHIS iS a tEST.";                                             
　 char b[] = "This Is ANothER Test.";                                       
　 size_t i = 1;                                                             
                                                                             
　 printf("     First string is: %s\n", a);                                  
　 printf("    Second string is: %s\n", b);                                  
　 printf("Equal characters are: ");                                         
　 while (_strnicmp(a, b, i) == 0)                                           
　　　printf("=", i++);                                                      
　 printf("^\nStrings are not equal at position %d", i);                     
}                                                                            
                                                                             
- 実行結果 -                                                                 
First string is: tHIS iS a tEST.                                             
　 　Second string is: This is ANothER Test.                                 
 Equal characters are: =========^                                            
 String are not equal at position 10                                         
                                                                             
-----------------------------------------------------------------------------
._strnset                                                                    
指定文字を文字列の一部または全部に書き込む                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
char *_strnset(char *strptr, int c, size_t kount);                           
                                                                             
- 内容 -                                                                     
_strnset関数は、strptrで指された文字列の中の最初のkount個の文字を、文字cで置 
き換えます。                                                                 
                                                                             
- 戻り値 -                                                                   
文字列の先頭へのポインタを返します。                                         
                                                                             
- 参照 -                                                                     
_strset, memset                                                              
                                                                             
- 例 -                                                                       
#include <strping.h>                                                         
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char a[] = "**failed** _strnset is working";                              
                                                                             
　 puts(a);                                                                  
　 _strnset(a, '+', 10);                                                     
　 puts(a);                                                                  
　 _strnset(a, '-', 55);                                                     
　 puts(a);                                                                  
　 _strnset(a, '&', 11);                                                     
　 puts(a);                                                                  
}                                                                            
                                                                             
- 実行結果 -                                                                 
**failed** _strnset is working                                               
++++++++++ _strnset is working                                               
------------------------------                                               
&&&&&&&&&&&-------------------                                               
                                                                             
-----------------------------------------------------------------------------
.strpbrk                                                                     
ある文字列中の任意の文字が、別の文字列中に最初に現われる位置を探す           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
char *strpbrk(const char *s1, const char *s2);                               
                                                                             
- 内容 -                                                                     
strpbrk関数は、文字列s2中の任意の文字が、文字列s1の中に最初に現われる位置を探
します。見つかったとき、その文字へのポインタを返します。見つからないとき、   
NULLを返します。                                                             
                                                                             
- 参照 -                                                                     
memchr, strchr, strcspn, strrchr, strspn                                     
                                                                             
これらの関数の短い記述については、memchrの参照の節を参照してください。       
                                                                             
- 例 -                                                                       
/*                                                                           
　この例は、strpbrk の使い方を示しています。                                 
*/                                                                           
#include <stdio.h>                                                           
#include <string.h>                                                          
                                                                             
void main() {                                                                
　 /*                                                                        
　　 tagsは、文字列中で検索したい文字を含みます。                            
　　 strは、その中を検索する文字列です。                                     
　　 ptrは、tagsの文字がstrに最初に現れる位置を指しています。                
　 */                                                                        
　 char tags[] = "N:";                                                       
　 char str[] = "Record # 7 Name: Bob.";                                     
　 char *ptr;                                                                
                                                                             
　 ptr = strpbrk(str, tags);                                                 
　 puts(ptr);                                                                
}                                                                            
                                                                             
- 実行結果 -                                                                 
Name: Bob.                                                                   
                                                                             
-----------------------------------------------------------------------------
.strrchr                                                                     
指定した文字が、文字列中に最後に現われる位置を探す                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
char *strrchr(const char *s, int c);                                         
                                                                             
- 内容 -                                                                     
sで指された文字列の中で文字c(int cの最下位バイト)が最後に現われる位置を探しま
す。見つかったとき、その文字へのポインタを返します。見つからないとき、NULLを 
返します。NULはcに対する正しい値であり、その結果は、文字列の終わりのポインタ 
(終わりのNULを指す)を返します。                                              
                                                                             
- 注意 -                                                                     
strrchrは、｢2.6　関数と引数｣で議論された慣習に適合するために、cをchar引数より
むしろintとして受け取ります。型charのオブジェクトがstrrchrに渡されたとき、自 
動的に型intに強制されます。                                                  
                                                                             
- 参照 -                                                                     
memchr, strchr, strcspn, strpbrk, strspn                                     
                                                                             
これらの関数の短い記述については、memchrの参照の節を参照してください。       
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <string.h>                                                          
                                                                             
void main() {                                                                
　 char *s = "This is a test for strrchr.";                                  
　 char *p = "                        ";                                     
　 int c = ' ';                                                              
                                                                             
　 p = strrchr(s, c);                                                        
　 puts(p);                                                                  
　 c = 's';                                                                  
　 c = strrchr(s, c);                                                        
　 puts(p);                                                                  
　 c = 'i';                                                                  
　 c = strrchr(s, c);                                                        
　 puts(p);                                                                  
　 c = 'r';                                                                  
　 c = strrchr(s, c);                                                        
　 puts(p);                                                                  
}                                                                            
                                                                             
- 実行結果 -                                                                 
strrchr.                                                                     
strrchr.                                                                     
is a test for strrchr.                                                       
r.                                                                           
                                                                             
-----------------------------------------------------------------------------
._strrev                                                                     
文字列を逆順に並べ換える                                                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
char *_strrev(char *strptr);                                                 
                                                                             
- 内容 -                                                                     
_strrev関数は、strptrで指された文字列を逆順に並べ換えます。最初の文字を最後の
文字と交換し、次の文字を最後から1つ前の文字と交換し、すべての文字が交換される
まで続けます。                                                               
                                                                             
- 戻り値 -                                                                   
この関数は、並べ換えられた文字列の先頭へのポインタを返します。               
                                                                             
- 参照 -                                                                     
strcpy, _strset, _swab                                                       
                                                                             
- 例 -                                                                       
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char a[]= "abcdefghijklmnopqrstuvwxyz";                                   
　 char b[]= "123456789";                                                    
                                                                             
　 puts("_strrev - string reversal");                                        
　 puts(a);                                                                  
　 puts(_strrev(a));                                                         
　 puts(b);                                                                  
　 puts(_strrev(b));                                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
_strrev - string reversal                                                    
abcdefghijklmnopqrstuvwxyz                                                   
zyxwvutsrqponmlkjihgfedcba                                                   
123456789                                                                    
987654321                                                                    
                                                                             
-----------------------------------------------------------------------------
._strset                                                                     
文字列中のすべての文字を、指定文字で置き換える                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
char *_strset(char *strptr, int c);                                          
                                                                             
- 内容 -                                                                     
_strset関数は、strptrで指された文字列の中のすべての文字を、文字cで置き換えま 
す。ただし、文字列の終わりのnull文字('\0')は除きます。                       
                                                                             
- 戻り値 -                                                                   
文字列の先頭へのポインタを返します。                                         
                                                                             
- 参照 -                                                                     
strnset                                                                      
                                                                             
- 例 -                                                                       
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char a[] = "_strset is working";                                          
　 char *b;                                                                  
                                                                             
　 puts(a);                                                                  
　 b = _strset(a, '-');                                                      
　 puts(b);                                                                  
　 b = _strset(a, '+');                                                      
　 puts(a);                                                                  
}                                                                            
                                                                             
- 実行結果 -                                                                 
_strset is working                                                           
------------------                                                           
++++++++++++++++++                                                           
                                                                             
-----------------------------------------------------------------------------
.strspn                                                                      
ある文字列の先頭部分(別の文字列の文字だけで構成された)の長さを決定する       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
size_t strspn(const char *s1, const char *s2);                               
                                                                             
- 内容 -                                                                     
文字列s1の中で、その文字列の先頭から始まり、文字列s2の中に現れる文字だけから 
成る部分の長さを返します。NULは、この目的に対してs2の部分ではありません。    
                                                                             
- 参照 -                                                                     
memchr, strchr, strcspn, strpbrk, strrchr                                    
                                                                             
これらの関数の短い記述については、memchrの参照の節を参照ください。           
                                                                             
-----------------------------------------------------------------------------
.strstr                                                                      
ある文字列が、別の文字列中に、最初に現れる位置を探す                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
char *strstr(const char *s1, const char *s2);                                
                                                                             
- 内容 -                                                                     
文字列s1の中で、文字列s2(終わりのNULは含まない)が最初に現われる位置を探しま  
す。見つかったとき、その文字へのポインタを返します。見つからないとき、NULLを 
返します。文字列s2の長さがゼロのとき、文字列s1を返します。                   
                                                                             
- 参照 -                                                                     
strchr                                                                       
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <string.h>                                                          
                                                                             
void main() {                                                                
　 char str[] = "When the going gets tough...";                              
　 char mark[] = "going";                                                    
　 char *ptr;                                                                
                                                                             
　 ptr = strstr(str, mark);                                                  
　 puts(ptr);                                                                
}                                                                            
                                                                             
- 実行結果 -                                                                 
going gets tough...                                                          
                                                                             
-----------------------------------------------------------------------------
._strtime                                                                    
時刻を文字列として返す                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <time.h>       /* 必須 */                                           
char *_strtime(char *sptr);                                                  
                                                                             
- 内容 -                                                                     
_strtime関数は、現在の時刻を得て、文字フォーマットに変換し、sptrで指された文 
字列に置きます。時刻のフォーマットはhh:mm:ssです。ただし、hhは時(24時形式)、 
mmは分、ssは秒です。時刻の各要素は2桁の数字であり、sptrが指す文字列は少なくと
も9バイト必要です。この関数は、時刻文字列の終わりにNUL文字を置きます。       
                                                                             
- 戻り値 -                                                                   
この関数は、文字列へのポインタを返します。                                   
                                                                             
- 参照 -                                                                     
asctime, ctime, gmtime, localtime, mktime, time, _tzset                      
                                                                             
- 例 -                                                                       
#include <time.h>                                                            
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char a[15];                                                               
                                                                             
　 _strtime(&a[0]);                                                          
　 puts("The time is --");                                                   
　 puts(a);                                                                  
}                                                                            
                                                                             
- 実行結果 - (変化する)                                                      
The time is --                                                               
17:04:10                                                                     
                                                                             
-----------------------------------------------------------------------------
.strtod                                                                      
文字列をdoubleに変換する                                                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h>     /* 必須 */                                           
double strtod(const char *nptr, char **endptr);                              
                                                                             
- 内容 -                                                                     
文字列nptrを浮動小数点数に変換し、その値を返します。nptrへのポインタは、変換 
を止めた場所を保持し、endptrによって参照されるポインタに置きます。           
strtodは、次の形式の文字列を認識します。                                     
                                                                             
　 Whitespace? Sign? Digits ('.' Digits)?                                    
　　　(('e' | 'E') Sign? Digits)?                                            
                                                                             
初めて上のシークエンスでない文字が現れたとき、変換を終了します。endptrがNULL 
でないとき、その文字へのポインタをendptrが指すオブジェクトに格納します。文字 
列が空のとき、またはシークエンス中にDigitsが見つからなかったとき、または、'e'
や'E'に続くDigitsだけが見つかったとき、strtodはゼロを返します。値が表現可能で
ないとき、結果は不定です。                                                   
                                                                             
- 参照 -                                                                     
atof  　  文字列を浮動小数点数に変換する。                                   
atoi  　  文字列をintに変換する。                                            
atol  　  文字列をlong intに変換する。                                       
strtol　  文字列をlong intに変換する。                                       
                                                                             
- 例 -                                                                       
/*                                                                           
 以下のプログラムは、半径が与えられた円の列の面積を計算します。              
 atofについての同様の例で、2つの関数の違いを示しています。                   
*/                                                                           
                                                                             
#include <stdio.h>                                                           
#include <stdlib.h>                                                          
#define INPUTS (5)                                                           
                                                                             
void main() {                                                                
　 char diameters[] = "1.03 67.94 9.2032e27 4 8e-32";                        
　 char *diameter = diameters;                                               
　 double pi = 3.141593;                                                     
　 double diam;                                                              
　 double area[INPUTS];                                                      
　 int i = 0;                                                                
                                                                             
　 /*文字列が終わるまで*/                                                    
　 while ( *diameter) {                                                      
　　　diam = strtod(diameter, &diameter);                                    
　　　area[i] = pi * diam * diam / 4.0;                                      
　　　printf("\ndiam=%-20.5g \tarea=%g",                                     
　　　　　　 diam, area[i++]);                                               
　 }                                                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
diam=1.03       area=0.833229                                                
diam=67.94      area=3625.28                                                 
diam=9.2032e+27 area=6.65224e+55                                             
diam=4          area=12.5664                                                 
diam=8e-32      area=5.02655e-63                                             
                                                                             
-----------------------------------------------------------------------------
.strtok                                                                      
文字列からトークンを切り出す                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
char *strtok(char *s1, const char *s2);                                      
                                                                             
- 内容 -                                                                     
文字列s1をトークンの列として扱います。トークンは、文字列s2に含まれない文字で 
構成され、s2に含まれた1個以上の文字によって区切られます。つまり、s2はトークン
の区切り文字を定義します。                                                   
                                                                             
strtokを最初に呼び出すと、最初のトークンを見つけ、s1中のトークンの終わりの位 
置にNULを書き込みます。そして、そのトークンの最初の文字へのポインタを返しま  
す。つまり、トークンを構成する部分文字列を作成して返します。                 
                                                                             
続いてstrtok(NULL, s2)を呼び出すと(第1番目の引数がヌルポインタであることに注 
意する)、同様の方法でNULで終わる次のトークンの最初の文字へのポインタを返しま 
す。                                                                         
                                                                             
トークンの区切り文字列s2は、呼び出し毎に変えることができます。               
strtokを呼び出してトークンが見つからないとき、NULLを返します。               
                                                                             
- 注意 -                                                                     
strtokは、s1上に書き込みます。                                               
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <string.h>                                                          
                                                                             
void main() {                                                                
　 char sentence[] = "Here's a sentence; it's complete,\                     
　　　　　　　　　　　whole. Parse this!\n";                                 
　 char limits[] = ".,?;:\"!";                                               
　 char *tmp;                                                                
                                                                             
　 if ((tmp = strtok(sentence, limits)) == NULL)                             
　　　return;                                                                
　 do {                                                                      
　　　printf("%s ", tmp);                                                    
　 } while ((tmp = strtok(NULL, limits)) != NULL);                           
}                                                                            
                                                                             
- 実行結果 -                                                                 
Here's a sentence it's complete whole Parse this                             
                                                                             
-----------------------------------------------------------------------------
.strtol                                                                      
文字列をlongに変換する                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h>     /* 必須 */                                           
long strtol(const char *nptr,                                                
　　　　　　char **endptr,                                                   
　　　　　　int base                                                         
　　　　　　);                                                               
                                                                             
- 内容 -                                                                     
文字列nptrの先頭部分をlong intに変換し、その値を返します。endptrがNULLでない 
とき、変換を止めた位置を指すnptr中へのポインタを、endptrで参照されたポインタ 
中に置きます。strtol関数は、次の形式の文字列を認識します。                   
                                                                             
　 Whitespace? Sign? ('0' ('x' | 'X'))? Digits                               
                                                                             
baseが16または0のときだけ、文字列に0x、0Xを指定できます。上のシークエンスでな
い文字が最初に現れると、変換を終了します。endptrがNULLでないとき、endptrが示 
すオブジェクトにその文字へのポインタを保存します。文字列が空、またはシークエ 
ンス中にDigitsが見つからなかったとき、strtolはゼロを返します。さらに、endptr 
がNULLでないとき、nptrをendptrによって指されるオブジェクトに格納します。値が 
表現可能でないとき、結果は不定です。                                         
                                                                             
baseが2から36のとき、変換の基数として使われます。baseが16のとき、0xまたは0Xを
数字列の前に指定できます。基数が0のとき、nptr自身が変換で使用する3つの基数を 
選択します。符号(もしあれば)に続いて、0xまたは0Xから始まると、基数16が使われ 
ます。Oから始まると、基数8が使われます。そうでなければ、基数10が使われます。 
base > 10のとき、論理的な限界までの英文字をDigits(16進数と同じように)として使
えます。例えば、基数17では、Gまたはgは16を表します。                         
                                                                             
数がlong intで表現できないほど大きいとき、errnoにERANGEを設定し、入力された符
号に依存して、LONG_MAXまたはLONG_MINを返します。                             
                                                                             
- 参照 -                                                                     
atoi    　文字列をintに変換する。                                            
atol    　文字列をlong intに変換する。                                       
atof    　文字列を浮動小数点数に変換する。                                   
strtod  　文字列をdoubleに変換する。                                         
strtoul 　文字列をunsigned longに変換する。                                  
                                                                             
- 例 -                                                                       
/*                                                                           
 以下のプログラムは、1週間と1日と1時間と1分と1秒の合計の秒数を計算します。   
 */                                                                          
                                                                             
#include <stdlib.h>                                                          
#include <stdio.h>                                                           
#define WEEK    "604800"                                                     
#define DAY     "86400"                                                      
#define HOUR    "07020"         /* 8進数  */                                 
#define MINUTE  "0x3c"          /* 16進数 */                                 
#define SECOND  "1"                                                          
                                                                             
void main() {                                                                
　 char *list[] = { WEEK, DAY, HOUR, MINUTE, SECOND, 0};                     
　 char *stopstring;                                                         
　 unsigned long seconds = 0;                                                
　 int i = 0;                                                                
                                                                             
　 while (list[i] && *list[i]) {                                             
　　　seconds += strtol(list[i], &stopstring, 0);                            
　　　i++;                                                                   
　 }                                                                         
　 printf("Total number of seconds in a week, day, hour"                     
　　　　　", minute,\nand second = %ld.\n", seconds);                        
}                                                                            
                                                                             
- 実行結果 -                                                                 
Total number of seconds in a week, day, hour, minute,                        
and second = 694861.                                                         
                                                                             
-----------------------------------------------------------------------------
.strtoul                                                                     
文字列をunsigned longに変換する                                              
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h>     /* 必須 */                                           
unsigned long strtoul(const char *nptr,                                      
　　　　　　　　　　　char **endptr,                                         
　　　　　　　　　　　int base                                               
　　　　　　　　　　　);                                                     
                                                                             
- 内容 -                                                                     
文字列nptrの先頭部分をunsigned long intに変換し、その値を返します。          
endptrがNULLでないとき、変換を止めた位置を指すnptr中へのポインタを、endptrで 
参照されたポインタ中に置きます。strtoul関数は、次の形式の文字列を認識します。
                                                                             
                                                                             
　 Whitespace? ('0' ('x' | 'X'))? Digits                                     
                                                                             
baseが16または0のときだけ、文字列に0x、0Xを指定できます。上のシークエンスでな
い文字が最初に現れると、変換を終了します。endptrがNULLでないとき、endptrが示 
すオブジェクトにその文字へのポインタを保存します。文字列が空、またはシークエ 
ンス中にDigitsが見つからなかったとき、strtoulはゼロを返します。さらに、endptr
がNULLでないとき、nptrをendptrによって指されるオブジェクトに格納します。値が 
表現可能でないとき、結果は不定です。                                         
                                                                             
baseが2から36のとき、変換の基数として使われます。baseが16のとき、0xまたは0Xを
数字列の前に指定できます。基数が0のとき、nptr自身が変換で使用する3つの基数を 
選択します。0xまたは0Xから始まると、基数16が使われます。Oから始まると、基数8 
が使われます。そうでなければ、基数10が使われます。base > 10のとき、論理的な限
界までの英文字をDigits(16進数と同じように) として使えます。例えば、基数17で  
は、Gまたはgは16を表します。                                                 
                                                                             
数がunsigned long intで表現できないほど大きいとき、errnoにERANGEを設定し、   
ULONG_MAXを返します。                                                        
                                                                             
- 参照 -                                                                     
strtol  文字列をlongに変換する。                                             
                                                                             
-----------------------------------------------------------------------------
._strupr                                                                     
文字列の中の小文字を大文字に変換する                                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
char *_strupr(char *strptr);                                                 
                                                                             
- 内容 -                                                                     
この関数は、strptrで指された文字列の中に含まれるすべての小文字を、大文字に変 
換します。他の文字は、変換しません。                                         
                                                                             
- 戻り値 -                                                                   
この関数は、その引数、つまり変換された文字列の先頭へのポインタを返します。   
                                                                             
- 参照 -                                                                     
strlwr                                                                       
                                                                             
- 例 -                                                                       
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char a[97];                                                               
　 char *c;                                                                  
　 int j;                                                                    
                                                                             
　 for (j = 0; j < 64; j++)                                                  
　　　a[j] = j + 33;                                                         
　 a[64] = '\n';                                                             
　 for (j = 65; j < 95; j++)                                                 
　　　a[j] = j + 32;                                                         
　 a[96] = 0;                                                                
　 printf("The original string:\n\n%s\n\n",a);                               
　 c = _strupr(a);                                                           
　 printf("  The _strupr string:\n\n%s\n\n",a);                              
　 printf("  The result string:\n\n%s\n",c);                                 
}                                                                            
                                                                             
- 実行結果 -                                                                 
The original string:                                                         
                                                                             
!"#$&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRST                          
UVWXYZ[\]^_'abcdefghijklmnopqrstuvwxyz{|}~                                   
                                                                             
　The _strupr string:                                                        
                                                                             
!"#$&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRST                          
UVWXYZ[\]^_'ABCDEFGHIJKLMNOPQRSTUVWXYZ{|}~                                   
                                                                             
　The result string:                                                         
                                                                             
!"#$&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRST                          
UVWXYZ[\]^_'ABCDEFGHIJKLMNOPQRSTUVWXYZ{|}~                                   
                                                                             
-----------------------------------------------------------------------------
.strxfrm                                                                     
文字列を地域に依存しない形式に変換する                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
size_t strxfrm(char *s1,                                                     
　　　　　　　　const char *s2,                                              
　　　　　　　　size_t n                                                     
　　　　　　　　);                                                           
                                                                             
- 内容 -                                                                     
変換後の2つの文字列に対してstrcmpを呼び出したとき、その結果が変換前の2つの文 
字列に対してstrcollを呼び出したときと同じ結果になるように、文字列s2を文字列s1
に変換します。変換結果Rの長さLを返します。つまり、L = strlen(R)です。n > Lの 
とき、変換結果は、s1に置かれます。n ≦ Lのとき、s1の内容は不確定です。s1とs2 
が重なっているとき、strxfrmの動作は不定です。                                
                                                                             
- 注意 -                                                                     
strxfrmは、第2番目の引数を第1番目の引数に変換します。                        
                                                                             
- 参照 -                                                                     
strcoll 　現在の地域性に基づいて、文字列を比較する。                         
strcmp  　ある文字列ともう1つの文字列を比較する。                            
                                                                             
-----------------------------------------------------------------------------
._swab                                                                       
ワード中のバイトを入れ換える                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h>     /* 必須 */                                           
void _swab(char *from_ptr,                                                   
　　       char *to_ptr,                                                     
　　       int kount                                                         
　　      );                                                                 
                                                                             
- 内容 -                                                                     
この関数は、文字列from_ptrから文字列to_ptrにkountバイトを複写します。        
バイトの各組が複写されるとき、その順序を逆転します。つまり、from_ptr[0]を    
to_ptr[1]に、from_ptr[1]をto_ptr[0]に複写し、同様にデータ領域中のバイトの偶数
と奇数の各組を逆転します。この関数は、バイトまたはワードの順序の異なるマシン 
間で、しばしば適用されます。                                                 
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <stdlib.h>                                                          
                                                                             
void main() {                                                                
　 char a[] = "abcdefghijkl";                                                
　 char b[13];                                                               
                                                                             
　 char b[12] = 0;                                                           
　 _swab(a, b, 12);                                                          
　 puts("_swab _swap bytes");                                                
　 puts(a);                                                                  
　 puts(b);                                                                  
}                                                                            
                                                                             
- 実行結果 -                                                                 
_swab _swap bytes                                                            
abcdefghijkl                                                                 
badcfehgjilk                                                                 
                                                                             
-----------------------------------------------------------------------------
.system                                                                      
DOSのコマンドを実行する                                                      
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h>                                                          
int system(const char *string);                                              
                                                                             
- 内容 -                                                                     
文字列stringをホスト環境のコマンドプロセッサに渡し、コマンドとして実行しま   
す。                                                                         
                                                                             
- 注意 -                                                                     
実行中のプロセスからプロセスを実行するには、実行形式を動作させるために、十分 
なリアルメモリ(640KB以下のメモリ)が必要です。リアルメモリが十分にないとき、そ
の結果は不定です。                                                           
リアルメモリは、Phar LapのDOS-Extenderの変数-MAXREALとMINREALを使うことによっ
て、制御することができます。                                                 
                                                                             
- 参照 -                                                                     
exec*   　子プロセスを起動する。                                             
spawn*  　子プロセスを起動する。                                             
                                                                             
- 例 -                                                                       
#include <stdlib.h>                                                          
                                                                             
void main() {                                                                
　 char c[129];                                                              
                                                                             
　 printf("system may hang your machine if"                                  
　　　　　" this program was no run with"                                    
　　　　　" -maxreal ffffh\n\n");                                            
　 printf("Enter command lien for system: ");                                
　 gets(c);                                                                  
　 if (c[0]) system(c);                                                      
}                                                                            
                                                                             
- 呼び出し法 -                                                               
run386 -maxreal ffffh system                                                 
                                                                             
- 実行結果 - (ファイルtest.datに依存する)                                    
System may hang your machine if this program was not run                     
with -maxreal ffffh                                                          
                                                                             
Enter command line for system: cat test.dat                                  
testing 1 abcd                                                               
testing=2 efgh                                                               
testing=3 ijkl                                                               
testing=4 mnop                                                               
testing=5 qrst                                                               
testing=6 uvwx                                                               
testing=7 yzAB                                                               
testing=8 CDEF                                                               
                                                                             
-----------------------------------------------------------------------------
.tan                                                                         
タンジェント(正接)の値を求める                                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <math.h>       /* 必須 */                                           
double tan(double x);                                                        
                                                                             
- 内容 -                                                                     
xのタンジェント(正接)を返します。xはラジアンで指定します。引数が大きすぎると 
き、その結果の有効数字が少ないまたは無いことがあります。                     
                                                                             
- 参照 -                                                                     
atan    ある角のアークタンジェントを求める。                                 
atan2   ある点で定義された角のアークタンジェントを求める。                   
                                                                             
-----------------------------------------------------------------------------
.tanh                                                                        
ハイパボリックタンジェント(双曲線正接)の値を求める                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <math.h>       /* 必須 */                                           
double tanh(double x);                                                       
                                                                             
- 内容 -                                                                     
xのハイパボリックタンジェント(双曲線正接)、つまり、sinh(x)/cosh(x)を返しま   
す。引数xが大きすぎて、sinh(x)やcosh(x)が表現できないとき、errnoにERAGEを設定
し、大きさがHUGE_VALであり、xと同じ符号を持つ値を返します。                  
                                                                             
- 参照 -                                                                     
cosh    ハイパボリックコサイン(双曲線余弦)を求める。                         
sinh    ハイパボリックサイン(双曲線正弦)を求める。                           
                                                                             
-----------------------------------------------------------------------------
._tell                                                                       
現在のファイル位置を報告する                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <io.h>         /* 必須 */                                           
long _tell(int file _handle);                                                
                                                                             
- 内容 -                                                                     
_tell関数は、現在のファイルポインタの位置を報告します。現在のファイルポインタ
の位置は、次のバイトをそこから読み込む、または、そこに書き込む場所です。     
                                                                             
- 戻り値 -                                                                   
無効なファイルハンドルのとき、errnoにEBADFを設定し、値-1を返します。そうでな 
いとき、ファイルハンドルがキャラクタデバイスを参照しない限り、ファイルの先頭 
からのバイト数を返します。ファイルハンドルがキャラクタデバイスを参照すると   
き、ファイル位置と戻り値は不定です。                                         
                                                                             
- 参照 -                                                                     
ftell, _lseek                                                                
                                                                             
- 例 -                                                                       
#include <io.h>                                                              
#include <fcntl.h>                                                           
#include <sys\stat.h>                                                        
#include <stdio.h>                                                           
#include <conio.h>                                                           
                                                                             
void main() {                                                                
　 int pan;                                                                  
　 char c;                                                                   
                                                                             
　 pan = _open("test.dat", O_RDONLY | O_BINARY);                             
　 if (pan != -1) {                                                          
　　　printf("File test.dat exists, handle = %d.\n", pan);                   
　　　while (_read(pan, &c, 1) > 0)                                          
　　　　 if (c == '=')                                                       
　　　　　　printf("Equal sign found at %ld.\n", _tell(pan));                
　　　_close(pan);                                                           
　 }                                                                         
　 else                                                                      
　　　printf("File test.dat cannot be opened,"                               
　　　　　　 " error code = %d.\n", pan);                                    
}                                                                            
                                                                             
出力結果(test.datの内容に依存する)                                           
File test.dat exists, handle = 5.                                            
Equal sign found at 24.                                                      
Equal sign found at 40.                                                      
Equal sign found at 56.                                                      
Equal sign found at 72.                                                      
Equal sign found at 88.                                                      
Equal sign found at 104.                                                     
Equal sign found at 120.                                                     
                                                                             
-----------------------------------------------------------------------------
.__TIME__                                                                    
ソースファイルのコンパイル時刻を生成するマクロ                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
/*                                                                           
 この内部マクロは、引数を必要としない。                                      
*/                                                                           
                                                                             
- 内容 -                                                                     
__TIME__  は、ソースファイルのコンパイル時刻を、(asctime関数で生成された時刻 
と同様に)hh:mm:ss形式の文字列として生成します。このマクロの値は、1つのコンパ 
イル単位を通して、不変です。                                                 
                                                                             
-----------------------------------------------------------------------------
.time                                                                        
システムの時刻を調べる                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <time.h>       /* 必須 */                                           
time_t time(time_t *timer);                                                  
                                                                             
- 内容 -                                                                     
システムの最良の知識と近似による現在の時刻と日付を返します。その形式は、     
time.hで提供された他の関数によって理解されます。timerがNULLでないとき、戻り値
はtimerが指すオブジェクトにも格納されます。                                  
                                                                             
time_tは時刻と日付を表す算術演算形式です。time.hに定義しています。           
                                                                             
- 参照 -                                                                     
clock           　　プロセッサの経過時間を見つける。                         
CLOCK_PER_SEC     　1秒当たりのクロック数。                                  
clock_t             時刻を表現するために使われる型。                         
time_t         　　 日付と時刻を表現するために使われる型。                   
                                                                             
- 例 -                                                                       
asctimeで提供されている例を参照してください。                                
                                                                             
-----------------------------------------------------------------------------
.time_t                                                                      
時刻と日付を表現する型                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <time.h>       /* 必須 */                                           
                                                                             
- 内容 -                                                                     
時刻と日付を表現する算術型です。                                             
                                                                             
- 参照 -                                                                     
time    時刻と日付を求める。                                                 
                                                                             
-----------------------------------------------------------------------------
.tm                                                                          
日付と時刻の構成要素を表現するために使われる型                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <time.h>       /* 必須 */                                           
                                                                             
- 内容 -                                                                     
時刻と日付のそれぞれの要素を持つstruct型です。                               
int tm_sec;    /* 秒(0-59)               */                                  
int tm_min;    /* 分(0-59)               */                                  
int tm_hour;   /* 時(0-23)　　           */                                  
int tm_mday;   /* 日(1-31)               */                                  
int tm_mon;    /* 1月からの月(0-11)      */                                  
int tm_year;   /* 1900からの年           */                                  
int tm_wday;   /* 日曜からの曜日(0-6)    */                                  
int tm_yday;   /* 1月1日からの日数(0-365)*/                                  
int tm_isdst;  /* 夏時間フラグ(-1,0,+1)  */                                  
                                                                             
tm_isdstの値は、夏時間を実施しているとき正、実施していないときゼロです。     
また、この情報が使用できないとき、負です。                                   
                                                                             
-----------------------------------------------------------------------------
.tmpfile                                                                     
テンポラリファイルをオープンする                                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>      /* 必須 */                                           
FILE *tmpfile(void);                                                         
                                                                             
- 内容 -                                                                     
ファイルを作成し、それを制御するFILE変数へのポインタを返します。ファイルは、 
バイナリファイルとして、更新モードでオープンします。ファイルは、クローズした 
とき、またはプログラムが終了したとき、自動的に削除されます。ファイルを作成で 
きないとき、NULLを返します。                                                 
                                                                             
- 注意 -                                                                     
プログラムが異常終了したとき、ファイルが削除されないことがあります。         
                                                                             
- 参照 -                                                                     
tmpnam  テンポラリファイルの名前を生成する。                                 
                                                                             
-----------------------------------------------------------------------------
.tmpnam                                                                      
テンポラリファイルの名前を生成する                                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>      /* 必須 */                                           
char *tmpnam(char *s);                                                       
                                                                             
- 内容 -                                                                     
テンポラリファイルの名前を生成します。tmpnamはそれが呼び出される毎に(TMP_MAX 
回まで)、異なるファイル名を生成します。人が付けたファイル名を破壊する名前が与
えられたときを除いて、テンポラリファイルは存在しません。それらは、標準ライブ 
ラリの呼び出しによって、まだオープンしたり、フラッシュしたり、削除したり、等 
々しなければなりません。                                                     
sがNULLでなければ、tmpnamはsに書き込み、文字列sを返します。sがNULLなら、内部 
のstatic文字列内にファイル名を書き込み、それを返します。続いてtmpnamを呼び出 
すと、その文字列に上書きします。                                             
                                                                             
整数定数TMP_MAXは、tmpnamが重複しないように生成できるファイル名の個数を示しま
す。TMP_MAXは、stdio.hで定義されています。                                   
                                                                             
- 注意 -                                                                     
sがNULLでないときは、tmpnamはsが何を指していても、L_tmpnamで示すバイト数までs
に書き出します。                                                             
                                                                             
- 参照 -                                                                     
rename  　ファイル名を変更する。                                             
tmpfile 　テンポラリファイルを生成し、オープンする。                         
                                                                             
-----------------------------------------------------------------------------
.tolower                                                                     
大文字を小文字に変換する                                                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <ctype.h>                                                           
int tolower(int c);                                                          
                                                                             
- 内容 -                                                                     
大文字を小文字に変換します。cが大文字ならば、tolowerはその文字に対応する小文 
字を返します。そうでなければ、cを返します。                                  
                                                                             
- 参照 -                                                                     
toupper,_tolower,_toupper                                                    
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <ctype.h>                                                           
                                                                             
void main() {                                                                
　 char s[45] = "teSTIng ToloWer (#1 @2 !3 &4 {}[]).";                       
　 int i = 0;                                                                
                                                                             
　 printf("Original string: %s\n"                                            
　　　　　"        Becomes: ",s);                                            
　 while (s[i] != '\0') {                                                    
　　　printf("%c", tolower(s[i]));                                           
　　　i++;                                                                   
　 }                                                                         
　 printf("\n");                                                             
}                                                                            
                                                                             
- 実行結果 -                                                                 
Original string: teSTInG ToloWer (#1 @2 !3 &4 {}[]).                         
　　　　Becomes: testing tolower (#1 @2 !3 &4 {}[]).                         
                                                                             
-----------------------------------------------------------------------------
._tolower                                                                    
大文字かどうか調べずに、小文字に変換する。                                   
マクロおよび関数として提供されている                                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <ctype.h>      /* マクロのために必須 */                             
int _tolower(int c);                                                         
                                                                             
- 内容 -                                                                     
_tolower(c)は、tolowerを作りかえたものであり、cが大文字であることが判明してい
るときに、使用することができます。                                           
                                                                             
- 注意 -                                                                     
常に、引数cをisupper()で調べてください。                                     
                                                                             
- 参照 -                                                                     
tolower,toupper,_toupper                                                     
                                                                             
- 例 -                                                                       
/*                                                                           
 このプログラムは、_tolower関数の使い方を示してします。                      
 文字について、isupper()で検査することに注意してください。                   
 _tolowerを使用するときは、この検査をしなければなりません。                  
*/                                                                           
                                                                             
#include <stdio.h>                                                           
#include <ctype.h>                                                           
                                                                             
void main() {                                                                
　 char s[45] =                                                              
　 "teSTInG _ToloWer  (#1 @2 !3 &4 {}[]).";                                  
　 int i = 0;                                                                
                                                                             
　 printf("Original string: %s\n"                                            
　　　　　"        Becomes: ",s);                                            
　 while (s[i] != '\0') {                                                    
　　　if (isupper(s[i]))                                                     
　　　　 s[i] = _tolower(s[i]);                                              
　　　i++;                                                                   
　 }                                                                         
　 printf("%s\n",s);                                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
Original string: teSTInG _ToloWer  (#1 @2 !3 &4  {}[]).                      
        Becomes: testing _tolower  (#1 @2 !3 &4  {}[]).                      
                                                                             
-----------------------------------------------------------------------------
.toupper                                                                     
小文字を大文字に変換する                                                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <ctype.h>                                                           
int toupper(int c);                                                          
                                                                             
- 内容 -                                                                     
小文字を大文字に変換します。cが小文字ならば、toupperはその文字に対応する大文 
字を返します。そうでなければ、cを返します。                                  
                                                                             
- 参照 -                                                                     
tolower,_tolower,_toupper                                                    
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <ctype.h>                                                           
                                                                             
void main() {                                                                
　 char s[45] = "teSTInG TouPPEr  (#1 @2 !3 &4 {}[]).";                      
　 int i = 0;                                                                
                                                                             
　 printf("Original string: %s\n"                                            
　　　　　"        Becomes: ",s);                                            
　 while (s[i] != '\0') {                                                    
　　　printf("%c", toupper(s[i]));                                           
　　　i++;                                                                   
　 }                                                                         
　 printf("\n");                                                             
}                                                                            
                                                                             
- 実行結果 -                                                                 
Original string: teSTInG TouPPEr  (#1 @2 !3 &4 {}[]).                        
        Becomes: TESTING TOUPPER  (#1 @2 !3 &4 {}[]).                        
                                                                             
-----------------------------------------------------------------------------
._toupper                                                                    
小文字かどうか調べずに、大文字に変換する。                                   
マクロおよび関数として提供されている。                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <ctype.h>      /* マクロのために必須 */                             
int _toupper(int c);                                                         
                                                                             
- 内容 -                                                                     
_toupper(c)は、toupperを作りかえたものであり、cが小文字であることが判明してい
るときに、使用することができます。                                           
                                                                             
- 注意 -                                                                     
常に、引数cをislower()で調べてください。                                     
                                                                             
- 参照 -                                                                     
tolower, _tolower, toupper                                                   
                                                                             
- 例 -                                                                       
/*                                                                           
 このプログラムは、_toupper関数の使い方を示してします。                      
 文字に対して、islower()で検査することに注意してください。                   
 _toupperを使用するときは、この検査をしなければなりません。                  
*/                                                                           
#include <stdio.h>                                                           
#include <ctype.h>                                                           
void main() {                                                                
　 char s[45] =                                                              
　 "teSTInG _TouPPEr  (#1 @2 !3 &4 {}[]).";                                  
　 int i = 0;                                                                
                                                                             
　 printf("Original string: %s\n"                                            
　　　　　"        Becomes: ",s);                                            
　 while (s[i] != '\0') {                                                    
　　　if (islower(s[i]))                                                     
　　　　 s[i] = _toupper(s[i]);                                              
　　　i++;                                                                   
　 }                                                                         
　 printf("%s\n",s);                                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
Original string: teSTInG _TouPPEr (#1 @2 !3 &4{}[]).                         
        Becomes: TESTING _TOUPPER (#1 @2 !3 &4{}[]).                         
                                                                             
-----------------------------------------------------------------------------
._tzset                                                                      
地方時間帯に関する情報をセットする                                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <time.h>                                                            
void _tzset(void);                                                           
                                                                             
- 内容 -                                                                     
_tzset関数は、DOSのTZ環境変数設定を使って、地方時間帯を決定します。TZ=は     
MS-DOSのコマンドからset tz=PST8PDTの形式で設定します。"PST"は、地方時間帯の名
前を意味する3文字の定数です。"8"は、協定世界時(UTC)からの偏差の時間を表しま  
す。"PDT"は夏時間を実施しているときの地方時間帯の名前を表します。            
そして夏時間が現在時間に反映されているかも示します。"PDT"は、夏時間を実施して
いないとき、省略します。                                                     
                                                                             
"PST"と"PDT"フィールドは、グローバル変数char *_tz-name[2]に("PST"は_tzname[0]
に、"PDT"は_tzname[1]に)にそれぞれ格納されます。UTCからの偏差の時間を秒に変換
して、グローバル変数timezoneに設定します。グローバル変数_daylightは、"PDT"が 
存在するとき1を、そうでなければゼロを設定します。tzに対するデフォルト値は、  
tz=PST8PDTです。                                                             
                                                                             
- 参照 -                                                                     
asctime, ftime, gmtime, localtime, time                                      
                                                                             
- 例 -                                                                       
#include <time.h>                                                            
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 printf("Before _tzset ---\n"                                              
　　　　　"tzname0:%s\n"                                                     
　　　　　"tzname1:%s\n"                                                     
　　　　　"timezone:%ld\n"                                                   
　　　　　"daylight:%d\n",                                                   
　　　　　_tzname[0],_tzname[1],_timezone,_daylight);                        
　 _tzset();                                                                 
　 printf("After _tzset ---\n"                                               
　　　　　"tzname0:%s\n"                                                     
　　　　　"tzname1:%s\n"                                                     
　　　　　"timezone:%ld\n"                                                   
　　　　　"daylight:%d\n",                                                   
　　　　　_tzname[0],_tzname[1],_timezone,_daylight);                        
}                                                                            
                                                                             
- 実行結果 -                                                                 
Before _tzset ---                                                            
tzname0:PST                                                                  
tzname1:PDT                                                                  
timezone:28800                                                               
daylight:-1                                                                  
After _tzset ---                                                             
tzname0:PST                                                                  
tzname1:PDT                                                                  
timezone:28800                                                               
daylight:1                                                                   
                                                                             
-----------------------------------------------------------------------------
._ultoa                                                                      
unsigned longをASCII文字列に変換する                                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h>     /* 必須 */                                           
char *_ultoa(unsigned long value,                                            
　　　　　　　char *target,                                                  
　　　　　　　int radix                                                      
　　　　　　 );                                                              
                                                                             
- 内容 -                                                                     
_ultoa関数は、任意のlong整数をASCII文字列targetに変換します。変換は、radixで 
指定された数システムに従って、実行します。基数radixは、2から36までの任意の数 
をとることができます。radixが2のとき、targetの最大長は終わりのヌルバイトを含 
んで33バイトです。radixが10のとき、targetの最大長は10桁の数字と最後のヌルバイ
トから成る11バイトです。                                                     
                                                                             
- 戻り値 -                                                                   
この関数は、変換後の文字列の先頭へのポインタを返します。                     
                                                                             
- 参照 -                                                                     
itoa,ltoa,sprintf                                                            
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <string.h>                                                          
#include <stdlib.h>                                                          
                                                                             
void main() {                                                                
　 char s[55], t[55];                                                        
　 unsigned long int j;                                                      
                                                                             
　 for (j = 1; j != 0; ) {                                                   
　　　puts("Enter a number, (zero to quit)");                                
　　　gets(s);                                                               
　　　j = atol((char *)&s);                                                  
　　　printf("The number you entered is: %ld.\n"                             
　　　　　　 "And in base 10, 10, 2, 16 and 36"                              
　　　　　　 " it is\n", j);                                                 
                                                                             
　　　puts(_ultoa(j, t, 10));                                                
　　　puts(t);                                                               
　　　puts(_ultoa(j, t, 2));                                                 
　　　puts(_ultoa(j, t, 16));                                                
　　　puts(_ultoa(j, t, 36));                                                
　 }                                                                         
}                                                                            
                                                                             
- 実行結果 - (変化する)                                                      
Enter a number, (zero to quit)                                               
The number you entered is: 18.                                               
And in base 10, 10, 2, 16 and 36 it is                                       
18                                                                           
18                                                                           
10010                                                                        
12                                                                           
I                                                                            
Enter a number, (zero to quit)                                               
The number you entered is: 0.                                                
And in base 10, 10, 2, 16 and 36 it is                                       
0                                                                            
0                                                                            
0                                                                            
0                                                                            
0                                                                            
                                                                             
-----------------------------------------------------------------------------
._umask                                                                      
ファイルのマスクを設定する                                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <sys/types.h>                                                       
#include <sys/stat.h>                                                        
#include <io.h>                                                              
int _umask(int permits);                                                     
                                                                             
- 内容 -                                                                     
_umask関数は、ファイルのアクセス許可マスクをpermitsで指定された値で設定しま  
す。このマスクは、open関数、creat関数、sopen関数で使われます。マスク中でセッ 
トされた任意のビットは、対応するアクセス権を禁止します。実際のファイルのアク 
セス権は、ファイルが初めてクローズされるまで、設定されません。マスク中で許さ 
れる値は、S_IWRITEとS_IREADの2つであり、stat.hで定義されています。これらの定 
数は、OR演算子で結合することもできます。DOS下では、読み出し禁止にできないた  
め、S_IREADは無効です。S_IWRITEを_umask関数で設定すると、creat関数、open関   
数、sopen関数を使用して作成したファイルは、クローズ後に、書き込みアクセスでき
なくなります。                                                               
                                                                             
- 戻り値 -                                                                   
ファイルアクセス許可マスクの以前の値を返します。                             
                                                                             
- 参照 -                                                                     
chmod, creat, mkdir, open, _sopen, close                                     
                                                                             
- 例 -                                                                       
#include <types.h>                                                           
#include <stat.h>                                                            
#include <io.h>                                                              
#include <fcntl.h>                                                           
#include <stdio.h>                                                           
#include <stdlib.h>                                                          
#include <sys\types.h>                                                       
#include <sys\stat.h>                                                        
                                                                             
void main() {                                                                
　 int oldmask, pan;                                                         
　 oldmask = _umask(S_IWRITE);                                               
　 pan = open("umasktst.tmp", O_CREAT | O_TRUNC |                            
　　　　　　　　　　 O_RDWR,S_IREAD | S_IWRITE);                             
　 _umask(oldmask);                                                          
　 if (pan < 0)                                                              
　　　printf("Failed to create umasktst.tmp, "                               
　　　　　　 "Error code is: %d\n", pan);                                    
　 else {                                                                    
　　　int ok = write(pan, "this is a test", 15);                             
　　　if (ok == -1)                                                          
　　　　 printf("wite failed\n");                                            
　　　else {                                                                 
　　　　 close(pan);                                                         
　　　　 pan = open("umasktst.tmp", O_RDWR);                                 
　　　　 if (pan < 0)                                                        
　　　　　　printf("Correctly failed to re-open "                            
　　　　　　　　　 "umasktst.tmp\n"                                          
　　　　　　　　　 "Error code is: %d\n"                                     
　　　　　　　　　 "error code is: %d\n", pan, errono);                      
　　　　 else {                                                              
　　　　　　ok = write(pan, "Yet another test", 16);                         
　　　　　　if (ok == -1)                                                    
　　　　　　　 printf("Cannot write to file, "                               
　　　　　　　　　　　"test is ok!!!");                                      
　　　　 }                                                                   
　　　}                                                                      
　 }                                                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
Correctly failed to re-open umaktst.tmp                                      
Error code is: -1                                                            
errno code is: 5                                                             
                                                                             
-----------------------------------------------------------------------------
.ungetc                                                                      
入力ストリームに、文字を戻す                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>      /* 必須 */                                           
int ungetc(int c, FILE *stream);                                             
                                                                             
- 内容 -                                                                     
文字c(int cの最下位バイト)を、入力ストリームstreamに戻します。fseek,rewind,  
fsetposのどれも最初に呼び出されないと仮定して、その文字は次のstreamからの読み
込み時に返されます。fseek, rewind, fsetposは、戻された文字を全て消去します。 
                                                                             
ungetcは、streamに結びついた外部メモリを変更しません。                       
                                                                             
ungetc関数は成功すると、戻した文字を返します。ストリームから文字を戻すことが 
できないとき、EOFを返します。                                                
                                                                             
- 注意 -                                                                     
ungetcは、｢2.6節 関数と引数｣で議論された慣習に適合するために、cをchar引数より
むしろintとして受け取ります。型charのオブジェクトがungetcに渡されたとき、自動
的に型intに強制されます。                                                    
                                                                             
- 参照 -                                                                     
fgetc, fgets, fputc, fputs, getc, getchar, putc, putchar, puts               
これらの関数についての短い記述については、fgetcの参照の節を参照ください。    
                                                                             
- 例 -                                                                       
/*                                                                           
 この例では、stdinから単語を読み込み、それを戻すためにungetcを使います。     
*/                                                                           
                                                                             
#include <stdio.h>                                                           
#include <string.h>                                                          
                                                                             
void main() {                                                                
　 char str[128];                                                            
　 int c;                                                                    
                                                                             
　 puts("Please enter a word.");                                             
　 gets(str);                                                                
　 puts(str);                                                                
　 for (c = strlen(str); c >= 0; c--)                                        
　　　ungetc(str[c], stdin);                                                 
　 puts("Please press return.");                                             
　 gets(str);                                                                
　 puts(str);                                                                
}                                                                            
                                                                             
- 実行結果 -                                                                 
Please enter a word.                                                         
Whacko!                                                                      
Whacko!                                                                      
Please press return.                                                         
Whacko!                                                                      
                                                                             
-----------------------------------------------------------------------------
._ungetch                                                                    
入力バッファに、読み込んだ文字を戻す                                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <conio.h>                                                           
int _ungetch(int c);                                                         
                                                                             
- 内容 -                                                                     
この関数は、入力バッファに文字cを戻します。次にgetchまたはgetcheを呼び出した 
とき、他の未決の入力文字を読み込む前に、その文字を返します。1文字だけが、この
関数で戻すことができます。文字cは、EOFコード以外でなければなりません。       
                                                                             
- 戻り値 -                                                                   
この関数は、文字cを戻します。                                                
                                                                             
- 参照 -                                                                     
_getch*                                                                      
                                                                             
- 例 -                                                                       
#include <conio.h>                                                           
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 int c;                                                                    
　 puts("Testing _ungetch...\n");                                            
　 puts("Please press the comma key.");                                      
　 _ungetch('A');                                                            
　 c = getche();                                                             
　 putch(c);                                                                 
　 if (c != 'A')                                                             
　　　puts("_ungetch/getch got wrong character.");                           
　 c = getche();                                                             
　 putch(c);                                                                 
　 if (c != ',')                                                             
　　　puts("getch did not get comma.");                                      
}                                                                            
                                                                             
- 実行結果 -                                                                 
A,,                                                                          
                                                                             
-----------------------------------------------------------------------------
._unlink                                                                     
ファイルを削除する                                                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>                                                           
int _unlink(const char *pathname);                                           
                                                                             
- 内容 -                                                                     
文字列pathnameで指定された名前を持つファイルを削除します。_unlinkは、処理に成
功すると、ゼロを返します。処理に失敗すると、errnoの値(ゼロ以外)を返します。  
ANSI互換のためには、remove関数を使用してください。                           
                                                                             
- 注意 -                                                                     
_unlinkがオープン中のファイルに対して呼び出されたとき、その動作は処理系に依存
し、戻り値が意味を持たないことがあります。                                   
                                                                             
- 参照 -                                                                     
fclose  　ファイルをクローズする。                                           
rename  　ファイル名を変更する。                                             
remove  　ファイルを削除する。                                               
                                                                             
- 例 -                                                                       
/*                                                                           
 以下のプログラムは、テンポラリファイルをオープンします。                    
 この例は、_unlinkとtmpnamの使い方を示しています。                           
*/                                                                           
                                                                             
#include <stdio.h>                                                           
void main() {                                                                
　 FILE *FP1;                                                                
　 char tmp[L_tmpnam];                                                       
                                                                             
　 /* tmpnam()は、ファイル名を生成する。 */                                  
　 if ((FP1 = fopen(tmpnam(tmp), "w+")) == NULL) {                           
　　　perror("Cannot open temporary file.");                                 
　　　return;                                                                
　 }                                                                         
　 else                                                                      
　　　printf("\ntmpnam has created file %s.", tmp);                          
　 fclose(FP1);                                                              
　 if (_unlink(tmp))                                                         
　　　perror("Cannot remove temporary file.");                               
　 else                                                                      
　　　printf("\nunlink has removed file %s.", tmp);                          
}                                                                            
                                                                             
- 実行結果 -                                                                 
tmpnam has created file 00240000.tmp                                         
unlink has removed file 00240000.tmp                                         
                                                                             
-----------------------------------------------------------------------------
._utime                                                                      
ファイルの日付/時刻スタンプを修正する                                        
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <sys/types.h>  /* 必須 */                                           
#include <sys/utime.h>  /* 必須 */                                           
int _utime(char *pathname, struct utimbuf *newtime);                         
                                                                             
- 内容 -                                                                     
この関数は、pathnameで指定されたファイルの日付と時刻を、newtime構造体の      
modtimeフィールドで与えられた日付と時刻に変更します。この関数はファイル(書き 
込み可能で、ファイルハンドルが使用可能でなければならない)をオープンし、そのフ
ァイルの日付と時刻を設定し、ファイルハンドルをクローズします。               
newtimeポインタがNULLのとき、DOSから現在の日付と時刻を得て、ファイルに適用し 
ます。                                                                       
                                                                             
- 戻り値 -                                                                   
成功したとき、ゼロの値を返します。エラーのとき、-1を返し、errnoに次の値の1つ 
を設定します。                                                               
┌─────┬────────────────────┐                     
│　　値　　│　　　　　　　意　　　　味　　　　　　　│                     
├─────┼────────────────────┤                     
│EACCES　　│ファイルにアクセスできません。　　　　　│                     
│EINVAL　　│引数が無効です。　　　　　　　　　　　　│                     
│EMFILE　　│ファイルハンドルが使えません。　　　　　│                     
│ENOENT　　│パス名がみつかりません。　　　　　　　　│                     
└─────┴────────────────────┘                     
                                                                             
- 参照 -                                                                     
asctime, ctime, ftime, gmtime, localtime, stat, time                         
                                                                             
- 例 -                                                                       
#include <fcntl.h>                                                           
#include <io.h>                                                              
#include <stat.h>                                                            
#include <stdio.h>                                                           
#include <utime.h>                                                           
                                                                             
void main() {                                                                
　 struct utimebuf tim;                                                      
                                                                             
　 puts("Testing _utime...\n");                                              
　 tim.modtime = 616444012;                                                  
                                                                             
　 int pan = open("utime.tmp", O_CREAT | O_TRUNC                             
　　　　　　　　　　　　　　 | O_RDWR, S_IWRITE );                           
　 close(pan);                                                               
　 if (_utime("utime.tmp", &tim) != 0)                                       
　　　perror("Error in changing time for utime.tmp.\n");                     
　 else                                                                      
　　　printf("Successfully changed the time"                                 
　　　　　　 " for file utime.tmp.\n");                                      
}                                                                            
                                                                             
- 実行結果 -                                                                 
Testing _utime...                                                            
Successfully changed the time for file utime.tmp.                            
                                                                             
-----------------------------------------------------------------------------
.va_arg                                                                      
無名引数の並びから次の引数を参照する(マクロのみで提供されている)             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdarg.h>     /* 必須 */                                           
void va_arg(va_list ap, type_spec);                                          
　　　　/* type_specを型指定子で置き換える。 */                              
                                                                             
- 内容 -                                                                     
ある関数の最も右の名前付きの引数が直前にva_startに渡されたとき、次の(まだ    
va_argで参照されていない)引数の値を返します。va_startは、va_argへの最初の呼び
出しの前に呼び出さなければなりません。va_argへの最初の呼び出しは、va_startに 
渡された引数の次の引数の値を返します。va_argへの次の呼び出しは、その次の引数 
の値を返します。type_specは型指定子であり、その型のオブジェクトへのポインタが
"*"をtype_specに追加することで得られなければなりません。                     
                                                                             
type_specは、2回以上評価されます。これは無害であるべきです。なぜならば、型指 
定子は副作用を持ってはならないからです。                                     
                                                                             
- 注意 -                                                                     
va_argは、apがva_startによって初期化されていると仮定します。va_startが正しく 
呼び出されていないとき、va_arg(ap,type)を呼び出すと、戻り値は不定になります。
                                                                             
va_argは、実際に参照可能な引数の個数を知りません。すべての引数を(va_argで)参 
照した後、va_argを呼び出すと、戻り値は不定になります。                       
                                                                             
- 参照 -                                                                     
va_end         va_list処理を終了する。                                       
va_start       va_listを初期化する。                                         
                                                                             
- 例 -                                                                       
#include <stdarg.h>                                                          
#include <stdio.h>                                                           
#define MAXARGS 100                                                          
                                                                             
void out(int n_ptrs, char *strings[]) {                                      
　 int i = 0;                                                                
　 if (n_ptrs < 0)                                                           
　　　return;                                                                
　 while (i < n_ptrs)                                                        
　　　printf("%s", strings[i++]);                                            
}                                                                            
                                                                             
void collect_args(int n_args, ...) {                                         
　 va_list ap;                                                               
　 char *args[MAXARGS];                                                      
　 int ptr_no = 0;                                                           
　 if (n_args > MAXARGS)                                                     
　　　n_args = MAXARGS;                                                      
　 va_start(ap, n_args);                                                     
　 while (ptr_no < n_args)                                                   
　　　args[ptr_no++] = va_arg(ap, char *);                                   
　 va_end(ap);                                                               
　 out (n_args, args);                                                       
}                                                                            
                                                                             
void main()  {                                                               
　 collect_args(3, "This ", "strikes me as ", "a little weird.\n");          
}                                                                            
                                                                             
- 実行結果 -                                                                 
This strikes me as a little weird.                                           
                                                                             
-----------------------------------------------------------------------------
.va_end                                                                      
va_list処理を終了する(マクロのみで提供されている)                            
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdarg.h>     /* 必須 */                                           
type va_end(va_list ap);                                                     
                                                                             
- 内容 -                                                                     
無名の引数の処理を一掃して、可変引数マクロを使用した関数から通常に復帰できる 
ようにします。va_endは、すべての引数をアクセスした後に、呼び出さなければなり 
ません。いくつかのシステムでは、va_endは空に展開されるので、そのコストはゼロ 
です。互換性のためには、常にva_endを使用することが最善です。                 
                                                                             
- 参照 -                                                                     
va_arg         並びの次の引数を参照する。                                    
va_start       va_list処理を初期化する。                                     
                                                                             
-----------------------------------------------------------------------------
.va_list                                                                     
可変引数マクロで使われる型                                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdarg.h>     /* 必須 */                                           
                                                                             
- 内容 -                                                                     
可変引数マクロで必要とされる情報を保持する適切な型に展開されます。これらのマ 
クロを使う関数は、この型の変数を宣言しなければなりません。                   
                                                                             
- 例 -                                                                       
va_argで提供されている例を参照してください。                                 
                                                                             
-----------------------------------------------------------------------------
.va_start                                                                    
va_listを初期化する(マクロのみで提供されている)                              
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdarg.h>     /* 必須 */                                           
void va_start(va_list ap, parmN);                                            
                                                                             
- 内容 -                                                                     
parmNを使用して、apを初期化します。続いてva_argが最初の無名引数を返すことがで
きるように、apは無名引数を持つ関数の最も右の名前付き引数でなければなりませ   
ん。va_startは、va_argの前に、呼び出さなければなりません。                   
                                                                             
- 参照 -                                                                     
va_arg 　　並びの次の引数を参照する。                                        
va_end 　　va_list処理を終了する。                                           
                                                                             
- 例 -                                                                       
va_argで提供されている例を参照してください。                                 
                                                                             
-----------------------------------------------------------------------------
.vfprintf                                                                    
可変引数マクロを使用して、ファイルに出力する                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>      /* 必須 */                                           
int vfprintf(FILE *stream,                                                   
　　　　　　 const char *format,                                             
　　　　　　 va_list arg                                                     
　　　　　　 );                                                              
                                                                             
- 内容 -                                                                     
fprintf(stream, format, arg)と等価です。ただし、argはマクロva_start(おそら   
く、続くva_argの呼び出しで更新される)によって、初期化されています。          
可変引数マクロについては、｢3.22 stdarg.h｣を参照してください。                
                                                                             
- 参照 -                                                                     
fprintf, fscanf, printf, scanf, sprintf, sscanf, vprintf, vsprintf           
                                                                             
これらの関数の短い記述については、fprintfの参照の節を参照してください。      
                                                                             
- 例 -                                                                       
#include <stdarg.h>                                                          
#inlcude <stdio.h>                                                           
#define MAXARGS 100                                                          
                                                                             
void collect_args2(int n_args, ...) {                                        
　 va_list ap;                                                               
　 FILE *FP;                                                                 
　 char *args[MAXARGS];                                                      
　 int ptr_no = 0;                                                           
                                                                             
　 if ((FP = fopen("vfprint.tmp","w")) == NULL)                              
　　　puts("Could not open file vfprintf.tmp.");                             
　 if (n_args > MAXARGS)                                                     
　　　n_args = MAXARGS;                                                      
　 va_start(ap, n_args);                                                     
　 while (ptr_no <  n_args) {                                                
　　　vfprintf(FP,"%s\n", ap);                                               
　　　vprintf("%s\n", ap);                                                   
　　　args[ptr_no++] = va_arg(ap, char*);                                    
　 }                                                                         
　 va_end(ap);                                                               
}                                                                            
                                                                             
void main() {                                                                
　 collect_args2(3, "This ", "strikes me as ",                               
　　　　　　　　     "a little weird.\n");                                   
}                                                                            
                                                                             
- 実行結果 - (stdoutとファイルvfprint.tmpに出力する)                         
This                                                                         
strikes me as                                                                
a little weird.                                                              
                                                                             
-----------------------------------------------------------------------------
.vprintf                                                                     
可変引数マクロを使用して、標準出力に出力する                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>      /* 必須 */                                           
int vprintf(const char *format, va_list arg);                                
                                                                             
- 内容 -                                                                     
printf(format, arg)と等価です。ただし、argはマクロva_start(たぶん続くva_argの
呼び出しで更新される)によって、初期化されています。可変引数マクロの議論につい
ては、｢3.22 stdarg.h｣を参照してください。                                    
                                                                             
- 参照 -                                                                     
fprintf, fscanf, printf, scanf, sprintf, sscanf, vfprintf,vsprintf           
                                                                             
これらの関数の短い記述については、fprintfの参照の節を参照してください。      
                                                                             
- 例 -                                                                       
vfprintfで提供された例を参照してください。                                   
                                                                             
-----------------------------------------------------------------------------
.vsprintf                                                                    
可変個引数を使用して、文字列に出力する                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>      /* 必須 */                                           
int vsprintf(char *s,                                                        
　　　　　　 const char *format,                                             
　　　　　　 va_list arg                                                     
　　　　　　);                                                               
                                                                             
- 内容 -                                                                     
sprintf(s, format, arg)と等価です。ただし、argはマクロva_start(たぶん続く    
va_argの呼び出しで更新される)によって、初期化されています。可変引数マクロにつ
いては、｢3.22 stdarg.h｣を参照してください。                                  
                                                                             
- 参照 -                                                                     
fprintf, fscanf, printf, scanf, sprintf, sscanf, vfprintf,vprintf            
                                                                             
- 例 -                                                                       
vfprintfで提供された例を参照してください。                                   
                                                                             
-----------------------------------------------------------------------------
.wchar_t                                                                     
拡張文字セットを表す型                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stddef.h>     /* 必須 */                                           
                                                                             
- 内容 -                                                                     
サポートされたすべての地域性の最も拡張された文字セットの、すべての値を表現す 
るために適切な範囲を持つ整数型。                                             
                                                                             
-----------------------------------------------------------------------------
.wcstombs                                                                    
wchar_t文字列をマルチバイト文字列に変換する                                  
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h>     /* 必須 */                                           
size_t wcstombs(char *s,                                                     
　　　　　　　　　const wchar_t *pwcs,                                       
　　　　　　　　　size_t n                                                   
　　　　　　　　 );                                                          
                                                                             
- 内容 -                                                                     
マルチバイト文字がnバイトの制限を超えるまで、またはヌル文字を格納するまで、  
pwcsで指された型wchar_tの値の配列を、マルチバイト文字列sに変換します。無効な 
マルチバイト文字に出合うと、(size_t)-1を返します。そうでなければ、変換された 
バイト数を返します。nバイトを超えては変換しません。                          
- 注意 -                                                                     
ヌル文字に出会う前に、nバイトが格納されたとき、sはヌルで終了しません。       
                                                                             
- 参照 -                                                                     
mbstowcs        マルチバイト文字列をwchar_t配列に変換する。                  
                                                                             
-----------------------------------------------------------------------------
.wctomb                                                                      
wchar_tコードをマルチバイト文字に変換する                                    
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h>     /* 必須 */                                           
int wctomb(char *s, wchar_t wchar);                                          
                                                                             
- 内容 -                                                                     
sがNULLでなければ、wctombはwchar(シフト状態の変更を含む)に対応するマルチバイ 
ト文字を表現するのに必要なバイト数を調べ、sにマルチバイト文字を格納します。  
wcharが無効なコードのときは-1、そうでなければマルチバイト文字を含むバイト数を
返します。高々MB_CUR_MAXバイトが格納されます。wcharの値がゼロのとき、その関数
は初期シフト状態のまま残します。                                             
文字列sがNULLのとき、マルチバイト文字が状態依存エンコードを持ってるならば、  
wctombはゼロ以外の値を返します。そうでなければ、wctombはゼロを返します。     
                                                                             
- 参照 -                                                                     
mblen   マルチバイト文字の長さ。                                             
mbtowc  マルチバイト文字をwchar_tコードに変換する。                          
                                                                             
-----------------------------------------------------------------------------
._write                                                                      
ファイルにデータを書き込む                                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <io.h>                                                              
int _write(int file_handle,                                                  
　　　　　 char *bufptr,                                                     
　　　　　 unsigned int kount                                                
          );                                                                 
                                                                             
- 内容 -                                                                     
_write関数は、bufptrの先頭からkountバイトを、現在file_handleでオープンされて 
いるファイルに、書き出します。ファイルを追加モードでオープンしない限り、書き 
込みはファイルの現在の位置に行います。追加モードでオープンしたとき、データは 
ファイルの現在の終わりに書き込まれます。書き込みが完了した後のファイル位置   
は、最後のバイトが書き込まれた後の次のバイトです。                           
                                                                             
- 戻り値 -                                                                   
バッファ(bufptr)から実際に受け取ったバイト数を返します。書き込みに失敗する   
と、戻り値がkountより少ないことがあります。エラーが起こると、エラーを意味する
-1を返し、errnoは次を示します。                                              
                                                                             
┌─────┬─────────────────────────┐           
│　　値　　│　　　　　　　　意　　　　　　味　　　　　　　　　│           
├─────┼─────────────────────────┤           
│EBADF 　　│不正なハンドルが指定されています。　　　　　　　　│           
│ENOSPC　　│書き込み処理を始めるデバイスの領域が足りません。　│           
└─────┴─────────────────────────┘           
                                                                             
signed intの最大値である32Kバイト未満のデータを書き込むとき、関数が定義された
ように処理することができます。32バイトを越えるデータを書き込むとき、戻り値   
は、unsigned intとして扱われるべきです。また、正確に64Kバイトのデータを書き込
むとき、エラー指示は正しくありません。なぜならば、-1と64Kは同じ値であるためで
す。ファイルがテキストモードのとき、戻り値には、追加された改行文字の数は含み 
ません。                                                                     
                                                                             
- 注意 -                                                                     
いくつかのキャラクタデバイスに書き込むとき、DOSはControl-Z文字をend-of-fileコ
ードとして扱い、その時点で書き込みを止めます。                               
                                                                             
- 例 -                                                                       
#include <io.h>                                                              
void main() {                                                                
　 int pan = 1;                                                              
　 char msg[] = "This is a test of\n"                                        
　　　　　　　　"the _write function!\n";                                    
　 char *c;                                                                  
　 c = &msg[0];                                                              
　 while (*c != 0)                                                           
　　　_write(pan, c++, 1);                                                   
　 c = &msg[0];                                                              
　 _write(pan, c, 37);                                                       
}                                                                            
                                                                             
- 実行結果 -                                                                 
This is a test of                                                            
 the _write function!                                                        
This is a test of                                                            
 the _write function                                                         
                                                                             
*****************************************************************************
付録Ａ　High Cイントリンシック                                               
*****************************************************************************
                                                                             
　実際にコンパイラが暗黙のうちにフェーズ c = a + bを理解し、このCコードに対し
て直接オブジェクトコードを生成するように、コンパイラも暗黙のうちに理解する関 
数の呼び出しがあります。これら"イントリンシック関数"(普通イントリンシックと呼
ばれる)は実は全然関数ではありません。つまり、コンパイラは関数呼び出しのオーバ
ヘッドを省き、同様に、イントリンシックに渡される引数に直接オブジェクトコード 
を仕立てるように、直接イントリンシックに対してオブジェクトコードを生成しま   
す。                                                                         
                                                                             
　例えば、_abs(a)はコンパイラによって直接理解され、適切なオブジェクトコードに
翻訳されます。_abs()に対してライブラリ関数の呼び出しは作られません。というの 
は、_absがライブラリ関数ではないからです。_abs(a)に対して生成されたコードは、
関数呼び出しのオーバヘッドがないので、非常に高速です。                       
Metaware社では、次のイントリンシックをサポートします。                       
                                                                             
__DATE__                                                                     
__FILE__                                                                     
__HIGHC__                                                                    
__LINE__                                                                     
__TIME__                                                                     
_abs                                                                         
_compare                                                                     
_fill_char                                                                   
_find_char                                                                   
_inb                                                                         
_ind                                                                         
_inline                                                                      
_insb                                                                        
_insd                                                                        
_insw                                                                        
_inw                                                                         
_max                                                                         
_min                                                                         
_move                                                                        
_move_right                                                                  
_offsetof                                                                    
_outb                                                                        
_outd                                                                        
_outsb                                                                       
_outsd                                                                       
_outsw                                                                       
_outw                                                                        
_skip_char                                                                   
                                                                             
- 例 -                                                                       
/*　イントリンシック_absによって、絶対値を計算するためのコードを生成するため 
に、ヘッダファイルをインクルードする必要はありません。                       
*/                                                                           
                                                                             
#include <stdio.h>      /* printf()宣言を得る。*/                            
#define NEGNUM -8                                                            
void main()  {                                                               
   printf("\nThe absolute value of %d is %d.\n",                             
           NEGNUM, _abs(NEGNUM));                                            
}                                                                            
                                                                             
- 実行結果 -                                                                 
The absolute value of -8 is 8.                                               
                                                                             
*****************************************************************************
付録Ｂ　High Cインタフェースファイル                                         
*****************************************************************************
                                                                             
- 警告 -                                                                     
　次のインタフェースファイルのすべては、High C Ver1.xコンパイラとの互換性のた
めに、単独に提供されています。それらは、新しいプログラムでの使用を予定してい 
るのではありません。                                                         
                                                                             
　この付録では、High CランタイムライブラリのANSI標準仕様に関連しない非標準ラ 
イブラリである拡張ライブラリ機能を説明します。                               
                                                                             
　これは、ランタイムライブラリで提供されるあるルーチンにアクセスするために、 
コンパイル内部で#includeを使いインクルードされるかもしれない"インタフェース" 
テキストの集りです。そのすべてのソースファイルは、Cインタフェースを意味するフ
ァイル拡張子".cf"を持っています。ファイルは次のとおりです。                  
                                                                             
┌───────┬────────────────────────────┐ 
│　 ファイル　 │　　　　　　　　　　　内　　　　容　　　　　　　　　　　│ 
├───────┼────────────────────────────┤ 
│ 87.cf        │_87_exists変数を宣言する  　　　　　　　　　　　　　　　│ 
│ debugaid.cf  │ランタイムデバッギングエイド  　　　　　　　　　　　　　│ 
