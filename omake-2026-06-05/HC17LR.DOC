-----------------------------------------------------------------------------
._itoa                                                                       
int値をASCII文字列に変換する                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h> 　　/* 必須 */                                           
char *_itoa(int value, char *target, int radix);                             
                                                                             
- 内容 -                                                                     
この関数は、整数valueをASCII文字列targetに変換します。変換はradixで示された数
システムにしたがって実行されます。radixは、2から36までの任意の数であることが 
可能です。radixが10進数の10であるとき、負の値は先頭に負符号が付けられます。  
radixが2進のとき、targetの最大サイズは、終了のヌル文字を含み、8086CPUでは17バ
イト、80386CPUでは33バイトです。radixが10進のとき、targetの最大の大きさは、  
8086CPUでは7バイト、80386CPUでは10バイトであり、オプションの負符号、5桁の数  
字、最後のヌルバイトから構成されます。                                       
                                                                             
- 戻り値 -                                                                   
この関数は、結果の文字列の先頭へのポインタを返します。                       
                                                                             
- 参照 -                                                                     
ltoa,ultoa,sprintf                                                           
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <stdlib.h>                                                          
                                                                             
void main() {                                                                
　 char s[35],t[35];                                                         
　 int j;                                                                    
　 for ( j = 1; j != 0;) {　　 /*ゼロになるまで、いつまでも。*/              
　　　puts("Enter a number (ZERO to quit)");                                 
　　　gets(s);　　　　　　　　　/*数を入力する。*/                           
　　　j = atoi(&s[0]);　　　　　/*整数に変換する。*/                         
　　　puts(_itoa(j,t,10));　　　/*10進数で表示する。*/                       
　　　puts(t);　　　　　　　　　/*再び表示する。*/                           
　　　puts(_itoa(j,t,2)); 　　　/*2進数で表示する。*/                        
　　　puts(_itoa(j,t,16));　　　/*16進数で表示する。*/                       
　　　puts(_itoa(j,t,36));　　　/*基数36で表示する。*/                       
　 }                                                                         
}                                                                            
                                                                             
- 実行結果 - (入力に依存する)                                                
Enter number (ZERO to quit)                                                  
20                                                                           
20                                                                           
10100                                                                        
14                                                                           
K                                                                            
Enter number (ZERO to quit)                                                  
0                                                                            
0                                                                            
0                                                                            
0                                                                            
0                                                                            
                                                                             
-----------------------------------------------------------------------------
