　　　　              );                                                     
                                                                             
　　　errno値:  Error_invalid_handle ― ファイルがオープンされていません。   
                                                                             
　　　　switch_char ― Switch文字を設定または復元します。                    
　　　　　　　void switch_char(char *C, int Set_it);                         
　　　　　　　Set_itであればそれを設定し、それ以外はCにそれを返します。      
                                                                             
　　　　trunc ― 現在の位置にファイルを連結します。                          
　　　　　　　void trunc(file_handle F);                                     
                                                                             
　　　　　　　errno値:  Error_invalid_handle.                                
　　　　　　　　　　　　 Error_access_denied.                                
                                                                             
　　　　write ― ファイルFに、アドレスがBufpであるバッファから、Cntバイト書き
                 込みます。                                                  
　　　　　　　　   unsigned write(file_handle F,                             
　　　　　　　　                  void *Bufp,                                
　　　　　　　　                  unsigned Cnt                               
　　　　　　　　                 );                                          
                                                                             
- 注意 -                                                                     
ディスクオーバフローが発生すると、errnoにError_disk_overflowという値が設定さ 
れ、Write関数は実際に書き込んだバイト数を返します。                          
                                                                             
errno値:Error_invalid_handle - ファイルがオープンされていません。            
　　　　 Error_access_denied - ファイルが書き込み専用でオープンされていませ  
                               ん｡                                           
                                                                             
B.12　オペレーティングシステムとのコミュニケーション:msdos.cf                
void calldos();                                                              
void callint(int interrupt);                                                 
                                                                             
B.12.1　msdos.cfで定義された型                                               
                                                                             
  次の型はcalldosとcallint関数を使うとき、ハードウェアレジスタにアクセスでき 
ることを可能にします。                                                       
                                                                             
  typedef union  {                                                           
  struct {char L,H;} LH; /* 16ビットレジスタの下位部と上位部 */              
  unsigned R;            /* レジスタ全体                     */              
  unsigned short W;      /* 386に対して、32ビットレジスタの下位16ビット部 */ 
  } Registers;                                                               
  typedef struct{                                                            
  Register AX, BX, CX, DX, SI, DI, DS, ES;                                   
  unsigned Flags;                                                            
  } dos_communication;                                                       
  /*                                                                         
 Flagの1番右側のビットがcarryビットです。DOSは通常エラーが発生するとcarryビッ
トをセットします。このように、復帰時にFlagが異常のとき、エラーが起こります。 
AXはエラー番号を含んでいます。                                               
 */                                                                          
 Dos_communication Registers;                                                
                                                                             
  calldosを呼び出す前に、これらのレジスタに直接代入する、またはレジスタの    
DOS_communicationブロックをクリエイトし、そしてRegistersのブロックに代入する 
ことのどちらでも可能です。                                                   
                                                                             
- 注意 -                                                                     
ランタイムライブラリは、calldosとこのRegisters変数を使います。DOSの通信を要求
するライブラリの呼び出しの間でRegisters変数が、保存されることを期待しないでく
ださい(例えば、Professional Pascal WritelnまたはHigh Cのprintfのように)。    
                                                                             
B.12.2　DOSを呼び出す                                                        
                                                                             
　グローバル Registers structの内部で、ユーザーが望む方法でレジスタ値を設定し
てください。その後すぐにcalldosを呼び出します。calldosはレジスタブロック内部 
の値を、実際のマシンレジスタにロードします。復帰時に、RegistersはDOSから戻っ 
たときのレジスタの内容を含みます。Flagワードは、DOSから戻った後の80x86フラグ 
レジスタの内容を含みます。callintは、同じような方法でレジスタを使いながら、任
意の割り込み番号の呼び出しが可能です。たとえば、callint(#21) とcalldos()は同 
じです。                                                                     
                                                                             
- 例 -                                                                       
/*                                                                           
  calldosの使い方を、拡張された例で紹介します。                              
 */                                                                          
#include <msdos.cf>                                                          
int KB_status(char *C){                                                      
   Registers.AX.LH.H = 0xB;                                                  
   calldos();                                                                
   *C = Registers.AX.LH.L;                                                   
   return*C != 0;                                                            
   }                                                                         
                                                                             
int KB_input_no_echo() {                                                     
   Registers.AX.LH.H= 0x8;                                                   
   calldos();                                                                
   return Registers.AX.LH.L;                                                 
   }                                                                         
                                                                             
void KB_write_char(char C)  {                                                
   Registers.AX.LH.H = 2;                                                    
   Registers.DX.LH.L = C;                                                    
   calldos();                                                                
   }                                                                         
                                                                             
void KB_write_string(char *s){                                               
   union {                                                                   
      void *A;                                                               
      struct {                                                               
         int Offset;                                                         
         short Segment; /* smallデータモデルには */                          
                        /* セグメントが存在しない。*/                        
                                                                             
      } Word;                                                                
   } Cheat;                                                                  
   Registers.AX.LH.H = 0x9;                                                  
   Cheat.A = S;                                                              
   Registers.DX.R = Cheat.Word.Offset;                                       
                                                                             
 /* ここで小さなトリック:非smallデータであれば、Sに対するセグメント値に      
Registers.DSを設定し、それ以外はDSの現在の値に設定しなければならない。       
これはgetds関数を使う理由です。                                              
*/                                                                           
   if (sizeof(S) > sizeof(int))                                              
      Registers.DS.R = Cheat.Word.Segment;                                   
   else                                                                      
      Registers.DS.R = getds();                                              
   calldos();                                                                
}                                                                            
                                                                             
void main() {                                                                
   int I; char C;                                                            
   while( !KB_status(&C)) {                                                  
      for (I=1; i <= 3000; I++);        /* 何もしない */                     
      KB_write_string("I'm waiting for you to type"                          
                      " a character...\r\n$");                               
   }                                                                         
   KB_write_string("Thank you for typing"                                    
                      " the character:$");                                   
   KB_write_char(KB_input_no_echo());                                        
}                                                                            
                                                                             
これはdsレジスタの値を得ます。Adr関数がそのオフセットだけを返すので、        
Registers.DSを設定するために、smallデータモデルではそれを使ってください。    
                                                                             
