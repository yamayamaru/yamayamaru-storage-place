-----------------------------------------------------------------------------
.fwrite                                                                      
ファイルに書き込む                                                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>　　　/* 必須 */                                           
size_t fwrite(const void *ptr,                                               
　　　　　　　size_t size,                                                   
　　　　　　　size_t nelem,                                                  
　　　　　　　FILE *stream                                                   
　　　　　　　);                                                             
                                                                             
- 内容 -                                                                     
streamに結びつけられたファイルに、ptrで参照された場所から始まるメモリ領域か  
ら、各々sizeバイトからなるnelem個の要素を書き込みます。書き込みエラーが発生し
たとき、fwriteはnelemより少ない要素を書き込んで戻ります。ファイルポインタは  
(もし定義されていれば)、書き込んだバイト数だけ進めます。fwriteは実際に書き込 
まれた要素数を返します。書き込みエラーが発生したとき、ファイル位置は(もしあれ
ば)、不確定です。                                                            
ストリームをバッファに結びつけるためにsetbufが以前に呼び出さた場合を除いて、 
バッファ化されたストリーム上では、最初の読み込みまたは書き込みリクエストによ 
って、ストリームに対するバッファが割り当てられます。                         
                                                                             
- 注意 -                                                                     
fwriteは、ptrで参照された場所から始まるメモリ領域から、nelem*sizeバイトを書き
込みます。                                                                   
                                                                             
- 参照 -                                                                     
fread 　ファイルから読み込む。                                               
setbuf　特定のバッファをストリームに結びつける。                             
                                                                             
- 例 -                                                                       
freadで提供された例を参照してください。                                      
                                                                             
-----------------------------------------------------------------------------
.getc                                                                        
ファイルから1文字入力する(マクロと関数の両方で提供)                          
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>　　　/* 必須 */                                           
int getc(FILE *stream);                                                      
                                                                             
- 内容 -                                                                     
fgetcと同等です。fgetcを参照してください。マクロとして使われたとき、streamは 
2回以上評価されます。                                                        
                                                                             
- 参照 -                                                                     
fgetc,fgets,fputc,getchar,gets,putc,putchar,puts,ungetc                      
                                                                             
これらの関数に対する短い記述については、fgetcの参照の節を参照してください。  
                                                                             
- 例 -                                                                       
/*                                                                           
このプログラムは、getc を使い"test.dat"を表示します。                        
*/                                                                           
                                                                             
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 FILE *FP;                                                                 
　 int c;                                                                    
                                                                             
　 if ((FP = fopen("test.dat", "r"))　== NULL)                               
　　　perror("fopen of test.dat");                                           
　 while (!feof(FP)) {                                                       
　　　c = getc(FP);                                                          
　　　printf("%c", c);                                                       
　 }                                                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
testing 1 abcd                                                               
testing=2 efgh                                                               
testing=3 ijkl                                                               
testing=4 mnop                                                               
testing=5 qrst                                                               
testing=6 uvwx                                                               
testing=7 yzAB                                                               
testing=8 CDEF                                                               
                                                                             
-----------------------------------------------------------------------------
._getch                                                                      
._getche                                                                     
キーボードから文字を読み込む                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <conio.h>                                                           
int _getch(void);                                                            
int _getche(void);                                                           
                                                                             
- 内容 -                                                                     
これらの関数は、キーボードから1文字を読み込みます。_getche関数は画面に文字を 
エコーバックしますが、_getch関数は画面に文字を表示しません。文字はDOSのキーボ
ード入力ルーチンによってふるいにかけられます。Control-Cのような文字コードはい
つも横取りされるので、これらの関数によって読み込むことはできません。         
                                                                             
- 戻り値 -                                                                   
これらの関数は、キーボードより読み込んだ1つの文字コードを返します。          
                                                                             
- 参照 -                                                                     
cgets,getchar,ungetch                                                        
                                                                             
- 例 -                                                                       
#include <conio.h>                                                           
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 int c;                                                                    
                                                                             
　 puts("Every other charcter you key"                                       
　　　　" will be displayed.");                                              
　 do {                                                                      
　　　c = _getche();                                                         
　　　if (c != '\r')                                                         
　　　　 c = _getch();                                                       
　 } while (c !='\r');                                                       
}                                                                            
                                                                             
- 実行結果 -                                                                 
Every other charcter you key will be displayed.                              
                                                                             
-----------------------------------------------------------------------------
.getchar                                                                     
標準入力から1文字を読み込む(マクロと関数の両方で提供)                        
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>                                                           
int getchar(void);                                                           
                                                                             
- 内容 -                                                                     
fgetc(stdin)と等価です。fgetcを参照してください。                            
                                                                             
マクロgetchar()は、getc(stdin)に展開されますが、これ自身もマクロかもしれませ 
ん。                                                                         
                                                                             
- 参照 -                                                                     
fgetc,fgets,fputs,getc,gets,putc,putchar,puts,ungetc                         
                                                                             
以上の関数の短い記述については、fgetcの参照の節を参照してください。          
                                                                             
- 例 -                                                                       
/*                                                                           
このプログラムは、標準入力から"getchar.tmp"と標準出力に1文字づつ複写します。 
同様のサンプルプログラムがfgetcとgetcにあります。                            
*/                                                                           
#include <stdio.h>                                                           
#undef getchar /* マクロを定義せずに　　　　　　　 */                        
#undef putchar /* 名前付きの関数としてアクセスする */                        
                                                                             
void main() {                                                                
　 FILE *FP1;                                                                
                                                                             
　 printf("Enter charcters; end with"                                        
　　　　　" the ENTER key.\n");                                              
　 if ((FP1 = fopen("getchar.tmp". "w")) == NULL)                            
　　　perror("Cannot open getchar.tmp.");                                    
　 while( ('\n' != fputc(putchar(getcahr()), FP1);                           
}                                                                            
                                                                             
- 実行結果 - (stdoutに)                                                      
This is my input.                                                            
                                                                             
(ファイルgetchar.tmpに)                                                      
This is my input.                                                            
                                                                             
-----------------------------------------------------------------------------
._getcwd                                                                     
カレントディレクトリのフルパス名を返す                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <direct.h> 　　/* 必須 */                                           
char *_getcwd(                                                               
　　　　char *cwd,　　　/*パス名を格納するバッファ*/                         
　　　　int maxlen　　　/*パス名の最大の長さ*/                               
　　　　);                                                                   
                                                                             
- 内容 -                                                                     
_getcwd関数は、カレントディレクトリのフルパス名をcwdに格納します。引数maxlen 
は、cwdに保持するパス名の最大の長さを指定します。パス名(終わりのヌル文字を含 
む)の長さがmaxlenより大きいとき、エラーが発生します。                        
                                                                             
cwdがNULLとして渡されたとき、_getcwdはカレントディレクトリを保持するのに十分 
なメモリを割り当てます。このメモリはmallocの呼び出しによって割り当てられるの 
で、_getcwdの戻り値を引数としてfreeを呼び出すことにより、このメモリを解放する
ことができます。                                                             
                                                                             
- 戻り値 -                                                                   
成功すると、_getcwdはcwdつまりカレントディレクトリを保持したバッファへのポイ 
ンタを返します。エラーが発生すると、_getcwdはNULLを返し、errnoに以下のいずれ 
かを設定します。                                                             
                                                                             
┌────┬──────────────────────────────┐   
│　 値　 │　　　　　　　　　　　　意　　　　味　　　　　　　　　　　　│   
├────┼──────────────────────────────┤   
│ENOMEM　│maxlenバイトを割り当てるのに十分なメモリが無かった。　　　　│   
│　　　　│　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　│   
│ERANGE　│パス名の長さがmaxlenより大きい。　　　　　　　　　　　　　　│   
└────┴──────────────────────────────┘   
                                                                             
- 参照 -                                                                     
chdir, mkdir, rmdir                                                          
                                                                             
- 例 -                                                                       
/*                                                                           
 このプログラムは、現在のワークディレクトリを得ます。                        
*/                                                                           
                                                                             
#include <stdio.h>                                                           
#include <direct.h>                                                          
                                                                             
void main() {                                                                
　 char *cwd = NULL;                                                         
　 int maxlen = 66;                                                          
                                                                             
　 if ((cwd = _getcwd(cwd, maxlen)) != NULL)                                 
　　　printf("Current working directory: %s\n", cwd);                        
　 else                                                                      
　　　perror("Error in _getcwd.");                                           
}                                                                            
                                                                             
- 実行結果 - (変化する)                                                      
Current working directory: C:\DOS\CLIBS14                                    
                                                                             
-----------------------------------------------------------------------------
.getenv                                                                      
環境変数の値を得る                                                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h> 　　/* 必須 */                                           
char *getenv(const char *name);                                              
                                                                             
- 内容 -                                                                     
各プログラムは、その親プロセスから環境ブロックと呼ばれるデータ構造を継承しま 
す。この環境ブロックは、ヌルで終了するname=parameterの形式を持つ文字列の集ま 
りです。これはプロセスが実行される環境を定義しています。getenv関数は、環境変 
数のリストからnameに対応する項目を捜します。                                 
                                                                             
- 戻り値 -                                                                   
getenvは、環境ブロックのnameに対応する項目へのポインタを返します。nameが現在 
の環境ブロック中に定義されていないならば、getenvはNULLを返します。           
                                                                             
- 参照 -                                                                     
putenv                                                                       
                                                                             
- 例 -                                                                       
/*                                                                           
このプログラムは、PATH環境変数の値を表示します。                             
*/                                                                           
#include <stdio.h>                                                           
#include <stdlib.h>                                                          
                                                                             
void main() {                                                                
　 char *ev;                                                                 
                                                                             
　 if ((ev = getenv("PATH")) != NULL)                                        
　　　printf("The value of PATH is:\n%s",　ev);                              
　 else                                                                      
　　　puts("The PATH variable is not set.\n");                               
}                                                                            
                                                                             
- 実行結果 - (変化する)                                                      
The value of PATH is:                                                        
C:\;C:\BIN;C:\SPP;C:\BATCH;D:\DV;C:\NET;C:\NFS;C:\DOS                        
                                                                             
-----------------------------------------------------------------------------
._getpid                                                                     
呼び出し中のプロセスの識別番号を返す                                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <process.h>                                                         
int _getpid(void);                                                           
                                                                             
- 内容 -                                                                     
_getpid関数は、呼び出し中のプロセスのプロセスIDを返します。プロセスIDは、他の
アクティブプロセスのIDと重複しない整数です。エラーリターンはありません。     
                                                                             
- 例 -                                                                       
/*                                                                           
 このプログラムは、自分自身のプロセスIDを表示します。                        
*/                                                                           
                                                                             
#include <process.h>                                                         
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 printf("The process ID is: %d\n", _getpid());                             
}                                                                            
                                                                             
- 実行結果 - (変化する)                                                      
The process ID is: 11711                                                     
                                                                             
-----------------------------------------------------------------------------
._getpvect                                                                   
現在のネイティブモードの割り込みハンドラを得る                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <dos.h>　　　　/* 必須 */                                           
_Far _INTERRPT void (* _getvect(int intno))();                               
                                                                             
- 内容 -                                                                     
_getpvect関数は、voidを返す関数への48ビットのポインタを返します。これは、    
80x86 16ビットライブラリの_dos_setvectと_dos_getvectで提供されるのと同じよう 
に、80386/80486をサポートするためのいくつかの関数(参照の節を参照してください)
の1つです。                                                                  
386ネイティブモードのDOS Extenderは、通常のDOSと異なった割り込み処理をするの 
で、_dos_setvectと_dos_getvectは、386ネイティブモードでは使えません。        
                                                                             
- 戻り値 -                                                                   
現在の386ネイティブモードのintnoに対するハンドラのアドレスを返します。また   
は、処理に失敗すると、-1を返します。                                         
                                                                             
- 注意 -                                                                     
独自の割り込みハンドラを組み込むときは、以前のハンドラの保存と復元に気をつけ 
てください。元のハンドラを復元しないならば、プログラムの終了後、機械が予期し 
ない動作をすることがあります。                                               
                                                                             
- 参照 -                                                                     
_getrvect　　　リアルモードのベクタを得る。                                  
_setrpvectp 　 ネイティブモードとリアルモード両方のベクタがネイティブモードの
               ハンドラを指すように設定する。                                
_setpvect　　　ネイティブモードのベクタを設定する。                          
_setrvect　　　リアルモードのベクタを設定する。                              
                                                                             
- 例 -                                                                       
_setrpvectp の例を参照してください。                                         
                                                                             
-----------------------------------------------------------------------------
._getrvect                                                                   
現在のリアルモードの割り込みハンドラを得る                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <dos.h>                                                             
_real_int_handler_t _getrvect(int intno));                                   
                                                                             
- 内容 -                                                                     
これは、80x86 16ビットライブラリの_dos_setvectと_dos_getvectで提供されるのと 
同じように、80386/80486をサポートするためのいくつかの関数(参照の節を参照くだ 
さい)の1つです。                                                             
                                                                             
386ネイティブモードのDOS Extenderは、通常のDOSと異なった割り込み処理をするの 
で、_dos_setvectと_dos_getvectは386ネイティブモードでは使えません。          
                                                                             
- 戻り値 -                                                                   
_getrvectは、現在のリアルモードのintnoに対するハンドラのアドレスを返します。 
または、処理に失敗すると、-1を返します。                                     
                                                                             
- 注意 -                                                                     
独自の割り込みハンドラを組み込むならば、以前のハンドラの保存と復元に気をつけ 
てください。元のハンドラを復元しないならば、プログラムの終了後、機械が予期し 
ない動作をすることがあります。                                               
                                                                             
- システム依存 -                                                             
この関数は現在組み込まれているDOS Extenderを検出し、それにしたがって動作しま 
す。extern char変数_mwenvの値を調べることによって、プログラムがどの環境で動作
しているかを決定することができます。値2は、Phar Lapの386|DOS-Extenderを意味  
し、3はErgoのOS/386を意味します。                                            
                                                                             
_getpvect　　　ネイティブモードのベクタを得る。                              
_setrpvectp　　ネイティブモードとリアルモードの両方のベクタがネイティブモード
               のハンドラを指すように設定する。                              
_setpvect　　　ネイティブモードのベクタを設定する。                          
_setrvect　　　リアルモードのベクタを設定する。                              
                                                                             
- 例 -                                                                       
_setrpvectp の例を参照してください。                                         
                                                                             
-----------------------------------------------------------------------------
.gets                                                                        
標準入力から1行のテキストを読み込む                                          
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>　　　/* 必須 */                                           
char *gets(char *s);                                                         
                                                                             
- 内容 -                                                                     
ストリームstdinから1行のテキストを読み込み、文字列sに格納し、最後にNULを追加 
します。end-of-fileまたは改行に出会った後、文字は読み込みません。改行は(もし 
あれば)捨てられます。                                                        
                                                                             
_getsは成功すると、sを返します。文字を読み込む前に、end-of-fileに出会うと、配
列は変更されず、getsはNULLを返します。読み込みエラーが発生したときは、配列の 
内容は不確定であり、getsはNULLを返します。                                   
                                                                             
- 注意 -                                                                     
sは改行までのすべての文字を含むのに十分な大きさを持つようにしてください。    
getsとfgetsは同じではありません:両関数は改行に出会うとリターンします。       
しかし、getsは改行を無視するにもかかわらず、fgetsは改行を格納します。        
                                                                             
- 参照 -                                                                     
fgetc,fgets,fputc,fputs,getc,getchar,putc,putchar,puts,ungetc                
これらの関数の短い記述については、fgetcの参照の節を参照ください。            
                                                                             
- 例 -                                                                       
/*                                                                           
 このプログラムは、標準入力から標準出力に1行複写します。                     
 これは、getsとputsの使い方を示しています。                                  
*/                                                                           
                                                                             
#include <stdio.h>                                                           
#define LINESIZE (256)                                                       
                                                                             
void main() {                                                                
　 char line[LINESIZE];                                                      
　 printf("\nWaiting for keyboard input: ");                                 
　 if (gets(line))                                                           
　　　puts(line);                                                            
}                                                                            
                                                                             
- 実行結果 - (ユーザの入力に依存する)                                        
Waiting for Keyboard input: Hello, World.                                    
Hello, World.                                                                
                                                                             
-----------------------------------------------------------------------------
.gmtime                                                                      
協定世界時(ＵＴＣ)に合わせて、time_t値をtm構造体に変換する                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <time.h> 　　　/* 必須 */                                           
struct tm *gmtime(const time_t *timer);                                      
                                                                             
- 内容 -                                                                     
timerによって表現された時刻を、協定世界時(ＵＴＣ)で表現された時刻と日付の個々
の要素を含むstructに変換します。そのstructへのポインタを返します。           
                                                                             
- 注意 -                                                                     
structは、gmtimeおよびlocaltimeを呼び出す毎に、上書きされます。              
                                                                             
- 参照 -                                                                     
localtime 　　　time_t値をstruct tmに変換する。                              
                                                                             
- 例 -                                                                       
/*                                                                           
この例は、time()とlocaltime()を使って、asctime()の使い方を説明します。       
*/                                                                           
#include <time.h>                                                            
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 time_t t;                                                                 
　 struct tm tim_hd;                                                         
　 char *str;                                                                
                                                                             
　 time(&t);                                                                 
　 tim_hd = *gmtime(&t);                                                     
　 str = asctime(&tim_hd);                                                   
　 printf("Greenwich Mean Time: %s", str);                                   
}                                                                            
                                                                             
- 実行結果 -                                                                 
Greenwich Mean Time:Wed Oct 18 01:04:04 1989                                 
                                                                             
-----------------------------------------------------------------------------
.__HIGHC__                                                                   
ANSIモードでコンパイルしない限り、High C上で予め1に定義されているマクロ      
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
/*                                                                           
この内部マクロは、引数を必要としません。                                     
*/                                                                           
                                                                             
- 内容 -                                                                     
マクロ__HIGHC__は，High Cの非ANSIサポートの機能に依存したコードを効率よく除外
することができます。                                                         
                                                                             
-----------------------------------------------------------------------------
.HUGE_VAL                                                                    
いくつかの数学関数からのエラー時の戻り値に使われるマクロ                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <math.h> 　　　/* 必須 */                                           
                                                                             
- 内容 -                                                                     
doubleに適合する最大の正の浮動小数点値であるdouble定数に展開します。いくつか 
の関数は、正しい結果が生成できないときに、HUGH_VALを返します。               
                                                                             
- 例 -                                                                       
#include <math.h>                                                            
#include <stdio.h>                                                           
#include <stdlib.h>                                                          
                                                                             
void main() {                                                                
　 double x = 1.0;                                                           
　 int counter;                                                              
　 for (counter = 1; counter <10000; (counter += 20))  {                     
　　　if (exp(x) >= HUGH_VAL) {                                              
　　　　 printf("\n%d\t...Number too big."                                   
　　　　　　　　" Bye.", counter);                                           
　　　　 break;                                                              
　　　}                                                                      
　　　else                                                                   
　　　　 printf("\n%d\t%g", counter, exp(x));                                
　　　x += counter;                                                          
　 }                                                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
1 　　　2.71828                                                              
21　　　7.38906                                                              
41　　　9.7448e+09                                                           
61　　　6.23515e+27                                                          
81　　　1.93558e+54                                                          
101 　　2.91517e+89                                                          
121 　　2.13013e+133                                                         
141 　　7.55159e+185                                                         
161 　　1.29885e+247                                                         
181 　　...Number too big. Bye.                                              
                                                                             
-----------------------------------------------------------------------------
._hypot                                                                      
直角三角形の斜辺を計算する                                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <math.h> 　　　/* 必須 */                                           
double _hypot(double side1, double side2);                                   
                                                                             
- 内容 -                                                                     
_hypot関数は、直角三角形の斜辺の長さを計算します。入力として、直角をはさむ2辺
の長さを使います。この関数は、次の文から成ります。                           
                                                                             
return sqrt(side1 * side1 + side2 * side2);                                  
                                                                             
- 戻り値 -                                                                   
この関数は、直角三角形の斜辺の長さを返します。通常の数学エラーの検査は有効で 
あり、適正であれば、オーバーフローを抑制します。エラーは、errnoにERANGEを設定
し、HUGE_VALを返すことで示されます。                                         
                                                                             
- 例 -                                                                       
#include <math.h>                                                            
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 double base=3.0, height=4.0;                                              
                                                                             
　 puts("Testing _hypot...\n");                                              
　 printf("Base = %.2f, Height = %.2f,"                                      
　　　　　"Hypotenuse = %.2f\n",                                             
　　　　　base,height,_hypot(base,height));                                  
　 base = 1.0, height = 1.0;                                                 
　 printf("Base = %.2f, Height = %.2f,"                                      
　　　　　"Hypotenuse = %.2f\n",                                             
　　　　　base,height,_hypot(base,height));                                  
　 base = 8.0, height = -6.0;                                                
　 printf("Base = %.2f, Height = %.2f,"                                      
　　　　　"Hypotenuse = %.2f\n",                                             
　　　　　base, height, _hypot(base,height));                                
}                                                                            
                                                                             
- 実行結果 -                                                                 
Testing _hypot...                                                            
                                                                             
Base = 3.00, Height = 4.00, Hypotenuse = 5.00                                
Base = 1.00, Height = 1.00, Hypotenuse = 1.41                                
Base = 8.00, Height = -6.00, Hypotenuse = 10.00                              
                                                                             
-----------------------------------------------------------------------------
._insb                                                                       
._insd                                                                       
._insw                                                                       
._inb                                                                        
._ind                                                                        
._inw                                                                        
ポート入力の内部関数                                                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
void _insb(int port, void *buf, int count);                                  
void _insd(int port, void *buf, int count);                                  
void _insw(int port, void *buf, int count);                                  
unsigned char _inb(int port);                                                
unsigned long _ind(int port);                                                
unsigned short _inw(int port);                                               
                                                                             
- 内容 -                                                                     
最初の3つの関数は、ポートからストリーム入力を実行します。                    
                                                                             
_insb,_insd,_inswはREP INS命令を生成します。その命令に備えるために、ediレジス
タにbuf引数をロードし、ecxレジスタにcountをロードします。                    
                                                                             
_insbは、次のように翻訳します。                                              
les di,buf;                                                                  
mov dx,port;                                                                 
mov cx,count;                                                                
rep insb                                                                     
                                                                             
他のストリーム命令も同様です。                                               
                                                                             
最後の3つの関数は、ポートから単一の入力操作を実行します。                    
                                                                             
_inbは、次のように翻訳します。                                               
mov dx,port;                                                                 
in al,dx                                                                     
                                                                             
alの値はinbの結果となります。同様に_inwは80386でaxにワードで、_insはeaxにダブ
ルワードで入力します。_insdと_indは、非386ネイティブコンパイラでは使えませ   
ん。なぜならば、このようなコンパイラは、4バイトレジスタ命令を実現することがで
きないからです。                                                             
                                                                             
- システム依存 -                                                             
_inbと_inwは、任意の80x86アーキテクチャで使うことができます。                
                                                                             
他のすべての命令は、High Cの80386/486バージョンでのみサポートされています。異
なるアーキテクチャ間の移植性が出てくるとき、このことに注意してください。     
                                                                             
-----------------------------------------------------------------------------
._inline                                                                     
バイトデータをコードに挿入する内部関数                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
_inline(...);                                                                
                                                                             
- 内容 -                                                                     
_inline(e1, e2, ...en)は、定数式e1, e2, ...enの最下位バイトを、命令ストリーム
中に直接置きます。これは、例えば、割り込みルーチン中で直接CLIまたはSTIを挿入 
するときに使われます。                                                       
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#define CLI _inline(0xfa)                                                    
#define STI _inline(0xfb)                                                    
int semaphor = 0;                                                            
                                                                             
void main() {                                                                
　 CLI; 　　　　/*割り込み禁止*/                                             
　 semaphor++;　/*リエントラント使用をプロテクトします。*/                   
　 STI; 　　　　/*割り込み許可*/                                             
　 puts("Multi-tasking semaphor is set.");                                   
}                                                                            
                                                                             
- 実行結果 -                                                                 
Multi-tasking semaphor is set.                                               
                                                                             
-----------------------------------------------------------------------------
._inp                                                                        
._inpw                                                                       
入出力ポートより1バイトまたは1ワード入力する                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <conio.h>                                                           
int _inp(unsigned port_number);                                              
unsigned int _inpw(unsigned port_number);                                    
                                                                             
- 内容 -                                                                     
これらの関数は、port_numberで指定されたハードウェア入力ポートから入力します。
_inp関数は8ビットを読み込み、intサイズにゼロ拡張します。_inpwは16ビットを読み
込み、unsigned intとして返します。                                           
                                                                             
- 戻り値 -                                                                   
これらの関数は、指定されたハードウェアから入力した値を、どのような点検や修正 
もせずに返します。                                                           
                                                                             
- 参照 -                                                                     
関数　　　　　　　:outp,outpw                                                
コンパイラ内部関数:_inb,_outw,_inw,_outb                                     
                                                                             
-----------------------------------------------------------------------------
._int86                                                                      
8086のソフトウェア割り込みを行う                                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <dos.h>　　　　/* 必須 */                                           
int _int86(int number,                                                       
　　　　　 union REGS *before,                                               
　　　　　 union REGS *after                                                 
　　　　　 );                                                                
                                                                             
- 内容 -                                                                     
この関数は、8086ハードウェアレジスタにbeforeレジスタをロードし、次にnumberで 
指定された8086の割り込み命令を実行します。割り込みから戻った後(もし戻れば)、 
関数はハードウェアレジスタからafterレジスタ構造体にコピーします。キャリーフラ
グは、1ビットからintに拡張され、afterレジスタ構造体のcflagフィールドに返され 
ます。これは、すべての汎用レジスタ(ax, bx, cx, dx, si, di)を制御することがで 
きますが、フラグレジスタ、セグメントレジスタ(cs, ds, ss, es)、スタックレジス 
タ(sp, bp)を制御することはできません。                                       
                                                                             
- 戻り値 -                                                                   
関数の戻り値は、afterレジスタ構造体のaxレジスタの値です。多くの割り込みは、エ
ラーを示すキャリーフラグを返し、これはafterレジスタ構造体のcflagフィールドに 
格納されます。_doserrno変数は、対応するDOSエラーコードに設定されます。       
                                                                             
- 参照 -                                                                     
bdos,intdos,intdosx,_int86x                                                  
                                                                             
- 例 -                                                                       
/*                                                                           
すべての256個の文字コードをノーマル、ボールドおよびブリンクモードで表示する。
                                                                             
*/                                                                           
#include <dos.h>                                                             
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 int j, k, l, m;                                                           
　 union REGS r;                                                             
                                                                             
　 for (l = 0; l < 25; l++)                                                  
　　　puts(" ");                                                             
　 l = 0;                                                                    
　 for (m = 0; m < 2; m++) {                                                 
　　　for (k = 0; k < 4; k++ ) {                                             
　　　　 for (j = 0; j < 64; j++ ) {                                         
　　　　　　r.h.ah = 2;                                                      
　　　　　　r.h.bh = 0;                                                      
　　　　　　r.h.dh = K + m + m + m + m;                                      
　　　　　　r.h.dl = j;                                                      
　　　　　　_int86(16, &r, &r);                                              
　　　　　　r.h.ah = 9;                                                      
　　　　　　r.h.al = l++;                                                    
　　　　　　r.h.bh = 0;                                                      
　　　　　　r.h.al = 128 + j + m * 128;                                      
　　　　　　r.x.cx = 1;                                                      
　　　　　　_int86(16, &r, &r);                                              
　　　　 }                                                                   
　　　}                                                                      
　 }                                                                         
　 for ( l = 0; l<8; l++)                                                    
　　　puts(" ");                                                             
}                                                                            
                                                                             
- 実行結果 -                                                                 
すべての256個の文字コードをノーマル、ボールドおよびブリンクモードで表示する。
                                                                             
-----------------------------------------------------------------------------
._int86x                                                                     
8086のソフトウェア割り込みを行う                                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <dos.h>　　　　/* 必須 */                                           
int _int86x(                                                                 
　 int number,                                                               
　 union REGS *before,                                                       
　 union REGS *after,                                                        
　 struct SREGS *segregs                                                     
　 );                                                                        
                                                                             
- 内容 -                                                                     
この関数は、8086ハードウェア汎用レジスタにbeforeレジスタをロードし、次にハー 
ドウェアレジスタds,esにsegregs構造体からロードします。次にnumberで指定された 
8086の割り込み命令を実行します。割り込みから戻った後(もし戻れば)、関数はハー 
ドウェア汎用レジスタをafterレジスタ構造体にコピーし、ds,esレジスタをsegregs構
造体にコピーします。キャリーフラグは、0または1の値として、afterレジスタ構造体
のcflagフィールドで返されます。                                              
                                                                             
- 戻り値 -                                                                   
この関数は、割り込みルーチンによって返されたaxレジスタの値を返します。この値 
は、afterレジスタ構造体のaxフィールドでも返されます。割り込みがキャリーフラグ
をセットして戻ったとき、_doserrno変数も対応して設定されます。                
                                                                             
- 参照 -                                                                     
関連関数とマクロ　　:_bdos,_intdos,_intdosx,_int86,FP_OFF                    
セグメントレジスタ値:_FP_SEG,_segread                                        
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <dos.h>                                                             
                                                                             
void main() {                                                                
　 union REGS r;                                                             
　 struct SREGS s;                                                           
                                                                             
　 /*割り込み21h ファンクション*/                                            
　 /*0x1Cです。*/                                                            
　 r.h.ah = 0x1c;                                                            
　 r.l.dl = 0;                                                               
　 segread(&s);                                                              
　 /*intdosx(&r,&r,&s);*/                                                    
　 _int86x(0x21,&r,&r,&s);                                                   
　 printf("Number of sectors per cluster is"                                 
　　　　　" %d\n", r.l.al);                                                  
　 printf("Number of bytes per sector is"                                    
　　　　　" %d\n", r.x.cx);                                                  
　 printf("Number of clusters is"                                            
　　　　　" %d\n", r.x.dx);                                                  
　 printf("Address of file allocation table is"                              
　　　　　" %x:%x\n", s.ds, r.x.bx);                                         
}                                                                            
                                                                             
- 実行結果 - (変化する)                                                      
Number of sectors per cluster is 4                                           
Number of bytes per sector is 512                                            
Number of clusters is 14815                                                  
Address of file allocation table is 34:2c70                                  
                                                                             
-----------------------------------------------------------------------------
._intdos                                                                     
DOS INT 21h割り込みを行う                                                    
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <dos.h>　　　　/* 必須 */                                           
int _intdos(union REGS *before, union REGS *after);                          
                                                                             
- 内容 -                                                                     
この関数は、8086ハードウェアレジスタにbeforeレジスタをロードし、次にDOS INT  
21hを実行します。割り込みから戻った後、関数はハードウェアレジスタからafterレ 
ジスタ構造体にコピーします。キャリーフラグは、1ビットからintに拡張され、after
レジスタ構造体のcflagフィールドに返されます。これはすべての汎用レジスタ(ax,  
 bx, cx, dx, si, di)を制御することができますが、フラグレジスタ、セグメントレ 
ジスタ(cs, ds, ss, es)、スタックレジスタ(sp, bp)を制御することはできません。 
                                                                             
- 戻り値 -                                                                   
関数の戻り値は、afterレジスタ構造体のaxレジスタの値です。多くの割り込みは、エ
ラーを示すキャリーフラグを返し、これはafterレジスタ構造体のcflagフィールドに 
格納されます。_doserrno変数は、対応するDOSエラーコードに設定されます。       
                                                                             
- 参照 -                                                                     
_bdos,_int86,_intdosx,_int86x                                                
                                                                             
- 例 -                                                                       
#include <dos.h>                                                             
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 union REGS r;                                                             
                                                                             
　 r.h.ah = 0x33;                                                            
　 r.l.al = 0;                                                               
　 _intdos(&r, &r);                                                          
　 printf("The Control-C flag was ");                                        
　 if (r.l.dl != 0)                                                          
　　　printf("on.\n");                                                       
　 else {                                                                    
　printf("off.\n");                                                          
　r.h.ah = 0x33;                                                             
　r.l.al = 1;                                                                
　r.l.dl = 1;                                                                
　_intdos(&r, &r);                                                           
　if(r.l.al != 255)                                                          
　　　　 printf("The Control-C flag is now on!\n");                          
　}                                                                          
 }                                                                           
                                                                             
- 実行結果 - (機械の状態に依存して変化する)                                  
The Control-C flag was on.                                                   
                                                                             
-----------------------------------------------------------------------------
._intdosx                                                                    
DOS INT 21h割り込みを行う                                                    
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <dos.h>　　　　/* 必須 */                                           
int _intdosx(                                                                
　 union REGS *before,                                                       
　 union REGS *after,                                                        
　 struct SREGS *segregs                                                     
　 );                                                                        
                                                                             
- 内容 -                                                                     
この関数は、8086ハードウェア汎用レジスタにbeforeレジスタをロードし、ハードウ 
ェアレジスタds,esにsegregs構造体からロードします。次にDOS INT 21hを実行しま  
す。割り込みから戻った後、関数はハードウェア汎用レジスタをafterレジスタ構造体
にコピーします。関数_int86xとは異なり、ds,esレジスタはsegregs構造体にコピーさ
れません。キャリーフラグは、0または1の値として、afterレジスタ構造体のcflag   
フィールドで返されます。                                                     
                                                                             
- 戻り値 -                                                                   
この関数は、割り込みルーチンによって返されたaxレジスタの値を返します。この値 
は、afterレジスタ構造体のaxフィールドでも返されます。割り込みがキャリーフラグ
をセットして戻ったとき、_doserrno変数も対応して設定されます。                
                                                                             
- 参照 -                                                                     
関連関数とマクロ　　:_bdos,_intdos,_int86x,_int86,_FP_OFF                    
セグメントレジスタ値:_FP_SEG,_segread                                        
                                                                             
-----------------------------------------------------------------------------
._IOFBF                                                                      
._IOLBF                                                                      
._IONBF                                                                      
setvbufの引数として使われるマクロ                                            
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>　　　/* 必須 */                                           
                                                                             
- 内容 -                                                                     
使用するバッファリングモードを示すために、setvbufへの3番目の引数として指定さ 
れる整数に展開されます。                                                     
                                                                             
_IOFBF フルバッファリングを示します。                                        
_IOLBF ラインバッファリングを示します。                                      
_IONBF バッファリングなしを示します。                                        
                                                                             
- 参照 -                                                                     
setvbuf                                                                      
                                                                             
-----------------------------------------------------------------------------
.isalnum                                                                     
英数字かどうかを調べる(マクロと関数の両方で提供)                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <ctype.h>　　　/* 必須 */                                           
int isalnum(int c);                                                          
                                                                             
- 内容 -                                                                     
cが英字または数字であれば、ゼロ以外の値を返し、そうでないときはゼロを返しま  
す。                                                                         
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <ctype.h>                                                           
#define True (1)                                                             
#define False (0)                                                            
                                                                             
void main() {                                                                
　 if ((isalnum('A')) != 0)                                                  
　　　puts("A is alphanumeric.");                                            
　 else                                                                      
　　　puts("A is not alphanumeric.");                                        
　 if ((isalnum('6')) != 0)                                                  
　　　puts("6 is alphanumeric.");                                            
　 else                                                                      
　　　puts("6 is not alphanumeric.");                                        
　 if ((isalnum('!')) != 0)                                                  
　　　puts("! is alphanumeric.");                                            
　 else                                                                      
　　　puts("! is not alphanumeric.");                                        
}                                                                            
                                                                             
- 実行結果 -                                                                 
A is alphanumeric.                                                           
6 is alphanumeric.                                                           
! is not alphanumeric.                                                       
                                                                             
-----------------------------------------------------------------------------
.isalpha                                                                     
英字かどうかを調べる(マクロと関数の両方で提供)                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <ctype.h>　　　/* マクロのために必須 */                             
int isalpha(int c);                                                          
                                                                             
- 内容 -                                                                     
cが英字であれば、ゼロ以外の値を返し、そうでないときはゼロを返します。        
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <ctype.h>                                                           
#define True (1)                                                             
#define False (0)                                                            
                                                                             
void main() {                                                                
　 if ((isalpha('+')) != 0)                                                  
　　　puts("+ is alphabetic.");                                              
　 else                                                                      
　　　puts("+ is not alphabetic.");                                          
　 if ((isalpha('A')) != 0)                                                  
　　　puts("A is alphabetic.");                                              
　 else                                                                      
　　　puts("A is not alphabetic.");                                          
}                                                                            
                                                                             
- 実行結果 -                                                                 
+ is not alphabetic.                                                         
A is alphabetic.                                                             
                                                                             
-----------------------------------------------------------------------------
._isascii                                                                    
ASCII文字かどうか調べる                                                      
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <ctype.h>                                                           
int _isascii(int c);                                                         
                                                                             
- 内容 -                                                                     
cがASCII文字であれば、ゼロ以外の値を返し、そうでなければゼロを返します。     
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <ctype.h>                                                           
#define  True  (1)                                                           
#define  False (0)                                                           
                                                                             
void main() {                                                                
　 if ((_isascii(128)) != 0) 　 /*ASCII コードは0-127です。*/                
　　　puts("\\128 is ASCII.");                                               
　 else                                                                      
　　　puts("\\128 is not ASCII.");                                           
                                                                             
　 if ((_isascii('-')) != 0)                                                 
　　　puts("- is ASCII.");                                                   
　 else                                                                      
　　　puts("- is not ASCII.");                                               
                                                                             
　 if ((_isascii(7))) != 0)　　 /*7 はbellのASCIIコードです。*/              
　　　puts("Bell is ASCII.");                                                
　 else                                                                      
　　　puts("Bell is not ASCII.");                                            
}                                                                            
                                                                             
- 実行結果 -                                                                 
\128 is not ASCII.                                                           
- is ASCII.                                                                  
Bell is ASCII.                                                               
                                                                             
-----------------------------------------------------------------------------
._isatty                                                                     
キャラクタデバイスかどうか調べる                                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <io.h>                                                              
int _isatty(int handle);                                                     
                                                                             
- 内容 -                                                                     
_isatty関数は、handleがターミナルやコンソール、プリンタ、シリアルポートのよう
なキャラクタデバイスを参照しているかどうかを調べます。_isattyは、予め定義され
ているファイルハンドルstdin, stdout, stderr, stdauxおよびstdprnのどれかが、フ
ァイルにリダイレクトされているかどうかを調べるために、使われることもありま   
す。                                                                         
                                                                             
- 戻り値 -                                                                   
_isattyは、handleがキャラクタデバイスであればゼロ以外の値を返し、そうでなけれ
ばゼロを返します。                                                           
                                                                             
- 例 -                                                                       
/*                                                                           
このプログラムは、標準出力がリダイレクトされているかどうかを調べます。       
リダイレクトされているときと、そうでないときで異なった結果になることを見るた 
めに、実行してみましょう。                                                   
*/                                                                           
#include <stdio.h>                                                           
#include <io.h>                                                              
                                                                             
void main() {                                                                
　 (_isatty(fileno(stdout))) ?                                               
　　　puts("stdout is not redirected.");                                     
　　　puts("stdout is redirected.");                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
stdout is not redirected.                                                    
                                                                             
-----------------------------------------------------------------------------
.iscntrl                                                                     
コントロール文字かどうか調べる(マクロと関数の両方で提供)                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <ctype.h>　　　/* マクロのために必須 */                             
int iscntrl(int c);                                                          
                                                                             
- 内容 -                                                                     
cがコントロール文字であれば、ゼロ以外の値を返し、そうでないときは、ゼロを返し
ます。コントロール文字は、文字セット中の英字、数字、区切り文字、' ' (スペー  
ス)でない任意の文字です。                                                    
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <ctype.h>                                                           
                                                                             
void main() {                                                                
　 if ((iscntrl('\12')) != 0)                                                
　　　puts("\\12 is control.");                                              
　 else                                                                      
　puts("\\12 is not control.");                                              
　 if ((iscntrl('$')) != 0)                                                  
　　　puts("$ is control.");                                                 
　 else                                                                      
　puts("$ is not control.");                                                 
}                                                                            
                                                                             
- 実行結果 -                                                                 
\12 is control.                                                              
$ is not control.                                                            
                                                                             
-----------------------------------------------------------------------------
.isdigit                                                                     
数字かどうか調べる(マクロと関数の両方で提供)                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <ctype.h>　　　/* マクロのために必須 */                             
int isdigit(int c);                                                          
                                                                             
- 内容 -                                                                     
cが数字であればゼロ以外の値を返し、そうでなければゼロを返します。            
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <ctype.h>                                                           
                                                                             
void main() {                                                                
　 if ((isdigit('&')) != 0)                                                  
　　　puts("& is a digit.");                                                 
　 else                                                                      
　　　puts("& is not a digit.");                                             
　 if ((isdigit('5')) != 0)                                                  
　　　puts("5 is a digit.");                                                 
　 else                                                                      
　　　puts("5 is not a digit.");                                             
}                                                                            
                                                                             
- 実行結果 -                                                                 
& is not a digit.                                                            
5 is a digit.                                                                
                                                                             
-----------------------------------------------------------------------------
.isgraph                                                                     
印字可能文字かどうか調べる(マクロと関数の両方で提供)                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <ctype.h>　　　/* マクロのために必須 */                             
int isgraph(int c);                                                          
                                                                             
- 内容 -                                                                     
cがスペース以外の印字可能文字であれば、ゼロ以外の値を返し、そうでなければゼロ
を返します。                                                                 
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <ctype.h>                                                           
                                                                             
void main() {                                                                
　 if ((isgraph(7)) != 0)                                                    
　　　puts("Bell is a printable character.");                                
　 else                                                                      
　　　puts("Bell is not a printable character.");                            
　 if ((isgraph(']')) != 0)                                                  
　　　puts("] is a printable character.");                                   
　 else                                                                      
　　　puts("] is not a printable character.");                               
　 if ((isgraph(' ')) != 0)                                                  
　　　puts("Space is a printable character.");                               
　 else                                                                      
　　　puts("Space is not a printable character.");                           
}                                                                            
                                                                             
- 実行結果 -                                                                 
Bell is not a printable character.                                           
] is a printable character.                                                  
Space is not a printable character.                                          
                                                                             
-----------------------------------------------------------------------------
.islower                                                                     
英小文字かどうか調べる(マクロと関数の両方で提供)                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <ctype.h>　　　/* マクロのために必須 */                             
int islower(int c);                                                          
                                                                             
- 内容 -                                                                     
cが英小文字ならば、ゼロ以外の値を返し、そうでなければゼロを返します。        
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <ctype.h>                                                           
                                                                             
void main() {                                                                
　 if (islower('A') != 0)                                                    
　　　puts("A is lowercase.");                                               
　 else                                                                      
　　　puts("A is not lowercase.");                                           
　 if (islower('a') != 0)                                                    
　　　puts("a is lowercase.");                                               
　 else                                                                      
　　　puts("a is not lowercase.");                                           
}                                                                            
                                                                             
- 実行結果 -                                                                 
A is not lowercase.                                                          
a is lowercase.                                                              
                                                                             
-----------------------------------------------------------------------------
._isodigit                                                                   
8進数字かどうか調べるマクロ                                                  
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <ctype.h>                                                           
int _isodigit(int c);                                                        
                                                                             
- 内容 -                                                                     
cが8進数字ならば、ゼロ以外の値を返し、そうでなければゼロを返します。マクロと 
してのみ提供します。                                                         
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <ctype.h>                                                           
                                                                             
void main() {                                                                
　 if ((_isodigit('a')) != 0)                                                
　　　puts("a is octal.");                                                   
　 else                                                                      
　　　puts("a is not octal.");                                               
　 if ((_isodigit('8')) != 0)                                                
　　　puts("8 is octal.");                                                   
　 else                                                                      
　　　puts("8 is not octal.");                                               
　 if ((_isodigit('\7')) != 0)                                               
　　　puts("7 is octal.");                                                   
　 else                                                                      
　　　puts("7 is not octal.");                                               
}                                                                            
                                                                             
- 実行結果 -                                                                 
a is not octal.                                                              
8 is not octal.                                                              
7 is octal.                                                                  
                                                                             
-----------------------------------------------------------------------------
.isprint                                                                     
印刷可能文字かどうか調べる(マクロと関数の両方で提供)                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <ctype.h>　　　/* マクロのために必須 */                             
int isprint(int c);                                                          
                                                                             
- 内容 -                                                                     
cが印刷可能文字(スペースを含む)であれば、ゼロ以外の値を返し、そうでなければゼ
ロを返します。                                                               
- 例 -                                                                       
#include <stdio.h>                                                           
#include <ctype.h>                                                           
                                                                             
void main() {                                                                
　 if ((isprint('0')) != 0)                                                  
　　　puts("0 is printable.");                                               
　 else                                                                      
　　　puts("0 is not printable.");                                           
　 if ((isprint(' ')) != 0)                                                  
　　　puts("space is printable.");                                           
　 else                                                                      
　　　puts("space is not printable.");                                       
　 if ((isprint('\t')) != 0)                                                 
　　　puts("tab is printable.");                                             
　 else                                                                      
　　　puts("tab is not printable.");                                         
　 if ((isprint('D')) != 0)                                                  
　　　puts("D is printable.");                                               
　 else                                                                      
　　　puts("D is not printable.");                                           
}                                                                            
                                                                             
- 実行結果 -                                                                 
0 is printable.                                                              
space is printable.                                                          
tab is not printable.                                                        
D is printable.                                                              
                                                                             
-----------------------------------------------------------------------------
.isprint                                                                     
(マクロと関数の両方で提供)                                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <ctype.h>　　　/* マクロのために必須 */                             
int ispunct(int c);                                                          
                                                                             
- 内容 -                                                                     
cが数字、英字、スペース以外の印字可能文字であれば、ゼロ以外の値を返し、そうで
なければゼロを返します。                                                     
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <ctype.h>                                                           
                                                                             
void main() {                                                                
　 if ((ispunct('X')) != 0)                                                  
　　　puts("X is punctuation.");                                             
　 else                                                                      
　　　puts("X is not punctuation.");                                         
　 if ((ispunct(' ')) != 0)                                                  
　　　puts("space is punctuation.");                                         
　 else                                                                      
　　　puts("space is not punctuation.");                                     
　 if ((ispunct('!')) != 0)                                                  
　　　puts("! is punctuation.");                                             
　 else                                                                      
　　　puts("! is not punctuation.");                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
X is not punctuation.                                                        
space is not punctuation.                                                    
! is punctuation.                                                            
                                                                             
-----------------------------------------------------------------------------
.isspace                                                                     
ホワイトスペース文字かどうか調べる(マクロと関数の両方で提供)                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <ctype.h>　　　/* マクロのために必須 */                             
int isspace(int c);                                                          
                                                                             
- 内容 -                                                                     
cがホワイトスペース(' ')、フォームフィード('\f')、水平タブ('\t')、           
改行('\n')、キャリッジリターン('\r')、垂直タブ('\v')のどれかであれば、ゼロ以 
外の値を返し、そうでなければゼロを返します。                                 
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <ctype.h>                                                           
                                                                             
void main() {                                                                
　 if  (isspace('\t')) != 0)                                                 
　　　puts("\\t is whitespace.");                                            
　 else                                                                      
　　　puts("\\t is not whitespace.");                                        
　 if  (isspace(' ')) != 0)                                                  
　　　puts("space is whitespace.");                                          
　 else                                                                      
　　　puts("space is not whitespace.");                                      
　 if  (isspace('R')) != 0)                                                  
　　　puts("R is whitespace.");                                              
　 else                                                                      
　　　puts("R is not whitespace.");                                          
　 if ((isspace('\7')) != 0)                                                 
　　　puts("Bell is whitespace.");                                           
　 else                                                                      
　　　puts("Bell is not whitespace.");                                       
}                                                                            
                                                                             
- 実行結果 -                                                                 
\t is whitespace.                                                            
spece is whitespace.                                                         
R is not whitespace.                                                         
Bell is not whitespace.                                                      
                                                                             
-----------------------------------------------------------------------------
.isupper                                                                     
英大文字かどうか調べる(マクロと関数の両方で提供)                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <ctype.h>　　　/* マクロのために必須 */                             
int isupper(int c);                                                          
                                                                             
- 内容 -                                                                     
cが英大文字であれば、ゼロ以外の値を返し、そうでなければゼロを返します。      
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <ctype.h>                                                           
                                                                             
void main() {                                                                
　 if (isupper('A') != 0)                                                    
　　　puts("A is uppercase.");                                               
　 else                                                                      
　　　puts("A is not uppercase.");                                           
                                                                             
　 if (isupper('a') != 0)                                                    
　　　puts("a is uppercase.");                                               
　 else                                                                      
　　　puts("a is not uppercase.");                                           
}                                                                            
                                                                             
