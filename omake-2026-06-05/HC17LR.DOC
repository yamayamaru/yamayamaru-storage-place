.log                                                                         
自然対数 (底e)を求める                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <math.h> 　　　/* 必須 */                                           
double log(double x);                                                        
                                                                             
- 内容 -                                                                     
底eに対するxの対数を返します。x< 0.0のとき、errnoにEDOMを設定し、0.0を返しま 
す。x = 0.0のとき、errnoにERANGEを設定し、-HUGE_VALを返します。              
                                                                             
- 参照 -                                                                     
exp 　　ｅのべき乗。                                                         
log10 　常用対数(底 10)。                                                    
                                                                             
- 例 -                                                                       
#include <math.h>                                                            
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 puts("Testing log...\n");                                                 
　 printf("log(100.0) = %lf.\n",log(100.0));                                 
　 printf("log(10.0) = %lf.\n",log(10.0));                                   
　 printf("log(256.1) = %lf.\n",log(256.1));                                 
　 printf("log(2.718281828) = %lf.\n",                                       
　　　　log(2.718281828));                                                   
}                                                                            
                                                                             
- 実行結果 -                                                                 
Testing log...                                                               
                                                                             
log(100.0) = 4.605170.                                                       
log(10.0) = 2.302585.                                                        
log(256.1) = 5.545568.                                                       
log(2.718281828) = 1.000000.                                                 
                                                                             
-----------------------------------------------------------------------------
.log10                                                                       
常用対数(底 10)を求める                                                      
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <math.h>                                                            
double log10(double x);                                                      
                                                                             
- 内容 -                                                                     
底10に対するxの対数を返します。x<0.0のとき、errnoにEDOMを設定し、0.0を返しま 
す。x = 0.0のとき、errnoにERANGEを設定し、-HUGE_VALを返します。              
                                                                             
- 参照 -                                                                     
log 　　自然対数(底 e)。                                                     
                                                                             
- 例 -                                                                       
#include <math.h>                                                            
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 puts("Testing log10...\n");                                               
　 printf("log10(100.0) = %lf.\n",log10(100.0));                             
　 printf("log10(10.0) = %lf.\n",log10(10.0));                               
　 printf("log10(256.1) = %lf.\n",log10(256.1));                             
　 printf("log10(2.718281828) = %lf.\n",                                     
　　　　　 log10(2.718281828));                                              
}                                                                            
                                                                             
- 実行結果 -                                                                 
Testing log10...                                                             
                                                                             
log10(100.0) = 2.000000.                                                     
log10(10.0) = 1.000000.                                                      
log10(256.1) = 2.408410.                                                     
log10(2.718281828) = 0.434294.                                               
                                                                             
-----------------------------------------------------------------------------
.longjmp                                                                     
非局所ジャンプを実行する                                                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <setjmp.h> 　　/* 必須 */                                           
void longjmp(jum_buf env, int val);                                          
                                                                             
- 内容 -                                                                     
envによって参照された呼び出し環境に復帰(ジャンプ)します。envは、以前の       
setjmp(env)の呼び出しによって、初期化されていなければなりません。envは、最も 
最近setjmp(env)を呼び出した点に存在する呼び出し環境を参照します。            
                                                                             
longjmpは、古典的な意味では、戻りません。longjmp呼び出しの完了は、対応する   
setjmpへの呼び出し(つまり、同一の引数envによる最も最近のsetjmpの呼び出し)への
復帰として現れます。このようなlongjmpからの"戻り"(setjmpからの戻りとして現れ 
る)は、ゼロでない値を返します。valがゼロならば、longjmpの"戻り"値は1です。そ 
うでなければ、valです。実際のsetjmpの呼び出しからの戻り値はゼロであるので、明
らかにsetjmpからの"戻り"の種類とは、区別することができます。(このプロトコル  
は、UNIXのfork呼び出しの後を模倣しています。)                                
                                                                             
longjmpの呼び出しは、対応するsetjmpを含む関数内で宣言されたregisterストレージ
クラスの任意の変数に不確定な影響を与えますが、他のオブジェクトには影響を与え 
ません。                                                                     
                                                                             
- 注意 -                                                                     
envがsetjmpで初期化されていなかったとき、またはsetjmpの呼び出しが起こるルーチ
ンが仮に対応するlongjmpの呼び出しをする前に戻ったときは、動作は不定です。初期
化されていない環境または懸垂した環境の参照は、混乱した環境中で実行しようとす 
る結果になります。                                                           
                                                                             
- 参照 -                                                                     
setjmp　続く非局所ジャンプのために現在の呼び出し環境への参照を保存する。     
                                                                             
- 例 -                                                                       
/*                                                                           
 この例は、longjmpとsetjmpの使い方の説明します。                             
*/                                                                           
#include <sdtio.h>                                                           
#include <setjmp.h>                                                          
#define RETURN 1                                                             
#define FAIL (-1)                                                            
jmp_buf jump_buffer;                                                         
void process();                                                              
                                                                             
void main(void) {                                                            
　 int Flag = 0;                                                             
　 printf("Initializing process...\n");                                      
　 /* longjmp関数を呼び出すと，このポイントに戻ります。*/                    
　 Flag = setjmp(jump_buffer);                                               
　 if (Flag != RETURN)                                                       
　　　process();                                                             
　 printf("Ending program.\n");                                              
}                                                                            
                                                                             
int setvar(void);                                                            
void process(void)  {                                                        
　 printf("Beginning processing...\n");                                      
　 /* プロセスはここでスキップし、何かが起こったようにみえます。*/           
　 if (setvar() == FAIL) {                                                   
　　　printf("Something failed! Bailing out.\n");                            
　　　longjmp(jump_buffer, RETURN);                                          
　 }                                                                         
　 /* setvar関数がFAILを返さなければ、ここで他のプロセスに置き変わります。   
　*/                                                                         
}                                                                            
                                                                             
int setbar(void)  {                                                          
　 return FAIL;                                                              
}                                                                            
                                                                             
- 実行結果 -                                                                 
Initializing process...                                                      
Beginning processing...                                                      
Something failed! Bailing out.                                               
Ending program.                                                              
                                                                             
-----------------------------------------------------------------------------
._lrotl                                                                      
._lrotr                                                                      
long intを左または右に回転する                                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h> 　　/* 必須 */                                           
unsigned long _lrotl(unsigned long word, int amount);                        
unsigned long _lrotr(unsigned long word, int amount);                        
                                                                             
- 内容 -                                                                     
これらの関数は、wordをamountビット左に(_lrotl)、または右に(_lrotr)回転しま   
す 。                                                                        
                                                                             
- 戻り値 -                                                                   
回転したwordを返します。                                                     
                                                                             
- 参照 -                                                                     
_rotl, _rotr                                                                 
                                                                             
- 例 -                                                                       
#include <stdlib.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 long int k1 = 1;                                                          
　 long int k7 = 1;                                                          
　 long int k8 = 1;                                                          
　 long int k9 = 1;                                                          
　 long int k15 = 1;                                                         
　 long int k17 = 1;                                                         
                                                                             
　 printf("Rotate bits left by\n　　 one　　　　7"                           
　　　　　" 　　　 8　　　　9 　　　15　　　 17\n");                         
　 do {                                                                      
　　　printf("%8lx %8lx %8lx %8lx %8lx %8lx\n",                              
　　　　　　　k1, k7, k8, k9, k15, k17);                                     
                                                                             
　　　k1 = _lrotl(k1,1);                                                     
　　　k7 = _lrotl(k7,7);                                                     
　　　k8 = _lrotl(k8,8);                                                     
　　　k9 = _lrotl(k9,9);                                                     
　　　k15= _lrotl(k15,15);                                                   
　　　k17= _lrotl(k17,17);                                                   
　 } while (k1 != 1);                                                        
}                                                                            
                                                                             
- 実行結果 -                                                                 
