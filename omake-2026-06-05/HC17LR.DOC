-----------------------------------------------------------------------------
._lseek                                                                      
ファイルの位置を指定する                                                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <io.h> /* 必須 */                                                   
#include <stdio.h>                                                           
int _lseek(int handle, long from, int where);                                
                                                                             
- 内容 -                                                                     
この関数は、handleで指定されたファイル内の現在位置を変更します。したがって、 
次の読み込みまたは書き込みが行われる場所を変更します。この関数は、位置の変更 
をどこから測り始めるかを、whereで決まる3つの方法で指定します。where引数は以下
のように設定されます。                                                       
                                                                             
SEEK_CUR 　　　現在のファイル位置を示します。                                
SEEK_END 　　　ファイルの最後を示します。                                    
SEEK_SET 　　　ファイルの先頭を示します。                                    
                                                                             
_lseek関数は、ファイル位置をwhereから始めて、fromで指定されたバイト数だけ移動
します。                                                                     
                                                                             
_lseek関数は、追加モードでオープンしたファイルに書き込むときには、効果があり 
ません。                                                                     
                                                                             
- 戻り値 -                                                                   
正常終了のとき、_lseek関数は、新しいファイル位置をファイルの先頭から測って返 
します。戻り値 long -1はエラーを示し、errnoに次の定数の1つを設定します。     
                                                                             
EBADF 　ファイルハンドルが正しくありません。                                 
EINVAL　不正な位置にファイル位置を動かそうとしました。                       
                                                                             
キーボードや画面のような非ファイル構造のデバイスについては、戻り値は不定です 
。                                                                           
                                                                             
- 参照 -                                                                     
fseek, tell                                                                  
                                                                             
- 例 -                                                                       
#include <io.h>                                                              
#include <fcntl.h>                                                           
#include <sys\stat.h>                                                        
#include <stdio.h>                                                           
#include <conio.h>                                                           
void main() {                                                                
　 char c;                                                                   
　 int　pan;                                                                 
　 long int k;                                                               
                                                                             
　 pan = open("test.dat", O_RDONLY | O_BINARY);                              
　 if (pan != -1){                                                           
　　　printf("File test.dat exists, "                                        
　　　　　　 "handle = %d.\n", pan);                                         
　　　/* ファイルの終わりから、前向きに読み込みます。*/                      
　　　k = _lseek(pan, -1l, SEEK_END);                                        
　　　while ((k = _lseek(pan,--k,SEEK_SET)) != -1l) {                        
　　　　 read(pan, &c, 1);                                                   
　　　　 printf("%c", c);                                                    
　　　}                                                                      
　 }                                                                         
　 else                                                                      
　　　printf("File test.dat cannot be opened,"                               
　　　　　　 "error code = %d.\n", pan);                                     
}                                                                            
                                                                             
- 実行結果 - (結果は"test.dat"の内容に依存します)                            
File test.dat exists, handle = 6.                                            
                                                                             
FEDC 8=gnitset                                                               
                                                                             
BAzy 7=gnitset                                                               
                                                                             
xwvu 6=gnitset                                                               
                                                                             
tsrq 5=gnitset                                                               
                                                                             
ponm 4=gnitset                                                               
                                                                             
lkji 3=gnitset                                                               
                                                                             
hgfe 2=gnitset                                                               
                                                                             
dcba 1 gnitset                                                               
                                                                             
-----------------------------------------------------------------------------
.L_tmpnam                                                                    
テンポラリファイルの名前のサイズを指定するマクロ                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>　　　/* 必須 */                                           
                                                                             
- 内容 -                                                                     
tmpnamの呼び出しで生成されるテンポラリファイル名を保持するのに十分な配列の大 
きさを(バイトで)表現する整数定数。                                           
                                                                             
- 例 -                                                                       
removeで提供された例を参照してください。                                     
                                                                             
-----------------------------------------------------------------------------
._ltoa                                                                       
long値をASCII文字列に変換する                                                
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h> 　　/* 必須 */                                           
char *_ltoa(long value, char *target, int radix);                            
                                                                             
- 内容 -                                                                     
この関数は、任意のlong整数valueをASCII文字列targetに変換します。変換はradixで
示された数システムにしたがって実行されます。radixは、2から36までの任意の数で 
あることが可能です。radixが10進数の10であるとき、負の値は先頭に負符号が付けら
れます。radixが2進のとき、targetの最大サイズは、終了のヌル文字を含み、33バイ 
トです。radixが10進のとき、targetの最大の大きさは12バイトであり、オプションの
負符号、10桁の数字、最後のヌルバイトから構成されます。                       
                                                                             
- 戻り値 -                                                                   
この関数は、変換結果の文字列へのポインタを返します。                         
                                                                             
- 参照 -                                                                     
itoa, ultoa, sprintf                                                         
                                                                             
- 例 -                                                                       
#include <stdlib.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char s[55], t[55];                                                        
　 long int j;                                                               
　 for( j = 1;j != 0;) {                                                     
　　　puts("Enter a number, (ZERO to quit)");                                
　　　gets(s);                                                               
　　　j = atol(s);                                                           
　　　printf("The number you entered is: %ld\n"                              
　　　　　　 "And in base 10, 10, 2, 16 and 36"                              
　　　　　　 "it is\n",j);                                                   
　　　puts(_ltoa(j, t, 10));                                                 
　　　puts(t);                                                               
　　　puts(_ltoa(j, t, 2));                                                  
　　　puts(_ltoa(j, t, 16));                                                 
　　　puts(_ltoa(j, t, 36));                                                 
　 }                                                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
Enter a number, (ZERO to quit)                                               
The number you entered is: 40                                                
And in base 10, 10, 2, 16, and 36 it is                                      
40                                                                           
40                                                                           
100100                                                                       
28                                                                           
14                                                                           
Enter a number, (ZERO to quit)                                               
The number you entered is: 50                                                
And in base 10, 10, 2, 16, and 36 it is                                      
50                                                                           
50                                                                           
110010                                                                       
32                                                                           
1E                                                                           
                                                                             
-----------------------------------------------------------------------------
._makepath                                                                   
パス名を表す文字列を作成する                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h> 　　/* 必須 */                                           
void _makepath(                                                              
　 char *path,　　　　　/*パス名のためのバッファ*/                           
　 char *drive, 　　　　/*ドライブ名*/                                       
　 char *dir, 　　　　　/*ディレクトリパス*/                                 
　 char *fname, 　　　　/*ファイル名*/                                       
　 char *ext　　　　　　/*ファイル拡張子*/                                   
　 );                                                                        
                                                                             
- 内容 -                                                                     
_makepath関数は、ドライブ名、ディレクトリパス、ファイル名、ファイル拡張子から
文字列を作成し、その結果をpathに返します。フィールドの大きさには制限がありま 
せんが、pathに返される合成文字列はstdlib.hで定義された_MAX_PATHより短くなけれ
ばなりません。またpathは完全なパス名を保持するのに十分な長さが必要です。     
drive, dir, fnameとext引数は、以下に記述されるパス名要素を含むバッファを指し 
ます。                                                                       
                                                                             
┌────┬───────────────────────────────┐ 
│バッファ│　　　　　　　　　　　　記　　　　述　　　　　　　　　　　　　│ 
├────┼───────────────────────────────┤ 
│　drive │指定するドライブに対応する英字(A,B,等々)。末尾のコロン(:)はオ │ 
│　　　　│　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　│ 
│　　　　│プションであり、省略されると_makepathによって挿入されます。   │ 
│　　　　│　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　│ 
│　　　　│driveがNULLまたは空文字列を指すならば、コロンとドライブ指定は │ 
│　　　　│　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　│ 
│　　　　│path文字列中に現れません。　　　　　　　　　　　　　　　　　　│ 
│　　　　│　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　│ 
│　dir 　│ドライブ指定やファイル名を含まないディレクトリパス。前か後に\ │ 
│　　　　│　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　│ 
│　　　　│が使われることがあります。末尾の\はオプションであり、省略され │ 
│　　　　│　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　│ 
│　　　　│ると_makepathによって挿入されます。dirがNULLまたは空文字列を指│ 
│　　　　│　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　│ 
│　　　　│すならば、\とディレクトリパスは、path文字列中に現れません。   │ 
│　　　　│　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　│ 
│　fname │拡張子を含まない基本ファイル名。　　　　　　　　　　　　　　　│ 
│　　　　│　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　│ 
│　ext 　│ファイル名の拡張子。ピリオドはオプションであり、省略されると　│ 
│　　　　│　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　│ 
│　　　　│_makepathによって挿入されます。extがNULLまたは空文字列を指すな│ 
│　　　　│　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　│ 
│　　　　│らば、ピリオドとファイル拡張子は、path文字列中に現れません。  │ 
└────┴───────────────────────────────┘ 
                                                                             
- 参照 -                                                                     
_getcwd　　　　カレントワークディレクトリを得る。                            
_mkdir 　　　　新しいディレクトリを作成する。                                
_mktemp　　　　唯一のファイル名を作成する。                                  
_rmdir 　　　　ティレクトリを削除する。                                      
_splitpath 　　パス名を構成要素に分解する。                                  
                                                                             
- 例 -                                                                       
/*                                                                           
 このプログラムは、指定された構成要素からフルパス名の文字列を構成する。      
*/                                                                           
                                                                             
#include <stdio.h>                                                           
#include <stdlib.h>                                                          
                                                                             
void main() {                                                                
　 char buffer[67];                                                          
　 char *dirve = "c";                                                        
　 char *dir　 = "highc\inc";                                                
　 char *fname = "stdio";                                                    
　 char *ext　 = "h";                                                        
                                                                             
　 -makepath(buffer, drive, dir, fname, ext);                                
　 printf("Path created with _makepath: %s\n\n",                             
　　　　　 buffer);                                                          
}                                                                            
                                                                             
- 実行結果 -                                                                 
Path created with _makepath: c:highc\inc\stdio.h                             
                                                                             
-----------------------------------------------------------------------------
.malloc                                                                      
初期化されていないメモリ領域を動的に確保する                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h> 　　/* 必須 */                                           
void *malloc(size_t size);                                                   
                                                                             
- 内容 -                                                                     
新たに確保されたsizeバイトの最下位バイトへのポインタを返します。メモリが確保 
できないときは、mallocはNULLを返します。                                     
                                                                             
- 参照 -                                                                     
alloca　スタックフレームから領域を確保する。                                 
calloc　ゼロで初期化された領域を動的に確保する。                             
free　　動的に確保された領域を解放する。                                     
realloc 以前に動的に確保された領域のサイズを変更する。                       
                                                                             
- 例 -                                                                       
/*                                                                           
 この例は、初期化されていない領域を確保するために、どのようにmallocを使うかを
説明します。                                                                 
*/                                                                           
                                                                             
#include <stdlib.h>                                                          
                                                                             
void main() {                                                                
　 char *name_ptr;                                                           
                                                                             
　 /* 文字配列に対して20バイト割り当てる。*/                                 
　 name_ptr = (char *) malloc(20 * sizeof(char));                            
                                                                             
　 if (name_ptr == NULL)                                                     
　　　printf("Out of Memory!\n");                                            
　 else                                                                      
　　　printf("malloc was used to allocate space.\n");                        
}                                                                            
                                                                             
- 実行結果 -                                                                 
malloc was used to allocate space.                                           
                                                                             
-----------------------------------------------------------------------------
._max                                                                        
._min                                                                        
任意の算術型の最大値または最小値を求める(コンパイラ内部関数)                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
_max(e1, e2, ...)                                                            
_min(e1, e2, ...)                                                            
                                                                             
- 内容 -                                                                     
この関数の引数は、算術型でなければなりません。結果はe1，e2， ...の最大値また 
は最小値です。                                                               
                                                                             
さらに正確には、_max(e1，e2)は型T = Common(e1の型，e2の型)を持ち、各々型Tにキ
ャストされたe1，e2の最大値です。n≧3のとき、_max(e1，e2，..., en)は(再帰的に)
_max(_max(e1, e2), e3, ..., en)で定義されます。                              
_minについても同様です。                                                     
                                                                             
_maxと_minのオペランドは、以下のmax(とmin)の標準的なマクロ定義とは異なり、高 
々1回評価されることが保証されます。                                          
                                                                             
#define max(x,y) ((x) > (y) ? (x) : (y))                                     
                                                                             
ここでは、一方の引数は1回評価され、他方は2回評価されます。                   
                                                                             
- 例 -                                                                       
/*                                                                           
 このプログラムは、min関数とmax関数をテストします。                          
*/                                                                           
float f;                                                                     
unsigned long ul;                                                            
int i;                                                                       
void main()  {                                                               
　 float r1;                                                                 
　 unsigned long r2;                                                         
　 f = 20.0;                                                                 
　 ul = 29;                                                                  
　 i = 10;                                                                   
                                                                             
　 puts("Testing _min & _max...\n");                                         
　 printf("Output of _min.\n");                                              
　 r1 = _min(f, ul, i);　　　　　　　　/*型floatを持つ。*/                   
　 printf("r1 ==> %.1f.\n",r1);                                              
　 r2 = _min(ul, i); 　　　　　　　　　/*型unsigned longを持つ。*/           
　 printf("r2 ==> %u.\n",r2);                                                
　 r1 = _min(i, f);　　　　　　　　　　/*型floatを持つ。*/                   
　 printf("r1 ==> %.1f.\n",r1);                                              
　 printf("output of _max.\n");                                              
　 r1 = _max(f, ul, i);　　　　　　　　/*型floatを持つ。*/                   
　 printf("r1 ==> %.1f.\n",r1);                                              
　 r2 = _max(ul, i); 　　　　　　　　　/*型unsigned long intを持つ。*/       
　 printf("r2 ==> %u.\n",r2);                                                
　 r1 = _max(i, f);　　　　　　　　　　/*型floatを持つ。*/                   
　 printf("r1 ==> %.1f.\n",r1);                                              
}                                                                            
                                                                             
- 実行結果 -                                                                 
Testing _min & _max...                                                       
Output of _min.                                                              
r1 ==> 10.0.                                                                 
r2 ==> 10.                                                                   
r1 ==> 10.0.                                                                 
output of _max.                                                              
r1 ==> 29.0.                                                                 
r2 ==> 29.                                                                   
r1 ==> 20.0.                                                                 
                                                                             
-----------------------------------------------------------------------------
._MAXSTRING                                                                  
文字列の長さを表現するマクロ                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h> 　　/* 必須 */                                           
                                                                             
- 内容 -                                                                     
文字列の最大長に展開します。                                                 
                                                                             
-----------------------------------------------------------------------------
.mblen                                                                       
マルチバイト文字の長さを調べる                                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h> 　　/* 必須 */                                           
int mblen(const char *s, size_t n);                                          
                                                                             
- 内容 -                                                                     
sがNULLでないとき、mblen関数はsで指されるマルチバイト文字の長さを調べます。  
sがヌル文字を指しているときは、ゼロを返します。次のnバイトまたはsで指されるよ
り少ないバイトが有効なマルチバイト文字でないときは、-1を返します。そうでなけ 
れば、変換されたマルチバイト文字を含むバイト数を返します。                   
                                                                             
sがNULLのときに、マルチバイト文字が状態依存でエンコードされていると、mblenは 
ゼロ以外の値を返します。それ以外はゼロを返します。                           
                                                                             
- 参照 -                                                                     
mbtowc　マルチバイト文字からwchar_tコードに変換する。                        
wctomb　wchar_tコードからマルチバイト文字に変換する。                        
                                                                             
-----------------------------------------------------------------------------
.mbstowcs                                                                    
マルチバイトの文字列をwchar_t配列に変換する                                  
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h> 　　/* 必須 */                                           
size_t mbstowcs(wchar_t *pwcs,                                               
　　　　　　　　const char *s,                                               
　　　　　　　　size_t n                                                     
　　　　　　　　);                                                           
                                                                             
- 内容 -                                                                     
初期シフト状態で始まるマルチバイト文字sを変換し、n個の値またはゼロの値が格納 
されるまで、pwcsによって指された型wcha_tの値の配列に格納します。無効なマルチ 
バイト文字に出会ったとき、size_tに変換された値-1を返します。そうでなければ、 
格納されたバイト数を返します。                                               
                                                                             
- 注意 -                                                                     
値ゼロが格納される前に、nバイトが格納されたとき、格納先の配列はゼロ値で終わら
ないでしょう。                                                               
                                                                             
- 参照 -                                                                     
wcstombs　wchar_tコードの配列からマルチバイト文字列に変換する。              
                                                                             
-----------------------------------------------------------------------------
.mbtowc                                                                      
マルチバイトの文字列をwchar_tコードに変換する                                
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdlib.h> 　　/* 必須 */                                           
int mbtowc(wchar_t *pwc,                                                     
　　　　　 const char *s,                                                    
　　　　　 size_t n                                                          
　　　　　 );                                                                
                                                                             
- 内容 -                                                                     
sがNULLでないとき、sで指されたマルチバイト文字の長さを調べます。次にそのマル 
チバイト文字に対応する型wchar_tの値を調べます。sが有効なマルチバイトを指し、 
pwcがNULLでなければ、pwcで指されたオブジェクトにその値を格納します。sが無効な
マルチバイト文字を指しているとき、-1を返します。sがヌル文字を指しているとき、
ゼロを返します。そうでなければ、変換されたマルチバイト文字を含むバイト数を返 
します。高々n文字を調べて、nを超えない値かMB_CUR_MAXの値を返します。         
                                                                             
sがNULLのとき、mbtowcはマルチバイト文字が状態依存でエンコードされていると、ゼ
ロ以外の値を返します。それ以外はゼロを返します。                             
                                                                             
- 参照 -                                                                     
mblen 　マルチバイト文字の長さ。                                             
wctomb　wchar_tコードからマルチバイト文字に変換する。                        
                                                                             
-----------------------------------------------------------------------------
._memccpy                                                                    
指定文字または指定数までのメモリブロックを複写する                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h> 　　/* 必須 */                                           
void *_memccpy( void *target,                                                
　　　　　　　　void *source,                                                
　　　　　　　　int c,                                                       
　　　　　　　　unsigned kount                                               
　　　　　　　);                                                             
                                                                             
- 内容 -                                                                     
この関数は、sourceからtargetに、文字cが複写されるかkountバイトが複写されるま 
で、バイトを複写します。                                                     
                                                                             
- 戻り値 -                                                                   
この関数は、文字cが見つからなかったとき、NULLを返します。そうでなければ、文字
cの次を指すtargetバイトへのポインタを返します。                              
                                                                             
- 参照 -                                                                     
memchr, memcmp, memcpy, memset                                               
                                                                             
- 例 -                                                                       
#include <memory.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char a[] = "This is a test!! of_memccpy - ignore this";                   
　 char x[100] = "this date will disappear";                                 
　 char *b, *c;                                                              
                                                                             
　 b = &x[0];                                                                
　 c = _memccpy(b, a, '-', 50);                                              
　 *(c + 15) = 0;                                                            
　 c = _memccpy(c, a, '-', 15);                                              
　 puts(x);                                                                  
}                                                                            
                                                                             
- 実行結果 -                                                                 
This is a test!! of _memccpy -This is a test!                                
                                                                             
-----------------------------------------------------------------------------
.memchr                                                                      
指定の文字をメモリ領域から探す                                               
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
void *memchr(const void *s, int c, size_t n);                                
                                                                             
- 内容 -                                                                     
sで参照された位置から始まるnバイトのメモリ領域を、文字c(int cの最下位バイト) 
が最初に見つかるまで、検索します。文字が見つかったとき、その文字へのポインタ 
を返します。そうでないとき、NULLを返します。                                 
                                                                             
- 参照 -                                                                     
findchr コンパイラ内部関数でメモリを検索する。                               
strchr  文字列中の文字の最初の出現を見つける。                               
strcspn 文字列の、別の文字列の文字を含まない頭部の長さを調べる。             
strpbrk 文字列の、別の文字列の文字の最初の出現を見つける。                   
strrchr 文字列中の文字の最後の出現を見つける。                               
strspn  文字列の、別の文字列の文字から構成された頭部の長さを調べる。         
                                                                             
- 例 -                                                                       
/*                                                                           
 このプログラムは、memchrを使って、英字Sの位置を見つけます。                 
*/                                                                           
#include <stddef.h>                                                          
#include <stdio.h>                                                           
#include <string.h>                                                          
                                                                             
void main() {                                                                
　 char *targ = "Sea Shells by the Sea Shore.";                              
　 char *pntr;                                                               
　 char find = 'S';                                                          
　 int len;                                                                  
                                                                             
　 len = strlen(targ);                                                       
　 printf("Search the string '%s'\nfor"                                      
　　　　　" the character '%c'\n",targ,find);                                
　 for (pntr = targ;;pntr++) {                                               
　　　pntr = memchr(pntr, find, len);                                        
　　　if (pntr == NULL)                                                      
　　　　 break;                                                              
　　　printf("There is an '%c' at position %d.\n",                           
　　　　 find,pntr-targ);                                                    
　 }                                                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
Search the string 'Sea Shells by the Sea Shore.'                             
for the character 'S'                                                        
There is an 'S' at position 0.                                               
There is an 'S' at position 4.                                               
There is an 'S' at position 18.                                              
There is an 'S' at position 22.                                              
There is an 'S' at position 32.                                              
                                                                             
-----------------------------------------------------------------------------
.memcmp                                                                      
2つのメモリ領域を比較する                                                    
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
int *memcmp(const void *s1, const void *s2, size_t n);                       
                                                                             
- 内容 -                                                                     
s1で指された場所から始まるnバイトと、s2で指された場所から始まるnバイトを比較 
します。バイトは文字として取り扱われ、比較は辞書式順序で行います。s1のバイト 
がs2のバイトより大きいならば、ゼロより大きい値が返されます。2つの領域が等しい
ならば、ゼロが返されます。s1のバイトがs2のバイトより小さいならば、ゼロより小 
さい値が返されます。                                                         
                                                                             
- 参照 -                                                                     
_memicmp     　バイトを比較する。                                            
strcmp          文字列と文字列を比較する。                                   
strncmp         文字列と文字列をある文字数だけ比較する。                     
                                                                             
- 例 -                                                                       
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char s1[] = "This is testing 1 2 3 4 5";                                  
　 char s2[] = "This is testing 1 2 3 4 5 6";                                
　 int res;                                                                  
　 size_t len = 0;                                                           
                                                                             
　 puts("Testing memcmp...\n");                                              
　 printf("Comparing Strings:\n1: '%s' and\n2:"                              
　　　　　" '%.25s'\n", s1, s2);                                             
　 len = strlen(s1);                                                         
　 res = (memcmp(s1, s2, len));                                              
　 if (res==0)                                                               
　　　printf("s1 is equal to s2.\n\n");                                      
　 else if (res < 0)                                                         
　　　printf("s1 is less than s2.\n\n");                                     
　 else                                                                      
　　　printf("s1 is greater than s2.\n\n");                                  
　 printf("Comparing Strings:\n1: '%s' and\n2:"                              
　　　　　" '%s'\n",s1, s2);                                                 
　 len = strlen(s2);                                                         
　 res = (memcmp(s1, s2, len));                                              
　 if (res==0)                                                               
　　printf("s1 is equal to s2.\n\n");                                        
　 else if(res < 0)                                                          
　　printf("s1 is less than s2.\n\n");                                       
　 else                                                                      
　　printf("s1 is greater than s2.\n\n");                                    
}                                                                            
                                                                             
- 実行結果 -                                                                 
Testing memcmp...                                                            
                                                                             
Comparing Strings:                                                           
1: 'This is testing 1 2 3 4 5' and                                           
2: 'This is testing 1 2 3 4 5'                                               
s1 is equal to s2.                                                           
                                                                             
Comparing Strings:                                                           
1: 'This is testing 1 2 3 4 5' and                                           
2: 'This is testing 1 2 3 4 5 6'                                             
s1 is less than s2.                                                          
                                                                             
-----------------------------------------------------------------------------
.memcpy                                                                      
メモリ上のある場所から別の場所に複写する                                     
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
void *memcpy(void *s1, const void *s2, size_t n);                            
                                                                             
- 内容 -                                                                     
s2で参照される場所からのnバイトから、s1で参照される場所にnバイトを複写しま   
す。s1が返されます。memcpyは、左から右(低アドレスから高アドレス)に複写しま   
す。s2<s1<s2+nであるとき、つまり複写先と複写元の領域が重なっていて、複写先が 
複写元の領域内で始まるとき、_rmemcpy関数を使用してください。                 
                                                                             
- 注意 -                                                                     
memcpyはnバイトを書き込みます。                                              
                                                                             
s2<s1<s2+nのように、複写先と複写元の領域が重なっているとき、その動作は不定で 
す。                                                                         
                                                                             
- 参照 -                                                                     
memset     メモリ領域を初期化する。                                          
_rmemcpy   ある場所から別の場所に、左から右(低アドレスから高アドレス)に複写す
           る。                                                              
_rstrcpy   ある文字列を別の文字列に、右から左(高アドレスから低アドレス)に複写
           する。                                                            
_rstrncpy  ある文字列を別の文字列に、右から左(高アドレスから低アドレス)に、一
           定の文字数だけ複写する。                                          
strcpy     ある文字列を別の文字列に、左から右(低アドレスから高アドレス)に複写
           する。                                                            
strncpy    ある文字列を別の文字列に、左から右(低アドレスから高アドレス)に、  
           一定の文字数だけ複写する。                                        
                                                                             
- 例 -                                                                       
/*                                                                           
 この例は、memcpy関数を使って、int配列の内容を別の配列に複写します。         
*/                                                                           
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void disp_ints();                                                            
void main() {                                                                
　 int i[5] = {1, 2, 3, 4, 5};                                               
　 int j[5] = {0, 0, 0, 0, 0};                                               
                                                                             
　 disp_ints(&i, &j);                                                        
　 memcpy(&j, &i, sizeof(j));                                                
　 disp_ints(&i, &j);                                                        
}                                                                            
                                                                             
void disp_ints(int *i, int *j)  {                                            
　 int c;                                                                    
                                                                             
　 printf("\ni =>");                                                         
　 for (c = 0; c < 5; c++)                                                   
　　　printf(" %d", i[c]);                                                   
　 printf("\nj =>");                                                         
　 for (c = 0; c < 5; c++)                                                   
　　　printf(" %d", j[c]);                                                   
}                                                                            
                                                                             
- 実行結果 -                                                                 
i => 1 2 3 4 5                                                               
j => 0 0 0 0 0                                                               
i => 1 2 3 4 5                                                               
j => 1 2 3 4 5                                                               
                                                                             
-----------------------------------------------------------------------------
._memicmp                                                                    
大文字小文字を区別しないで文字列を比較する                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
int memicmp(void *ptr1, void *ptr2, unsigned kount);                         
                                                                             
- 内容 -                                                                     
この関数は、ptr1およびptr2から始まる2つのメモリ領域を、kountバイト続けて比較 
します。比較では、大文字と小文字を区別しません。各文字はテンポラリ領域で小文 
字に変換され、次に比較されます。それらの文字が等しいならば、kountバイトを比較
してしまうまで、次のバイトを比較し続けます。                                 
                                                                             
- 戻り値 -                                                                   
すべてのバイトが等しいとき、ゼロを返します。等しくないバイトが見つかったと   
き、ptr1で指されるバイト位置がptr2のバイト位置よりも小さいならば、負の値を返 
します。そうでなければ、正の値を返します。                                   
- 参照 -                                                                     
_memccpy, memchr, memcmp, memcpy, memset                                     
                                                                             
- 例 -                                                                       
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char a[]  ="tHIS iS a tEST Z1";                                           
　 char b[]  ="This Is A Test z2";                                           
　 char aa[] ="tHIS iS a tEST ZA1";                                          
　 char bb[] ="This Is A Test za2";                                          
　 char c[]  ="[]";                                                          
　 char d[]  ="{}";                                                          
　 char e[]  ="1234";                                                        
　 char f[]  ="5678";                                                        
                                                                             
　 if (memicmp(a,b,(size_t)16) == 0)                                         
　　　puts("memicmp equal test ok");                                         
　 else                                                                      
　　　puts("memicmp equal test failed");                                     
　 if (memicmp(c,d,(size_t)2) == 0)                                          
　　　puts("memicmp unequal test failed");                                   
　 else                                                                      
　　　puts("memicmp unequal test ok");                                       
　 if (memicmp(e,e,(size_t)4) == 0)                                          
　　　puts("memicmp equal2 test ok");                                        
　 else                                                                      
　　　puts("memicmp equal2 test failed");                                    
　 if (memicmp(e,f,(size_t)4) == 0)                                          
　　　puts("memicmp unequal test failed");                                   
　 else                                                                      
　　　puts("memicmp unequal test ok");                                       
　 if (memicmp(a,b,(size_t)17) == 0)                                         
　　　puts("memicmp equal3 test failed");                                    
　 else                                                                      
　　　puts("memicmp equal3 test ok");                                        
　 if (memicmp(a,b,(size_t)18) == 0)                                         
　　　puts("memicmp equal4 test failed");                                    
　 else                                                                      
　　　puts("memicmp equal4 test ok");                                        
　 if (memicmp(aa,bb,(size_t)17) == 0)                                       
　　　puts("memicmp equal5 test ok");                                        
　 else                                                                      
　　　puts("memicmp equal5 test failed");                                    
}                                                                            
                                                                             
- 実行結果 -                                                                 
memicmp eaual test ok                                                        
memicmp unequal test ok                                                      
memicmp eaual2 test ok                                                       
memicmp unequal test ok                                                      
memicmp equal3 test ok                                                       
memicmp equal4 test ok                                                       
memicmp equal5 test ok                                                       
                                                                             
-----------------------------------------------------------------------------
.memmove                                                                     
メモリを非破壊的に複写する                                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
void *memmove(void *target,                                                  
　　　　　　　const void *source,                                            
　　　　　　　size_t n                                                       
　　　　　　　);                                                             
                                                                             
- 内容 -                                                                     
sourceで参照される場所からtargetで参照される場所にnバイトを複写します。      
複写は、複写元と複写先の領域が重なっていても、正しく行われます。             
                                                                             
- 注意 -                                                                     
memmoveは、第2引数を最初の引数に複写します。                                 
                                                                             
- 参照 -                                                                     
memcpy　　 　　ある場所から別の場所にメモリを複写する。                      
_rmemcpy   　  ある場所から別の場所にメモリを複写する。                      
                                                                             
-----------------------------------------------------------------------------
.memset                                                                      
メモリ領域を指定文字で初期化する                                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>     /* 必須 */                                           
void *memset(void *s, int c, size_t n);                                      
                                                                             
- 内容 -                                                                     
文字c(int cの最下位バイト)を、sで指された場所から始まるnバイトの各々に複写し 
ます。                                                                       
                                                                             
- 注意 -                                                                     
memsetは、nバイト書き込みます。                                              
memsetは、｢2.6節 関数と引数｣で議論された慣習に適合するために、cをchar引数より
むしろintとして受け取ります。型charのオブジェクトがmemsetに渡されたとき、自動
的に型intに強制されます。                                                    
                                                                             
- 参照 -                                                                     
memcpy  ある場所から別の場所にメモリを複写する。                             
strcpy  ある文字列から別の文字列に文字を複写する。                           
strncpy ある文字列から別の文字列に文字を一定数だけ複写する。                 
                                                                             
- 例 -                                                                       
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void strip (char *s1, char *s2) {                                            
　 int i;                                                                    
　 while (*s1 != 0) {  /*s1の終わりでないならば、*/                          
　　　/*s1を、s2に現れないs1の最初の文字に設定する。*/                       
　　　s1 += strspn(s1, s2);                                                  
　　　/*iを、s2の文字を含まないs1の先頭部の長さに設定する。*/                
　　　/*このような各文字にNULを書き込む。*/                                  
　　　memset(s1, 0, i = strcspn(s1, s2));                                    
　　　/*s1を、最後のNULが書かれた後の文字を指すように設定する。*/            
　　　s1 += i;                                                               
　 }                                                                         
}                                                                            
                                                                             
void main() {                                                                
　 char *s1 = "Those funny char's are leaving! --->!#$";                     
　 char *s2 = "Those funny char's are leaving!";                             
                                                                             
　 puts(s1);                                                                 
　 strip(s1, s2);                                                            
　 puts(s1);                                                                 
　 }                                                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
Those funny char's are leaving! --->!#$                                      
Those funny char's are leaving!                                              
                                                                             
-----------------------------------------------------------------------------
._mkdir                                                                      
新しいディレクトリを作成する                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <direct.h>        /*  必須 */                                       
int _mkdir(char *path);                                                      
                                                                             
- 内容 -                                                                     
_mkdir関数は、pathで指定された新ディレクトリを作成します。pathの各構成要素   
は、最後を除いて、既に存在するディレクトリを参照していなければなりません。   
マルチレベルのディレクトリ構造を作成するには、各構成要素に対して別々に_mkdir 
を呼び出してください。例えば、                                               
                                                                             
_mkdir("c:\\top");                                                           
_mkdir("c:\\top\\next");                                                     
_mkdir("c:\\top\\next\\bottom");                                             
　または、もしc:\top\nextが既に存在するならば、以下のようにします。          
                                                                             
_mkdir("c:\\top\\next\\bottom");                                             
                                                                             
- 戻り値 -                                                                   
_mkdir関数は、新しいディレクトリを作成できたならば、ゼロを返します。呼び出し 
の結果がエラーならば、-1を返し、errnoに次の値の1つを設定します。             
                                                                             
┌─────┬────────────────────────────┐     
│　　値　　│　　　　　　　　　　意　　　　　味　　　　　　　　　　　│     
├─────┼────────────────────────────┤     
│　EACCES  │ディレクトリが作成できません。パス名が存在している　　　│     
│　　　　　│ディレクトリを参照しています。　　　　　　　　　　　　　│     
│　ENOENT　│パス名が見つかりません。パス名の要素がありません。　　　│     
└─────┴────────────────────────────┘     
                                                                             
- 参照 -                                                                     
_chdir,_getcwd,_rmdir                                                        
                                                                             
- 例 -                                                                       
/*                                                                           
 このプログラムは，ディレクトリを作成します。                                
*/                                                                           
#include <stdio.h>                                                           
#include <direct.h>                                                          
#include <time.h>                                                            
                                                                             
void main() {                                                                
　 /*新しいディレクトリを作成する。*/                                        
　 char a[20]="c:\\";                                                        
　 _strtime(&a[3]);                                                          
　 a[5]='-';                                                                 
　 a[8]='-';                                                                 
　 if (_mkdir(a) == -1)                                                      
　　　perror("Error in _mkdir.");                                            
　 else                                                                      
　　　printf("Directory %s successfully created.\n",a);                      
}                                                                            
                                                                             
- 実行結果 - (変化する)                                                      
Directory c:\14-46-41 successfully created.                                  
                                                                             
-----------------------------------------------------------------------------
._mktemp                                                                     
唯一のファイル名(クリエイトまたはオープンできない)を作成する                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <io.h> /* 必須 */                                                   
char *_mktemp(char *template);                                               
                                                                             
- 内容 -                                                                     
_mktemp関数は、以下の形式(ただし、baseは0,1または2文字から成る列)            
                                                                             
baseXXXXXX                                                                   
を持つtemplate引数を操作して、唯一の名前を生成します。_mktemptempalteの6個のX
を、英数字に続く5桁の数字に置き換えます。最初の呼び出したとき英数字が0であれ 
ば、英小文字aからzに続きます。5桁の数字の値は、呼び出しプロセスを識別するプロ
セスID(_getpidを参照)です。                                                  
                                                                             
繰り返して呼び出すと、_mktempは以前に返された名前が、同じ名前のファイルとして
存在するかどうかを調べます。利用できる名前がなければ、_mktempはテンプレートの
英数字を1増加させて，新しい名前を作成します。                                
                                                                             
- 戻り値 -                                                                   
_mktemp関数は新しい唯一のファイル名を作成できないとき、またはテンプレート引数
が正しい形式でないとき、NULLを返します。そうでなければ、新しい修正されたテン 
プレートへのポインタを返します。                                             
                                                                             
- 参照 -                                                                     
fopen,_getpid,_open                                                          
                                                                             
- 例 -                                                                       
/*                                                                           
 このプログラムは、新しい唯一のファイル名を作成するために_mktempを呼び出し、 
それからfopenを呼び出してそのファイルをオープンします。                      
*/                                                                           
#include <stdio.h>                                                           
#include <process.h>                                                         
#include <io.h>                                                              
                                                                             
FILE *stream1, *stream2;                                                     
char *tempname;                                                              
                                                                             
void main() {                                                                
　 if ((tempname = _mktemp("myXXXXXX")) == NULL)                             
　　　printf("_mktemp failed on file 1\n");                                  
　 else{                                                                     
　　　stream1 = fopen(tempname, "w");                                        
　　　printf("Opened temp file %s\n", tempname);                             
　　　if ((tempname = _mktemp("myXXXXXX")) == NULL)                          
　　　　 printf("_mktemp failed on file 2\n");                               
　　　else {                                                                 
　　　　 stream2 = fopen(tempname, "w");                                     
　　　　 printf("Opened temp file %s\n", tempname);                          
　　　　 fclose(stream2);                                                    
　　　}                                                                      
　　　fclose(stream1);                                                       
　 }                                                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
Opened temp file myd00036                                                    
Opened temp file mye00036                                                    
                                                                             
-----------------------------------------------------------------------------
.mktime                                                                      
struct tmをtime_tに変換する                                                  
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <time.h>       /* 必須 */                                           
time_t mktime(struct tm *tptr);                                              
                                                                             
- 内容 -                                                                     
この関数は、tptrによって指されたtm構造体に記述された地域時間を取り、time関数 
で返された時刻形式と同等の形式に変換します。tm構造体の値は正確であるべきです 
が、標準の範囲内にある必要はありません。tm_wdayとtm_yearフィールドは無視され 
ます。時刻を計算し、そして正確な値をtm構造体のフィールドに設定するために、   
localtime関数を実行します。                                                  
                                                                             
mktime関数は、環境変数TZに依存します。TZが設定されていないとき、協定世界時   
(UTC)をデフォルトにします。                                                  
                                                                             
- 戻り値 -                                                                   
この関数は、tm構造体で与えられる地域時間に同等なカレンダ時間を返します。     
                                                                             
- 参照 -                                                                     
asctime, gmtime, localtime, time, tm                                         
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <time.h>                                                            
                                                                             
void main() {                                                                
　 time_t t;                                                                 
　 struct tm *p;                                                             
                                                                             
　 time(&t);                                                                 
　 p = localtime(&t);                                                        
　 printf("The time is %ld.\n", mktime(p));                                  
}                                                                            
                                                                             
- 実行結果 - (変化する)                                                      
The time is 655679912.                                                       
                                                                             
-----------------------------------------------------------------------------
.modf                                                                        
doubleを整数部と小数部に分離する                                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <math.h>       /* 必須 */                                           
double modf(double value, double *iptr);                                     
                                                                             
- 内容 -                                                                     
valueの小数部を返します。valueの整数部は、iptrで指されたオブシェクトに格納さ 
れます。                                                                     
                                                                             
- 参照 -                                                                     
frexp   doubleを仮数部と指数部に分離する。                                   
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <math.h>                                                            
                                                                             
void main() {                                                                
　 double x, i;                                                              
                                                                             
　 x = modf(2.4, &i);                                                        
　 printf("%e %e", x, i);                                                    
}                                                                            
                                                                             
- 実行結果 -                                                                 
4.000000e-01 2.000000e+00                                                    
                                                                             
-----------------------------------------------------------------------------
._move                                                                       
バイトをアドレスからアドレスに移動する(コンパイラ内部関数)                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
void _move(void *from, void *to , unsigned len);                             
                                                                             
- 内容 -                                                                     
_move関数は、アドレス((char *)from)からアドレス((char *)to)に、lenバイト移動 
します。この移動は、右から左(低アドレスから高アドレス)に行います。from < to <
 from+lenのとき、関数_move_rightを使用してください。                         
                                                                             
この関数は、標準ライブラリのmemcpy関数を実現するために使われています。       
                                                                             
#define memcpy(dest,src,len) _move(src,dest,len)                             
                                                                             
- 参照 -                                                                     
memmove,memcpy,_movedata,_move_right                                         
                                                                             
- 例 -                                                                       
#include <string.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char array1[40] =                                                         
　　　"                          QRSTUVWXYZ";                                
　 char array2[40] =                                                         
　　　"1234567890abcdefghijklmnopqrstuvwxyz";                                
　 char *dest = &array2[0], *source = array1;                                
　 int i;                                                                    
                                                                             
　 _move(dest,source,26);                                                    
　 puts("Array 2 is moved into Array 1.");                                   
　 puts("Now Array 1 looks like this:");                                     
　 for (i = 0; i <= 37; i++)                                                 
　　　putchar(array1[i]);                                                    
　 printf("\n");                                                             
}                                                                            
                                                                             
- 実行結果 -                                                                 
Array 2 is moved into Array 1.                                               
Now Array 1 looks like this:                                                 
1234567890abcdefghijklmnopQRSTUVWXYZ                                         
                                                                             
-----------------------------------------------------------------------------
._movedata                                                                   
バイトをメモリ上の任意の場所に移動する                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <string.h>                                                          
void _movedata(                                                              
　 unsigned int from_seg,                                                    
　 unsigned int from_offset,                                                 
　 unsigned int to_seg,                                                      
　 unsigned int to_offset,                                                   
　 unsigned int kount                                                        
　 );                                                                        
                                                                             
- 内容 -                                                                     
この関数は、kountバイトを、任意のセグメント:オフセットで指定されたアドレスか 
ら、他のセグメント:オフセットで指定されたアドレスに複写します。複写は、どのよ
うなフィールドの重なりにも関わらず、右から左(低メモリアドレスから高メモリアド
レス)に行います。ハードウェアの能力に依存して、バイト、ワード、ダブルワードの
移動が使われます。                                                           
                                                                             
- 戻り値 -                                                                   
なし                                                                         
                                                                             
- 参照 -                                                                     
FP_OFF,FP_SEG,memcpy,memmove,move,segread                                    
                                                                             
- 例 -                                                                       
#include <memory.h>                                                          
void main() {                                                                
　 unsigned int scrn;                                                        
                                                                             
　 for (scrn = 1; scrn<21; scrn++)                                           
　　　printf("This is screen line %d.\n"                                     
　　　　　　 "  %*s%*s",scrn,scrn," ",scrn," ");                             
　 if (sizeof(int) == 2)                                                     
　　　scrn = 0xb000;                                                         
　 else                                                                      
　　　scrn = 0x1c;      /*386 ネイティブモード*/                             
                                                                             
　 _movedata(scrn, 0, scrn, 80 * 24, 80 * 12);                               
}                                                                            
                                                                             
- 実行結果 - (出力はクリア後の画面に依存する)                                
c:\>run386 movedata                                                          
This is screen line 1.                                                       
　　This is screen line 2.                                                   
　　　This is screen line 3.                                                 
　　　　This is screen line 4.                                               
　　　　　This is screen line 5.                                             
　　　　　　This is screen line 6.                                           
　　　　　　　This is screen line 7.                                         
　　　　　　　　This is screen line 8.                                       
　　　　　　　　　This is screen line 9.                                     
　　　　　　　　　　This is screen line 10.                                  
                                                                             
c:\>run386 movedata                                                          
This is screen line 1.                                                       
　　This is screen line 2.                                                   
　　　This is screen line 3.                                                 
　　　　This is screen line 4.                                               
　　　　　　　　　　　　　 This is screen line 17.                           
　　　　　　　　　　　　　　 This is screen line 18.                         
　　　　　　　　　　　　　　　 This is screen line 19.                       
　　　　　　　　　　　　　　　　 This is screen line 20.                     
                                                                             
-----------------------------------------------------------------------------
._move_right                                                                 
バイトをアドレスからアドレスに、右から左に移動する(コンパイラ内部関数)       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
void _move_right(void *from, void *to , unsigned  len);                      
                                                                             
- 内容 -                                                                     
_move_rightは、右から左(高アドレスから低アドレス)に移動する点を除いて、_move 
と同じです。to < from < to+lenのときは、_move関数を使用してください。        
                                                                             
- 参照 -                                                                     
memmove,memcpy,_move,_movedata                                               
                                                                             
-----------------------------------------------------------------------------
._nfree                                                                      
メモリブロックを解放する(スモールデータモデル専用)                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <malloc.h>     /* 必須 */                                           
void _nfree(void *array);                                                    
                                                                             
- 内容 -                                                                     
_nfree関数は、メモリブロックを解放します。引数arrayは、以前にmallocまたは    
_nmallocを呼び出して割り当てられたメモリブロックを指します。                 
                                                                             
- 戻り値 -                                                                   
なし                                                                         
                                                                             
- 注意 -                                                                     
この関数は、他のコンパイラとの互換性のために提供されています。この関数はHigh 
Cと他のコンパイラの間で移植可能ではないので、これを避けてfreeを使うべきです。
                                                                             
- 参照 -                                                                     
malloc,free,_nmalloc                                                         
                                                                             
- 例 -                                                                       
#include <malloc.h>                                                          
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char *new_array;                                                          
　 new_array = _nmalloc (5000 * sizeof(long));                               
                                                                             
　 if (new_array == NULL) {                                                  
　　　printf("\nfree:Not enough memory"                                      
　　　　　　 "for 5,000 longs\n");                                           
　 }                                                                         
　 else{                                                                     
　　　printf("\nfree: Allocated 5,000 longs at %x \n",                       
　　　　　　 new_array);                                                     
　　　printf("\nfree: Dellocating memory block at %x \n",                    
　　　　　　 new_array);                                                     
                                                                             
　　　_nfree(new_array);                                                     
　 }                                                                         
}                                                                            
                                                                             
- 実行結果 - (アドレスは変化する)                                            
nfree: Allocated 5,000 longs at                                              
nfree: Dellocating memory block at                                           
                                                                             
-----------------------------------------------------------------------------
._nmalloc                                                                    
nearヒープにメモリブロックを割り当てる(スモールデータモデル専用)             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <malloc.h>     /* 必須 */                                           
void _Near _nmalloc(size_t size);                                            
                                                                             
- 内容 -                                                                     
_nmalloc関数は、デフォルトデータセグメントに、少なくともsizeバイトの配列を割 
り当てます。メモリブロックはアライメント情報とメインテナンス情報を必要としま 
すので、sizeより大きくメモリブロックを割り当てることがあります。             
_nmalloc関数は、割り当てられたメモリ空間へのvoid Nearポインタを返します。    
                                                                             
High Cは、他の市販のコンパイラと異なって、高度に最適化されたメモリ管理システ 
ムを提供しています。_nmallocは、実際にHigh Cの標準malloc関数に写像されます。 
                                                                             
- 戻り値 -                                                                   
この関数は、割り当てられた領域へのvoid _Nearポインタを返します。この領域は、 
任意の型のオブジェクトに対して、適切にアラインされていることを保証していま   
す。リクエストを満足できないとき、戻り値はNULLです。                         
                                                                             
- 注意 -                                                                     
この関数は、他のコンパイラとの互換性のために提供されています。この関数はHigh 
Cと他のコンパイラの間で移植可能ではないので、これを避けてmallocを使うべきで  
す。                                                                         
                                                                             
- 参照 -                                                                     
calloc,_fmalloc,free,halloc,hfree,malloc,realloc                             
                                                                             
- 例 -                                                                       
#include <stdio.h>                                                           
#include <malloc.h>                                                          
                                                                             
void main() {                                                                
　 char *new_array;                                                          
                                                                             
　 new_arry = _nmalloc(15000 * sizeof(long));                                
                                                                             
　 if (new_array == NULL) {                                                  
　　　printf("_nmalloc: Not enough memory"                                   
　　　　　　 " for 15,000 long.\n");                                         
　　　new_array = _nmalloc(5000 * sizeof(longs)  );                          
　　　if (new_array == NULL) {                                               
　　　　 printf("_nmalloc: Not enough memory"                                
　　　　　　　　" for 5,000 longs.\n");                                      
　　　}                                                                      
　　　 else {                                                                
　　　　 printf("_nmalloc:Allocated 5000 longs"                              
　　　　　　　　" at %lx \n", new_array);                                    
　　　}                                                                      
　 }                                                                         
　 else                                                                      
　　　printf("_nmalloc: Allocated 15,000 longs"                              
　　　　　　 " at %lx \n", new_array);                                       
}                                                                            
                                                                             
- 実行結果 - (変化する)                                                      
_nmalloc: Not enough memory for 15,000 longs.                                
_nmalloc: Allocated 5000 longs at 138600fe                                   
                                                                             
-----------------------------------------------------------------------------
.NULL                                                                        
ヌルポインタを表すために使われるマクロ                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>      /* 必須 */                                           
                                                                             
- 内容 -                                                                     
任意のデータポインタ型と代入互換性があり、定数ゼロと比較して等しくなる値に展 
開されます。よってヌルポインタの表現として最適です。ポインタのサイズは文字NUL
のサイズと同じではないので、NULLは文字列の終了文字として使えないことに注意し 
てください。                                                                 
                                                                             
NULLはlocal.h,stddef.h,stdio.h,stdlib.h,string.h,time.hで定義されています。  
                                                                             
-----------------------------------------------------------------------------
.offsetof                                                                    
構造体の要素のオフセットを調べる                                             
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stddef.h>     /* 必須 */                                           
size_t offsetof(type, identifier);                                           
                                                                             
- 内容 -                                                                     
構造体内の構造体要素のオフセットを調べます。typeは構造体の型です。           
identifierは要素の名前です。結果は、構造体のはじまりからの要素のオフセットを 
バイト単位で返します。指定された要素がビットフィールドであるとき、動作は不定 
です。                                                                       
                                                                             
offsetofはマクロとしてのみ提供されています。                                 
                                                                             
- 参照 -                                                                     
_offsetof                                                                    
                                                                             
- 例 -                                                                       
_offsetofで提供されている例を参照してください。                              
                                                                             
-----------------------------------------------------------------------------
._offsetof                                                                   
structまたはunion構造体のフィールドオフセットを得る(コンパイラ内部関数)      
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
_offsetof(any_struct_type, any_field_name)                                   
_offsetof(any_expression_of_a_struct_type, any_field_name)                   
                                                                             
- 内容 -                                                                     
_offsetofは、予め定義された関数というよりは、実際には句構造文法への追加です。
最初の引数の構文は、sizeofと同じです。つまり、構造体型のある式か、構造体型の 
抽象宣言子です。その結果は、sizeofと同じ型をもち、構造体のはじまりからの指定 
フィールドのバイトオフセットを意味します。名前フィールドは、もちろん指定され 
た構造体型の要素でなければなりません。                                       
                                                                             
_offsetofは、ANSI標準によって要求されるoffsetofマクロを実現するために、用意さ
れています。                                                                 
                                                                             
#define offsetof(Type, Field) \                                              
　　 　_offsetof(Type, Field)                                                
しかし、_offsetof関数は、第1引数として(sizeofのように)型の代わりに引数の式が 
使えますから、より柔軟性があります。                                         
                                                                             
- 例 -                                                                       
/*                                                                           
 第1引数はいつもstruct型であると仮定されていることに、注意してください。     
*/                                                                           
                                                                             
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 struct s{                                                                 
　　　char x, y;                                                             
　　　int a[10];                                                             
　 } x;                                                                      
                                                                             
　 printf("Offset of x is %d\n",_offsetof(struct s,x));                      
　 printf("Offset of y is %d\n",_offsetof(struct s,y));                      
/*                                                                           
　 _offsetofは struct xと char xを区別します。                               
*/                                                                           
　 printf("Offset of a is %d\n",_offsetof(x,a));                             
}                                                                            
                                                                             
- 実行結果 -                                                                 
Offset of x is 0                                                             
Offset of y is 1                                                             
Offset of a is 2                                                             
                                                                             
-----------------------------------------------------------------------------
._open                                                                       
パス名でファイルハンドルをオープンする                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <io.h>                                                              
#include <stat.h>                                                            
#include <types.h>                                                           
#include <fcntl.h>                                                           
int _open(char *pathname,                                                    
　　　　　int flags);   /*既に存在するファイルのとき*/                       
int _open(char *pathname,                                                    
　　　　　int flags,                                                         
　　　　　int mode);    /*新しいファイル*/                                   
                                                                             
- 内容 -                                                                     
_open関数は、既存のファイルをオープンしたり、新しいファイルを作成します。読み
込み専用、書き込み専用、読み書き両用でオープンできます。これらの動作は、     
fcnt.hで定義されたflagによって制御されます。両立できるフラグは、OR演算子|で結
合することができます。                                                       
                                                                             
┌───────┬───────────────────────────┐   
│　　フラグ　　│　　　　　　　　　　意　　　　　味　　　　　　　　　　│   
├───────┼───────────────────────────┤   
│_O_APPEND     │追加モードでオープンします。すべての書き込みはファイル│   
│　　　　　　　│の終わりから実行され、既にファイルにあるデータを拡張し│   
│　　　　　　　│ます。　　　　　　　　　　　　　　　　　　　　　　　　│   
│_O_BINARY     │バイナリモードでオープンします。特殊文字の変換は、実行│   
│　　　　　　　│されません。すべての文字は、変更されずに渡されます。　│   
│_O_CREAT      │ファイルが既に存在しなければ、ファイルをクリエイトしま│   
│　　　　　　　│す。ファイルが既に存在するとき、フラグは無視されます。│   
│_O_EXCL       │ファイルが既に存在すると、エラーを返します。ファイルは│   
│　　　　　　　│新しいファイルのときのみオープンされます。_O_CREATのみ│   
│　　　　　　　│と、共に指定することができます。　　　　　　　　　　　│   
│_O_RDONLY   　│ファイルが書き込まれないことを指定します。読み込みのみ│   
│　　　　　　　│が実行されます。　　　　　　　　　　　　　　　　　　　│   
│_O_RDWR     　│読み書き両用でオープンします。　　　　　　　　　　　　│   
│_O_TEXT     　│テキストモード変換を可能にして、ファイルをオープンしま│   
│　　　　　　　│す。これは、Cの行の終わり\nと、DOSの行の終わり\r\nの間│   
│　　　　　　　│を変換します。またControl-Zをend-of-fileマーカとして扱│   
│　　　　　　　│います。　　　　　　　　　　　　　　　　　　　　　　　│   
│_O_TRUNC 　 　│指定されたパス名でオープンする前に、既に存在するファイ│   
│　　　　　　　│ルを消去します。この効果はファイルに書き込まれるため、│   
│　　　　　　　│ファイルは書き込みが許可されていなければなりません。　│   
│_O_WRONLY   　│ファイルが読み込まれないことを指定します。しかし、書き│   
│　　　　　　　│込みのみが実行されます。　　　　　　　　　　　　　　　│   
└───────┴───────────────────────────┘   
                                                                             
- 注意 -                                                                     
_O_RDONLY,_O_RDWR,_O_WRONLYのただ1つだけが指定可能です。                     
オープン時にファイル中の全ての存在するデータを破壊するので、注意して_O_TRUNC 
フラグを使用してください。                                                   
                                                                             
_O_CREATフラグは、新しいファイルがクリエイトされてもよいことを指定します。新 
しいファイルは、modeパラメータによって属性が与えられます。可能なmodeの値は、 
stat.h(このファイルは、sysサブディレクトリに配置されていることがあり、       
sys\stat.h)で定義されています。ファイルは、読み込み可能または書き込み可能また
は読み書き可能でクリエイトされます。DOSでは、すべてのファイルは読み込み可能な
ので、読み込み可能は他のシステムとの互換性のために含まれており、ここでは無視 
されます。                                                                   
                                                                             
┌────────────┬───────────────────────┐ 
│        mode        　　│　　　　　　　意　　　　　　味　　　　　　　  │ 
├────────────┼───────────────────────┤ 
│_S_IWRITE  　　　       │クローズ後そして後で再オープンしたとき、ファイ│ 
│　　　　　　　　　　　　│ルへの再書き込みを許可します。DOSではこのモー │ 
│　　　　　　　　　　　　│ドは使えません。DOSは書き込み専用ファイルを確 │ 
│　　　　　　　　　　　　│識せず、読み書きファイルとして扱います。      │ 
│_S_IREAD 　　　　　     │クローズ後そして後で再オープンしたとき、ファイ│ 
│　　　　　　  　　　　　│ルからの読み込みを許可します。  　　　　　　　│ 
│_S_IREAD|_S_IWRITE      │読み書きを共に許可します。　　　　　　　　　　│ 
└────────────┴───────────────────────┘ 
                                                                             
ファイルのmodeは、ファイルが最初にクローズしたとき、有効になります。最初のク 
ローズ後の任意のオープンは、ここで与えられた許可によって制御されます。       
                                                                             
ファイルの許可を設定する前に、_open関数はそのモードをumaskによって設定された 
現在のファイル許可マスクに適用します。                                       
                                                                             
- 戻り値 -                                                                   
ファイルのオープンに成功すると、ファイルハンドルを返します。エラーのときは、 
-1を返し、errnoに次の表の値の1つを設定します。                               
                                                                             
┌─────┬────────────────────────────┐     
│　　値　　│　　　　　　　　　意　　　　　　　味　　　　　　　　　　│     
├─────┼────────────────────────────┤     
│　EACCESS │パス名で指定されたファイルをアクセスできません。パス名が│     
│　　　　　│読み込み専用ファイルか、ディレクトリか、またはネットワー│     
│　　　　　│ク上で共有ファイルの競合が発生しています。　　　　　　　│     
│　EEXIST  │既に存在するファイルを示しているので、新たにクリエイトで│     
│　　　　　│きません。　　　　　　　　　　　　　　　　　　　　　　　│     
│　EINVAL  │引数が正しくありません。　　　　　　　　　　　　　　　　│     
│　EMFILE  │ファイルハンドルが不足しています。　　　　　　　　　　　│     
│　ENOENT  │パス名がみつかりません。　　　　　　　　　　　　　　　　│     
└─────┴────────────────────────────┘     
                                                                             
- 参照 -                                                                     
_access      ファイルのアクセス権を調べる。                                  
_chmod 　　　ファイルに設定されている許可を変更する。                        
_creat 　　　空ファイルを作成する。                                          
_fdopen      オープンされたハンドルにストリームを結びつける。                
_fsopen      ファイルをオープンし、シェアリングモードを設定する。            
lseek   　　　ファイルの現在位置を変更する。                                 
_open  　　　パス名でファイルハンドルをオープンする。                        
_sopen 　　　パス名で共有モードでファイルをオープンする。                    
_stat　　　　ファイルまたはディレクトリについての情報を得る。                
tell  　　　  ファイルの現在位置を報告する。                                 
_umask 　　　ファイル許可マスクを設定する。                                  
                                                                             
- 例 -                                                                       
#include <io.h>                                                              
#include <fcntl.h>                                                           
#include <sys\stat.h>                                                        
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 int pan;                                                                  
                                                                             
　 pan = _open("test.dat",O_RDONLY | O_TEXT);                                
　 if (pan != -1)                                                            
　　　printf("file test.dat exists, handle=%d\n",pan);                       
　 else                                                                      
　　　printf("file test.dat cannot be opened,"                               
　　　　　　 " error code=%d\n",pan);                                        
                                                                             
　 pan=_open("open.tmp",                                                     
　　　　　　　O_CREAT | O_BINARY | O_EXCL,                                   
　　　　　　　O_IREAD | O_IWRITE);                                           
　 if (pan == -1)                                                            
　　　printf("cannot create file open.tmp,"                                  
　　　　　　 " error code=%d\n",pan);                                        
　 else                                                                      
　　　pirntf("file open.tmp has been created,"                               
　　　　　　 " handle=%d\n",pan);                                            
                                                                             
　 pan=_open("open.tmp",                                                     
　　　　　　　O_CREAT | O_BINARY | O_TRUNC,                                  
　　　　　　　O_IREAD | O_IWRITE);                                           
　 if (pan == -1)                                                            
　　　printf("cannot truncate file open.tmp,"                                
　　　　　　 " error code=%d\n",pan);                                        
　 else                                                                      
　　　printf("file open.tmp has been truncated,"                             
　　　　　　 " handle=%d\n",pan);                                            
}                                                                            
                                                                             
- 実行結果 -                                                                 
file test.dat exists, handle=5                                               
file open.tmp has been created, handle=6                                     
file open.tmp has been truncated, handle=7                                   
                                                                             
-----------------------------------------------------------------------------
._outsb                                                                      
._outsd                                                                      
._outsw                                                                      
._outb                                                                       
._outd                                                                       
._outw                                                                       
ポート出力の内部関数                                                         
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
void _outsb(int port , void *buf, int count);                                
void _outsw(int port , void *buf, int count);                                
void _outsd(int port , void *buf, int count);                                
void _outb(int port , int data);                                             
void _outw(int port , int data);                                             
void _outd(int port , int data);                                             
                                                                             
- 内容 -                                                                     
最初の3つの関数は、ポートへのストリーム出力を実行します。                    
                                                                             
_outsb, _outsd, _outsw関数はREP OUTS命令を生成します。この命令を使うには、buf
引数をesiレジスタに、countをecxレジスタに、それぞれロードします。            
                                                                             
最後の3つの関数は、ポートに1回の出力操作を実行します。                       
_outbは、以下のように翻訳されます。                                          
                                                                             
 mov dx,port;                                                                
 mov al, data;                                                               
 out dx,al;                                                                  
_outwと_outd関数も同様に実行されます。                                       
                                                                             
- システム依存 -                                                             
この命令は、High Cの80386/486バージョンのみでサポートされています。他の異なる
アーキテクチャ間の移植性が出てくるとき、このことに注意してください。         
                                                                             
- 参照 -                                                                     
_inp,_inpw,_outp,_outpw                                                      
                                                                             
-----------------------------------------------------------------------------
._outp                                                                       
._outpw                                                                      
ハードウェアポートに1バイトまたは1ワードを出力する                           
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <conio.h>      /* 関数宣言のために必須 */                           
int _outp (unsigned int portadr, int data);                                  
int _outpw(unsigned int portadr, unsigned intdata);                          
                                                                             
- 内容 -                                                                     
_outp関数は、portadrで示されたハードウェアポートに8ビットdataを出力します。  
_outw関数はportadrで示されたハードウェアポートに16ビットdataを出力します。値 
は、そのデータ型のハードウェアの実現によってのみ制限されます。               
各関数は、ハードウェアポートアドレスに出力されたdata項目の値を返します。     
エラーを見つけたり、表示したりすることはできません。                         
                                                                             
- 参照 -                                                                     
コンパイラ内部関数:_inp,_inpw,_inw,_outb,_outw                               
関数:outp,outpw                                                              
                                                                             
- 例 -                                                                       
#include <conio.h>                                                           
#define MHZ 20                                                               
                                                                             
void main() {                                                                
　 volatile int j;                                                           
　 int k, n;                                                                 
                                                                             
　 printf("Listen to the tone.\n");                                          
                                                                             
　 for (n = 0; n < 500; n++){                                                
　　　k = inp(0x61) & 0xfc;                                                  
　　　outp(0x61, k | 2);                                                     
　　　for (j = 0; j < 5 * MHZ; j++);    /* Listen */                         
　　　outp(0x61, k | 2);                                                     
　　　for (j = 0; j < 10 * MHZ; j++);   /*  to    */                         
　　　outp(0x61, k | 2);                                                     
　　　for (j = 0; j < 10 * MHZ; j++);   /*  the   */                         
                                                                             
　　　outp(0x61, k | 2);                                                     
　　　for (j = 0; j < 20 * MHZ; j++);   /*  tone. */                         
　 }                                                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
Listen to the tone.                                                          
                                                                             
-----------------------------------------------------------------------------
.perror                                                                      
エラーメッセージを表示する                                                   
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>      /* 必須 */                                           
void perror(const char *s);                                                  
                                                                             
- 内容 -                                                                     
文字列s、次に" :"を画面に表示した後、次にerrnoの現在値に関連したエラーメッセ 
ージ、最後に改行を、標準エラー出力に出力します。引数sがNULL、またはsの最初の 
文字がNUL文字のとき、" :"は出力されません。                                  
                                                                             
- 例 -                                                                       
/*                                                                           
 このプログラムは、ファイルexists.notをオープンしようとし、オープンに失敗した
とき、perrorを実行します。                                                   
*/                                                                           
                                                                             
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 FILE *FP1;                                                                
                                                                             
　 if ((FP1 = fopen("exists.not","r")) == NULL) {                            
　　　perror("exists.not");                                                  
　 }                                                                         
　 else {                                                                    
　　　printf("File exists, cannot test perror.\n");                          
　　　fclose(FP1);                                                           
　 }                                                                         
}                                                                            
                                                                             
- 実行結果 -                                                                 
exists.not :File not found                                                   
                                                                             
-----------------------------------------------------------------------------
.pow                                                                         
doubleのべき乗を求める                                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <math.h>       /* 必須 */                                           
double pow(double x, double y);                                              
                                                                             
- 内容 -                                                                     
x^yを返します。x=0.0かつy≦0.0のとき、errnoにEDOMを設定し、0.0を返します。   
x<0.0かつyが整数でないとき、errnoにEDOMを設定し、0.0を返します。             
|x^y|>HUGE_VALのとき、powの戻り値は、大きさがHUGE_VALであり、x^yと同じ符号を 
持ちます。                                                                   
                                                                             
- 参照 -                                                                     
exp     eのべき乗を求める。                                                  
ldexp   数に2のべき乗を掛ける。                                              
                                                                             
-----------------------------------------------------------------------------
.printf                                                                      
標準出力にフォーマットによる出力を行う                                       
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stdio.h>      /* 必須 */                                           
int printf(const char *format,...);                                          
                                                                             
- 内容 -                                                                     
fprintf(stdout,format,...)と同等です。fprintfを参照してください。            
                                                                             
- 注意 -                                                                     
printfの引数の数は、formatで指定される数に等しいか、またはそれより大きくなけ 
ればなりません。そうでなければ、ごみが出力されることがあります。             
                                                                             
printfの引数の型は、formatで指定される型に一致しなければなりません。そうでな 
ければ、ごみが出力されることがあります。                                     
                                                                             
- 参照 -                                                                     
fprintf, fscanf, scanf, sprintf, sscanf, vfprintf, vprintf, vsprintf         
                                                                             
これらの関数の記述については、fprintfの参照の節を参照してください。          
                                                                             
- 例 -                                                                       
/*                                                                           
 fprintfと同様の例。2つの関数の類似性を示しています。                        
*/                                                                           
                                                                             
#include <stdio.h>                                                           
                                                                             
void main() {                                                                
　 char s[14] = "like the one", c ='*';                                      
　 int i = 10, x = 255, o = 45;                                              
　 double d = 3.1415927, nf = -3.449123;                                     
                                                                             
　 printf("printf prints strings (%s),\n",s);                                
　 printf("decimal numbers (%d),", i);                                       
　 printf(" hex numbers (%04X),\n", x);                                      
　 printf("floating-point numbers (%+.4e)\n", d);                            
　 printf("percent signs (%%),\n");                                          
　 printf("characters (%-5c),\n", c);                                        
　 printf("\negative floating-points (% 010,2e),\n", nf);                    
　 printf("and even octal numbers (%-+#5o).", o);                            
}                                                                            
                                                                             
- 実行結果 -                                                                 
printf prints strings (like this one),                                       
decimal numbers (10), hex numbers (00FF),                                    
floating-point numbers (+3.1416e+00),                                        
percent signs (%),                                                           
characters (*    ),                                                          
negative floating-points (-03.45e+00),                                       
and even octal numbers (055  ).                                              
                                                                             
-----------------------------------------------------------------------------
.ptrdiff_t                                                                   
型指定子として使われるマクロ                                                 
-----------------------------------------------------------------------------
                                                                             
- 定義 -                                                                     
#include <stddef.h>     /* 必須 */                                           
                                                                             
- 内容 -                                                                     
2つのポインタの減算結果である整数型に展開されます。                          
                                                                             
