				;**** G-Extender ver 0.0.1 ****
				
				;=== SYSTEM SELECTION ===
 = 0000				_SYSTEM_PC9801 =	0	; NEC PC9801 se
				ris
 = 0001				_SYSTEM_PCAT   =	1	; IBM-PC/AT com
				patible arch.
				
				;=== SEGMENT DEFINITIONS ===
 0000				_TEXT		segment para public use16 'CODE
				'
 0000				_TEXT		ends
				;** GX data part **
 0000				_DATA		segment para public use16 'DATA
				'
 0000				_DATA		ends
 0000				STACK		segment para stack use16
 0000				STACK		ends
				;** data is shared by both mode **
				DGROUP		group	_DATA, STACK
				;** 32-bit protect mode **
 0000				_TEXT_GX	segment para public use32
 0000				TextGxOffset0	label	byte
 0000				_TEXT_GX	ends
				;** users address space (use32) **
 0000				_TEXT_USER	segment para public use32
 0000				_TEXT_USER	ends
 0000				_DATA_USER	segment para public use32
 0000				_DATA_USER	ends
				
				;** 80386/80486 segment descriptor **
				_DESC		struc		; descriptor sk
				elton
 0000  0000			_LIM_0_15	dw	0	; segment limit
 0002  0000			_BAS_0_15	dw	0	; base (0 - 15)
 0004  00			_BAS_16_23	db	0	; base (16 - 23
				)
 0005  00			_ACCESS		db	0	; access right 
				byte
 0006  00			_GRAN		db	0	; granurity
 0007  00			_BAS_24_31	db	0	; base (24 - 31
				)
 0008				_DESC		ends
				
				;=== segment selector definition ===
 = 0008				SEG_ALIAS	=	08h		; alias
				 selector offset
