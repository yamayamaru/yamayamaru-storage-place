				;** Protect modo Interrupt handler **
				_ProtIntHandler	macro	n
				IdtEntry&n&:	push	dword ptr n	
					; push interrupt number
						jmp	near ptr ProtIntHandler
					; re-issue it in real mode
						endm
 = 0000				_IdtEntryNumber =	0
