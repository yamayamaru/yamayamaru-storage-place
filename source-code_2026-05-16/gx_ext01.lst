				_CompLinearAddr	macro	seg,off		
					;; compute lineaar address, seg:off ==>
				 eax
					ifb	<off>
						xor	eax, eax
					  ifnb	<seg>
						mov	ax, seg
						shl	eax, 4
					  endif
					else
						xor	eax, eax
						mov	ax, seg
						shl	eax, 4
						lea	eax, off[eax]
					endif
						endm
				_SetDescBase	macro	seg,off,dst	
					;; setup each field
