				_GotoProtMode	macro	dst
						push	word ptr SEG_GX_CODE
					;; simulate 16-bit mode far call
						push	word ptr (offset dst - 
				offset TextGxOffset0)
						jmp	near ptr GotoProtMode
						endm
				;** actual mode switching code **
						align	4
 0000				GotoProtMode	proc	far
 0000  8C 1E 0882 R				mov	RealModeSegDS, ds
					; save real mode segment
 0004  8C 06 0884 R				mov	RealModeSegES, es
 0008  8C 16 0886 R				mov	RealModeSegSS, ss
 000C  66| 50					push	eax		
					; save eax
 000E  66					db	66h		
					; 32-bit form LGDT inst
 000F  0F 01 16 0870 R				lgdt	GdtPtr
 0014  66					db	66h		
					; 32-bit form LGDT inst
 0015  0F 01 1E 0876 R				lidt	IdtPtr
 001A  0F 20 C0					mov	eax, cr0	
					; protection enable
 001D  0C 01					or	al, 1		
					; set bit-0 (PE)
 001F  0F 22 C0					mov	cr0, eax
 0022  EB 00					jmp	short GotoProtMode1
					; flush instruction queue
						align	4
 0024  B8 0010			GotoProtMode1:	mov	ax, SEG_LDT	
					; setup LDT
 0027  0F 00 D0					lldt	ax
 002A  8E 1E 0888 R				mov	ds, ProtModeSegDS
					; setup protect mode segment
 002E  8E 06 088A R				mov	es, ProtModeSegES
 0032  8E 16 088C R				mov	ss, ProtModeSegSS
 0036  66| 58					pop	eax
 0038  CB					ret			
					; 16bit-mode far return
 0039				GotoProtMode	endp
				
				;** MACRO _GotoRealMode <dst>
